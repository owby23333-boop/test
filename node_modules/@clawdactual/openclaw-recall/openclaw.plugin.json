{
  "id": "openclaw-recall",
  "uiHints": {
    "maxSnippets": {
      "label": "Max Snippets",
      "help": "Maximum number of recalled snippets to inject per message (the primary control for recall volume)"
    },
    "minRelevanceScore": {
      "label": "Min Relevance Score",
      "help": "Minimum score (0-1) to include a result"
    },
    "skipShortMessages.enabled": {
      "label": "Skip Short Messages",
      "help": "Disable recall for very short messages"
    },
    "skipShortMessages.minChars": {
      "label": "Min Message Length",
      "help": "Skip recall for messages shorter than this (chars)"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "skipMemorySearchIfLancedb": {
        "type": "boolean",
        "default": true,
        "description": "Skip the memory-search source when memory-lancedb is active (it handles its own recall). Other sources (LCM, QMD) still run."
      },
      "skipIfLancedb": {
        "type": "boolean",
        "description": "Deprecated: use skipMemorySearchIfLancedb instead. Kept for backwards compatibility."
      },
      "maxSnippets": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 5
      },
      "minRelevanceScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.3
      },
      "skipShortMessages": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "minChars": {
            "type": "integer",
            "minimum": 1,
            "default": 40
          }
        }
      },
      "skipHeartbeats": {
        "type": "boolean",
        "default": true
      },
      "excludeFiles": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Files to exclude from recall (already in context). Defaults to OpenClaw bootstrap files."
      },
      "excludePatterns": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Glob patterns to exclude (additive — built-in defaults always included). Supports * and ** wildcards."
      },
      "sources": {
        "type": "object",
        "properties": {
          "memorySearch": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "maxResults": { "type": "integer", "minimum": 1, "default": 5 }
            }
          },
          "qmd": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "command": { "type": "string", "default": "qmd search" },
              "maxResults": { "type": "integer", "minimum": 1, "default": 5 }
            }
          },
          "lcm": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "maxResults": { "type": "integer", "minimum": 1, "default": 3 },
              "scope": {
                "type": "string",
                "enum": ["messages", "summaries", "both"],
                "default": "summaries"
              }
            }
          }
        }
      },
      "debug": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "logPath": { "type": "string", "default": ".recall/debug.log" }
        }
      }
    }
  }
}
