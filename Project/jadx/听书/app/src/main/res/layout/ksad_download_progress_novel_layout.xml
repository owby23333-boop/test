<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.kwad.components.core.page.widget.TextProgressBar
        android:id="@+id/ksad_progress_bar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:indeterminateOnly="false"
        android:progressDrawable="@drawable/ksad_feed_download_progress_novel"/>
    <TextView
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/ksad_normal_text"
        android:background="@drawable/ksad_feed_actionbar_cover_pressed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:ksad_downloadTextSize="14dp"/>
    <View
        android:id="@+id/ksad_foreground_cover"
        android:background="@drawable/ksad_feed_actionbar_cover_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</FrameLayout>
