<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:id="@+id/ksad_shake_combo_root"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="177dp">
    <com.kwad.components.ad.splashscreen.widget.KsButtonBorderSpreadView
        android:layout_gravity="center_horizontal"
        android:id="@+id/ksad_shake_combo_button_spread"
        android:layout_width="300dp"
        android:layout_height="88dp"
        android:layout_marginTop="11dp">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/ksad_shake_combo_button_background"
            android:layout_width="263dp"
            android:layout_height="65dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ksad_splash_shake_combo_button"
            android:scaleType="fitXY"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="263dp"
            android:layout_height="62dp"
            android:layout_marginTop="13dp">
            <LinearLayout
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="240dp"
                android:layout_height="30dp"
                android:layout_marginTop="8dp">
                <com.kwad.components.ad.splashscreen.widget.KsShakeView
                    android:id="@+id/ksad_shake_combo_shake_icon"
                    android:layout_width="31dp"
                    android:layout_height="30dp"
                    app:ksad_innerCirclePadding="10dp"
                    app:ksad_innerCircleStrokeColor="#00ffffff"
                    app:ksad_innerCircleStrokeWidth="3dp"
                    app:ksad_outerStrokeColor="#00ffffff"
                    app:ksad_outerStrokeWidth="1dp"
                    app:ksad_shakeIcon="@drawable/ksad_ic_shake_combo_hand"
                    app:ksad_solidColor="#00ffffff"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="@android:color/white"
                    android:ellipsize="end"
                    android:id="@+id/ksad_shake_combo_shake_main_text"
                    android:paddingTop="0dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:maxWidth="190dp"
                    android:text="@string/ksad_splash_shake_combo_action_text"
                    android:maxLines="1"
                    android:layout_marginStart="9dp"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="#99ffffff"
                android:ellipsize="end"
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_shake_combo_sub_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:text="@string/ksad_splash_shake_combo_sub_text"
                android:maxLines="1"/>
        </LinearLayout>
    </com.kwad.components.ad.splashscreen.widget.KsButtonBorderSpreadView>
    <com.kwad.components.ad.splashscreen.widget.KsSlidePopUpView
        android:id="@+id/ksad_shake_combo_slide_popup_view"
        android:background="@drawable/ksad_slide_square_bg_shape"
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:layout_marginTop="177dp"
        android:layout_marginStart="9dp"
        android:layout_marginEnd="9dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.kwad.components.ad.splashscreen.widget.KsSlideArrowView
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_shake_combo_slide_arrow_top"
                android:layout_width="19dp"
                android:layout_height="10dp"
                android:layout_marginTop="9dp"/>
            <com.kwad.components.ad.splashscreen.widget.KsSlideArrowView
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_shake_combo_slide_arrow_bottom"
                android:layout_width="19dp"
                android:layout_height="10dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#99ffffff"
                android:ellipsize="end"
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_shake_combo_slide_action_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:maxWidth="270dp"
                android:text="@string/ksad_splash_slide_guide_text"
                android:maxLines="1"/>
        </LinearLayout>
    </com.kwad.components.ad.splashscreen.widget.KsSlidePopUpView>
</FrameLayout>
