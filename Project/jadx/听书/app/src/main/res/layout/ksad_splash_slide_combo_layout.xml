<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:id="@+id/ksad_slide_combo_root"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="460dp">
    <com.kwad.components.ad.splashscreen.widget.KsSlideHandView
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/ksad_slide_combo_slide_hand"
        android:layout_width="306dp"
        android:layout_height="242dp"
        android:layout_marginBottom="200dp"/>
    <com.kwad.components.ad.splashscreen.widget.KsSlideRoundView
        android:layout_gravity="bottom"
        android:id="@+id/ksad_slide_combo_round_bg"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        app:ksad_shakeIcon="@drawable/ksad_splash_slide_round_white_bg"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="348dp">
        <TextView
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:id="@+id/ksad_slide_combo_action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ksad_splash_slide_combo_guide_text"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="5"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:id="@+id/ksad_slide_combo_action_sub_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/ksad_splash_slide_combo_sub_text"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="5"/>
    </LinearLayout>
</FrameLayout>
