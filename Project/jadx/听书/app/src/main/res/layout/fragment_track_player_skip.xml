<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">
    <TextView
        android:textSize="10sp"
        android:textColor="@color/secondary_text_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="仅对本书生效"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳过片头"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:id="@+id/tvSkipStart"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0s"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <com.qmuiteam.qmui.widget.QMUISlider
        android:id="@+id/sliderSkipStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:qmui_slider_bar_normal_color="@color/player_progress_background_color"
        app:qmui_slider_bar_progress_color="@color/secondary_color"
        app:qmui_slider_bar_record_progress_color="@color/player_progress_cached_color"
        app:qmui_slider_bar_tick_count="180"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0s"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="180s"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳过片尾"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:id="@+id/tvSkipEnd"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0s"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <com.qmuiteam.qmui.widget.QMUISlider
        android:id="@+id/sliderSkipEnd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:qmui_slider_bar_normal_color="@color/player_progress_background_color"
        app:qmui_slider_bar_progress_color="@color/secondary_color"
        app:qmui_slider_bar_record_progress_color="@color/player_progress_cached_color"
        app:qmui_slider_bar_tick_count="180"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0s"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="180s"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.qmuiteam.qmui.layout.QMUIFrameLayout
        android:id="@+id/btnSaveSetting"
        android:background="@color/positive_button_background_start_color"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="50dp"
        android:paddingVertical="10dp"
        app:qmui_radius="90dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/positive_button_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="保存设置"/>
    </com.qmuiteam.qmui.layout.QMUIFrameLayout>
</LinearLayout>
