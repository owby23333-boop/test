<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">
    <LinearLayout
        android:gravity="start|bottom"
        android:orientation="horizontal"
        android:id="@+id/lySpeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="语速设置"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <com.qmuiteam.qmui.widget.QMUISeekBar
        android:id="@+id/seekBarSpeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:qmui_seek_bar_tick_height="4dp"
        app:qmui_seek_bar_tick_width="2dp"
        app:qmui_slider_bar_normal_color="@color/player_progress_cached_color"
        app:qmui_slider_bar_progress_color="@color/secondary_color"
        app:qmui_slider_bar_record_progress_color="@color/player_progress_cached_color"
        app:qmui_slider_bar_tick_count="10"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.5x"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/secondary_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.0x"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
