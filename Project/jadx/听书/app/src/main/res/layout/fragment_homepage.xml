<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:background="@color/homepage_background_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.qmuiteam.qmui.widget.QMUIWindowInsetLayout
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.qmuiteam.qmui.layout.QMUIFrameLayout
                android:id="@+id/lySearchBar"
                android:background="@color/homepage_search_bar_background_color"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginVertical="5dp"
                android:paddingVertical="8dp"
                app:qmui_radius="185dp">
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_search_bar"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/fourth_text_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/homepage_search_bar_placeholder"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </com.qmuiteam.qmui.layout.QMUIFrameLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="16dp">
                <com.angcyo.tablayout.DslTabLayout
                    android:id="@+id/lyTab"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    app:tab_deselect_color="@color/secondary_text_color"
                    app:tab_enable_gradient_scale="true"
                    app:tab_max_scale="1.2"
                    app:tab_min_scale="1"
                    app:tab_select_color="@color/primary_text_color"/>
            </LinearLayout>
            <com.qmuiteam.qmui.layout.QMUILinearLayout
                android:background="@color/homepage_tab_bottom_line_color"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"/>
            <com.qmuiteam.qmui.widget.QMUIViewPager
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>
    </com.qmuiteam.qmui.widget.QMUIWindowInsetLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
