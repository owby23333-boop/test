<?xml version="1.0" encoding="utf-8"?>
<com.drake.statelayout.StateLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/state"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.qmuiteam.qmui.layout.QMUILinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/lyTrackHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/third_text_color"
                android:id="@+id/tvTrackCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="共0集"
                android:layout_alignParentStart="true"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/lyTrackAscending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_album_track_sort"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/third_text_color"
                        android:id="@+id/tvTrackAscending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="正序"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/lyTrackSelections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_album_track_selections"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/third_text_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选集"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <com.qmuiteam.qmui.layout.QMUILinearLayout
            android:background="@color/track_list_header_line_color"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"/>
        <com.qmuiteam.qmui.layout.QMUIFrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.qmuiteam.qmui.layout.QMUIConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="16dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTracks"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintEnd_toEndOf="@+id/rvTracks"
                    app:layout_constraintTop_toTopOf="@+id/rvTracks">
                    <com.qmuiteam.qmui.widget.roundwidget.QMUIRoundButton
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:id="@+id/btnTop"
                        android:visibility="gone"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="顶部"
                        app:qmui_backgroundColor="@color/secondary_color"
                        app:qmui_borderWidth="0dp"/>
                    <com.qmuiteam.qmui.widget.roundwidget.QMUIRoundButton
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:id="@+id/btnBottom"
                        android:visibility="gone"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="6dp"
                        android:text="底部"
                        app:qmui_backgroundColor="@color/secondary_color"
                        app:qmui_borderWidth="0dp"/>
                    <com.qmuiteam.qmui.widget.roundwidget.QMUIRoundButton
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:id="@+id/btnCurrent"
                        android:visibility="gone"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="6dp"
                        android:text="当前"
                        app:qmui_backgroundColor="@color/secondary_color"
                        app:qmui_borderWidth="0dp"/>
                </LinearLayout>
            </com.qmuiteam.qmui.layout.QMUIConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTrackSelections"
                android:background="@color/album_detail_background_color"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="16dp"/>
        </com.qmuiteam.qmui.layout.QMUIFrameLayout>
    </com.qmuiteam.qmui.layout.QMUILinearLayout>
</com.drake.statelayout.StateLayout>
