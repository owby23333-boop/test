<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:background="@drawable/bg_user_edit"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.qmuiteam.qmui.widget.QMUIWindowInsetLayout
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="horizontal"
                android:id="@+id/topBar"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:paddingStart="8dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:id="@+id/appBack"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_back"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="编辑信息"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">
                <com.qmuiteam.qmui.widget.QMUIRadiusImageView
                    android:layout_gravity="center"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="32dp"
                    android:src="@mipmap/default_user_cover"
                    app:qmui_border_width="0dp"
                    app:qmui_is_circle="true"/>
                <com.qmuiteam.qmui.layout.QMUIFrameLayout
                    android:background="@color/login_input_account_box_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="13dp"
                    app:qmui_borderColor="@color/primary_color"
                    app:qmui_borderWidth="1dp"
                    app:qmui_radius="63dp">
                    <EditText
                        android:textSize="14sp"
                        android:textColor="@color/login_input_account_text_color"
                        android:textColorHint="@color/login_input_account_text_color"
                        android:id="@+id/etNickname"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="昵称"
                        android:lines="1"
                        android:singleLine="true"
                        android:textAlignment="center"
                        android:layout_marginStart="8dp"/>
                </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text_color"
                    android:id="@+id/tvAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="ID:"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text_color"
                    android:id="@+id/tvEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="邮箱:"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text_color"
                    android:id="@+id/tvPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="手机号:"/>
                <com.qmuiteam.qmui.layout.QMUIFrameLayout
                    android:id="@+id/btnSave"
                    android:background="@drawable/bg_gradient_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="13dp"
                    app:qmui_borderWidth="0dp"
                    app:qmui_radius="63dp">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/positive_button_text_color"
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="保存修改"/>
                </com.qmuiteam.qmui.layout.QMUIFrameLayout>
            </LinearLayout>
        </LinearLayout>
    </com.qmuiteam.qmui.widget.QMUIWindowInsetLayout>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/loading"
        android:visibility="gone"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_fileName="lottie/loading.json"
        app:lottie_loop="true"
        app:lottie_repeatMode="restart"/>
</androidx.constraintlayout.widget.ConstraintLayout>
