<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:background="@color/feedback_background_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.qmuiteam.qmui.widget.QMUIWindowInsetLayout
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="horizontal"
                android:id="@+id/topBar"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:paddingStart="8dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:id="@+id/appBack"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_back"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="意见反馈"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="问题类型"/>
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.qmuiteam.qmui.layout.QMUIFrameLayout
                            android:orientation="vertical"
                            android:id="@+id/lyType0"
                            android:background="@color/filter_box_background_selected_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="4dp"
                            app:qmui_borderWidth="0dp"
                            app:qmui_radius="226dp">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/filter_box_text_selected_color"
                                android:id="@+id/tvType0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="功能建议"/>
                        </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                        <com.qmuiteam.qmui.layout.QMUIFrameLayout
                            android:orientation="vertical"
                            android:id="@+id/lyType1"
                            android:background="@color/filter_box_background_normal_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="4dp"
                            app:qmui_borderWidth="0dp"
                            app:qmui_radius="226dp">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/filter_box_text_normal_color"
                                android:id="@+id/tvType1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="系统异常"/>
                        </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                        <com.qmuiteam.qmui.layout.QMUIFrameLayout
                            android:orientation="vertical"
                            android:id="@+id/lyType2"
                            android:background="@color/filter_box_background_normal_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="4dp"
                            app:qmui_borderWidth="0dp"
                            app:qmui_radius="226dp">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/filter_box_text_normal_color"
                                android:id="@+id/tvType2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="网络异常"/>
                        </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                        <com.qmuiteam.qmui.layout.QMUIFrameLayout
                            android:orientation="vertical"
                            android:id="@+id/lyType3"
                            android:background="@color/filter_box_background_normal_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="4dp"
                            app:qmui_borderWidth="0dp"
                            app:qmui_radius="226dp">
                            <TextView
                                android:textSize="12sp"
                                android:textColor="@color/filter_box_text_normal_color"
                                android:id="@+id/tvType3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="其他"/>
                        </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                    </LinearLayout>
                </HorizontalScrollView>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="反馈内容"/>
                <com.qmuiteam.qmui.layout.QMUIFrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="8dp"
                    app:qmui_borderColor="@color/primary_color"
                    app:qmui_borderWidth="0.7dp"
                    app:qmui_radius="9dp">
                    <EditText
                        android:textSize="14sp"
                        android:textColor="@color/primary_text_color"
                        android:gravity="start|top"
                        android:id="@+id/etContent"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lines="10"
                        android:textAlignment="textStart"
                        android:layout_marginStart="8dp"/>
                </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="联系方式（选填）"/>
                <com.qmuiteam.qmui.layout.QMUIFrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="8dp"
                    app:qmui_borderColor="@color/primary_color"
                    app:qmui_borderWidth="0.7dp"
                    app:qmui_radius="9dp">
                    <EditText
                        android:textSize="14sp"
                        android:textColor="@color/primary_text_color"
                        android:textColorHint="@color/secondary_text_color"
                        android:id="@+id/etContact"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="微信/QQ/手机号"
                        android:maxLines="1"
                        android:lines="1"
                        android:layout_marginStart="8dp"/>
                </com.qmuiteam.qmui.layout.QMUIFrameLayout>
                <com.qmuiteam.qmui.layout.QMUIFrameLayout
                    android:id="@+id/btnSubmit"
                    android:background="@drawable/bg_gradient_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="13dp"
                    app:qmui_borderWidth="0dp"
                    app:qmui_radius="63dp">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/positive_button_text_color"
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="确认提交"/>
                </com.qmuiteam.qmui.layout.QMUIFrameLayout>
            </LinearLayout>
        </LinearLayout>
    </com.qmuiteam.qmui.widget.QMUIWindowInsetLayout>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/loading"
        android:visibility="gone"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_fileName="lottie/loading.json"
        app:lottie_loop="true"
        app:lottie_repeatMode="restart"/>
</androidx.constraintlayout.widget.ConstraintLayout>
