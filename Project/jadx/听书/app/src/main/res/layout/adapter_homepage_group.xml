<?xml version="1.0" encoding="utf-8"?>
<com.qmuiteam.qmui.layout.QMUIConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.qmuiteam.qmui.layout.QMUIRelativeLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/lyGroupHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.qmuiteam.qmui.layout.QMUILinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_alignParentStart="true">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text_color"
                android:id="@+id/tvGroupName"
                android:background="@drawable/bg_homepage_group_name"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分组标题"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_homepage_group_name_star"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="20dp"/>
            </LinearLayout>
        </com.qmuiteam.qmui.layout.QMUILinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/lyMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_alignParentEnd="true">
            <TextView
                android:textSize="12sp"
                android:textColor="@color/secondary_text_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/homepage_group_more"/>
            <com.qmuiteam.qmui.widget.QMUIRadiusImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_item_more"
                app:qmui_border_width="0dp"/>
        </LinearLayout>
    </com.qmuiteam.qmui.layout.QMUIRelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGroupItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lyGroupHeader"/>
</com.qmuiteam.qmui.layout.QMUIConstraintLayout>
