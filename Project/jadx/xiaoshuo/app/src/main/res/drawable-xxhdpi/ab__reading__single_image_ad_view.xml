<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/reading__app_ad__bg"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="17dp"
        android:layout_marginTop="17dp"
        android:layout_marginRight="17dp"
        android:layout_marginBottom="10dp">
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/reading__app_ad_view__summary"
                android:paddingTop="3dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"/>
            <LinearLayout
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:paddingBottom="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp">
                <TextView
                    android:textSize="8sp"
                    android:textColor="#999999"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__ad_sign_bold"
                    android:background="@drawable/reading__app_ad_view__ad_border_bold"
                    android:paddingLeft="2dp"
                    android:paddingTop="1dp"
                    android:paddingRight="2dp"
                    android:paddingBottom="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/general__shared__ad"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="#999999"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="3dp"/>
                <TextView
                    android:textSize="5sp"
                    android:textColor="#999999"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__ad_sign"
                    android:background="@drawable/reading__app_ad_view__ad_border"
                    android:paddingLeft="2dp"
                    android:paddingTop="1dp"
                    android:paddingRight="2dp"
                    android:paddingBottom="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/general__shared__ad"/>
            </LinearLayout>
        </FrameLayout>
        <ImageView
            android:id="@+id/reading__single_image_view__image"
            android:layout_width="96dp"
            android:layout_height="64dp"
            android:scaleType="fitXY"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="top|right"
        android:id="@+id/reading__app_ad_view__close"
        android:padding="9dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ab__reading__app_ad_view__close"/>
</FrameLayout>
