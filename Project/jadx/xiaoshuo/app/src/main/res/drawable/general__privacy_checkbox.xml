<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape>
                    <size
                        android:height="16dp"
                        android:width="16dp"/>
                    <padding
                        android:top="3dp"
                        android:right="3dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="0.7dp"
                        android:color="#ffff8e4d"/>
                    <solid android:color="#ffff8e4d"/>
                    <corners android:radius="3dp"/>
                </shape>
            </item>
            <item
                android:gravity="center"
                android:height="7dp"
                android:width="7dp"
                android:drawable="@drawable/general__privacy_checkbox__selected"/>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <size
                        android:height="16dp"
                        android:width="16dp"/>
                    <padding
                        android:top="3dp"
                        android:right="3dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="0.7dp"
                        android:color="#ffd8d8d8"/>
                    <solid android:color="#fff0f0f0"/>
                    <corners android:radius="3dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
