<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <bitmap android:src="@drawable/free_store__choose_gender_view__male_bg"/>
            </item>
            <item android:gravity="top|right">
                <bitmap android:src="@drawable/free_personal__choose_gender_view__select_icon"/>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="false">
        <bitmap android:src="@drawable/free_store__choose_gender_view__male_bg"/>
    </item>
</selector>
