<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center"
        android:id="@android:id/background"
        android:height="@dimen/view_dimen_6">
        <shape>
            <corners android:radius="@dimen/view_dimen_3_5"/>
            <solid android:color="@color/general__day_night__f2f2f2_f2f2f2_40"/>
        </shape>
    </item>
    <item
        android:gravity="center"
        android:id="@android:id/progress"
        android:height="@dimen/view_dimen_6">
        <clip>
            <shape>
                <corners android:radius="@dimen/view_dimen_3_5"/>
                <solid android:color="@color/general__day_night__ffd014_ffd014_80"/>
            </shape>
        </clip>
    </item>
    <item
        android:id="@android:id/secondaryProgress"
        android:height="@dimen/view_dimen_6">
        <clip>
            <shape>
                <solid android:color="@color/white"/>
            </shape>
        </clip>
    </item>
</layer-list>
