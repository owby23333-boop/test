<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#57292929"/>
            <size
                android:height="32dp"
                android:width="32dp"/>
            <padding
                android:left="9dp"
                android:top="7dp"
                android:right="11dp"
                android:bottom="7dp"/>
        </shape>
    </item>
    <item
        android:top="4.5dp"
        android:bottom="11.5dp">
        <rotate android:fromDegrees="315">
            <shape>
                <solid android:color="#ffffff"/>
                <corners android:radius="1dp"/>
            </shape>
        </rotate>
    </item>
    <item
        android:top="11.5dp"
        android:bottom="4.5dp">
        <rotate android:fromDegrees="45">
            <shape>
                <solid android:color="#ffffff"/>
                <corners android:radius="1dp"/>
            </shape>
        </rotate>
    </item>
</layer-list>
