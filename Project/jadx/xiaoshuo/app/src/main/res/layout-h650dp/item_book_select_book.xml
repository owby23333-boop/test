<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout-h650dp/item_book_select_book_0"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_1554"
    android:paddingHorizontal="@dimen/view_dimen_46">
    <TextView
        android:textSize="@dimen/view_dimen_56"
        android:textStyle="bold"
        android:tag="binding_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_198"
        android:text="@string/store__select_category"
        android:alpha="0.9"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.kyleduo.switchbutton.SwitchButton
        android:id="@+id/sb_switch"
        android:tag="binding_2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_109"
        android:layout_marginTop="@dimen/view_dimen_304"
        app:kswBackColor="@color/general__day_night__switch_bg"
        app:kswBackRadius="@dimen/view_dimen_36"
        app:kswThumbColor="@color/general__day_night__switch_btn"
        app:kswThumbMargin="@dimen/view_dimen_10"
        app:kswThumbRadius="@dimen/view_dimen_30"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tv_boy"
        android:tag="binding_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/store__category_male"
        app:layout_constraintBottom_toBottomOf="@+id/sb_switch"
        app:layout_constraintEnd_toStartOf="@+id/tv_girl"
        app:layout_constraintStart_toStartOf="@+id/sb_switch"
        app:layout_constraintTop_toTopOf="@+id/sb_switch"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tv_girl"
        android:tag="binding_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/store__category_female"
        app:layout_constraintBottom_toBottomOf="@+id/sb_switch"
        app:layout_constraintEnd_toEndOf="@+id/sb_switch"
        app:layout_constraintStart_toEndOf="@+id/tv_boy"
        app:layout_constraintTop_toTopOf="@+id/sb_switch"/>
    <com.classic.common.MultipleStatusView
        android:id="@+id/status_Layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:layout_marginBottom="@dimen/view_dimen_200"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sb_switch"
        app:loadingView="@layout/fragment_store_tab_loading_layout">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:nestedScrollingEnabled="false"/>
    </com.classic.common.MultipleStatusView>
    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="@dimen/view_dimen_34"
        android:layout_height="@dimen/view_dimen_34"
        android:layout_marginBottom="@dimen/view_dimen_18"
        app:layout_constraintBottom_toTopOf="@+id/tv_select"
        app:layout_constraintEnd_toEndOf="@+id/tv_select"
        app:layout_constraintStart_toStartOf="@+id/tv_select"
        app:lottie_autoPlay="true"
        app:lottie_fileName="category_slide_up.json"
        app:lottie_repeatCount="-1"/>
    <TextView
        android:textSize="@dimen/view_dimen_42"
        android:textStyle="bold"
        android:id="@+id/tv_select"
        android:tag="binding_5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_198"
        android:layout_marginBottom="@dimen/view_dimen_51"
        android:text="@string/store__select_category_bottom"
        android:alpha="0.7"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
