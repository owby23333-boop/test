<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/frameLayout2"
        android:background="#a6000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/general__permission_denied_guide_dialog__main"
        android:background="@drawable/free_vip__exchange_dialog_bg"
        android:layout_width="264dp"
        android:layout_height="230dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/general__permission_denied_guide_dialog__icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="@dimen/view_dimen_235"
        app:layout_constraintLeft_toLeftOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintRight_toRightOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintTop_toTopOf="@+id/general__permission_denied_guide_dialog__main"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/general__day_night__1A1A1A_ffffff_70"
        android:gravity="center"
        android:id="@+id/general__permission_denied_guide_dialog__desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.3dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintStart_toStartOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintTop_toBottomOf="@+id/general__permission_denied_guide_dialog__icon"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintEnd_toEndOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintLeft_toLeftOf="@+id/general__permission_denied_guide_dialog__main"
        app:layout_constraintStart_toStartOf="@+id/general__permission_denied_guide_dialog__main">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/general__day_night__333333_ffffff"
            android:gravity="center"
            android:id="@+id/general__permission_denied_guide_dialog__no_grant"
            android:background="@drawable/free_permission_denied_controller_no_grant_btn_bg"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="@dimen/view_dimen_58"
            android:layout_marginRight="@dimen/view_dimen_19"
            android:layout_marginBottom="15.5dp"
            android:text="@string/general__storage_permission__button2"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/general__day_night__ffffff_333333"
            android:gravity="center"
            android:id="@+id/general__permission_denied_guide_dialog__grant"
            android:background="@drawable/free_account__login_main__next_enabled"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="@dimen/view_dimen_19"
            android:layout_marginRight="@dimen/view_dimen_58"
            android:layout_marginBottom="15.5dp"
            android:text="@string/general__storage_permission__button"
            android:layout_weight="1"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
