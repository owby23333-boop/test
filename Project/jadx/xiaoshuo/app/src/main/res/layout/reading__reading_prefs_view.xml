<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/reading__reading_prefs_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:id="@+id/reading__reading_prefs_view__scrollerview"
        android:background="@color/general__day_night__ffffff"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__b3b3b3"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/view_dimen_40"
            android:paddingBottom="@dimen/view_dimen_30"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_prefs_view__operations"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60"/>
        <FrameLayout
            android:id="@+id/reading__reading_options_view__typesetting_container"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_menu_reading_settings_spacing"/>
            <com.duokan.core.ui.LinearScrollView
                android:gravity="end|center_vertical"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:id="@+id/reading__reading_options_view__typesetting_scroll"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/view_dimen_144"
                android:layout_marginEnd="@dimen/view_dimen_60">
                <ImageView
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_options_view__typesetting_tight"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="@dimen/view_dimen_120"
                    android:layout_height="@dimen/view_dimen_84"
                    android:src="@drawable/reading__reading_options_view__typesetting_tight_inner"
                    android:scaleType="center"
                    android:contentDescription="@string/reading__reading_options_view__typesetting_tight_inner"
                    android:layout_marginEnd="@dimen/view_dimen_30"/>
                <ImageView
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_options_view__typesetting_normal"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="@dimen/view_dimen_120"
                    android:layout_height="@dimen/view_dimen_84"
                    android:src="@drawable/reading__reading_options_view__typesetting_normal_inner"
                    android:scaleType="center"
                    android:contentDescription="@string/reading__reading_options_view__typesetting_normal_inner"
                    android:layout_marginEnd="@dimen/view_dimen_30"/>
                <ImageView
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_options_view__typesetting_loose"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="@dimen/view_dimen_120"
                    android:layout_height="@dimen/view_dimen_84"
                    android:src="@drawable/reading__reading_options_view__typesetting_loose_inner"
                    android:scaleType="center"
                    android:contentDescription="@string/reading__reading_options_view__typesetting_loose_inner"
                    android:layout_marginEnd="@dimen/view_dimen_30"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_options_view__typesetting_original"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="@dimen/view_dimen_120"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_options_view__typesetting_original_inner"
                    android:contentDescription="@string/reading__reading_options_view__typesetting_original"
                    android:layout_marginEnd="@dimen/view_dimen_30"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_options_view__typesetting_custom"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_options_view__typesetting_custom_btn"
                    android:lines="1"
                    android:contentDescription="@string/reading__reading_options_view__typesetting_custom"
                    android:paddingStart="@dimen/view_dimen_44"
                    android:paddingEnd="@dimen/view_dimen_44"/>
            </com.duokan.core.ui.LinearScrollView>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__chs_to_cht"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_options_view__chs_to_cht"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_options_view__typesetting_chs_to_cht"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_options_view__chs_to_cht_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__annotation_style"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__annotation_style"/>
            <com.duokan.core.ui.LinearScrollView
                android:gravity="end|center_vertical"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/view_dimen_390">
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_prefs_view__annotation_style_note"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_prefs_view__annotation_style_note"
                    android:contentDescription="@string/reading__reading_prefs_view__annotation_style_note"
                    android:paddingStart="@dimen/view_dimen_20"
                    android:paddingEnd="@dimen/view_dimen_20"
                    android:layout_marginEnd="@dimen/view_dimen_20"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_prefs_view__annotation_style_bubble"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_prefs_view__annotation_style_bubble"
                    android:contentDescription="@string/reading__reading_prefs_view__annotation_style_bubble"
                    android:paddingStart="@dimen/view_dimen_20"
                    android:paddingEnd="@dimen/view_dimen_20"/>
            </com.duokan.core.ui.LinearScrollView>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__left_tap"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_prefs_view__left_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__left_tap"/>
            <com.duokan.core.ui.LinearScrollView
                android:gravity="end|center_vertical"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:id="@+id/reading__reading_options_view__left_tap_backward_scroll"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/view_dimen_390">
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_prefs_view__left_tap_backward"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_prefs_view__left_tap_backward"
                    android:contentDescription="@string/reading__reading_prefs_view__left_tap_backward"
                    android:paddingStart="@dimen/view_dimen_20"
                    android:paddingEnd="@dimen/view_dimen_20"
                    android:layout_marginEnd="@dimen/view_dimen_20"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__333333"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__reading_prefs_view__left_tap_forward"
                    android:background="@drawable/reading__reading_menu_bottom_prefs_item_background"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_84"
                    android:text="@string/reading__reading_prefs_view__left_tap_forward"
                    android:contentDescription="@string/reading__reading_prefs_view__left_tap_forward"
                    android:paddingStart="@dimen/view_dimen_20"
                    android:paddingEnd="@dimen/view_dimen_20"/>
            </com.duokan.core.ui.LinearScrollView>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__volume_key"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__volume_key"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_prefs_view__volume_key_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__read_last"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__read_last"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_prefs_view__read_last_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__rapid_slide"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__rapid_slide"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_prefs_view__rapid_slide_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <View
            android:background="#1a000000"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_1"
            android:layout_marginTop="@dimen/view_dimen_30"
            android:layout_marginBottom="@dimen/view_dimen_30"
            android:contentDescription="@null"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__b3b3b3"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/view_dimen_40"
            android:paddingBottom="@dimen/view_dimen_30"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_prefs_view_title"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60"/>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__eyes_saving"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_brightness_view__eyes_saving"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_prefs_view__eyes_saving_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_prefs_view__screen"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_prefs_view__screen_timeout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__screen_timeout"/>
            <TextView
                android:textSize="@dimen/general_font__shared__g"
                android:textColor="@color/general__day_night__00000080"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_prefs_view__screen_timeout_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_prefs_view__5min"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/personal__personal_setting_view__more"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__custom_screen_view__show_system_bar"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__custom_screen_view__show_system_bar"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__custom_screen_view__show_system_bar_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__custom_screen_view__show_nav_bar"
            android:background="@drawable/personal__personal_settings_view__item_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:paddingStart="@dimen/view_dimen_60"
            android:paddingEnd="@dimen/view_dimen_60">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textColor="@color/general__day_night__1a1a1a"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__custom_screen_view__show_nav_bar"/>
            <CheckBox
                android:enabled="false"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/rreading__custom_screen_view__show_nav_bar_switch"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/reading__menu_prefs_switch"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/reading__reading_prefs_view__normal_pref_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/reading__custom_screen_view__show_chapter_name"
                android:background="@drawable/personal__personal_settings_view__item_bg"
                android:layout_width="match_parent"
                android:layout_height="@dimen/personal__personal_settings_view__middle_height"
                android:paddingStart="@dimen/view_dimen_60"
                android:paddingEnd="@dimen/view_dimen_60">
                <TextView
                    android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/general__day_night__1a1a1a"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__custom_screen_view__show_chapter_name"/>
                <CheckBox
                    android:enabled="false"
                    android:layout_gravity="end|center_vertical"
                    android:id="@+id/reading__custom_screen_view__show_chapter_name_switch"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/reading__menu_prefs_switch"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/reading__custom_screen_view__show_reading_status"
                android:background="@drawable/personal__personal_settings_view__item_bg"
                android:layout_width="match_parent"
                android:layout_height="@dimen/personal__personal_settings_view__middle_height"
                android:paddingStart="@dimen/view_dimen_60"
                android:paddingEnd="@dimen/view_dimen_60">
                <TextView
                    android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/general__day_night__1a1a1a"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__custom_screen_view__show_reading_status"/>
                <CheckBox
                    android:enabled="false"
                    android:layout_gravity="end|center_vertical"
                    android:id="@+id/reading__custom_screen_view__show_reading_status_switch"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/reading__menu_prefs_switch"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/reading__reading_prefs_view__limited_data_plan"
                android:background="@drawable/personal__personal_settings_view__item_bg"
                android:layout_width="match_parent"
                android:layout_height="@dimen/personal__personal_settings_view__middle_height"
                android:paddingStart="@dimen/view_dimen_60"
                android:paddingEnd="@dimen/view_dimen_60">
                <TextView
                    android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/general__day_night__1a1a1a"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_prefs_view__limited_data_plan"/>
                <CheckBox
                    android:enabled="false"
                    android:layout_gravity="end|center_vertical"
                    android:id="@+id/reading__reading_prefs_view__limited_data_plan_switch"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/reading__menu_prefs_switch"/>
            </FrameLayout>
        </LinearLayout>
    </com.duokan.core.ui.LinearScrollView>
</LinearLayout>
