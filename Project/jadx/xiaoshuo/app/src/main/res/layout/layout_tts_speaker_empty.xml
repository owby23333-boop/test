<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_data_empty"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/general__day_night__000000_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:text="@string/dk_tts_speaker_empty_tip"
        android:layout_marginStart="@dimen/view_dimen_144"
        android:layout_marginEnd="@dimen/view_dimen_144"/>
    <Button
        android:textSize="@dimen/general__shared_dimen__16sp"
        android:textColor="@color/general__day_night__fafafa"
        android:id="@+id/btn_more_speaker"
        android:background="@drawable/bg_orange_corner"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_90"
        android:text="@string/dk_tts_more_speaker"
        android:layout_marginStart="@dimen/view_dimen_144"
        android:layout_marginEnd="@dimen/view_dimen_144"/>
</LinearLayout>
