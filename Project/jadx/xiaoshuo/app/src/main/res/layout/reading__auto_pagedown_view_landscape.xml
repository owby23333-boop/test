<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/reading__auto_pagedown_menu_view__root"
        android:background="@color/reading__reading_menu_primary_background_color"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_128">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__auto_pagedown_menu_view__down"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/reading__reading_menu_bottom_submenu_down"
                android:layout_marginStart="@dimen/view_dimen_100"/>
            <TextView
                android:textSize="@dimen/text_font_size_50"
                android:textStyle="bold"
                android:textColor="@color/general__day_night__e6e6e6"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_mode_view__auto_pagedown"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_128"
            android:layout_marginTop="@dimen/view_dimen_27"
            android:layout_marginBottom="@dimen/view_dimen_60">
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/view_dimen_128"
                android:layout_weight="1"
                android:paddingStart="@dimen/view_dimen_100"
                android:paddingEnd="@dimen/view_dimen_60">
                <TextView
                    android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/general__day_night__e6e6e6"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_mode_view__speed"/>
                <LinearLayout
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/reading__auto_pagedown_menu_view__decelerate"
                        android:background="@drawable/reading__reading_options_view_background"
                        android:layout_width="@dimen/view_dimen_182"
                        android:layout_height="@dimen/view_dimen_80"
                        android:src="@drawable/reading__auto_pagedown_view__minus"
                        android:scaleType="centerInside"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_42"
                        android:textColor="@color/general__day_night__e6e6e6"
                        android:gravity="center"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/reading__auto_pagedown_menu_view__speed"
                        android:layout_width="@dimen/view_dimen_175"
                        android:layout_height="match_parent"/>
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/reading__auto_pagedown_menu_view__accelerate"
                        android:background="@drawable/reading__reading_options_view_background"
                        android:layout_width="@dimen/view_dimen_182"
                        android:layout_height="@dimen/view_dimen_80"
                        android:src="@drawable/reading__auto_pagedown_view__plus"
                        android:scaleType="centerInside"/>
                </LinearLayout>
            </FrameLayout>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__day_night__e6e6e6"
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__auto_pagedown_menu_view__close"
                android:background="@drawable/reading__reading_pagedown_view_exit_background"
                android:layout_width="0dp"
                android:layout_height="@dimen/view_dimen_88"
                android:text="@string/reading__reading_mode_view__exit"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/view_dimen_60"
                android:layout_marginEnd="@dimen/view_dimen_100"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
