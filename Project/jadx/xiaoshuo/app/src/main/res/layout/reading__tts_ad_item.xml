<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/view_dimen_212"
    android:layout_height="@dimen/view_dimen_206"
    android:layout_marginHorizontal="@dimen/view_dimen_6">
    <TextView
        android:textSize="@dimen/text_font_size_27"
        android:textStyle="bold"
        android:textColor="#ff6015"
        android:gravity="center"
        android:id="@+id/tv_tips"
        android:background="@drawable/reading_tts_ad_item_tip_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_42"
        android:text="@string/reading__tts_ad_item_tips"
        android:fontFamily="mipro-semibold"
        android:paddingHorizontal="@dimen/view_dimen_12"
        android:textFontWeight="520"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/iv_clock"
        android:layout_width="@dimen/view_dimen_54"
        android:layout_height="@dimen/view_dimen_45"
        android:src="@drawable/ic_clock_tts_following"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toTopOf="@+id/tv_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="@dimen/text_font_size_33"
        android:textColor="@color/white_95_transparent"
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_3"
        android:fontFamily="mipro-semibold"
        android:textFontWeight="450"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_clock"/>
</androidx.constraintlayout.widget.ConstraintLayout>
