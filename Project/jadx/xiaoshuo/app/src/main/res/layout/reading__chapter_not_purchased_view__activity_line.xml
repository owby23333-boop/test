<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/reading__chapter_not_purchased_view__activity_line_bg"
    android:paddingLeft="6dp"
    android:paddingRight="10dp"
    android:layout_width="match_parent"
    android:layout_height="33dp">
    <ImageView
        android:id="@+id/reading__chapter_not_purchased_view__activity_line_icon"
        android:layout_width="23dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/reading__chapter_not_purchased_view__activity_line_summary"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#a77906"
        android:id="@+id/reading__chapter_not_purchased_view__activity_line_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/reading__chapter_not_purchased_view__activity_line_icon"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#a77906"
        android:id="@+id/reading__chapter_not_purchased_view__activity_line_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:drawableRight="@drawable/reading__chapter_not_purchased_view__arrow"
        android:drawablePadding="7dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
