<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/reading__reading_menu_bottom_view__sub_menu_mask"
        android:background="@color/black_60_transparent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/reading__reading_menu_bottom_view__main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="right"
                android:orientation="vertical"
                android:id="@+id/reading__reading_menu_bottom_view__top_more"
                android:background="@drawable/reading__reading_menu_bottom_view__top_more_bg"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_260"
                android:layout_marginEnd="@dimen/view_dimen_35">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/black_75_transparent"
                    android:gravity="center_vertical"
                    android:id="@+id/reading__reading_menu_view__add_launcher_shortcut"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginTop="@dimen/view_dimen_30"
                    android:text="@string/reading__reading_menu_view__add_launcher_shortcut"
                    android:drawableLeft="@drawable/reading__reading_menu_view_epub__add_desktop"
                    android:drawablePadding="@dimen/view_dimen_24"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/black_75_transparent"
                    android:gravity="center_vertical"
                    android:id="@+id/reading__reading_menu_bottom_view__top_more_report"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="@string/reading__reading_error_report"
                    android:drawableLeft="@drawable/reading__reading_menu_bottom_view__top_more_report"
                    android:drawablePadding="@dimen/view_dimen_24"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/black_75_transparent"
                    android:gravity="center_vertical"
                    android:id="@+id/reading__reading_menu_bottom_view__top_more_book_introduction"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginBottom="@dimen/view_dimen_30"
                    android:text="@string/reading__reading_book_introduction"
                    android:drawableLeft="@drawable/reading__reading_menu_bottom_view__top_more_book_detail"
                    android:drawablePadding="@dimen/view_dimen_24"/>
            </LinearLayout>
        </FrameLayout>
        <FrameLayout
            android:background="@color/general__141414_95"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.duokan.core.ui.BoxView
                android:layout_gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="400dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:paddingLeft="20dp"
                    android:paddingTop="15dp"
                    android:paddingRight="20dp"
                    android:paddingBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="10dp"
                        android:src="@drawable/reading__reading_menu_bottom_view__idea_editor_anchor"/>
                    <TextView
                        android:textSize="@dimen/general_font__shared__b"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/reading__reading_menu_bottom_view__idea_editor_hint"
                        android:singleLine="true"
                        android:layout_weight="1"/>
                </LinearLayout>
            </com.duokan.core.ui.BoxView>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__reading_menu_bottom_view_epub__tts_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/view_dimen_250">
            <ImageView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/reading__reading_menu_bottom_view_epub__tts"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/reading__reading_menu_bottom_view_epub__tts"
                android:layout_marginEnd="@dimen/view_dimen_60"/>
        </FrameLayout>
        <include layout="@layout/reading__reading_menu_bottom_view__menu_free"/>
    </LinearLayout>
    <FrameLayout
        android:enabled="false"
        android:layout_gravity="bottom"
        android:id="@+id/reading__reading_menu_bottom_view__sub_menu_frame"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/reading__reading_menu_bottom_height"/>
    <FrameLayout
        android:enabled="false"
        android:layout_gravity="bottom"
        android:id="@+id/reading__reading_menu_bottom_view__overlay_menu_frame"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</FrameLayout>
