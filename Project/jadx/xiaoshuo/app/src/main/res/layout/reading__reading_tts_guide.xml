<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/black_60_transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="top"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_font_size_48"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading_tts_guide_double_click"/>
                <ImageView
                    android:layout_width="@dimen/view_dimen_300"
                    android:layout_height="@dimen/view_dimen_300"
                    android:layout_marginTop="@dimen/view_dimen_30"
                    android:src="@drawable/reading__reading_tts_guide_double_click"
                    android:importantForAccessibility="no"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/text_font_size_48"
                android:textColor="@color/white_70_transparent"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="或"
                android:layout_marginStart="@dimen/view_dimen_120"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/view_dimen_120">
                <TextView
                    android:textSize="@dimen/text_font_size_48"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading_tts_guide_long_press"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_30">
                    <TextView
                        android:textSize="@dimen/text_font_size_38"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_gravity="bottom"
                        android:background="@drawable/reading__reading_tts_guide_menu_bg"
                        android:paddingTop="@dimen/view_dimen_20"
                        android:layout_width="@dimen/view_dimen_200"
                        android:layout_height="@dimen/view_dimen_116"
                        android:text="@string/reading_tts_guide_long_press_menu"/>
                    <ImageView
                        android:layout_width="@dimen/view_dimen_246"
                        android:layout_height="@dimen/view_dimen_275"
                        android:src="@drawable/reading__reading_tts_guide_long_press"
                        android:importantForAccessibility="no"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_60"
            android:text="@string/reading_tts_guide_tips"/>
        <TextView
            android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/white_95_transparent"
            android:gravity="center"
            android:background="@drawable/elegant__personal_login__dialog_btn_bg"
            android:layout_width="@dimen/view_dimen_420"
            android:layout_height="@dimen/view_dimen_120"
            android:layout_marginTop="@dimen/view_dimen_66"
            android:text="@string/general__shared__iknow"/>
    </LinearLayout>
</FrameLayout>
