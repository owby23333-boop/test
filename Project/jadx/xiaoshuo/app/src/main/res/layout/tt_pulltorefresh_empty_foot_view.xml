<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:layout_gravity="center"
    android:orientation="horizontal"
    android:id="@+id/footer_view"
    android:background="#f3f5f8"
    android:paddingRight="5dp"
    android:focusable="true"
    android:visibility="invisible"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <View
        android:id="@+id/anim_view_left"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>
    <com.bytedance.sdk.openadsdk.core.nativeexpress.onepointfive.LoadingMoreView
        android:id="@+id/more"
        android:layout_width="15dp"
        android:layout_height="38dp"/>
    <View
        android:id="@+id/anim_view_middle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="14sp"
        android:textColor="#57161823"
        android:id="@+id/tips"
        android:focusable="false"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2dp"
        android:text="左滑查看更多"
        android:ems="1"/>
    <View
        android:id="@+id/anim_view_right"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>
</LinearLayout>
