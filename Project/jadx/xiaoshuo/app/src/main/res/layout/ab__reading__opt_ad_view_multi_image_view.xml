<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__large_image_view__image_multi"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/view_dimen_50">
    <ImageView
        android:id="@+id/reading__multi_image_view__img1"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/reading__multi_image_view__img2"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        android:layout_marginStart="@dimen/view_dimen_12"
        android:layout_marginEnd="@dimen/view_dimen_12"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img3"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img1"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/reading__multi_image_view__img3"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/general__page__close_ad_view_style2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
