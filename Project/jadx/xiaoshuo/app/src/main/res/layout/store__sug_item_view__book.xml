<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_width="42.67dp"
        android:layout_height="56.73dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">
        <ImageView
            android:id="@+id/store__sug_item_view__book_cover"
            android:background="@drawable/store__feed_book_cover_frame_background"
            android:padding="0.3dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="9.3sp"
            android:textColor="@color/general__shared__ffffff"
            android:layout_gravity="bottom|right"
            android:id="@+id/store__sug_item_view__book_cover_marker"
            android:background="#b3000000"
            android:paddingTop="1.5dp"
            android:paddingBottom="1.5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </FrameLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__day_night__1a1a1a"
        android:ellipsize="end"
        android:id="@+id/store__sug_item_view__book_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingStart="15dp"/>
</LinearLayout>
