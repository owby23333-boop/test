<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.advertisement.ui.PageAdContainerView
        android:layout_gravity="center_vertical"
        android:id="@+id/page_ad_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@+id/reading__app_ad_view_linear_layout"
            android:background="@drawable/ab__general__shared__rounded_corner_ad"
            android:paddingLeft="14dp"
            android:paddingTop="13.33dp"
            android:paddingRight="14dp"
            android:paddingBottom="13.33dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.473"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.43">
            <TextView
                android:textSize="16sp"
                android:textColor="#000000"
                android:ellipsize="end"
                android:id="@+id/reading__app_ad_view__summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <FrameLayout
                android:id="@+id/reading__large_image_view__area"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="11dp"
                app:layout_constraintDimensionRatio="h,16:9"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__summary"/>
            <TextView
                android:textSize="@dimen/text_font_size_28"
                android:textColor="@color/general__ffffff_90"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/reading__reading_xout"
                android:background="@drawable/general__page__close_ad_view_background"
                android:paddingLeft="@dimen/view_dimen_15"
                android:paddingRight="@dimen/view_dimen_10"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/view_dimen_40"
                android:layout_margin="@dimen/view_dimen_20"
                android:text="@string/reading__close_ad_view__close_text"
                android:drawableRight="@drawable/reading__app_ad_view__close_right_x_icon"
                android:drawablePadding="@dimen/view_dimen_12"
                android:layout_alignTop="@+id/reading__large_image_view__area"
                android:layout_alignRight="@+id/reading__large_image_view__area"
                app:layout_constraintRight_toRightOf="@+id/reading__large_image_view__area"
                app:layout_constraintTop_toTopOf="@+id/reading__large_image_view__area"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/reading__app_ad_view__info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6.67dp"
                android:layout_below="@+id/reading__large_image_view__area"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/reading__large_image_view__area">
                <com.anythink.nativead.api.ATNativeImageView
                    android:id="@+id/reading__app_ad_view__logo"
                    android:visibility="gone"
                    android:layout_width="@dimen/view_dimen_72"
                    android:layout_height="@dimen/view_dimen_72"
                    android:layout_marginRight="10dp"
                    android:scaleType="centerCrop"
                    app:radius="@dimen/view_dimen_12"/>
                <TextView
                    android:textSize="@dimen/text_font_size_40"
                    android:textColor="@color/black_40_transparent"
                    android:ellipsize="end"
                    android:id="@+id/reading__app_ad_view__title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <include
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="@dimen/view_dimen_20"
            android:layout_marginRight="@dimen/view_dimen_20"
            android:layout_marginBottom="16.67dp"
            app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__download"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view_linear_layout"
            layout="@layout/general__close_ad_view"/>
        <TextView
            android:textSize="15.33sp"
            android:textColor="#000000"
            android:gravity="center"
            android:id="@+id/reading__app_ad_view__download"
            android:background="@drawable/general__shared__rounded_button_yellow"
            android:layout_width="216.67dp"
            android:layout_height="40dp"
            android:layout_marginTop="16.67dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view_linear_layout"/>
    </com.duokan.advertisement.ui.PageAdContainerView>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/general__text__day_night__888888_ffffff_80"
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/tv_ad_slide_tip"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:text="@string/slide_to_continue"/>
</FrameLayout>
