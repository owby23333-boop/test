<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/personal__redeem_info_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.FrameScrollView
        android:background="@color/general__day_night__ebebeb"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/general__day_night__f7f7f7"
                android:padding="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.duokan.reader.ui.general.BookCoverView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/personal__redeem_info_view__book_cover"
                    android:layout_marginTop="25dp"
                    style="@style/general__shared__cover_detail"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__b"
                    android:textColor="@color/general__day_night__333333"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/personal__redeem_info_view__title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25dp"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__day_night__999999"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/personal__redeem_info_view__author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/personal__redeem_info_view__arrow"
                android:background="@color/general__day_night__f7f7f7"
                android:layout_width="match_parent"
                android:layout_height="10dp">
                <View
                    android:background="@drawable/personal__redeem_info_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/personal__redeem_info_view__useded"
                android:padding="15dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/personal__redeem_info_view__msg_root"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.duokan.reader.ui.general.deprecatedDkTextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__333333"
                        android:id="@+id/personal__redeem_info_view__msg_content"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__999999"
                        android:layout_gravity="right"
                        android:id="@+id/personal__redeem_info_view__msg_from"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"/>
                    <View
                        android:background="@color/general__day_night__list_line_bcbcbc"
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginTop="30dp"
                        android:layout_marginBottom="30dp"/>
                </LinearLayout>
                <RelativeLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.duokan.personal.ui.view.DkBigFaceView
                        android:id="@+id/personal__redeem_info_view__received_face"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_toRightOf="@+id/personal__redeem_info_view__received_face"
                        android:layout_centerVertical="true">
                        <com.duokan.reader.ui.general.DkLabelView
                            android:textSize="@dimen/general_font__shared__c"
                            android:textColor="@color/general__day_night__333333"
                            android:id="@+id/personal__redeem_info_view__received_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <com.duokan.reader.ui.general.DkLabelView
                            android:textSize="@dimen/general_font__shared__c"
                            android:textColor="@color/general__day_night__999999"
                            android:id="@+id/personal__redeem_info_view__received_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/personal__redeem_info_view__unused"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:background="@color/general__day_night__f7f7f7"
                    android:paddingBottom="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__999999"
                        android:id="@+id/personal__redeem_info_view__msg"
                        android:background="@drawable/general__shared__edit_text_box"
                        android:padding="15dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="15dp"
                        android:text="@string/personal__personal_redeem_info_view__hint"
                        android:layout_weight="1"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__666666"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/personal__personal_redeem_info_view__label"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/personal__redeem_info_view__wx"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/personal__redeem_info_view__wx_icon"
                                android:background="@drawable/general__shared__weichat_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__c"
                                android:textColor="@color/general__shared__666666_disabled"
                                android:layout_gravity="bottom|center_horizontal"
                                android:id="@+id/personal__redeem_info_view__wx_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/personal__personal_redeem_info_view__weixin"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <View
                android:id="@+id/personal__redeem_info_view__placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </com.duokan.core.ui.FrameScrollView>
</LinearLayout>
