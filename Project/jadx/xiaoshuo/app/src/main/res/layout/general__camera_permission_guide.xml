<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:background="#a6000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/general__camera_permission_guide_dialog__main"
        android:background="@drawable/general__permission_guide__background"
        android:layout_width="310dp"
        android:layout_height="389dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="16dp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:id="@+id/general__camera_permission_guide_dialog__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27dp"
        android:text="@string/general__camera_permission_guide_dialog__title"
        app:layout_constraintBottom_toTopOf="@+id/general__camera_permission_guide_dialog__description"
        app:layout_constraintLeft_toLeftOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintRight_toRightOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintTop_toTopOf="@+id/general__camera_permission_guide_dialog__main"/>
    <TextView
        android:textSize="15dp"
        android:textColor="#1a1a1a"
        android:id="@+id/general__camera_permission_guide_dialog__description"
        android:paddingLeft="21dp"
        android:paddingRight="21dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="23dp"
        android:text="@string/general__camera_permission_guide_dialog__desc"
        android:lineSpacingExtra="7dp"
        app:layout_constraintLeft_toLeftOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintRight_toRightOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintTop_toBottomOf="@+id/general__camera_permission_guide_dialog__title"/>
    <TextView
        android:textSize="15.33dp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:id="@+id/general__camera_permission_guide_dialog__ok"
        android:background="@drawable/general__camera_permission_guide_dialog__action_button"
        android:layout_width="150dp"
        android:layout_height="40dp"
        android:layout_marginBottom="23dp"
        android:text="@string/general__camera_permission_guide_dialog__action"
        app:layout_constraintBottom_toBottomOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintLeft_toLeftOf="@+id/general__camera_permission_guide_dialog__main"
        app:layout_constraintRight_toRightOf="@+id/general__camera_permission_guide_dialog__main"/>
</androidx.constraintlayout.widget.ConstraintLayout>
