<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/store_feed_banner_book"
    android:layout_width="match_parent"
    android:layout_height="@dimen/store__banner_height"
    style="@style/store_feed_book_cover_frame_style">
    <TextView
        android:textSize="15dp"
        android:textColor="@android:color/white"
        android:id="@+id/store_feed_banner_book_desc1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="43dp"
        android:layout_marginTop="13dp"
        android:layout_marginRight="6.6dp"
        android:maxLines="1"
        android:layout_toLeftOf="@+id/store_feed_banner_book_cover"
        android:layout_alignParentLeft="true"/>
    <TextView
        android:textSize="23dp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:id="@+id/store_feed_banner_book_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="43dp"
        android:layout_marginRight="6.6dp"
        android:maxLines="1"
        android:layout_toLeftOf="@+id/store_feed_banner_book_cover"
        android:layout_below="@+id/store_feed_banner_book_desc1"
        android:layout_alignParentLeft="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/store_feed_banner_book_author_container"
        android:background="@drawable/store__feed_banner_book_author_container_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="43dp"
        android:layout_marginTop="11dp"
        android:layout_below="@+id/store_feed_banner_book_title">
        <TextView
            android:textSize="11dp"
            android:textColor="@android:color/white"
            android:id="@+id/store_feed_banner_book_author_desc"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/store__shared__author"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="#386d8d"
            android:id="@+id/store_feed_banner_book_author"
            android:background="@drawable/store__feed_banner_book_author_bg"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxEms="6"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/store_feed_banner_book_desc_other"
        android:background="@drawable/store__feed_banner_book_decs_bg"
        android:paddingTop="5dp"
        android:layout_width="39dp"
        android:layout_height="39dp"
        android:layout_marginLeft="11dp"
        android:layout_marginTop="4dp"
        android:layout_toRightOf="@+id/store_feed_banner_book_author_container"
        android:layout_below="@+id/store_feed_banner_book_title"
        android:rotation="330">
        <TextView
            android:textSize="8dp"
            android:textColor="#456c8a"
            android:id="@+id/store_feed_banner_book_desc2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="#456c8a"
            android:id="@+id/store_feed_banner_book_desc3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/store_feed_banner_book_cover"
        android:layout_width="64.7dp"
        android:layout_height="88.7dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="51.3dp"
        android:layout_marginBottom="12dp"
        android:scaleType="fitXY"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
    <ImageView
        android:layout_width="68dp"
        android:layout_height="101dp"
        android:layout_marginRight="50dp"
        android:src="@drawable/store__feed_banner_book_cover_bg"
        android:scaleType="fitXY"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
