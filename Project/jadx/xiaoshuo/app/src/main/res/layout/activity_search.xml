<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/general__day_night__ffffff"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/store__store_search_root_view__rl_top"
            android:background="@color/general__day_night__ffffff"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_144">
            <ImageView
                android:id="@+id/store__store_search_root_view__iv_back"
                android:paddingTop="@dimen/view_dimen_50"
                android:paddingBottom="@dimen/view_dimen_50"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/view_dimen_144"
                android:src="@drawable/general__shared__back"
                android:scaleType="centerCrop"
                android:layout_centerVertical="true"
                android:paddingStart="@dimen/view_dimen_50"
                android:paddingEnd="@dimen/view_dimen_50"/>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="#bbbbbb"
                android:gravity="center"
                android:id="@+id/store__store_search_root_view__tv_search"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/general__shared__search"
                android:layout_centerVertical="true"
                android:paddingStart="@dimen/view_dimen_40"
                android:paddingEnd="@dimen/view_dimen_50"
                android:layout_alignParentEnd="true"/>
            <RelativeLayout
                android:orientation="horizontal"
                android:background="@drawable/store__store_search_root_view__search_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/store__store_search_root_view__tv_search"
                android:layout_toEndOf="@+id/store__store_search_root_view__iv_back">
                <ImageView
                    android:id="@+id/store__store_search__icon"
                    android:layout_width="@dimen/view_dimen_40"
                    android:layout_height="@dimen/view_dimen_40"
                    android:src="@drawable/store__store_search__search_icon"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/view_dimen_30"
                    android:layout_marginEnd="@dimen/view_dimen_30"/>
                <EditText
                    android:textSize="@dimen/text_font_size_38"
                    android:textColor="@color/general__text__day_night__333333"
                    android:textColorHint="@color/general__text__day_night__999999"
                    android:ellipsize="end"
                    android:id="@+id/store__store_search_root_view__edt_search"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/view_dimen_94"
                    android:hint="@string/store__search__hint"
                    android:singleLine="true"
                    android:layout_centerVertical="true"
                    android:imeOptions="actionSearch"
                    android:layout_marginEnd="@dimen/view_dimen_30"
                    android:layout_toStartOf="@+id/store__store_search__associate_cancel"
                    android:layout_toEndOf="@+id/store__store_search__icon"/>
                <ImageView
                    android:id="@+id/store__store_search__associate_cancel"
                    android:padding="@dimen/view_dimen_26"
                    android:visibility="invisible"
                    android:layout_width="@dimen/view_dimen_94"
                    android:layout_height="@dimen/view_dimen_94"
                    android:src="@drawable/store__store_search__associate_cancel"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
        </RelativeLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/store__store_search_root_view__recycler_view"
                android:background="@color/general__day_night__ffffff"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/store__store_search_root_view__associate_recycler_view"
                android:background="@color/general__day_night__ffffff"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:id="@+id/store__search_result_container"
                android:background="@color/general__day_night__ffffff"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/store__store_search__ll_loading"
                android:background="@color/general__day_night__ffffff"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ProgressBar
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    style="@style/refresh_progressbar"/>
            </LinearLayout>
            <ViewStub
                android:id="@+id/store__store_search__net_error"
                android:layout="@layout/general__net_error_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
