<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/store_feed_layer_wrapper"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/store_feed_layer_content"
        android:layout_width="@dimen/store__layer_width"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:id="@+id/store_feed_layer_img"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitXY"/>
    </FrameLayout>
    <ImageView
        android:id="@+id/store_feed_layer_close"
        android:paddingLeft="@dimen/view_dimen_118"
        android:paddingRight="@dimen/view_dimen_10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/general__layer_close"
        android:layout_above="@+id/store_feed_layer_content"
        android:layout_alignRight="@+id/store_feed_layer_content"
        android:paddingVertical="@dimen/view_dimen_10"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/store_feed_layer_destined_cl"
        android:background="@drawable/general__layer_item_destined_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:layout_below="@+id/store_feed_layer_content"
        android:layout_centerHorizontal="true"
        android:paddingHorizontal="@dimen/view_dimen_36"
        android:paddingVertical="@dimen/view_dimen_22">
        <ImageView
            android:id="@+id/store_feed_layer_destined_icon"
            android:layout_width="@dimen/view_dimen_84"
            android:layout_height="@dimen/view_dimen_45"
            android:src="@drawable/ic_destined_close"
            app:layout_constraintEnd_toStartOf="@+id/store_feed_layer_destined_text"/>
        <ImageView
            android:id="@+id/store_feed_layer_destined_success_icon"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_50"
            android:layout_height="@dimen/view_dimen_50"
            android:src="@drawable/ic_destined_success"
            app:layout_constraintEnd_toStartOf="@+id/store_feed_layer_destined_text"/>
        <TextView
            android:textSize="@dimen/view_dimen_33"
            android:textColor="@android:color/white"
            android:id="@+id/store_feed_layer_destined_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/destined_text"
            android:paddingStart="@dimen/view_dimen_21"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>
