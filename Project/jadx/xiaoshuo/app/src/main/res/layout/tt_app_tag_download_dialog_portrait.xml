<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tt_common_download_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/tt_empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.38"/>
    <RelativeLayout
        android:gravity="center_horizontal"
        android:id="@+id/tt_download_layout"
        android:background="@drawable/tt_common_download_bg"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.62">
        <RelativeLayout
            android:id="@+id/tt_dialog_head"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/tt_close_iv"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:src="@drawable/tt_dialog_close_btn"
                android:scaleType="centerInside"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#161823"
                android:gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tt_application_detail"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:textAlignment="center"/>
        </RelativeLayout>
        <View
            android:id="@+id/tt_divider_line_top"
            android:background="#e8e8e8"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@+id/tt_dialog_head"/>
        <LinearLayout
            android:orientation="vertical"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tt_divider_line_top"
            android:layout_marginHorizontal="@dimen/tt_download_dialog_marginHorizontal">
            <com.bytedance.sdk.openadsdk.widget.TTRoundRectImageView
                android:layout_gravity="center_horizontal"
                android:id="@+id/tt_app_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="36.5dp"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#161823"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="top|center_horizontal"
                android:id="@+id/tt_app_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="0sp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#161823"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tt_app_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:singleLine="true"
                android:alpha="0.5"/>
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/tt_app_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/tt_rating_ll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <com.bytedance.sdk.openadsdk.widget.TTRatingBar2
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tt_app_score_rb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="#161823"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tt_app_score_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:layout_marginStart="3dp"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="#57161823"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tt_app_version"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_above="@+id/tt_app_developer"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="@dimen/tt_download_dialog_marginHorizontal"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#4d161823"
            android:gravity="center"
            android:id="@+id/tt_app_developer"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_above="@+id/tt_more_message"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="@dimen/tt_download_dialog_marginHorizontal"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/tt_more_message"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:layout_above="@+id/tt_divider_line"
            android:layout_marginHorizontal="@dimen/tt_download_dialog_marginHorizontal">
            <TextView
                android:textSize="12sp"
                android:textColor="#161823"
                android:id="@+id/tt_app_func_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能"
                android:alpha="0.75"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
            <ImageView
                android:layout_gravity="center"
                android:background="#d8d8d8"
                android:layout_width="0.5dp"
                android:layout_height="9dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#161823"
                android:id="@+id/tt_app_permission_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="权限"
                android:alpha="0.75"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
            <ImageView
                android:layout_gravity="center"
                android:background="#d8d8d8"
                android:layout_width="0.5dp"
                android:layout_height="9dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#161823"
                android:id="@+id/tt_app_privacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="隐私"
                android:alpha="0.75"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>
        <View
            android:id="@+id/tt_divider_line"
            android:background="#e8e8e8"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_above="@+id/tt_app_download_btn"/>
        <Button
            android:textSize="15sp"
            android:textColor="@color/tt_white"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tt_app_download_btn"
            android:background="@drawable/tt_download_app_btn_bg"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="46dp"
            android:text="@string/tt_privacy_start_download"
            android:layout_alignParentBottom="true"
            android:layout_marginHorizontal="@dimen/tt_download_dialog_marginHorizontal"
            android:paddingVertical="13dp"/>
    </RelativeLayout>
</LinearLayout>
