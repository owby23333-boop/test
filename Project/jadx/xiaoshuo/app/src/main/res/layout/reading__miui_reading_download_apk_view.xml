<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="71.67dp">
    <ImageView
        android:id="@+id/reading__miui_reading_download_apk_view__close_button"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:paddingBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="4dp"
        android:src="@drawable/reading__miui_reading_download_apk_view__close"/>
    <ImageView
        android:id="@+id/reading__miui_reading_download_apk_view__hint_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__miui_reading_download_apk_view__hint"
        android:scaleType="fitEnd"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/reading__miui_reading_download_apk_view__container"
        android:background="#4d727272"
        android:paddingLeft="2.12dp"
        android:paddingRight="2.12dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"/>
</LinearLayout>
