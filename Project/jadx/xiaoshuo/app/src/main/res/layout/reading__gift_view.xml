<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.reading.GiftView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.personal.ui.view.DkBigFaceView
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__gift_view__face"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="30dp"
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__gift_view__label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/reading__gift_view__label"/>
        <View
            android:id="@+id/reading__gift_view__space"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>
        <com.duokan.core.ui.FrameScrollView
            android:id="@+id/reading__gift_view__scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.duokan.reader.ui.general.deprecatedDkTextView
                android:textSize="20dp"
                android:id="@+id/reading__gift_view__msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.duokan.core.ui.FrameScrollView>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="15dp"
            android:layout_gravity="right"
            android:id="@+id/reading__gift_view__from"
            android:paddingBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="xxx于xxxx年x月x日"/>
    </LinearLayout>
</com.duokan.reader.ui.reading.GiftView>
