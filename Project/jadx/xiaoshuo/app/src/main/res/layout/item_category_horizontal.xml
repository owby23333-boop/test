<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_category_icon"
        android:layout_width="@dimen/view_dimen_100"
        android:layout_height="@dimen/view_dimen_100"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/general__view__dimen__13_09dp"
        android:textColor="@color/store_rank_selected__day_night__CC000000_CCFFFFFF"
        android:gravity="center"
        android:id="@+id/tv_category_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_26"
        android:layout_marginStart="@dimen/general__view__dimen__4_36dp"
        app:layout_constraintStart_toEndOf="@+id/iv_category_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_category_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
