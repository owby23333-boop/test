<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__shared__ffffff"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.core.ui.LinearScrollView
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="55dp"
            android:layout_marginBottom="35dp"
            android:src="@drawable/general__choose_user_tendency_view__logo"
            android:scaleType="center"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#808080"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome__choose_user_tendency_view__title"
            android:includeFontPadding="false"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/general__choose_user_tendency_view__content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"/>
    </com.duokan.core.ui.LinearScrollView>
    <TextView
        android:textSize="15sp"
        android:textColor="@color/general__shared__ffffff"
        android:gravity="center"
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/general__choose_user_tendency_view__confirm"
        android:background="@drawable/general__choose_user_tendency_view__confirm"
        android:layout_width="300dp"
        android:layout_height="42dp"
        android:layout_marginBottom="50dp"
        android:text="@string/welcome__choose_user_tendency_view__start_read"/>
</LinearLayout>
