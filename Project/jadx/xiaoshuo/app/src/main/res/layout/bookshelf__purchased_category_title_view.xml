<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/bookshelf__purchased_category_title_view__top_line"
        android:background="@color/general__day_night__line_color_c4c4c4"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__999999"
        android:id="@+id/bookshelf__purchased_category_title_view__title"
        android:paddingLeft="15dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <View
        android:id="@+id/bookshelf__purchased_category_title_view__bottom_line"
        android:background="@color/general__day_night__line_color_c4c4c4"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
