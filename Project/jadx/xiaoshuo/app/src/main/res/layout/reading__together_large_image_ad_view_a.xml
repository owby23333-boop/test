<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/reading__app_ad_view_click"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:background="@drawable/general__shared__corner_ad_bg"
            android:paddingLeft="@dimen/view_dimen_42"
            android:paddingTop="@dimen/view_dimen_50"
            android:paddingRight="@dimen/view_dimen_42"
            android:paddingBottom="@dimen/view_dimen_50"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/text_font_size_48"
                android:textStyle="bold"
                android:textColor="#000000"
                android:ellipsize="end"
                android:id="@+id/reading__app_ad_view__summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"/>
            <ImageView
                android:id="@+id/reading__large_image_view__image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_42"
                android:layout_below="@+id/reading__app_ad_view__summary"/>
            <include
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/reading__large_image_view__image"
                android:layout_alignRight="@+id/reading__large_image_view__image"
                layout="@layout/general__page__close_ad_view"/>
            <include
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_30"
                android:layout_below="@+id/reading__large_image_view__image"
                layout="@layout/reading__ad_view_title_icon_xout_a"/>
            <TextView
                android:textSize="@dimen/text_font_size_24"
                android:textColor="@color/general__ffffff_90"
                android:id="@+id/reading__app_ad_view__ad_icon"
                android:background="@drawable/general__page__close_ad_view_background"
                android:paddingLeft="@dimen/view_dimen_11"
                android:paddingTop="@dimen/view_dimen_3"
                android:paddingRight="@dimen/view_dimen_11"
                android:paddingBottom="@dimen/view_dimen_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/view_dimen_20"
                android:layout_marginBottom="@dimen/view_dimen_20"
                android:text="@string/general__shared__ad"
                android:layout_alignRight="@+id/reading__large_image_view__image"
                android:layout_alignBottom="@+id/reading__large_image_view__image"/>
        </RelativeLayout>
        <include
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/view_dimen_10"
            android:layout_marginRight="@dimen/view_dimen_10"
            layout="@layout/general__close_ad_view"/>
    </FrameLayout>
    <include layout="@layout/reading__ad_view_download_view_a"/>
</LinearLayout>
