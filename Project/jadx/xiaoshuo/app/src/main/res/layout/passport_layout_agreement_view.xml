<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <CheckBox
        android:id="@+id/user_agreement_checkbox"
        android:layout_marginEnd="@dimen/passport_account_login_margin_small"
        style="@style/PassportWidget.CheckBox"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/passport_user_agreement_text"
        android:textColorHighlight="@android:color/transparent"
        android:gravity="start"
        android:id="@+id/user_agreement_hint"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/passport_user_agreement_hint_with_mobile"/>
</LinearLayout>
