<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/general__shared__1b314a"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/personal__readed_books_view__sync"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="50dp"
            android:text="@string/personal__readed_books_view__sync_closed"/>
        <ImageView
            android:layout_gravity="right"
            android:id="@+id/personal__readed_books_view__sync_switcher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:src="@drawable/general__shared__switch"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/personal__readed_books_view__header_bg"
            android:scaleType="center"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:id="@+id/personal__readed_books_view__ranking_total"
            android:paddingLeft="110dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <ImageView
        android:gravity="bottom|center_horizontal"
        android:background="@drawable/personal__readed_books_view__bottom_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"/>
    <View
        android:background="@color/general__day_night__ffffff"
        android:layout_width="match_parent"
        android:layout_height="20dp"/>
    <View
        android:background="@color/general__day_night__cccccc"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
