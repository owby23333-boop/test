<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/reading_error_icon"
        android:layout_width="@dimen/view_dimen_600"
        android:layout_height="@dimen/view_dimen_340"
        android:src="@drawable/reading_error_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/black_30_transparent"
        android:id="@+id/reading_error_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading_error_icon"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/color_white"
        android:gravity="center"
        android:id="@+id/reading_error_retry"
        android:background="@drawable/shape_corner_55_solid_ff8640"
        android:layout_width="@dimen/view_dimen_340"
        android:layout_height="@dimen/view_dimen_100"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:text="@string/reading_retry"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading_error_tip"/>
</androidx.constraintlayout.widget.ConstraintLayout>
