<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_view"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.store.view.StoreNestedScrollView
        android:id="@+id/store__fiction_detail_view__scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/store__fiction_detail_view__rl_bottom">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/store__fiction_detail_view__ll_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@+id/store__fiction_detail_view__header"
                layout="@layout/store__fiction_detail_view__header"/>
            <include
                android:id="@+id/store__fiction_detail_view__score"
                layout="@layout/store__fiction_detail_view__score"/>
            <include
                android:id="@+id/store__fiction_detail_view__rank"
                layout="@layout/store__fiction_detail_view__rank"/>
            <include
                android:id="@+id/store__fiction_detail_view__divider"
                layout="@layout/store__fiction_detail_view__divider"/>
            <include layout="@layout/store__fiction_detail_view__catalogue"/>
        </LinearLayout>
    </com.duokan.reader.ui.store.view.StoreNestedScrollView>
    <FrameLayout
        android:orientation="vertical"
        android:id="@+id/store__fiction_detail_view__top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_144">
            <ImageView
                android:id="@+id/store__fiction_detail_view__iv_back"
                android:paddingTop="@dimen/view_dimen_50"
                android:paddingBottom="@dimen/view_dimen_50"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/view_dimen_144"
                android:src="@drawable/store__fiction_detail_view__back_icon_white"
                android:scaleType="centerCrop"
                android:layout_centerVertical="true"
                android:paddingStart="@dimen/view_dimen_50"
                android:paddingEnd="@dimen/view_dimen_50"/>
            <TextView
                android:textSize="@dimen/text_font_size_62"
                android:textStyle="bold"
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/store__fiction_detail_view__tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lines="1"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/view_dimen_60"
                android:layout_marginEnd="@dimen/view_dimen_204"
                android:layout_toEndOf="@+id/store__fiction_detail_view__iv_back"/>
        </RelativeLayout>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/store__fiction_detail_view__ll_tab_group"
        android:background="@color/general__day_night__ffffff"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/store__fiction_detail_view__top_bar">
        <com.duokan.reader.ui.store.view.TabGroup
            android:id="@+id/store__fiction_detail_view__top_bar_tab_group"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/view_dimen_120"
            android:layout_marginTop="@dimen/view_dimen_10"
            app:active_scale="1"
            app:inactive_scale="1"
            app:indicator_color="#ffd014"
            app:indicator_corners_radius="20"
            app:indicator_factor="1"
            app:indicator_height="@dimen/view_dimen_10"
            app:indicator_type="1"
            app:indicator_weight="@dimen/view_dimen_50"
            app:pivot_type="1"/>
        <View style="@style/HorizontalDivider"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/store__fiction_detail_view__rl_bottom"
        android:background="@color/general__day_night__ffffff_212121"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_190"
        android:layout_alignParentBottom="true">
        <View style="@style/HorizontalDivider"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:weightSum="2">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/store__fiction_detail_view__ll_add_to_bookshelf"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/view_dimen_54"
                    android:layout_height="@dimen/view_dimen_54"
                    android:src="@drawable/store__fiction_detail_view__add_to_bookshelf"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="@dimen/view_dimen_16"/>
                <TextView
                    android:textSize="@dimen/text_font_size_46"
                    android:textColor="@color/store__fiction_detail_view__333333_selected"
                    android:gravity="center"
                    android:id="@+id/store__fiction_detail_view__tv_add_to_bookshelf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/store__fiction_detail_add_to_bookshelf"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__333333"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/store__fiction_detail_view__tv_read"
                android:background="@drawable/store__fiction_detail_view__free_read_bg"
                android:layout_width="0dp"
                android:layout_height="@dimen/view_dimen_120"
                android:text="@string/store__fiction_detail_view__freeread"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/view_dimen_40"
                android:layout_marginEnd="@dimen/view_dimen_40"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/store__fiction_detail_view__ll_loading"
        android:background="@color/general__day_night__ffffff"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ProgressBar
            android:layout_width="22dp"
            android:layout_height="22dp"
            style="@style/refresh_progressbar"/>
    </LinearLayout>
    <ViewStub
        android:id="@+id/store__fiction_detail_view__net_error"
        android:layout="@layout/general__net_error_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</RelativeLayout>
