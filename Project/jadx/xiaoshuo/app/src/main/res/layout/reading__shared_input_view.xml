<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reading__shared_input_view__comment"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/reading__idea_input_view__editor_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/reading__idea_input_view__anchor"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__cccccc"
            android:gravity="center"
            android:id="@+id/reading__shared_input_view__comment_hint"
            android:background="@null"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:text="@string/reading__reading_menu_bottom_view__idea_editor_hint"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__000000"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="@string/general__shared__send"/>
    </LinearLayout>
</FrameLayout>
