<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:background="@drawable/reading__shared__floating_bar"
    android:paddingLeft="5dp"
    android:paddingRight="5dp"
    android:layout_width="wrap_content"
    android:layout_height="40dp">
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__ffffffcc"
        android:gravity="center"
        android:id="@+id/reading__page_clip_tool_view__odd_even_symmetry"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:text="@string/reading__page_clip_tool_view__odd_even_symmetry"
        android:drawableLeft="@drawable/general__shared__single_checkbox"
        android:drawablePadding="5dp"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__ffffffcc"
        android:gravity="center"
        android:id="@+id/reading__page_clip_tool_view__rollback"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:text="@string/reading__page_clip_tool_view__rollback"
        android:layout_weight="1"/>
    <ImageView
        android:id="@+id/reading__page_clip_tool_view__cancel"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__page_clip_tool_view__cancel"
        android:layout_weight="1"
        android:contentDescription="@null"/>
    <ImageView
        android:id="@+id/reading__page_clip_tool_view__ok"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__page_clip_tool_view__ok"
        android:scaleType="center"
        android:layout_weight="1"
        android:contentDescription="@null"/>
</LinearLayout>
