<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/reading__confirm_download__background"
        android:background="@color/black_60_transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom"
        android:id="@+id/reading__confirm_download__content"
        android:background="@drawable/general__free_dialog_box__bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/reading__confirm_download__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_90"
            android:text="@string/reading__confirm_download_title_text"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_46"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/reading__confirm_download__description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_50"
            android:text="@string/reading__confirm_download_description_text"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__confirm_download__title"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:gravity="center"
            android:id="@+id/reading__confirm_download__forgo"
            android:layout_width="@dimen/view_dimen_440"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/view_dimen_63"
            android:layout_marginBottom="@dimen/view_dimen_80"
            android:text="@string/reading__forgo_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/reading__confirm_download__download_now"
            app:layout_constraintTop_toBottomOf="@+id/reading__confirm_download__description"
            style="@style/DkReader.Widget.Button"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:gravity="center"
            android:id="@+id/reading__confirm_download__download_now"
            android:layout_width="@dimen/view_dimen_440"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginLeft="@dimen/view_dimen_40"
            android:layout_marginTop="@dimen/view_dimen_63"
            android:layout_marginBottom="@dimen/view_dimen_80"
            android:text="@string/reading__download_now_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/reading__confirm_download__forgo"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__confirm_download__description"
            style="@style/DkReader.Widget.Button.DkPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
