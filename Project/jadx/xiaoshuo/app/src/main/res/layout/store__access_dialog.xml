<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/general__free_dialog_box__bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/free_splash__access_dialog__top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/free_store__access_top_bg"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_486"
        android:src="@drawable/free_store__access_bg_oval"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:textSize="26.67dp"
        android:textStyle="bold"
        android:textColor="@color/general__000000"
        android:id="@+id/free_splash__access_dialog__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_72"
        android:text="@string/app__shared__shortcut_name"
        android:layout_marginStart="@dimen/view_dimen_76"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_50"
        android:textColor="#000000"
        android:id="@+id/free_splash__access_dialog__subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_13"
        android:text="@string/free_splash__access_dialog_protect"
        android:layout_marginStart="@dimen/view_dimen_79"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/free_splash__access_dialog__title"/>
    <com.duokan.reader.ui.general.DkTextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/general__day_night__1A1A1A_ffffff_70"
        android:gravity="fill_horizontal"
        android:id="@+id/free_splash__access_dialog__content1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_25"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:text="@string/free_store__access_dialog_content1_v2"
        android:layout_marginStart="@dimen/view_dimen_70"
        android:layout_marginEnd="@dimen/view_dimen_70"
        app:layout_constraintTop_toBottomOf="@+id/free_splash__access_dialog__top"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="@color/general__day_night__000000_50"
        android:id="@+id/free_store__access_dialog__content2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_35"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:text="@string/free_store__access_dialog_content2"
        android:layout_marginStart="@dimen/view_dimen_70"
        android:layout_marginEnd="@dimen/view_dimen_70"
        app:layout_constraintTop_toBottomOf="@+id/free_splash__access_dialog__content1"/>
    <com.duokan.reader.ui.general.DkTextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/general__day_night__1A1A1A_ffffff_70"
        android:gravity="fill_horizontal"
        android:id="@+id/free_store__access_dialog__content3"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_35"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:text="@string/free_store__access_dialog_content3"
        android:layout_marginStart="@dimen/view_dimen_70"
        android:layout_marginEnd="@dimen/view_dimen_70"
        app:layout_constraintTop_toBottomOf="@+id/free_store__access_dialog__content2"/>
    <TextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/general__day_night__1A1A1A_ffffff_70"
        android:id="@+id/free_store__access_dialog__content4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_35"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:text="@string/free_store__access_dialog_content4_v2"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/view_dimen_70"
        android:layout_marginEnd="@dimen/view_dimen_70"
        app:layout_constraintBottom_toTopOf="@+id/free_splash__access_dialog__disagree"
        app:layout_constraintTop_toBottomOf="@+id/free_store__access_dialog__content3"/>
    <TextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="@color/general__day_night__333333"
        android:gravity="center"
        android:id="@+id/free_splash__access_dialog__disagree"
        android:background="@drawable/free_store__access_dialog_disagree_bg"
        android:layout_width="@dimen/view_dimen_440"
        android:layout_height="@dimen/view_dimen_120"
        android:layout_marginBottom="@dimen/view_dimen_70"
        android:text="@string/free_splash__access_dialog_disagree"
        android:layout_marginStart="@dimen/view_dimen_80"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_46"
        android:textStyle="bold"
        android:textColor="@color/general__333333"
        android:gravity="center"
        android:id="@+id/free_splash__access_dialog__agree"
        android:background="@drawable/free_store__access_dialog_agree_bg"
        android:layout_width="@dimen/view_dimen_440"
        android:layout_height="@dimen/view_dimen_120"
        android:layout_marginBottom="@dimen/view_dimen_70"
        android:text="@string/free_splash__access_dialog_agree"
        android:layout_marginEnd="@dimen/view_dimen_80"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
