<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/general__shared__cover_left_shadow_margin_10dip"
    android:layout_marginTop="15dp"
    android:layout_marginRight="@dimen/general__shared__cover_left_shadow_margin_10dip"
    android:layout_marginBottom="15dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.store.AdView
            android:id="@+id/store__recommends_view__ad1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <com.duokan.reader.ui.store.AdView
            android:id="@+id/store__recommends_view__ad2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <com.duokan.reader.ui.store.AdView
            android:id="@+id/store__recommends_view__ad3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <com.duokan.reader.ui.store.AdView
            android:id="@+id/store__recommends_view__ad4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
