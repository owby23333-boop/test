<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_fl"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="@dimen/general__shared_dimen__15dp">
    <com.duokan.advertisement.ui.DkVideoAdView
        android:id="@+id/reading__app_ad_view_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ad_bottom_tips"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="@dimen/general__shared_dimen__16dp"
            android:layout_marginTop="@dimen/general__shared_dimen__30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__opt_ad_view__clickable_area">
            <TextView
                android:textSize="@dimen/general__shared_dimen__14dp"
                android:textColor="@color/general__text__day_night__888888_ffffff_80"
                android:gravity="center"
                android:id="@+id/tv_ad_slide_tip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/slide_to_continue_new"
                android:layout_marginEnd="@dimen/general__shared_dimen__40_67dp"
                app:layout_constraintEnd_toStartOf="@+id/tv_ad_reward_video_tip"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_goneMarginEnd="0dp"/>
            <TextView
                android:textSize="@dimen/general__shared_dimen__14dp"
                android:textColor="@color/general__text__day_night__888888_ffffff_80"
                android:gravity="center"
                android:id="@+id/tv_ad_reward_video_tip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/click_to_watch_reward_video"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tv_ad_slide_tip"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.duokan.advertisement.ui.ReadingPageBottomRewardAdView
            android:id="@+id/const_reward"
            android:paddingTop="@dimen/general__shared_dimen__20dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__10dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__opt_ad_view__clickable_area"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/ad_free_try_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__56dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
            app:layout_constraintBottom_toTopOf="@+id/ad_bottom_tips"/>
        <TextView
            android:textSize="@dimen/text_font_size_33"
            android:textColor="@color/general__day_night__ad_tips_color_1A1A1A"
            android:id="@+id/reading__ad_bottom_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__33_33dp"
            android:text="@string/reading__ad_view__user_tip_new"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="@dimen/general__shared_dimen__11dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/reading__opt_ad_view__clickable_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__32_33dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__15dp"
            android:contentDescription="@string/ad_appstore_card"
            app:cardBackgroundColor="@color/black_05_transparent"
            app:cardCornerRadius="@dimen/general__shared_dimen__20dp"
            app:cardElevation="@dimen/general__shared_dimen__0dp"
            app:layout_constraintBottom_toTopOf="@+id/ad_bottom_tips"
            app:layout_constraintTop_toBottomOf="@+id/reading__ad_bottom_tips"
            app:layout_goneMarginBottom="@dimen/general__shared_dimen__15dp">
            <com.duokan.advertisement.ui.PageAdContainerView
                android:id="@+id/page_ad_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/general__shared_dimen__586_66dp">
                <ImageView
                    android:id="@+id/reading__large_image_view__image_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
                <com.duokan.reader.ui.general.ClipFrameLayout
                    android:id="@+id/fl_container_video"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.duokan.advertisement.ui.DkVideoView
                        android:id="@+id/reading__video_view__video"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:resize_mode="fixed_height"/>
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/reading__app_ad_view__video_play"
                        android:visibility="gone"
                        android:layout_width="@dimen/view_dimen_120"
                        android:layout_height="@dimen/view_dimen_120"
                        android:src="@drawable/reading__ad_view_play"/>
                </com.duokan.reader.ui.general.ClipFrameLayout>
                <ImageView
                    android:background="@drawable/bg_top_ad"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/general__shared_dimen__100dp"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:background="@drawable/bg_bottom_ad"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/general__shared_dimen_336_66dp"
                    app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView
                    android:textSize="@dimen/text_font_size_24"
                    android:textColor="@color/white_70_transparent"
                    android:id="@+id/reading__app_ad_view__version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/general__shared_dimen__12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/divider"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"/>
                <TextView
                    android:textSize="@dimen/text_font_size_24"
                    android:textColor="@color/white_70_transparent"
                    android:id="@+id/divider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | "
                    app:layout_constraintBaseline_toBaselineOf="@+id/reading__app_ad_view__version"
                    app:layout_constraintEnd_toStartOf="@+id/reading__app_ad_view__permission_privacy"
                    app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__version"/>
                <TextView
                    android:textSize="@dimen/text_font_size_24"
                    android:textColor="@color/white_70_transparent"
                    android:id="@+id/reading__app_ad_view__permission_privacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/general__shared__permission_privacy"
                    app:layout_constraintBaseline_toBaselineOf="@+id/divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/divider"/>
                <TextView
                    android:textSize="@dimen/text_font_size_24"
                    android:textColor="@color/white_70_transparent"
                    android:id="@+id/developer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="开发者："
                    app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__version"
                    app:layout_constraintEnd_toStartOf="@+id/reading__app_ad_view__developer"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"/>
                <TextView
                    android:textSize="@dimen/text_font_size_24"
                    android:textColor="@color/white_70_transparent"
                    android:id="@+id/reading__app_ad_view__developer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBaseline_toBaselineOf="@+id/developer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/developer"/>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/reading__app_ad_view_videoAd_A"
                    android:paddingLeft="@dimen/general__shared_dimen__14dp"
                    android:paddingRight="@dimen/general__shared_dimen__14dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="108.67dp"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:id="@+id/reading__app_ad_view__logo_videoAd_A"
                        android:layout_width="@dimen/general__shared_dimen__14dp"
                        android:layout_height="@dimen/general__shared_dimen__14dp"
                        android:layout_marginBottom="@dimen/general__shared_dimen__20dp"
                        android:src="@drawable/ad_bottom_mi_video_logo"
                        android:scaleType="centerInside"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__10sp"
                        android:textColor="@color/white_60_transparent"
                        android:id="@+id/reading__app_ad_view__logo_desc_videoAd_A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/general__shared_dimen__8dp"
                        android:layout_marginTop="@dimen/general__shared_dimen__7dp"
                        android:layout_marginBottom="@dimen/general__shared_dimen__20dp"
                        android:text="@string/reading__app_ad_view__logo_desc"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__logo_videoAd_A"/>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__12sp"
                        android:textColor="@color/white_70_transparent"
                        android:ellipsize="end"
                        android:id="@+id/reading__app_ad_view__summary_videoAd_A"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/general__shared_dimen__7dp"
                        android:maxLines="2"
                        app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__logo_videoAd_A"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_45"
                        android:textStyle="bold"
                        android:textColor="@color/white_70_transparent"
                        android:id="@+id/reading__app_ad_view__title_videoAd_A"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/general__shared_dimen__1dp"
                        app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__summary_videoAd_A"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintVertical_bias="0"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <TextView
                    android:textSize="@dimen/general__shared_dimen__14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white_90_transparent"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/reading__app_ad_btn_videoAd_B"
                    android:background="@drawable/reading__app_ad_view_mi_video_btn_bg"
                    android:visibility="gone"
                    android:layout_width="@dimen/general__shared_dimen__150dp"
                    android:layout_height="40.67dp"
                    android:text="@string/reading__app_ad_view__top_tip"
                    android:layout_centerHorizontal="true"
                    app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view_videoAd_B"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/reading__app_ad_view_videoAd_B"
                    android:paddingLeft="@dimen/general__shared_dimen__14dp"
                    android:paddingTop="25.3dp"
                    android:paddingRight="@dimen/general__shared_dimen__14dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="108.67dp"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:textSize="@dimen/text_font_size_45"
                        android:textStyle="bold"
                        android:textColor="@color/white_90_transparent"
                        android:id="@+id/reading__app_ad_view__title_videoAd_B"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_39"
                        android:textColor="@color/white_70_transparent"
                        android:ellipsize="end"
                        android:id="@+id/reading__app_ad_view__summary_videoAd_B"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/general__shared_dimen__6dp"
                        android:layout_marginBottom="@dimen/general__shared_dimen__28dp"
                        android:maxLines="2"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__title_videoAd_B"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <TextView
                    android:textSize="@dimen/view_dimen_33"
                    android:textColor="@color/dkcommon__ffffff_80"
                    android:gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__close"
                    android:background="@drawable/reading_ad_top_bt_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_86"
                    android:layout_marginTop="@dimen/view_dimen_42"
                    android:text="@string/general__shared__ad"
                    android:drawablePadding="@dimen/view_dimen_10"
                    android:contentDescription="@string/ad_appstore_close"
                    android:drawableEnd="@drawable/reading_ad_close_icon"
                    android:layout_marginStart="@dimen/view_dimen_42"
                    android:paddingHorizontal="@dimen/view_dimen_23"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="@dimen/view_dimen_33"
                    android:textColor="@color/dkcommon__ffffff_80"
                    android:gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__reward"
                    android:background="@drawable/reading_ad_top_bt_bg"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_86"
                    android:layout_marginTop="@dimen/view_dimen_42"
                    android:drawablePadding="@dimen/view_dimen_6"
                    android:drawableEnd="@drawable/reading_ad_reward_icon"
                    android:paddingStart="@dimen/view_dimen_28"
                    android:paddingEnd="@dimen/view_dimen_28"
                    android:layout_marginEnd="@dimen/view_dimen_42"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:layout_gravity="start"
                    android:id="@+id/reading__app_ad_view__volume"
                    android:layout_width="@dimen/view_dimen_86"
                    android:layout_height="@dimen/view_dimen_86"
                    android:src="@drawable/reading__video_view__mute"
                    android:contentDescription="@string/ad_appstore_volume_switch"
                    android:layout_marginStart="@dimen/view_dimen_12"
                    app:layout_constraintBottom_toBottomOf="@+id/reading__app_ad_view__close"
                    app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__close"
                    app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view__close"/>
            </com.duokan.advertisement.ui.PageAdContainerView>
        </androidx.cardview.widget.CardView>
        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@+id/reading__reward_blur_bg"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/reading__reward_bg_dim"
            app:layout_constraintBottom_toBottomOf="@+id/reading__opt_ad_view__clickable_area"
            app:layout_constraintLeft_toLeftOf="@+id/reading__opt_ad_view__clickable_area"
            app:layout_constraintRight_toRightOf="@+id/reading__opt_ad_view__clickable_area"
            app:layout_constraintTop_toTopOf="@+id/reading__opt_ad_view__clickable_area"
            app:round="@dimen/general__shared_dimen__20dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/reading__app_ad_view__reward_layout"
            android:background="@drawable/ad_bottom_reward_container_bg"
            android:visibility="gone"
            android:layout_width="@dimen/general__shared_dimen__0dp"
            android:layout_height="@dimen/view_dimen_130"
            android:layout_marginLeft="@dimen/view_dimen_55"
            android:layout_marginTop="@dimen/view_dimen_50"
            android:layout_marginRight="@dimen/view_dimen_55"
            app:layout_constraintEnd_toEndOf="@+id/reading__opt_ad_view__clickable_area"
            app:layout_constraintStart_toStartOf="@+id/reading__opt_ad_view__clickable_area"
            app:layout_constraintTop_toBottomOf="@+id/reading__opt_ad_view__clickable_area">
            <ImageView
                android:layout_width="@dimen/view_dimen_80"
                android:layout_height="@dimen/view_dimen_80"
                android:src="@drawable/ad_bottom_reward_icon"
                android:layout_marginStart="@dimen/view_dimen_30"/>
            <TextView
                android:textSize="@dimen/view_dimen_37"
                android:textColor="@color/dkcommon__000000_90"
                android:id="@+id/reading__app_ad_view_bottom_tv"
                android:layout_width="@dimen/general__shared_dimen__0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/view_dimen_20"
                android:layout_marginRight="@dimen/view_dimen_20"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/view_dimen_36"
                android:textColor="@color/dkcommon__ffffff"
                android:gravity="center"
                android:id="@+id/reading__app_ad_view__reward_bt"
                android:background="@drawable/ad_bottom_reward_bt_bg"
                android:layout_width="@dimen/view_dimen_160"
                android:layout_height="@dimen/view_dimen_80"
                android:layout_marginRight="@dimen/view_dimen_30"
                android:text="@string/general__shared__launch_short"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/view_dimen_42"
            android:textColor="@color/black_40_transparent"
            android:id="@+id/ad_force_scan_tips"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_220"
            android:drawablePadding="@dimen/view_dimen_12"
            app:drawableRightCompat="@drawable/reading_ad_reward_arraw_black40"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__opt_ad_view__clickable_area"/>
    </com.duokan.advertisement.ui.DkVideoAdView>
</FrameLayout>
