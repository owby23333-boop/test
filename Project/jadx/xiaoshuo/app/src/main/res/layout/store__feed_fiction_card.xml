<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.general.RoundFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/store__feed_book_cover_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="?android:attr/selectableItemBackground"
    style="@style/store_feed_book_cover_round_style">
    <ImageView
        android:id="@+id/store__feed_book_common_cover"
        android:background="@color/general__day_night__f2f2f2_2a2a2a"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"/>
    <TextView
        android:textSize="@dimen/general_font__shared__e"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_gravity="end|top"
        android:id="@+id/store__feed_book_common_label"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/store__feed_book_vip_width"
        android:singleLine="true"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"/>
    <ImageView
        android:id="@+id/store__feed_book_common_img"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="center"/>
</com.duokan.reader.ui.general.RoundFrameLayout>
