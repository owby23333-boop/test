<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.core.ui.BoxView
        android:id="@+id/account__bitmap_factory_content_view__text_box"
        android:background="#fff5e4"
        android:paddingLeft="40px"
        android:paddingTop="30px"
        android:paddingRight="40px"
        android:paddingBottom="30px"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.deprecatedDkTextView
            android:textSize="48px"
            android:textColor="@color/general__shared__8d6752"
            android:ellipsize="end"
            android:gravity="fill"
            android:id="@+id/account__bitmap_factory_content_view__text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:layout_alignParentTop="true"/>
    </com.duokan.core.ui.BoxView>
    <RelativeLayout
        android:layout_gravity="bottom"
        android:id="@+id/account__bitmap_factory_content_view__book_info"
        android:background="#f6f6f6"
        android:paddingLeft="20px"
        android:paddingTop="20px"
        android:paddingRight="20px"
        android:paddingBottom="20px"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30px">
        <com.duokan.reader.ui.general.BookCoverView
            android:id="@+id/account__bitmap_factory_content_view__book_cover"
            android:background="@null"
            android:layout_width="204px"
            android:layout_height="278px"
            android:layout_marginLeft="6dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_centerVertical="true"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="48px"
            android:textColor="@color/general__shared__333333"
            android:ellipsize="end"
            android:gravity="top"
            android:id="@+id/account__bitmap_factory_content_view__book_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30px"
            android:layout_marginTop="@dimen/general__shared__cover_top_shadow_size"
            android:layout_marginRight="30px"
            android:maxLines="2"
            android:includeFontPadding="false"
            android:layout_toRightOf="@+id/account__bitmap_factory_content_view__book_cover"
            android:layout_alignTop="@+id/account__bitmap_factory_content_view__book_cover"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="36px"
            android:textColor="@color/general__shared__666666"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/account__bitmap_factory_content_view__book_author"
            android:paddingTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30px"
            android:layout_marginRight="30px"
            android:singleLine="true"
            android:layout_toRightOf="@+id/account__bitmap_factory_content_view__book_cover"
            android:layout_below="@+id/account__bitmap_factory_content_view__book_name"/>
    </RelativeLayout>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="32px"
        android:textColor="@color/general__shared__999999"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:layout_gravity="bottom|right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30px"
        android:layout_marginBottom="30px"
        android:text="@string/share_form_app"
        android:singleLine="true"/>
</LinearLayout>
