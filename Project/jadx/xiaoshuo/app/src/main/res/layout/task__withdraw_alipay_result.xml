<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__f8f8f8"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/task__withdraw_alipay_result__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/task__withdraw_alipay_result__content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15.5sp"
                android:textColor="#000000"
                android:id="@+id/task__withdraw_alipay_result__count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26.6dp"
                android:layout_marginStart="65dp"/>
            <TextView
                android:textSize="12.3sp"
                android:textColor="#bdbdbd"
                android:id="@+id/task__withdraw_alipay__result_requested_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.3dp"
                android:layout_marginStart="65dp"/>
            <TextView
                android:textSize="15.5sp"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="45dp"
                android:text="@string/task__withdraw_alipay__result_done_time"
                android:layout_marginStart="65dp"/>
            <TextView
                android:textSize="12.3sp"
                android:textColor="#bdbdbd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.3dp"
                android:text="@string/task__withdraw_alipay__result_done_time_hint"
                android:layout_marginStart="65dp"/>
            <TextView
                android:textSize="15.5sp"
                android:textColor="#bdbdbd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="45dp"
                android:text="@string/task__withdraw_alipay__result_done"
                android:layout_marginStart="65dp"/>
        </LinearLayout>
        <ImageView
            android:background="@drawable/task__withdraw_alipay_result_flow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26.6dp"
            android:layout_marginBottom="-3dp"
            android:layout_alignTop="@+id/task__withdraw_alipay_result__content"
            android:layout_alignBottom="@+id/task__withdraw_alipay_result__content"
            android:layout_marginStart="30.6dp"/>
    </RelativeLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/task__withdraw_alipay__more_coins"
        android:background="@drawable/task__bind_alipay_account__button_bg"
        android:layout_width="match_parent"
        android:layout_height="40.6dp"
        android:layout_marginTop="57.3dp"
        android:text="@string/task__withdraw_alipay__more_coins"
        android:layout_marginStart="19.3dp"
        android:layout_marginEnd="19.3dp"/>
</LinearLayout>
