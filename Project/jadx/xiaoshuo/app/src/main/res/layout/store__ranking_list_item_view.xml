<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="60dp">
    <View
        android:id="@+id/store__ranking_list_item_view__top"
        android:background="@color/general__shared__bcbcbc"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_alignParentTop="true"/>
    <ImageView
        android:id="@+id/store__ranking_list_item_view__icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__333333"
        android:id="@+id/store__ranking_list_item_view__name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:maxLines="1"
        android:layout_toRightOf="@+id/store__ranking_list_item_view__icon"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/store__discript_view__more_root"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__333333"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__discript_view__more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:text="@string/store__shared__more"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/store__discript_view__more_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
    <View
        android:id="@+id/store__ranking_list_item_view__bottom"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
