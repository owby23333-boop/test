<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__page_header_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/general__multiline_input_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/general__multiline_input_view__description"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="22dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/general__text_input_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="15dp">
            <EditText
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__day_night__333333"
                android:gravity="top|left"
                android:id="@+id/general__multiline_input_view__editor"
                android:background="@android:color/transparent"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="8dp"
                android:paddingBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:singleLine="false"
                android:textCursorDrawable="@null"/>
            <com.duokan.reader.ui.general.DkNumView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__day_night__555555"
                android:layout_gravity="right"
                android:id="@+id/general__multiline_input_view__remained_length"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginRight="12dp"
                android:layout_marginBottom="6dp"
                android:text="14"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/general__multiline_input_view__save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:background="#c6c6c6"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="15dp"
                android:contentDescription="@null"/>
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__day_night__ff6518"
                android:gravity="center"
                android:id="@+id/general__multiline_input_view__save_text"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/general__shared__confirm"/>
            <ImageView
                android:background="#c6c6c6"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:contentDescription="@null"/>
        </LinearLayout>
    </com.duokan.core.ui.LinearScrollView>
</LinearLayout>
