<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:layout_marginBottom="13.33dp"
        android:text="@string/general__shared__choose_payment"
        android:fontFamily="sans-serif-medium"
        style="@style/general__shared__dialog_title"/>
    <TextView
        android:textSize="@dimen/general_font__shared__dialog_button"
        android:textColor="@color/audio__audio_player_view__timer_text"
        android:gravity="center_vertical"
        android:id="@+id/general__choose_payment_method_dialog__mipay"
        android:background="@drawable/general__shared__dialog_list_item"
        android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
        android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared__dialog_menu_item_height"
        android:text="@string/general__shared__mipay"
        android:drawableLeft="@drawable/general__shared__mipay"
        android:drawablePadding="15dp"
        android:fontFamily="sans-serif-medium"/>
    <TextView
        android:textSize="@dimen/general_font__shared__dialog_button"
        android:textColor="@color/audio__audio_player_view__timer_text"
        android:gravity="center_vertical"
        android:id="@+id/general__choose_payment_method_dialog__alipay"
        android:background="@drawable/general__shared__dialog_list_item"
        android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
        android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared__dialog_menu_item_height"
        android:text="@string/general__shared__alipay"
        android:drawableLeft="@drawable/general__shared__alipay"
        android:drawablePadding="15dp"
        android:fontFamily="sans-serif-medium"/>
    <TextView
        android:textSize="@dimen/general_font__shared__dialog_button"
        android:textColor="@color/audio__audio_player_view__timer_text"
        android:gravity="center_vertical"
        android:id="@+id/general__choose_payment_method_dialog__wxpay"
        android:background="@drawable/general__shared__dialog_list_item"
        android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
        android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared__dialog_menu_item_height"
        android:text="@string/general__shared__wxpay"
        android:drawableLeft="@drawable/general__shared__wxpay"
        android:drawablePadding="15dp"
        android:fontFamily="sans-serif-medium"/>
    <TextView
        android:textSize="@dimen/general_font__shared__dialog_button"
        android:textStyle="bold"
        android:textColor="@color/general__shared__dialog_button_cancel"
        android:gravity="center"
        android:id="@+id/general__choose_payment_method_dialog__cancel"
        android:background="@drawable/general__shared__dialog_button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared__dialog_button_height"
        android:layout_marginLeft="@dimen/general__shared__dialog_horizontal_padding"
        android:layout_marginTop="17.33dp"
        android:layout_marginRight="@dimen/general__shared__dialog_horizontal_padding"
        android:layout_marginBottom="@dimen/general__shared__dialog_small_padding"
        android:text="@string/general__shared__cancel"/>
</LinearLayout>
