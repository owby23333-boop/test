<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.sdk.openadsdk.core.widget.GifView
        android:layout_gravity="center"
        android:id="@+id/tt_splash_eye_icon"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/tt_splash_eye_close_btn"/>
    <ImageView
        android:id="@+id/tt_splash_eye_close_btn"
        android:background="@drawable/tt_dislike_icon"
        android:visibility="visible"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginBottom="5dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
