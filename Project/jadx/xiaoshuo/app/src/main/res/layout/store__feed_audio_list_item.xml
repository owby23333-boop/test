<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="0dp"
    android:layout_marginBottom="@dimen/view_dimen_60"
    android:foreground="?android:attr/selectableItemBackground"
    style="@style/store__shared__item_parent">
    <com.duokan.reader.ui.general.RoundFrameLayout
        android:id="@+id/store_feed_book_audio_card"
        android:layout_width="@dimen/store__list_audio_cover_size"
        android:layout_height="@dimen/store__list_audio_cover_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/general__shared_dimen__4dp">
        <ImageView
            android:id="@+id/store_feed_book_audio_cover"
            android:layout_width="@dimen/store__list_audio_cover_size"
            android:layout_height="@dimen/store__list_audio_cover_size"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="10dp"
            android:textColor="@color/general__day_night__ffffff"
            android:layout_gravity="end|top"
            android:id="@+id/store_feed_book_audio_label"
            android:background="@drawable/store__feed_book_tag_free"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/store__label_recommend"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
        <TextView
            android:textSize="9sp"
            android:textColor="@color/general__shared__ffffff"
            android:ellipsize="none"
            android:gravity="center"
            android:layout_gravity="bottom"
            android:id="@+id/store_feed_book_audio_play_count"
            android:background="@drawable/store__feed_book_audio__play_count_bg"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/store__list_audio_play_count_height"
            android:text="5000wan"
            android:singleLine="true"
            android:drawablePadding="1.67dp"
            android:drawableStart="@drawable/store__feed_audio_play"
            android:paddingStart="5dp"
            android:paddingEnd="6dp"/>
    </com.duokan.reader.ui.general.RoundFrameLayout>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12_67sp"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@+id/store_feed_book_audio_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@+id/store_feed_book_audio_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_summary"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__11_3sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/store_feed_book_audio_summary"
        android:paddingTop="5.3dp"
        android:paddingBottom="5.3dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store_feed_book_audio_card"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__11_3sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:ellipsize="end"
        android:id="@+id/store_feed_book_audio_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_summary"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_audio_summary"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__11_3sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:id="@+id/store_feed_book_audio_category"
        android:paddingRight="3dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:drawableRight="@drawable/store__audio_book_list_item_separator"
        android:drawablePadding="3dp"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_summary"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_audio_summary"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__11_3sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:id="@+id/store_feed_book_audio_chapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        app:layout_constraintBottom_toBottomOf="@+id/store_feed_book_audio_category"
        app:layout_constraintStart_toEndOf="@+id/store_feed_book_audio_category"
        app:layout_constraintTop_toTopOf="@+id/store_feed_book_audio_category"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__11_3sp"
        android:textColor="#e6ff942b"
        android:id="@+id/store_feed_book_audio_price"
        android:paddingLeft="3dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/store__audio_book_list_item_separator"
        android:drawablePadding="3dp"
        app:layout_constraintBottom_toBottomOf="@+id/store_feed_book_audio_category"
        app:layout_constraintStart_toEndOf="@+id/store_feed_book_audio_chapter"
        app:layout_constraintTop_toTopOf="@+id/store_feed_book_audio_category"/>
</androidx.constraintlayout.widget.ConstraintLayout>
