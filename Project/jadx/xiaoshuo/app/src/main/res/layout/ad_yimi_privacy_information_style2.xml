<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/ad_reading_privacy_information"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/view_dimen_30"
        android:textColor="#66000000"
        android:gravity="start|center_vertical"
        android:id="@+id/ad_tv_reading_app_developer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="1"
        style="@style/AdReadingPrivacy"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_16">
        <TextView
            android:textSize="@dimen/view_dimen_28"
            android:textColor="#4d000000"
            android:id="@+id/ad_tv_reading_app_permission"
            android:background="@drawable/bg_ad_reading_privacy_style2"
            android:paddingTop="@dimen/view_dimen_2"
            android:paddingBottom="@dimen/view_dimen_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="权限"
            android:alpha="1"
            android:paddingStart="@dimen/view_dimen_18"
            android:paddingEnd="@dimen/view_dimen_18"
            style="@style/AdReadingPrivacy"/>
        <TextView
            android:textSize="@dimen/view_dimen_28"
            android:textColor="#4d000000"
            android:id="@+id/ad_tv_reading_app_privacy"
            android:background="@drawable/bg_ad_reading_privacy_style2"
            android:paddingTop="@dimen/view_dimen_2"
            android:paddingBottom="@dimen/view_dimen_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="隐私"
            android:alpha="1"
            android:paddingStart="@dimen/view_dimen_18"
            android:paddingEnd="@dimen/view_dimen_18"
            android:layout_marginStart="@dimen/view_dimen_14"
            style="@style/AdReadingPrivacy"/>
    </LinearLayout>
</LinearLayout>
