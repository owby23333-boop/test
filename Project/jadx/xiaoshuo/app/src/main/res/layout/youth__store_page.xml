<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/general__day_night__f5f5f5_121212"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/padding_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/bg_red"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_540"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/bg_compress_red"
        android:background="@color/general__red_mode_bg"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/youth__store_page__content"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__17_33sp"
        android:textColor="@color/general__day_night__333333"
        android:id="@+id/youth__store_page__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:paddingVertical="@dimen/main_padding_35"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/padding_top"/>
    <FrameLayout
        android:id="@+id/youth__store_page__content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/youth__store_page__title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
