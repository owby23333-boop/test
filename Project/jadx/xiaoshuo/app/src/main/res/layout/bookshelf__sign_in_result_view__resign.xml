<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center_horizontal"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__shared__666666"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bookshelf__sign_in_status_view__pay_method"
        android:fontFamily="sans-serif-medium"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/bookshelf__sign_in_result_view__pay_method_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:scaleType="center"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__shared__666666"
        android:layout_gravity="center"
        android:id="@+id/bookshelf__sign_in_result_view__pay_method_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:fontFamily="sans-serif-medium"/>
    <View
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bookshelf__sign_in_result_view__payment_more_dark"
        android:scaleType="center"/>
</LinearLayout>
