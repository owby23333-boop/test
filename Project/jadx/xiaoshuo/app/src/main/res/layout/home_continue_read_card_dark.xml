<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/shape_corner_30_solid_white_p90"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_220">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/home_continue_read_card_cover"
        android:layout_width="@dimen/view_dimen_99"
        android:layout_height="@dimen/view_dimen_147"
        android:scaleType="centerCrop"
        android:layout_marginStart="@dimen/view_dimen_42"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/white_60_transparent"
        app:strokeWidth="@dimen/view_dimen_2"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/home_continue_read_card_close"
        android:padding="@dimen/view_dimen_28"
        android:layout_width="@dimen/view_dimen_88"
        android:layout_height="@dimen/view_dimen_88"
        android:src="@drawable/continue_read_close_dark"
        android:layout_marginEnd="@dimen/view_dimen_21"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_32"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/home_continue_read_card_btn"
        android:background="@drawable/shape_corner_50_solid_ff7433"
        android:layout_width="@dimen/view_dimen_200"
        android:layout_height="@dimen/view_dimen_90"
        android:text="@string/go_on_read"
        android:layout_marginEnd="@dimen/view_dimen_21"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/home_continue_read_card_close"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="@color/black_90_transparent"
        android:ellipsize="end"
        android:id="@+id/home_continue_read_card_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_marginHorizontal="@dimen/view_dimen_30"
        app:layout_constraintBottom_toTopOf="@+id/home_continue_read_card_progress"
        app:layout_constraintEnd_toStartOf="@+id/home_continue_read_card_btn"
        app:layout_constraintStart_toEndOf="@+id/home_continue_read_card_cover"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_32"
        android:textColor="@color/color_494a4d"
        android:ellipsize="end"
        android:id="@+id/home_continue_read_card_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_21"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/home_continue_read_card_title"
        app:layout_constraintStart_toStartOf="@+id/home_continue_read_card_title"
        app:layout_constraintTop_toBottomOf="@+id/home_continue_read_card_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
