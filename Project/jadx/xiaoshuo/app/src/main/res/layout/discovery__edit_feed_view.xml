<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.PageHeaderView
            android:id="@+id/discovery__edit_feed_view__header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <EditText
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__333333"
            android:textColorHint="@color/general__shared__8d8d8d"
            android:id="@+id/discovery__edit_feed_view__title"
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/discovery__edit_feed_view__title_hint"
            android:singleLine="true"/>
        <View
            android:background="@color/general__day_night__cccccc"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <com.duokan.core.ui.LinearScrollView
            android:orientation="vertical"
            android:id="@+id/discovery__edit_feed_view__feed"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <EditText
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__day_night__333333"
                android:textColorHint="@color/general__shared__8d8d8d"
                android:id="@+id/discovery__edit_feed_view__reason"
                android:padding="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/discovery__edit_feed_view__reason_hint"/>
        </com.duokan.core.ui.LinearScrollView>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__day_night__ffffff"
        android:layout_gravity="bottom|left"
        android:id="@+id/discovery__edit_feed_view__add"
        android:background="@drawable/general__shared__rounded_corner_button"
        android:padding="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:text="@string/discovery__edit_feed_view__add_book"/>
</com.duokan.core.ui.BoxView>
