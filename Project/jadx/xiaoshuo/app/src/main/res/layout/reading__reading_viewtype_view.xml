<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__shared__141414f2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/reading__pdf_set_view_type__selected"
        android:gravity="center"
        android:layout_gravity="left"
        android:id="@+id/reading__reading_viewtype_view__single_page"
        android:paddingLeft="20dp"
        android:paddingTop="25dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reading__reading_viewtype_view__single_page"
        android:drawableLeft="@drawable/reading__reading_viewtype_view__single_page"
        android:drawablePadding="15dp"
        android:layout_weight="1"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/reading__pdf_set_view_type__selected"
        android:gravity="center"
        android:layout_gravity="left"
        android:id="@+id/reading__reading_viewtype_view__scroll"
        android:paddingLeft="20dp"
        android:paddingTop="10dp"
        android:paddingRight="20dp"
        android:paddingBottom="25dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reading__reading_viewtype_view__scroll"
        android:drawableLeft="@drawable/reading__reading_viewtype_view__scroll"
        android:drawablePadding="15dp"
        android:layout_weight="1"/>
</LinearLayout>
