<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__day_night__dialog_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="310dp">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/general__common_dialog_view__content_layout"
                android:paddingTop="6.67dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/general_font__shared__dialog_title"
                    android:textColor="@color/general__day_night__000000"
                    android:ellipsize="end"
                    android:gravity="fill"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/general__common_dialog_view__title"
                    android:paddingLeft="@dimen/general__shared_dimen__26_67sp"
                    android:paddingRight="@dimen/general__shared_dimen__26_67sp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:singleLine="true"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__dialog_button"
                    android:textColor="@color/general__day_night__dialog_prompt_context_000000b2"
                    android:ellipsize="end"
                    android:gravity="fill"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/general__common_dialog_view__prompt"
                    android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
                    android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:maxLines="5"/>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/general__common_dialog_view__extra_content_frame"
                android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
                android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="22dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/general__common_dialog_view__check_frame"
                android:paddingLeft="@dimen/general__shared__dialog_menu_item_padding"
                android:paddingRight="@dimen/general__shared__dialog_menu_item_padding"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/general__common_dialog_view__button_frame"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/general__shared_dimen__26_67dp"
            android:layout_marginTop="@dimen/general__shared_dimen__26_67dp"
            android:layout_marginRight="@dimen/general__shared_dimen__26_67dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__23_33dp"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/general__common_dialog_view__check_layout"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15.67dp"/>
    </LinearLayout>
</com.duokan.core.ui.BoxView>
