<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/store__feed_category_item_new_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_40">
    <ImageView
        android:background="@drawable/store__feed_category_item_book_bg"
        android:layout_width="@dimen/view_dimen_154"
        android:layout_height="@dimen/view_dimen_105"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
    <com.duokan.reader.ui.view.FontTextView
        android:textSize="@dimen/text_font_size_50"
        android:textColor="@color/general__222222"
        android:id="@+id/store_feed_category_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_50"
        android:fontFamily="sans-serif-medium"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="#8d7881"
        android:id="@+id/store_feed_category_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_24"
        android:layout_marginBottom="@dimen/view_dimen_42"
        android:includeFontPadding="false"
        android:layout_below="@+id/store_feed_category_title"
        android:fontFamily="sans-serif-medium"/>
</RelativeLayout>
