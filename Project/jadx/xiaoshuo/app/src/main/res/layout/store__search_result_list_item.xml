<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="@dimen/view_dimen_30"
    android:paddingBottom="@dimen/view_dimen_30"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground"
    android:paddingStart="@dimen/view_dimen_50"
    android:paddingEnd="@dimen/view_dimen_50"
    app:layout_constraintVertical_chainStyle="packed">
    <include
        android:id="@+id/search__result_book_cover_card"
        android:layout_width="@dimen/view_dimen_202"
        android:layout_height="@dimen/view_dimen_282"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/store__feed_fiction_card"/>
    <TextView
        android:id="@+id/search__result_book_common_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/view_dimen_50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/search__result_book_cover_card"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/store__feed_book_title_style"/>
    <TextView
        android:id="@+id/search__result_book_common_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/view_dimen_50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/search__result_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/search__result_book_common_title"
        style="@style/store__feed_book_summary_style"/>
    <TextView
        android:id="@+id/search__result_book_common_tag"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/view_dimen_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/search__result_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/search__result_book_common_summary"
        style="@style/store__feed_book_detail_style"/>
</androidx.constraintlayout.widget.ConstraintLayout>
