<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/reading__ad_feedback_close_dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/general__shared_dimen__33_33dp"
    android:paddingHorizontal="@dimen/general__shared_dimen__23_33dp"
    android:paddingVertical="@dimen/general__shared_dimen__26_67dp">
    <TextView
        android:textSize="@dimen/general__shared_dimen__16_67sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:id="@+id/ad__feedback_close_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__14sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/ad__feedback_close_dialog_button"
        android:background="@drawable/reading__ad_feedback_close_dialog_bg_button"
        android:paddingTop="@dimen/general__shared_dimen__12_33dp"
        android:paddingBottom="@dimen/general__shared_dimen__12_33dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__26_67dp"
        android:text="@string/general__ad_feedback_close_confirm"
        app:layout_constraintTop_toBottomOf="@+id/ad__feedback_close_dialog_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
