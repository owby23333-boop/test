<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/reading__app_ad_view_click"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.58">
            <FrameLayout
                android:paddingLeft="@dimen/view_dimen_42"
                android:paddingTop="@dimen/view_dimen_50"
                android:paddingRight="@dimen/view_dimen_81"
                android:paddingBottom="@dimen/view_dimen_50"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:background="@drawable/general__shared__corner_ad_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/view_dimen_30"
                    android:layout_marginRight="@dimen/view_dimen_30">
                    <FrameLayout
                        android:id="@+id/reading__single_image_view__container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/reading__single_image_view__image"
                            android:layout_width="@dimen/view_dimen_301"
                            android:layout_height="@dimen/view_dimen_301"
                            android:scaleType="fitXY"/>
                        <ImageView
                            android:layout_gravity="end|bottom"
                            android:id="@+id/reading__app_ad_view__close"
                            android:layout_width="@dimen/view_dimen_77"
                            android:layout_height="@dimen/view_dimen_30"
                            android:layout_marginBottom="@dimen/view_dimen_20"
                            android:src="@drawable/reading__ad_view_close_c"
                            android:layout_marginEnd="@dimen/view_dimen_20"/>
                    </FrameLayout>
                    <TextView
                        android:textSize="@dimen/text_font_size_48"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/reading__app_ad_view__summary"
                        android:paddingTop="3dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:layout_marginStart="@dimen/view_dimen_40"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/reading__single_image_view__container"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <include
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_18"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view__summary"
                        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__summary"
                        layout="@layout/reading__opt_ad_view_info_icon_title"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/reading__close_ad_view___container"
                    android:background="@color/general__day_night__000000_80"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/view_dimen_30"
                    android:layout_marginRight="@dimen/view_dimen_30">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/reading__close_ad_view__title_container"
                        android:background="@drawable/general__shared__rounded_button_white_ffffff_17"
                        android:layout_width="@dimen/view_dimen_406"
                        android:layout_height="@dimen/view_dimen_88"
                        android:layout_marginTop="@dimen/view_dimen_93"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/reading__close_ad_view__title_left_icon_iv"
                            android:layout_width="@dimen/view_dimen_36"
                            android:layout_height="@dimen/view_dimen_36"
                            android:src="@drawable/reading__close_ad_view__title_left_icon"
                            android:scaleType="centerCrop"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toLeftOf="@+id/reading___close_ad_view__title"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:textSize="@dimen/text_font_size_36"
                            android:textColor="@color/general__ffffff"
                            android:id="@+id/reading___close_ad_view__title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/view_dimen_16"
                            android:text="@string/reading__close_ad_view__title_text"
                            android:includeFontPadding="false"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintLeft_toRightOf="@+id/reading__close_ad_view__title_left_icon_iv"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <ImageView
                        android:id="@+id/reading__close_ad_view__close_ad_icon_iv"
                        android:padding="@dimen/view_dimen_10"
                        android:layout_width="@dimen/view_dimen_50"
                        android:layout_height="@dimen/view_dimen_50"
                        android:layout_marginTop="@dimen/view_dimen_20"
                        android:layout_marginRight="@dimen/view_dimen_20"
                        android:src="@drawable/reading__close_ad_view__close_icon"
                        android:scaleType="centerCrop"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_28"
                        android:textColor="@color/general__666666"
                        android:id="@+id/reading__close_ad_view__subtitle_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/view_dimen_14"
                        android:layout_marginBottom="@dimen/view_dimen_24"
                        android:text="@string/reading__close_ad_view__subtitle_text"
                        android:includeFontPadding="false"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintLeft_toLeftOf="@+id/reading__close_ad_view__title_container"
                        app:layout_constraintRight_toLeftOf="@+id/reading__close_ad_view_subtitle_right_icon"/>
                    <ImageView
                        android:id="@+id/reading__close_ad_view_subtitle_right_icon"
                        android:layout_width="@dimen/view_dimen_12"
                        android:layout_height="@dimen/view_dimen_24"
                        android:src="@drawable/bookshelf__close_ad_view__subtitle_icon"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="@+id/reading__close_ad_view__subtitle_tv"
                        app:layout_constraintLeft_toRightOf="@+id/reading__close_ad_view__subtitle_tv"
                        app:layout_constraintRight_toRightOf="@+id/reading__close_ad_view__title_container"
                        app:layout_constraintTop_toTopOf="@+id/reading__close_ad_view__subtitle_tv"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>
            <include layout="@layout/reading__ad_view_download_view_a"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
