<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:background="@color/general__day_night__page_header_background"
    android:layout_width="match_parent"
    android:layout_height="50dp">
    <TextView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__666666"
        android:gravity="center_vertical"
        android:id="@+id/personal__auto_buy_group_title_view__text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="15dp"
        android:text="@string/personal__auto_buy_view__group_title"
        android:singleLine="true"
        android:layout_weight="1"/>
    <View
        android:id="@+id/personal__auto_buy_group_title_view__bottom_line"
        android:background="@color/general__day_night__bcbcbc"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
