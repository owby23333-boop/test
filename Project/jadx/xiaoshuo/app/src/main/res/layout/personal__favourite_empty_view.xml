<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/store__favourite_empty_view__icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/store__favourite_empty_view__icon"
        android:contentDescription="@null"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__555555"
        android:id="@+id/personal__favourite_empty_view__no_book"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/personal__favourite_empty_view__no_book"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__888888"
        android:id="@+id/personal__favourite_empty_view__hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/personal__favourite_empty_view__hint"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:layout_gravity="center"
        android:id="@+id/personal__favourite_empty_view__go_store"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/personal__favourite_empty_view__go_store"
        style="@style/general__shared__button_43dip_ffffff"/>
</LinearLayout>
