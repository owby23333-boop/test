<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_1220">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/notification_banner_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/notification_banner_icon_dark"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="h,27:14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/notification_bottom_bg"
        android:background="@color/color_232323"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/notification_banner_icon"/>
    <TextView
        android:textSize="@dimen/text_font_size_51"
        android:textStyle="bold"
        android:textColor="@color/white_90_transparent"
        android:id="@+id/notification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_81"
        android:text="@string/open_notification_tip"
        android:layout_marginHorizontal="@dimen/view_dimen_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/notification_banner_icon"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/white_70_transparent"
        android:gravity="center"
        android:id="@+id/notification_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_51"
        android:text="@string/notification_benefits"
        android:layout_marginHorizontal="@dimen/view_dimen_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/notification_title"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textStyle="bold"
        android:textColor="@color/white_80_transparent"
        android:gravity="center"
        android:id="@+id/notification_cancel"
        android:background="@drawable/shape_corner_100_solid_white_06_transparent"
        android:layout_width="@dimen/view_dimen_440"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_35"
        android:text="@string/cancel"
        app:layout_constraintEnd_toStartOf="@+id/notification_open"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/notification_tip"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textStyle="bold"
        android:textColor="@color/color_white"
        android:gravity="center"
        android:id="@+id/notification_open"
        android:background="@drawable/shape_corner_100_solid_ff7433"
        android:layout_width="@dimen/view_dimen_440"
        android:layout_height="@dimen/view_dimen_140"
        android:text="@string/to_open"
        android:layout_marginStart="@dimen/view_dimen_40"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/notification_cancel"
        app:layout_constraintTop_toTopOf="@+id/notification_cancel"/>
</androidx.constraintlayout.widget.ConstraintLayout>
