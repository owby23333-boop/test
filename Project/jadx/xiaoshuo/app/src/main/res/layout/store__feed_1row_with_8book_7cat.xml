<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/store__feed_horizontal_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/store__shared__list_item_7cat">
        <include
            android:layout_width="@dimen/view_dimen_213"
            android:layout_height="@dimen/view_dimen_284"
            layout="@layout/store__feed_fiction_common_cover_7cat"/>
        <RelativeLayout
            android:layout_gravity="bottom"
            android:background="@drawable/store__feed_top_horizontal_bg_7cat"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_251"
            android:paddingStart="@dimen/view_dimen_36"
            android:paddingEnd="@dimen/view_dimen_36">
            <TextView
                android:id="@+id/store__feed_book_common_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_32"
                android:layout_marginEnd="@dimen/view_dimen_116"
                style="@style/store__feed_book_title_style_7cat"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__6A758E"
                android:ellipsize="end"
                android:id="@+id/store__feed_book_common_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_12"
                android:maxLines="2"
                android:includeFontPadding="false"
                android:layout_below="@+id/store__feed_book_common_title"/>
            <TextView
                android:textSize="@dimen/text_font_size_56"
                android:textStyle="bold"
                android:textColor="@color/general__FCA000"
                android:id="@+id/store__feed_book_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_23"
                android:includeFontPadding="false"
                android:layout_toStartOf="@+id/store__feed_book_common_score_tv"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__FCA000"
                android:id="@+id/store__feed_book_common_score_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/view_dimen_5"
                android:text="@string/store__feed_book_score_unit"
                android:layout_alignBottom="@+id/store__feed_book_score"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <include
        android:id="@+id/store__feed_horizontal_4fiction_1line"
        layout="@layout/store__feed_horizontal_4fiction_7cat"/>
    <include
        android:id="@+id/store__feed_horizontal_4fiction_2line"
        layout="@layout/store__feed_horizontal_4fiction_7cat"/>
</LinearLayout>
