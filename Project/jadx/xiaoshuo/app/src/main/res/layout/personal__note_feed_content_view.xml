<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.personal.PersonalNoteFeedContentView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/personal__note_feed_content_view__root"
    android:paddingLeft="0dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.deprecatedDkTextView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__555555"
        android:ellipsize="end"
        android:gravity="fill"
        android:id="@+id/personal__note_feed_content_view__note"
        android:paddingLeft="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:maxLines="4"
        android:singleLine="false"/>
    <com.duokan.reader.ui.general.PinView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__8d6752"
        android:ellipsize="end"
        android:id="@+id/personal__note_feed_content_view__ref_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="1dp"
        android:layout_marginTop="4dp"
        android:maxLines="4"/>
</com.duokan.reader.ui.personal.PersonalNoteFeedContentView>
