<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/personal__user_type_view__header"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.classic.common.MultipleStatusView
        android:id="@+id/status_layout"
        android:background="@color/general__day_night__ffffff"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:errorView="@layout/fragment_store_tab_error_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/personal__user_type_view__header"
        app:loadingView="@layout/status_loading">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__day_night__1a1a1a"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_30"
                android:text="@string/personal__user_type_view__page_title"
                android:layout_marginStart="@dimen/view_dimen_80"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/divider"
                android:background="@color/general__day_night__cccccc"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="@dimen/view_dimen_50"
                app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
            <com.airbnb.epoxy.EpoxyRecyclerView
                android:id="@+id/rv_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:overScrollMode="never"
                app:layout_constraintBottom_toTopOf="@+id/tv_go_to_store"
                app:layout_constraintTop_toBottomOf="@+id/divider"/>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_go_to_store"
                android:background="@drawable/general__shared__primary_dialog_button"
                android:layout_width="@dimen/view_dimen_962"
                android:layout_height="@dimen/view_dimen_140"
                android:layout_marginBottom="40dp"
                android:text="@string/personal__user_type_view__go_to_store"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.classic.common.MultipleStatusView>
</androidx.constraintlayout.widget.ConstraintLayout>
