<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_live_backup_draw"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/tt_live_draw_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <RelativeLayout
        android:layout_gravity="bottom"
        android:id="@+id/tt_live_draw_layout"
        android:background="#ffffff"
        android:layout_width="260dp"
        android:layout_height="100dp"
        android:layout_marginLeft="12dp"
        android:layout_marginBottom="104dp"
        android:layout_marginStart="12dp">
        <RelativeLayout
            android:id="@+id/tt_live_draw_avatar_layout"
            android:background="@drawable/tt_live_avatar_bg"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_marginLeft="14dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp">
            <com.bytedance.sdk.openadsdk.widget.RoundImageView
                android:id="@+id/tt_live_draw_avatar"
                android:layout_width="65dp"
                android:layout_height="65dp"/>
            <ImageView
                android:id="@+id/tt_live_ad_avatar_status"
                android:background="@drawable/tt_live_ad_status_icon"
                android:layout_width="42dp"
                android:layout_height="16dp"
                android:layout_alignParentBottom="true"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="15dp"
            android:layout_toRightOf="@+id/tt_live_draw_avatar_layout"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="15dp"
            android:layout_toEndOf="@+id/tt_live_draw_avatar_layout">
            <TextView
                android:textSize="15sp"
                android:textColor="#161823"
                android:ellipsize="end"
                android:id="@+id/tt_live_draw_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:singleLine="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bf161823"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tt_live_draw_fans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:layout_below="@+id/tt_live_draw_name"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/tt_live_ad_img"
                android:background="#57161823"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginLeft="8dp"
                android:layout_toRightOf="@+id/tt_live_draw_fans"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@+id/tt_live_draw_fans"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bf161823"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tt_live_draw_watch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:layout_toRightOf="@+id/tt_live_ad_img"
                android:layout_below="@+id/tt_live_draw_name"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@+id/tt_live_ad_img"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bf161823"
                android:ellipsize="end"
                android:id="@+id/tt_live_draw_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:layout_below="@+id/tt_live_draw_fans"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <RelativeLayout
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:id="@+id/tt_live_ad_draw_btn"
        android:background="@drawable/tt_reward_full_live_ad_btn_bg"
        android:layout_width="260dp"
        android:layout_height="34dp"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="12dp">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true">
            <ImageView
                android:id="@+id/tt_live_ad_draw_btn_status"
                android:background="@drawable/tt_live_ad_loading_btn_status"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginRight="6dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:gravity="center_vertical"
                android:id="@+id/tt_live_ad_draw_btn_text"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tt_live_loading_btn"
                android:singleLine="true"
                android:layout_toRightOf="@+id/tt_live_ad_draw_btn_status"
                android:layout_toEndOf="@+id/tt_live_ad_draw_btn_status"/>
            <ImageView
                android:gravity="center"
                android:background="@drawable/tt_splash_click_bar_go"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_toRightOf="@+id/tt_live_ad_draw_btn_text"
                android:layout_centerInParent="true"
                android:layout_toEndOf="@+id/tt_live_ad_draw_btn_text"/>
        </RelativeLayout>
    </RelativeLayout>
</FrameLayout>
