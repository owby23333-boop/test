<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/general__net_error_view__rl"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/general__net_error_view__iv_back"
        android:paddingTop="@dimen/view_dimen_50"
        android:paddingBottom="@dimen/view_dimen_50"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_144"
        android:src="@drawable/general__shared__back"
        android:scaleType="centerCrop"
        android:paddingStart="@dimen/view_dimen_50"
        android:paddingEnd="@dimen/view_dimen_50"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/general__net_error_view__iv_back">
        <ImageView
            android:layout_width="@dimen/view_dimen_617"
            android:layout_height="@dimen/view_dimen_419"
            android:src="@drawable/net_error"/>
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/general__text__day_night__999999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_60"
            android:text="@string/net_error"/>
        <TextView
            android:textColor="@color/general__333333"
            android:gravity="center"
            android:id="@+id/general__net_error_view__retry"
            android:background="@drawable/store__fiction_detail_view__free_read_bg"
            android:layout_width="@dimen/view_dimen_200"
            android:layout_height="@dimen/view_dimen_110"
            android:layout_marginTop="@dimen/view_dimen_40"
            android:text="@string/net_error__button_text"/>
    </LinearLayout>
</RelativeLayout>
