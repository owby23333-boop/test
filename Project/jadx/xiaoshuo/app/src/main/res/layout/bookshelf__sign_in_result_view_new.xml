<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/bookshelf__sign_in_result_view__background"
        android:background="#99000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="center"
            android:background="@drawable/sign_in_result_view__panel"
            android:layout_width="274.6641dp"
            android:layout_height="257.3281dp">
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp">
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/white_80_transparent"
                    android:id="@+id/bookshelf__sign_in_result_view__first_line"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="81dp"
                    android:text="@string/bookshelf__sign_in_status_view__sign_in_succeed"/>
                <TextView
                    android:textSize="18.67dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="bottom"
                    android:id="@+id/bookshelf__sign_in_result_view__second_line"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="获得 0 书豆"
                    android:maxLines="1"/>
                <TextView
                    android:textSize="14dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/bookshelf__sign_in_result_view__ad_button"
                    android:layout_width="186dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="43dp"/>
            </LinearLayout>
        </FrameLayout>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:id="@+id/bookshelf__sign_in_result_view__third_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="13.33dp"/>
    </LinearLayout>
</FrameLayout>
