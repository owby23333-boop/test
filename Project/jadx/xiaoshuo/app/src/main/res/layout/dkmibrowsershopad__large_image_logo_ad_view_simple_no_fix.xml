<?xml version="1.0" encoding="utf-8"?>
<com.duokan.advertisement.ui.ConstraintLayoutEx xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__app_ad_view_constraint_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/reading__app_ad_view_click"
        android:background="@drawable/general__shared__corner_ad_bg"
        android:paddingLeft="@dimen/view_dimen_42"
        android:paddingTop="@dimen/view_dimen_50"
        android:paddingRight="@dimen/view_dimen_42"
        android:paddingBottom="@dimen/view_dimen_50"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/view_dimen_30"
        android:layout_marginRight="@dimen/view_dimen_30">
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textStyle="bold"
            android:textColor="#000000"
            android:ellipsize="end"
            android:id="@+id/dkmibrowsershopad__ad_view_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_42">
            <ImageView
                android:id="@+id/reading__large_image_view__image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <ImageView
                android:layout_gravity="end|bottom"
                android:id="@+id/dkmibrowsershopad__ad_view_x"
                android:layout_width="@dimen/view_dimen_77"
                android:layout_height="@dimen/view_dimen_30"
                android:layout_marginBottom="@dimen/view_dimen_20"
                android:src="@drawable/reading__ad_view_close"
                android:layout_marginEnd="@dimen/view_dimen_20"/>
        </FrameLayout>
        <include layout="@layout/reading__ad_view_title_icon_xout"/>
    </LinearLayout>
    <include
        android:id="@+id/dkmibrowsershopad__ad_view_big_button_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view_click"
        layout="@layout/dkmibrowsershopad__ad_big_button_view"/>
</com.duokan.advertisement.ui.ConstraintLayoutEx>
