<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_live_finish_root"
    android:background="#99000000"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true">
        <com.bytedance.sdk.openadsdk.widget.RoundImageView
            android:id="@+id/tt_live_finish_avatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="30dp"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:id="@+id/tt_live_finish_studio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_below="@+id/tt_live_finish_avatar"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:id="@+id/tt_live_finish_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/tt_live_finish"
            android:layout_below="@+id/tt_live_finish_studio"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</RelativeLayout>
