<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingBottom="17dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#161823"
        android:gravity="center_vertical"
        android:id="@+id/tt_item_title_tv"
        android:paddingTop="19dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginStart="16dp"/>
    <ImageView
        android:id="@+id/tt_item_select_img"
        android:background="@drawable/tt_open_app_detail_list_item"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="7dp"
        android:layout_below="@+id/tt_item_title_tv"
        android:layout_alignLeft="@+id/tt_item_title_tv"
        android:layout_alignStart="@+id/tt_item_title_tv"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#161823"
        android:gravity="center_vertical"
        android:id="@+id/tt_item_desc_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="6dp"
        android:layout_toRightOf="@+id/tt_item_select_img"
        android:layout_below="@+id/tt_item_title_tv"
        android:alpha="0.5"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@+id/tt_item_select_img"/>
</RelativeLayout>
