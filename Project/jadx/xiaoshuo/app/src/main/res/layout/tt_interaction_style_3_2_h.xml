<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@+id/tt_reward_full_native_root"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3">
        <FrameLayout
            android:id="@+id/tt_ad_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:id="@+id/tt_full_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>
        <TextView
            android:layout_gravity="bottom"
            android:id="@+id/tt_ad_logo"
            android:background="@drawable/tt_ad_logo_new"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>
    </FrameLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <com.bytedance.sdk.openadsdk.widget.TTRoundRectImageView
            android:id="@+id/tt_full_ad_icon"
            android:background="@android:color/transparent"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="fitXY"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:id="@+id/tt_full_ad_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:maxLines="1"
            android:layout_toRightOf="@+id/tt_full_ad_icon"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/tt_full_ad_download"
            android:background="@drawable/tt_backup_btn_1"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:text="@string/tt_image_download_apk"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</LinearLayout>
