<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/general__shared__rounded_white_bg"
    android:padding="@dimen/view_dimen_40"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/free__ad_ad_view_icon"
        android:layout_width="58.66dp"
        android:layout_height="58.66dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_20"/>
    <com.duokan.reader.ui.general.FlowLayout
        android:gravity="center_vertical"
        android:id="@+id/reading__app_ad_view__title__container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/view_dimen_31"
        android:layout_marginEnd="@dimen/view_dimen_21"
        app:layout_constraintLeft_toRightOf="@+id/free__ad_ad_view_icon"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/free__ad_ad_view_icon">
        <TextView
            android:textSize="@dimen/text_font_size_40"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/reading__app_ad_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/view_dimen_20"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toRightOf="@+id/free__ad_ad_view_icon"
            app:layout_constraintRight_toLeftOf="@+id/ad_tv_reading_app_version"
            app:layout_constraintTop_toTopOf="@+id/free__ad_ad_view_icon"/>
        <include
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/reading__app_ad_view__title"
            app:layout_constraintLeft_toRightOf="@+id/reading__app_ad_view__title"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view__title"
            layout="@layout/ad_yimi_privacy_version_style1"/>
    </com.duokan.reader.ui.general.FlowLayout>
    <TextView
        android:textSize="@dimen/view_dimen_36"
        android:textColor="@color/general__day_night__999999"
        android:ellipsize="end"
        android:id="@+id/reading__app_ad_view__summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/view_dimen_31"
        android:layout_marginTop="@dimen/view_dimen_18"
        android:maxLines="2"
        app:layout_constraintLeft_toRightOf="@+id/free__ad_ad_view_icon"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__title__container"/>
    <include
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_20"
        app:layout_constraintLeft_toLeftOf="@+id/reading__app_ad_view__summary"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__summary"
        layout="@layout/ad_yimi_privacy_information_style1"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/free__ad_yimi_video_detail_view_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="free__ad_ad_view_icon, ad_reading_privacy_information"/>
    <ImageView
        android:id="@+id/free__ad_yimi_video_detail_view_x"
        android:paddingLeft="@dimen/view_dimen_39"
        android:paddingBottom="@dimen/view_dimen_39"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/free__ad_yimi_video_detail_view_x"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:textSize="@dimen/view_dimen_40"
        android:textColor="@color/general__day_night__333333"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/free__ad_yimi_video_detail_view_barrier"
        layout="@layout/free__ad_big_button_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>
