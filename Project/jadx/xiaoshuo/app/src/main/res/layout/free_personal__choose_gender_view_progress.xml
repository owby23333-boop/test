<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/free_personal__choose_gender_view__progress_layout"
    android:background="@color/general__day_night__ffffff"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/free_personal__choose_gender_view__progress"
        android:layout_width="200dp"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/general__day_night__66000000_66ffffff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/free_personal__choose_gender_loading"
        android:singleLine="true"/>
</LinearLayout>
