<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__app_ad_title_summary_view_c"
    android:paddingTop="@dimen/view_dimen_50"
    android:paddingBottom="@dimen/view_dimen_60"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_50"
    android:paddingEnd="@dimen/view_dimen_50">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__app_ad_view__logo"
        android:layout_width="@dimen/view_dimen_140"
        android:layout_height="@dimen/view_dimen_140"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textStyle="bold"
        android:textColor="@color/black_70_transparent"
        android:ellipsize="end"
        android:id="@+id/reading__app_ad_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_marginStart="@dimen/view_dimen_38"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginStart="0dp"/>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/black_40_transparent"
        android:ellipsize="end"
        android:id="@+id/reading__app_ad_view__summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_8"
        android:singleLine="true"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view__title"
        app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
