<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/reading__chapter_end_recommend_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:id="@+id/reading__chapter_end_recommend_title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/free_reading__recommend_title"
        android:layout_marginStart="20dp"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/reading__chapter_end_recommend_card_view"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:contentPadding="18dp">
        <ImageView
            android:id="@+id/reading__chapter_end_recommend_cover"
            android:layout_width="78dp"
            android:layout_height="104dp"/>
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-2dp"
            android:src="@drawable/bookshelf__shelf_recommend_flag"
            android:layout_marginStart="4dp"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:id="@+id/reading__chapter_end_recommend_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="111dp"
            android:maxLines="1"
            android:maxEms="7"/>
        <TextView
            android:textSize="15sp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/reading__chapter_end_recommend_summary"
            android:layout_width="wrap_content"
            android:layout_height="104dp"
            android:maxLines="4"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginStart="97.33dp"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#e92a20"
            android:gravity="center"
            android:layout_gravity="end"
            android:id="@+id/reading__chapter_end_recommend_reading_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="112dp"
            android:drawablePadding="4dp"
            android:drawableStart="@drawable/reading__chapter_end_recommend_read"/>
    </androidx.cardview.widget.CardView>
</LinearLayout>
