<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@string/reading__reading_menu_view__desc">
    <RelativeLayout
        android:enabled="false"
        android:gravity="center_vertical"
        android:id="@+id/reading__reading_menu_view__top"
        android:background="@color/reading__reading_menu_primary_background_color"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140">
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true">
            <ImageView
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_menu_view__back"
                android:layout_width="@dimen/view_dimen_80"
                android:layout_height="@dimen/view_dimen_80"
                android:src="@drawable/reading__reading_menu_view__back_icon"
                android:scaleType="center"
                android:contentDescription="@string/reading__reading_menu_view__back_to_bookshelf"
                android:layout_marginStart="@dimen/view_dimen_33"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/reading__reading_menu_view__top_right_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/view_dimen_18"
            android:layout_alignParentEnd="true">
            <TextView
                android:textSize="@dimen/text_font_size_44"
                android:textColor="@color/reading__reading_menu_top_text_selector"
                android:gravity="center"
                android:id="@+id/reading__reading_menu_view__add_bookshelf"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/reading__reading_menu_top_add_to_bookshelf"
                android:singleLine="true"
                android:paddingStart="@dimen/view_dimen_30"
                android:paddingEnd="@dimen/view_dimen_30"/>
            <TextView
                android:textSize="@dimen/text_font_size_44"
                android:textColor="@color/reading__reading_menu_top_text_selector"
                android:gravity="center"
                android:id="@+id/reading__reading_menu_view__book_comment"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/reading__reading_menu_top_book_comment"
                android:contentDescription="@string/reading__reading_menu_top_book_comment"
                android:paddingStart="@dimen/view_dimen_30"
                android:paddingEnd="@dimen/view_dimen_30"/>
        </LinearLayout>
    </RelativeLayout>
    <include
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        layout="@layout/reading__reading_menu_bottom_view"/>
</FrameLayout>
