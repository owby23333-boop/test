<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/reading__comment_view__content"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#3a3121"
        android:layout_gravity="center"
        android:id="@+id/reading__comment_view__book_status"
        android:paddingTop="75dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reading__comment_view__finished"
        android:singleLine="true"
        android:includeFontPadding="false"/>
    <TextView
        android:textSize="14sp"
        android:textColor="#3a3121"
        android:gravity="center"
        android:id="@+id/reading__comment_view__off_shelf"
        android:paddingLeft="25dp"
        android:paddingTop="75dp"
        android:paddingRight="25dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reading__comment_view__off_shelf"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/reading__comment_view__related_book_container"
        android:background="@drawable/reading__comment_view__related_book_background"
        android:paddingBottom="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="37dp"
        android:layout_marginTop="70dp"
        android:layout_marginRight="37dp">
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#3a3121"
            android:id="@+id/reading__comment_view__related_book_continue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:layout_marginTop="15dp"
            android:text="@string/reading__comment_view__continue"/>
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__comment_view__related_book_cover"
            android:layout_width="147dp"
            android:layout_height="214dp"
            android:layout_marginTop="26dp"/>
        <TextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#3a3121"
            android:ellipsize="end"
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__comment_view__related_book_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="83dp"
            android:layout_marginRight="83dp"
            android:maxLines="2"/>
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="13sp"
            android:textColor="#3a3121"
            android:ellipsize="end"
            android:gravity="fill_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__comment_view__related_book_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="57dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="57dp"
            android:maxLines="2"
            android:alpha="0.72"/>
    </LinearLayout>
</LinearLayout>
