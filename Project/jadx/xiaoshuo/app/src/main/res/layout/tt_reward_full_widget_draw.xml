<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_reward_full_native_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.sdk.component.widget.recycler.RecyclerView
        android:id="@+id/tt_reward_draw_recycler_view"
        android:background="@color/tt_video_shadow_color"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.bytedance.sdk.openadsdk.core.component.reward.draw.RewardGuideSlideUp
        android:id="@+id/tt_reward_draw_slip_up_glide"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</FrameLayout>
