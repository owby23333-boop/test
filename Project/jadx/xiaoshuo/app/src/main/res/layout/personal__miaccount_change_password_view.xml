<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__shared__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/personal__miaccount_change_password_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="15dp">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__333333"
                android:layout_width="74dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:text="@string/personal__miaccount_change_password_view__old_password_label"/>
            <EditText
                android:id="@+id/personal__miaccount_change_password_view__old_password"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:inputType="textPassword"
                style="@style/general__shared__text_input_gray_bg_black_text"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="15dp">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__333333"
                android:layout_width="74dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:text="@string/personal__miaccount_change_password_view__new_password_label"/>
            <EditText
                android:id="@+id/personal__miaccount_change_password_view__new_password"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:inputType="textPassword"
                style="@style/general__shared__text_input_gray_bg_black_text"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/personal__miaccount_change_password_view__captcha_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="15dp">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__333333"
                android:layout_width="74dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:text="@string/personal__miaccount_change_password_view__captcha"/>
            <EditText
                android:id="@+id/personal__miaccount_change_password_view__captcha"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                style="@style/general__shared__text_input_gray_bg_black_text"/>
        </LinearLayout>
        <CheckBox
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__999999"
            android:layout_gravity="left"
            android:id="@+id/personal__miaccount_change_password_view__show_password"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="20dp"
            android:button="@null"
            android:text="@string/personal__miaccount_change_password_view__show_password"
            android:drawableLeft="@drawable/general__shared__single_checkbox"
            android:drawablePadding="5dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/personal__miaccount_change_password_view__save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:background="#c6c6c6"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="15dp"
                android:contentDescription="@null"/>
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__ff6518"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/general__shared__confirm"/>
            <ImageView
                android:background="#c6c6c6"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:contentDescription="@null"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/personal__miaccount_change_password_view__captcha_img"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.duokan.core.ui.LinearScrollView>
</LinearLayout>
