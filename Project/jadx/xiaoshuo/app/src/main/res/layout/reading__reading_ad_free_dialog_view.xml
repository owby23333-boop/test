<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/reading__reading_ad_free_dialog_view_content"
        android:background="@drawable/general__half_page_dialog_round_corner_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_750">
        <ImageView
            android:id="@+id/reading__reading_ad_free_dialog_view_img"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/reading__reading_ad_free_dialoig_vew__vip"
            app:layout_constraintBottom_toTopOf="@+id/reading__reading_ad_free_dialog_view_title"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textColor="@color/general__333333"
            android:id="@+id/reading__reading_ad_free_dialog_view_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_65"
            android:text="看视频，最高可免30分钟广告"
            android:singleLine="true"
            app:layout_constraintBottom_toTopOf="@+id/reading__reading_ad_free_dialog_view_action_button"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__reading_ad_free_dialog_view_img"/>
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/general__333333"
            android:gravity="center"
            android:id="@+id/reading__reading_ad_free_dialog_view_action_button"
            android:background="@drawable/general__shared__rounded_button_yellow"
            android:paddingLeft="@dimen/view_dimen_166"
            android:paddingRight="@dimen/view_dimen_166"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/view_dimen_120"
            android:layout_marginTop="@dimen/view_dimen_90"
            android:text="看视频，领免广告特权"
            android:singleLine="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__reading_ad_free_dialog_view_title"/>
        <ImageView
            android:layout_gravity="right"
            android:id="@+id/reading__reading_ad_free_dialog_view_xout"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:layout_marginTop="@dimen/view_dimen_60"
            android:layout_marginRight="@dimen/view_dimen_60"
            android:src="@drawable/reading__reading_ad_free_dialog_view_close"
            android:scaleType="center"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.duokan.core.ui.BoxView>
