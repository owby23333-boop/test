<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/tt_splash_slide_up_circle"
        android:background="@drawable/tt_splash_slide_up_circle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="-24dp"
        android:layout_alignBottom="@+id/tt_splash_slide_up_guide_bar"
        android:layout_centerHorizontal="true"
        android:alpha="0"/>
    <ImageView
        android:id="@+id/tt_splash_slide_up_bg"
        android:background="@drawable/tt_splash_slide_up_bg"
        android:layout_width="10dp"
        android:layout_height="0dp"
        android:layout_marginLeft="-7dp"
        android:layout_toRightOf="@+id/tt_splash_slide_up_guide_bar"
        android:layout_alignBottom="@+id/tt_splash_slide_up_guide_bar"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/tt_splash_slide_up_finger"
        android:background="@drawable/tt_splash_slide_up_finger"
        android:layout_width="91dp"
        android:layout_height="68dp"
        android:layout_marginLeft="-7dp"
        android:layout_marginBottom="-20dp"
        android:layout_toRightOf="@+id/tt_splash_slide_up_guide_bar"
        android:layout_alignBottom="@+id/tt_splash_slide_up_guide_bar"
        android:layout_centerHorizontal="true"
        android:alpha="0"/>
    <ImageView
        android:id="@+id/tt_splash_slide_up_guide_bar"
        android:background="@drawable/tt_splash_slide_up_arrow"
        android:layout_width="14dp"
        android:layout_height="124dp"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="上滑查看更多内容"/>
</RelativeLayout>
