<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="15dp"
    android:paddingTop="25dp"
    android:paddingRight="25dp"
    android:paddingBottom="25dp"
    android:layout_width="220dp"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__333333"
        android:id="@+id/store__category_item_view__first_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="10dp"
        android:text="name"
        android:layout_toLeftOf="@+id/store__category_item_view__second_line"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
    <com.duokan.reader.ui.general.DkNumView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__999999"
        android:gravity="right"
        android:id="@+id/store__category_item_view__second_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="222"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
