<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="53dp">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="15dp"
            android:textColor="@color/general__shared__333333"
            android:id="@+id/reading__translation_settings__item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="12sp"
            android:textColor="@color/general__shared__8d8a88"
            android:layout_gravity="center"
            android:id="@+id/reading__translation_settings__item_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/reading__select_dic__custom_font_color"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/reading__translation_settings__item_download"
        android:background="@drawable/reading__day_night__custom_font_list_view_download_bg"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="下载"/>
    <ImageView
        android:layout_gravity="bottom"
        android:background="@color/general__shared__cfcfcf"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:contentDescription="@null"/>
</FrameLayout>
