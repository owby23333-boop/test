<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ProgressBar
        android:id="@+id/reading_loading_icon"
        android:layout_width="@dimen/view_dimen_60"
        android:layout_height="@dimen/view_dimen_60"
        android:indeterminate="true"
        android:indeterminateDrawable="@drawable/progress_bar_rotate_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_39"
        android:textColor="@color/white_40_transparent"
        android:gravity="center_vertical"
        android:id="@+id/reading_loading_txt"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_70"
        android:layout_marginTop="@dimen/view_dimen_10"
        android:text="@string/reading_loading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading_loading_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
