<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="17sp"
        android:textColor="#222222"
        android:ellipsize="end"
        android:id="@+id/tt_live_feed_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp"
        android:maxLines="2"
        android:singleLine="false"
        android:lineSpacingMultiplier="1"/>
    <FrameLayout
        android:id="@+id/tt_live_feed_video"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:scaleType="centerCrop"
        android:layout_below="@+id/tt_live_feed_desc"/>
    <ImageView
        android:id="@+id/tt_live_feed_icon"
        android:background="@drawable/tt_live_ad_status_icon"
        android:layout_width="45dp"
        android:layout_height="16dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:layout_alignLeft="@+id/tt_live_feed_video"
        android:layout_alignTop="@+id/tt_live_feed_video"
        android:layout_marginStart="8dp"
        android:layout_alignStart="@+id/tt_live_feed_video"/>
    <RelativeLayout
        android:gravity="center_vertical"
        android:id="@+id/tt_live_feed_layout"
        android:background="#f8f8f8"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_below="@+id/tt_live_feed_video">
        <RelativeLayout
            android:id="@+id/tt_live_feed_avatar_layout"
            android:background="@drawable/tt_live_avatar_bg"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginLeft="10dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp">
            <com.bytedance.sdk.openadsdk.widget.RoundImageView
                android:id="@+id/tt_live_feed_avatar"
                android:layout_width="37dp"
                android:layout_height="37dp"/>
            <ImageView
                android:id="@+id/tt_live_ad_avatar_status"
                android:background="@drawable/tt_live_feed_status_icon"
                android:layout_width="30dp"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="#161823"
            android:ellipsize="end"
            android:id="@+id/tt_live_feed_title"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/tt_live_feed_avatar_layout"
            android:layout_alignTop="@+id/tt_live_feed_avatar_layout"
            android:layout_marginStart="9dp"
            android:layout_toEndOf="@+id/tt_live_feed_avatar_layout"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#80161823"
            android:gravity="center"
            android:id="@+id/tt_live_feed_fans"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_toRightOf="@+id/tt_live_feed_avatar_layout"
            android:layout_below="@+id/tt_live_feed_title"
            android:layout_alignLeft="@+id/tt_live_feed_title"
            android:layout_toEndOf="@+id/tt_live_feed_avatar_layout"
            android:layout_alignStart="@+id/tt_live_feed_title"/>
        <ImageView
            android:id="@+id/tt_live_ad_img"
            android:background="#80161823"
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_marginLeft="8dp"
            android:layout_toRightOf="@+id/tt_live_feed_fans"
            android:layout_below="@+id/tt_live_feed_title"
            android:layout_alignTop="@+id/tt_live_feed_fans"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@+id/tt_live_feed_fans"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#80161823"
            android:gravity="center"
            android:id="@+id/tt_live_feed_watch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="2dp"
            android:layout_toRightOf="@+id/tt_live_ad_img"
            android:layout_below="@+id/tt_live_feed_title"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@+id/tt_live_ad_img"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#f04142"
            android:gravity="center"
            android:id="@+id/tt_live_feed_down"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:layout_marginRight="12dp"
            android:text="@string/tt_live_feed_btn"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:background="@drawable/tt_live_icon_red"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginRight="4dp"
            android:layout_toLeftOf="@+id/tt_live_feed_down"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:layout_toStartOf="@+id/tt_live_feed_down"/>
    </RelativeLayout>
    <TextView
        android:id="@+id/tt_live_feed_logo"
        android:background="@drawable/tt_ad_logo_new"
        android:layout_width="36dp"
        android:layout_height="14dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/tt_live_feed_layout"
        android:layout_marginStart="16dp"/>
    <TextView
        android:textSize="10sp"
        android:textColor="#57161823"
        android:id="@+id/tt_live_feed_logo_desc"
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="12dp"
        android:text="@string/tt_live_feed_logo"
        android:layout_toRightOf="@+id/tt_live_feed_logo"
        android:layout_below="@+id/tt_live_feed_layout"
        android:layout_marginStart="4dp"
        android:layout_toEndOf="@+id/tt_live_feed_logo"/>
    <TextView
        android:id="@+id/tt_live_feed_close"
        android:background="@drawable/tt_titlebar_close_press_for_dark"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="16dp"
        android:layout_below="@+id/tt_live_feed_layout"
        android:layout_alignParentRight="true"
        android:layout_marginEnd="16dp"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
