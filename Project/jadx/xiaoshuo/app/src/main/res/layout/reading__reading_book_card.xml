<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_333333_90"
    android:paddingBottom="@dimen/view_dimen_60"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__reading_book_card_back_container"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_60"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:layout_marginStart="@dimen/view_dimen_42"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/reading__reading_book_card_back_icon"
            android:layout_width="@dimen/view_dimen_60"
            android:layout_height="@dimen/view_dimen_60"
            android:src="@drawable/reading_reading_book_card_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/dkcommon__ffffff_50"
            android:gravity="center"
            android:id="@+id/reading__reading_book_card_back_txt"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:text="@string/reading__reading_book_card_back_store"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/reading__reading_book_card_back_icon"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/reading__reading_book_card_close"
        android:layout_width="@dimen/view_dimen_45"
        android:layout_height="@dimen/view_dimen_45"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:src="@drawable/reading_reading_book_card_close"
        android:layout_marginEnd="@dimen/view_dimen_42"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="@color/general__ffffff_80"
        android:id="@+id/reading__reading_book_card_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:text="@string/reading__reading_book_card_you_are_looking"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/reading__reading_book_card_cover"
        android:layout_width="@dimen/view_dimen_140"
        android:layout_height="@dimen/view_dimen_204"
        android:layout_marginTop="@dimen/view_dimen_145"
        android:scaleType="centerCrop"
        android:layout_marginStart="@dimen/view_dimen_60"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundCorner12"
        app:strokeColor="@color/general__000000_10"
        app:strokeWidth="@dimen/view_dimen_1"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__ffffff_90"
        android:ellipsize="end"
        android:id="@+id/reading__reading_book_card_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/view_dimen_30"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/reading__reading_book_card_tag"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@+id/reading__reading_book_card_cover"
        app:layout_constraintTop_toTopOf="@+id/reading__reading_book_card_cover"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_30"
        android:textColor="@color/general__ffffff"
        android:ellipsize="end"
        android:id="@+id/reading__reading_book_card_tag"
        android:background="@drawable/shape_corner_10_solid_ff7433"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/view_dimen_280"
        android:maxLines="1"
        android:layout_marginStart="@dimen/view_dimen_21"
        android:paddingHorizontal="@dimen/view_dimen_20"
        android:paddingVertical="@dimen/view_dimen_4"
        app:layout_constraintBottom_toBottomOf="@+id/reading__reading_book_card_name"
        app:layout_constraintEnd_toEndOf="@+id/reading__reading_book_card_close"
        app:layout_constraintStart_toEndOf="@+id/reading__reading_book_card_name"
        app:layout_constraintTop_toTopOf="@+id/reading__reading_book_card_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/general__ffffff_50"
        android:ellipsize="end"
        android:id="@+id/reading__reading_book_card_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_15"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="@+id/reading__reading_book_card_close"
        app:layout_constraintStart_toStartOf="@+id/reading__reading_book_card_name"
        app:layout_constraintTop_toBottomOf="@+id/reading__reading_book_card_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/general__ffffff_50"
        android:ellipsize="end"
        android:id="@+id/reading__reading_book_card_recommend"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_15"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="@+id/reading__reading_book_card_close"
        app:layout_constraintStart_toStartOf="@+id/reading__reading_book_card_name"
        app:layout_constraintTop_toBottomOf="@+id/reading__reading_book_card_info"/>
</androidx.constraintlayout.widget.ConstraintLayout>
