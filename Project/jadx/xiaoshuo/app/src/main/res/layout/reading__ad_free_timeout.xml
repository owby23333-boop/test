<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#a6000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/reading__ad_free_timeout__bg"
        android:layout_width="match_parent"
        android:layout_height="147dp"
        android:layout_marginLeft="26.7dp"
        android:layout_marginRight="26.7dp"
        android:src="@drawable/reading__ad_free_timeout__bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:id="@+id/reading__ad_free_timeout__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="33dp"
        app:layout_constraintLeft_toLeftOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintRight_toRightOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintTop_toTopOf="@+id/reading__ad_free_timeout__bg"/>
    <TextView
        android:textSize="15.3sp"
        android:textColor="#333333"
        android:gravity="center"
        android:id="@+id/reading__ad_free_timeout__ok"
        android:background="@drawable/reading__ad_free_timeout__yellow_button"
        android:layout_width="217dp"
        android:layout_height="40dp"
        android:layout_marginBottom="26.7dp"
        android:text="@string/reading__ad_free_timeout__ok"
        app:layout_constraintBottom_toBottomOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintLeft_toLeftOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintRight_toRightOf="@+id/reading__ad_free_timeout__bg"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ccffffff"
        android:id="@+id/reading__ad_free_timeout__cancel"
        android:padding="7dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/reading__ad_free_timeout__cancel"
        app:layout_constraintLeft_toLeftOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintRight_toRightOf="@+id/reading__ad_free_timeout__bg"
        app:layout_constraintTop_toBottomOf="@+id/reading__ad_free_timeout__bg"/>
</androidx.constraintlayout.widget.ConstraintLayout>
