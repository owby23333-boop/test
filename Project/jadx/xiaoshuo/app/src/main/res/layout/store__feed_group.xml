<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/store_feed_book_list__container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/general__shared_dimen__16_67dp"
    android:layout_marginBottom="@dimen/view_dimen_56"
    android:layout_marginStart="@dimen/store__share__feed_item_margin">
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/store_feed_book_list_title_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="center"
        android:layout_marginEnd="5dp"
        app:layout_constraintBottom_toTopOf="@+id/store_feed_book_list_sub_title"
        app:layout_constraintEnd_toStartOf="@+id/store_feed_book_list_title"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/store_feed_book_list_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:layout_marginEnd="5dp"
        app:layout_constraintBottom_toTopOf="@+id/store_feed_book_list_sub_title"
        app:layout_constraintEnd_toStartOf="@+id/store_feed_book_list_right"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/store_feed_book_list_title_img"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/store__feed_book_list_title_style"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__day_night__999999"
        android:ellipsize="end"
        android:id="@+id/store_feed_book_list_sub_title"
        android:paddingTop="3.3dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/store_feed_book_list_right"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_list_title"/>
    <FrameLayout
        android:id="@+id/store_feed_book_list_right"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/store_feed_book_list_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store_feed_book_list_title"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/general__shared_dimen__11_3sp"
            android:textColor="@color/general__day_night__ff808080_80FFFFFF"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:id="@+id/store_feed_book_list_more"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/store__feed__view_more"
            android:drawablePadding="3.3dp"
            android:drawableEnd="@drawable/store__feed_audio_more"
            android:paddingEnd="16.67dp"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__11_3sp"
            android:textColor="@color/general__day_night__9ca0a8"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:id="@+id/store_feed_book_list_exchange"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:foreground="?android:attr/selectableItemBackground"
            android:text="@string/store_feed_book_list_exchange"
            android:drawablePadding="6.67dp"
            android:drawableEnd="@drawable/store__feed_book_list__change"
            android:paddingStart="20dp"
            android:paddingEnd="16.67dp"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
