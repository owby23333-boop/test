<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/reading__comment_item_view__root"
    android:background="@color/general__day_night__catalogue_app_dark_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40">
        <ImageView
            android:id="@+id/reading__comment_item_view__color"
            android:layout_width="@dimen/view_dimen_42"
            android:layout_height="@dimen/view_dimen_42"
            android:layout_centerVertical="true"
            android:contentDescription="@null"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/general__808080"
            android:id="@+id/reading__comment_item_view__page_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignWithParentIfMissing="true"
            android:layout_marginStart="@dimen/view_dimen_20"
            android:layout_toStartOf="@+id/reading__comment_item_view__add_time"
            android:layout_toEndOf="@+id/reading__comment_item_view__color"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/text_font_size_34"
            android:textColor="@color/general__808080"
            android:ellipsize="end"
            android:id="@+id/reading__comment_item_view__add_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.duokan.reader.ui.general.DkTextView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__day_night__b3b3b3"
        android:ellipsize="end"
        android:gravity="fill"
        android:id="@+id/reading__comment_item_view__content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="3"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/reading__comment_item_view__sample"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="@dimen/view_dimen_20">
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__c"
            android:id="@+id/reading__comment_item_view__sample_mark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__comment_item_view__sample_mark"/>
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__c"
            android:layout_gravity="fill"
            android:id="@+id/reading__comment_item_view__sample_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>
