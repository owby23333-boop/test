<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="@dimen/general_font__shared__a"
        android:gravity="center"
        android:id="@+id/reading__download_full_book_view__name"
        android:layout_width="250dp"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/reading__download_full_book_view__download"
        android:background="@drawable/general__shared__rounded_button_orange"
        android:layout_width="207dp"
        android:layout_height="36dp"
        android:layout_marginTop="20dp"
        android:text="@string/reading__shared__download_full_book"/>
</LinearLayout>
