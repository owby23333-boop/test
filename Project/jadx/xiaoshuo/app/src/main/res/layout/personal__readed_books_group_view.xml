<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:paddingLeft="15dp"
    android:paddingTop="10dp"
    android:paddingRight="15dp"
    android:paddingBottom="5dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__585858"
        android:id="@+id/personal__readed_books_item_view__group_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__585858"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/personal__readed_books_group_view__year"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="24sp"
        android:textColor="@color/general__shared__585858"
        android:id="@+id/personal__readed_books_item_view__group_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__585858"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/personal__readed_books_group_view__month"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__585858"
        android:id="@+id/personal__readed_books_item_view__group_before"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/personal__readed_books_group_view__before"/>
    <View
        android:background="@color/general__shared__d1d6db"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="1px"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="21dp"
        android:layout_marginRight="10dp"
        android:layout_weight="1"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__a3a3a3"
        android:id="@+id/personal__readed_books_item_view__group_size"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
