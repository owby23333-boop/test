<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/reading__tts_notification_view__icon"
        android:layout_width="39dp"
        android:layout_height="39dp"
        android:layout_marginLeft="3dp"
        android:src="@drawable/logo"
        android:scaleType="centerInside"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_weight="1">
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/reading__tts_notification_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__day_night__666666"
            android:id="@+id/reading__tts_notification_view__author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/reading__tts_notification_view__resume"
        android:paddingLeft="16dp"
        android:paddingRight="5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__tts_notification_view__resume"
        android:scaleType="center"/>
    <ImageView
        android:id="@+id/reading__tts_notification_view__pause"
        android:paddingLeft="16dp"
        android:paddingRight="5dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__tts_notification_view__pause"
        android:scaleType="center"/>
    <ImageView
        android:id="@+id/reading__tts_notification_view__close"
        android:paddingLeft="5dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__tts_notification_view__close"
        android:scaleType="center"/>
</LinearLayout>
