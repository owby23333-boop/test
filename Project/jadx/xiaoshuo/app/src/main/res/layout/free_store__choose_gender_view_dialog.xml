<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.access.StoreGenderSelectionView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:id="@+id/free_store__choose_gender_view"
    android:background="@drawable/general__free_dialog_box__bg"
    android:paddingBottom="@dimen/view_dimen_150"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_font_size_60"
        android:textColor="@color/general__day_night__000000"
        android:id="@+id/free_store__choose_gender_view__title"
        android:paddingTop="@dimen/view_dimen_80"
        android:paddingBottom="@dimen/view_dimen_80"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/free_store__choose_gender_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="19.33dp"
        android:textColor="@color/general__text__day_night__333333_666666"
        android:gravity="center"
        android:id="@+id/free_store__choose_gender_view__male"
        android:background="@drawable/free_store__choose_gender_view__male_bg_selector"
        android:layout_width="@dimen/view_dimen_390"
        android:layout_height="@dimen/view_dimen_240"
        android:text="@string/free_store__choose_gender_male"
        android:layout_marginStart="@dimen/view_dimen_116"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/free_store__choose_gender_view__title"/>
    <TextView
        android:textSize="19.33dp"
        android:textColor="@color/general__text__day_night__333333_666666"
        android:gravity="center"
        android:id="@+id/free_store__choose_gender_view__female"
        android:background="@drawable/free_store__choose_gender_view__female_bg_selector"
        android:layout_width="@dimen/view_dimen_390"
        android:layout_height="@dimen/view_dimen_240"
        android:layout_marginBottom="@dimen/view_dimen_232"
        android:text="@string/free_store__choose_gender_female"
        android:layout_marginEnd="@dimen/view_dimen_116"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/free_store__choose_gender_view__male"/>
</com.duokan.reader.access.StoreGenderSelectionView>
