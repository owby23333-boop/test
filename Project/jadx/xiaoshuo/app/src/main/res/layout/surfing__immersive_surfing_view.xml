<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/surfing__immersive_surfing_view__search_bar"
        android:background="@drawable/store__store_header_view_search_bg"
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="9dp"
        android:layout_marginRight="15dp">
        <TextView
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center_vertical"
            android:id="@+id/surfing__immersive_surfing_view__search_bar_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="33dp"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/bookshelf__bookshelf_header_view__search_icon"
            android:foregroundGravity="center"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="7dp"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/surfing__immersive_surfing_view__content"
        android:layout_width="match_parent"
        android:layout_height="49dp">
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/surfing__immersive_surfing_view__phone_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.duokan.core.ui.BoxView
                android:id="@+id/surfing__immersive_surfing_view__right"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:maxWidth="120dp"
                android:layout_alignParentRight="true"/>
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/surfing__immersive_surfing_view__tabs"
                    android:paddingLeft="17dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:baselineAlignedChildIndex="0"/>
                <ImageView
                    android:layout_gravity="bottom"
                    android:id="@+id/surfing__immersive_surfing_view__dot"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/personal__account_summary_view__task_dot"/>
            </FrameLayout>
        </RelativeLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/surfing__immersive_surfing_view__single_header"
            android:layout_width="match_parent"
            android:layout_height="33dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="9dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="11dp">
            <TextView
                android:textSize="20sp"
                android:textColor="@android:color/black"
                android:layout_gravity="center_vertical"
                android:id="@+id/surfing__immersive_surfing_view__single_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="42.3dp"
                android:minHeight="28dp"
                android:text="@string/general__shared__store"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/surfing__immersive_surfing_view__single_search_bar"
                android:background="@drawable/store__store_header_view_search_bg"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/bookshelf__bookshelf_header_view__search_icon"
                    android:foregroundGravity="center"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:ellipsize="end"
                    android:id="@+id/surfing__immersive_surfing_view__single_search_bar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_marginStart="9dp"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/surfing__immersive_surfing_view__single_search_bar_redeem_vip"
                android:background="@drawable/store__store_search_view_redeem_vip"
                android:paddingLeft="26.3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="58.7dp"
                android:minHeight="28.7dp"
                android:text="@string/store__store__search_redeem_vip"
                android:paddingEnd="8dp"/>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/surfing__immersive_surfing_view__hd_content"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@+id/surfing__immersive_surfing_view__tabs_hd"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:layout_gravity="right"
                android:id="@+id/surfing__immersive_surfing_view__right_hd"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="16dp"
                android:layout_width="190dp"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
