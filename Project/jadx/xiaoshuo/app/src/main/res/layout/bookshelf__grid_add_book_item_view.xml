<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/bookshelf__inline_item_add_book__container"
        android:background="@drawable/general__shared__book_free_grid_shadow"
        android:clipChildren="true"
        android:layout_width="@dimen/view_dimen_260"
        android:layout_height="@dimen/view_dimen_348">
        <com.duokan.dkbookshelf.ui.drawable.DkShelfCoverView
            android:id="@+id/bookshelf__inline_item_add_book__image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bookshelf__inline_item_add_book__icon"
            android:scaleType="centerCrop"/>
    </FrameLayout>
</LinearLayout>
