<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/general__shared__common_center_dialog_three_style_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/view_dimen_100">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="@dimen/general__shared_dimen__16_67sp"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__000000"
            android:layout_gravity="center_horizontal"
            android:id="@+id/privacy__privacy_version_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__26_67dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__16_67dp"
            android:text="@string/privacy__privacy_vesion_update_title"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__16sp"
            android:textColor="@color/general__day_night__000000cc"
            android:id="@+id/privacy__privacy_version_view__content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:maxHeight="@dimen/view_dimen_910"
            android:text="@string/privacy__privacy_vesion_update_content"
            android:layout_weight="1"
            android:paddingHorizontal="@dimen/general__shared_dimen__26_67dp"/>
        <TextView
            android:textSize="@dimen/text_font_size_34"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__0000004d"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/privacy__privacy_version_cancel_bt"
            android:paddingTop="@dimen/general__shared_dimen__10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/general__shared__app_exit"/>
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textColor="@color/general__shared__ffffff"
            android:gravity="center"
            android:id="@+id/privacy__privacy_version_confirm_bt"
            android:background="@drawable/welcome__privacy__dialog_bottom_button_cancel"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/view_dimen_30"
            android:text="@string/welcome__privacy_notify__ok"/>
    </LinearLayout>
</RelativeLayout>
