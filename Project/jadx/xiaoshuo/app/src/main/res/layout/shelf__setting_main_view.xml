<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.theme.themeview.ThemeLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/dkcommon__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.HeaderView
        android:id="@+id/personal__personal_settings_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/shelf__shelf_import_local_book"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_189">
        <com.duokan.reader.theme.themeview.ThemeTextView
            android:gravity="center"
            android:layout_marginLeft="15dp"
            android:text="@string/shelf__import_local_book"
            android:layout_weight="1"
            style="@style/shelf__read_setting_option_label"/>
        <View
            android:layout_gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
    <com.duokan.reader.theme.themeview.ThemeView
        android:background="@color/dkcommon__day_night__f2f2f2_3d3d3d"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_1"
        android:layout_marginStart="@dimen/view_dimen_45"
        android:layout_marginEnd="@dimen/view_dimen_45"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/shelf__shelf_settings_show_style"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_189">
        <com.duokan.reader.theme.themeview.ThemeTextView
            android:gravity="center"
            android:layout_marginLeft="15dp"
            android:text="@string/shelf__shelf_show_type"
            android:layout_weight="1"
            style="@style/shelf__read_setting_option_label"/>
        <View
            android:layout_gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <com.duokan.reader.theme.themeview.ThemeTextView
            android:textSize="13sp"
            android:textColor="@color/dkcommon__day_night__999999"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/shelf__shelf_show_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:text="@string/shelf__shelf_show_list"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
    <com.duokan.reader.theme.themeview.ThemeView
        android:background="@color/dkcommon__day_night__f2f2f2_3d3d3d"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_1"
        android:layout_marginStart="@dimen/view_dimen_45"
        android:layout_marginEnd="@dimen/view_dimen_45"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/shelf__shelf_settings_view__feedback"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_189">
        <com.duokan.reader.theme.themeview.ThemeTextView
            android:gravity="center"
            android:layout_marginLeft="15dp"
            android:text="@string/shelf__setting_report_label"
            android:layout_weight="1"
            style="@style/shelf__read_setting_option_label"/>
        <View
            android:layout_gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
    <com.duokan.reader.theme.themeview.ThemeView
        android:background="@color/dkcommon__day_night__f2f2f2_3d3d3d"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_1"
        android:layout_marginStart="@dimen/view_dimen_45"
        android:layout_marginEnd="@dimen/view_dimen_45"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/shelf__shelf_settings_view__about"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_189">
        <com.duokan.reader.theme.themeview.ThemeTextView
            android:gravity="center"
            android:layout_marginLeft="15dp"
            android:text="@string/shelf__setting_view_abount"
            android:layout_weight="2"
            style="@style/shelf__read_setting_option_label"/>
        <View
            android:layout_gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
</com.duokan.reader.theme.themeview.ThemeLinearLayout>
