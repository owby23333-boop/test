<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/reading__idea_input_view__background"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/reading__idea_input_view__content"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__idea_input_view__content"
        android:background="@color/general__day_night__idea_dialog_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/nav_bar">
        <View
            android:id="@+id/reading__idea_input_view__divider"
            android:background="@color/general__day_night__26000000"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__0_33dp"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/reading__idea_input_view__edittext_root"
            android:background="@drawable/reading__new_idea_present_view__edittext_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__10dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
            android:layout_marginStart="@dimen/general__shared_dimen__18_7dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__10dp"
            app:layout_constraintBottom_toTopOf="@+id/reading__idea_input_view__status"
            app:layout_constraintEnd_toStartOf="@+id/reading__idea_input_view__send"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__idea_input_view__divider">
            <EditText
                android:textSize="@dimen/general__shared_dimen__12_67sp"
                android:textColor="@color/general__day_night__1f2126"
                android:textColorHint="@color/general__day_night__abaeb3"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__idea_input_view__edittext"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general__shared_dimen__10dp"
                android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
                android:maxLines="4"
                android:lineSpacingExtra="@dimen/general__shared_dimen__3_33dp"
                android:imeOptions="flagNoExtractUi|flagNoFullscreen"
                android:layout_marginStart="@dimen/general__shared_dimen__13_33dp"
                android:layout_marginEnd="@dimen/general__shared_dimen__13_33dp"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/general__shared_dimen__12_67sp"
            android:textColor="@color/general__day_night__ff8640"
            android:layout_gravity="center"
            android:id="@+id/reading__idea_input_view__send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/general__shared_dimen__8dp"
            android:text="@string/general__shared__send"
            android:layout_marginEnd="@dimen/general__shared_dimen__18_7dp"
            app:layout_constraintBottom_toBottomOf="@+id/reading__idea_input_view__edittext_root"
            app:layout_constraintEnd_toEndOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/reading__idea_input_view__status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
            android:layout_marginStart="@dimen/general__shared_dimen__18_7dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__18_7dp"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:textSize="@dimen/general__shared_dimen__10_67sp"
                android:textColor="@color/general__day_night__abaeb3"
                android:ellipsize="end"
                android:id="@+id/reading__idea_input_view__sample"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/general__shared_dimen__10dp"/>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/reading__idea_input_view__visibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/reading__idea_input_view__visibility_pic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/reading__new_idea_input_view__unlocked"
                    android:scaleType="center"/>
                <TextView
                    android:textSize="@dimen/general__shared_dimen__10_67sp"
                    android:textColor="@color/general__day_night__abaeb3"
                    android:gravity="center"
                    android:id="@+id/reading__idea_input_view__visibility_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/general__shared_dimen__2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@+id/nav_bar"
        android:background="@color/general__day_night__idea_dialog_background"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
