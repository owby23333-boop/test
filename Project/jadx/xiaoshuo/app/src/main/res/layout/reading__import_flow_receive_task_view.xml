<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_90"
    android:paddingEnd="@dimen/view_dimen_90">
    <TextView
        android:textSize="@dimen/view_dimen_60"
        android:textStyle="bold"
        android:textColor="@color/general__000000"
        android:id="@+id/reading__flow_receive_task_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/view_dimen_36"
        android:textColor="@color/general__1A1A1A_60"
        android:id="@+id/reading__flow_receive_task_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_receive_task_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_46"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__flow_receive_task_10minute_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_80"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_receive_task_summary"/>
    <TextView
        android:textSize="@dimen/view_dimen_34"
        android:textColor="@color/general__999999"
        android:id="@+id/reading__flow_receive_task_10minute_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_receive_task_10minute_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_36"
        android:textColor="@color/general__shared__333333_enabled_333333_40"
        android:gravity="center"
        android:id="@+id/reading__flow_receive_task_10minute_reward"
        android:background="@drawable/reading__import_flow_receive_button_bg"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_286"
        android:layout_height="@dimen/view_dimen_90"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_10minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_10minute_title"/>
    <com.duokan.ui.view.CircleProgressView
        android:id="@+id/reading__flow_receive_task_10minute_progress"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_129"
        android:layout_height="@dimen/view_dimen_129"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_10minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_10minute_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_24"
        android:textColor="@color/general__1A1A1A"
        android:gravity="center"
        android:id="@+id/reading__flow_receive_task_10minute_progress_tv"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_129"
        android:layout_height="@dimen/view_dimen_129"
        android:text="5/10分钟"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_10minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_10minute_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_46"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__flow_receive_task_5minute_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_78"
        android:text="@string/reading__import_flow_get_vip_second_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_receive_task_10minute_summary"/>
    <TextView
        android:textSize="@dimen/view_dimen_34"
        android:textColor="@color/general__999999"
        android:id="@+id/reading__flow_receive_task_5minute_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_receive_task_5minute_title"/>
    <TextView
        android:enabled="false"
        android:textSize="@dimen/view_dimen_36"
        android:textColor="@color/general__shared__333333_enabled_333333_40"
        android:gravity="center"
        android:id="@+id/reading__flow_receive_task_5minute_reward"
        android:background="@drawable/reading__import_flow_receive_button_bg"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_286"
        android:layout_height="@dimen/view_dimen_90"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_5minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_5minute_title"/>
    <com.duokan.ui.view.CircleProgressView
        android:id="@+id/reading__flow_receive_task_5minute_progress"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_129"
        android:layout_height="@dimen/view_dimen_129"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_5minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_5minute_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_24"
        android:textColor="@color/general__1A1A1A"
        android:gravity="center"
        android:id="@+id/reading__flow_receive_task_5minute_progress_tv"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_129"
        android:layout_height="@dimen/view_dimen_129"
        android:text="1/5分钟"
        app:layout_constraintBottom_toBottomOf="@+id/reading__flow_receive_task_5minute_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__flow_receive_task_5minute_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
