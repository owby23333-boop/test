<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.DkTextView
        android:textSize="17dp"
        android:textColor="@color/general__shared__343434"
        android:ellipsize="end"
        android:id="@+id/account__share_bitmap_factory_view__pub_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp"/>
    <View
        android:id="@+id/account__share_bitmap_factory_view__pub_text_gap"
        android:background="@drawable/general__shared__dash_line_light"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginLeft="28dp"
        android:layout_marginTop="30dp"
        android:layout_marginRight="28dp"
        android:layout_marginBottom="30dp"
        android:layerType="software"/>
    <com.duokan.reader.ui.general.DkTextView
        android:textSize="17dp"
        android:textColor="@color/general__shared__343434"
        android:ellipsize="end"
        android:id="@+id/account__share_bitmap_factory_view__pub_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp"
        android:layout_marginBottom="30dp"/>
    <View
        android:background="@drawable/general__shared__dash_line_light"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp"
        android:layout_marginBottom="30dp"
        android:layerType="software"/>
    <RelativeLayout
        android:id="@+id/account__share_bitmap_factory_view__content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp">
        <ImageView
            android:id="@+id/account__share_bitmap_factory_view__cover"
            android:layout_width="101dp"
            android:layout_height="146dp"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/general__shared__c2"
            android:ellipsize="end"
            android:id="@+id/account__share_bitmap_factory_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:maxLines="2"
            android:layout_toRightOf="@+id/account__share_bitmap_factory_view__cover"
            android:layout_alignParentTop="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/general__shared__c7"
            android:ellipsize="end"
            android:id="@+id/account__share_bitmap_factory_view__author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="5dp"
            android:maxLines="2"
            android:layout_toRightOf="@+id/account__share_bitmap_factory_view__cover"
            android:layout_below="@+id/account__share_bitmap_factory_view__title"/>
        <ImageView
            android:id="@+id/account__share_bitmap_factory_view__qrcode"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginLeft="20dp"
            android:scaleType="fitXY"
            android:layout_toRightOf="@+id/account__share_bitmap_factory_view__cover"
            android:layout_below="@+id/account__share_bitmap_factory_view__author"
            android:layout_alignParentBottom="true"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/account__share_bitmap_factory_view__qrcode"
            android:layout_alignParentBottom="true">
            <TextView
                android:textSize="11dp"
                android:textColor="@color/general__shared__c7"
                android:id="@+id/account__share_bitmap_factory_view__hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginBottom="-2dp"
                android:includeFontPadding="false"/>
        </FrameLayout>
    </RelativeLayout>
    <View
        android:background="@drawable/general__shared__dash_line_light"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginLeft="28dp"
        android:layout_marginTop="30dp"
        android:layout_marginRight="28dp"
        android:layout_marginBottom="20dp"
        android:layerType="software"/>
    <TextView
        android:textSize="12dp"
        android:textColor="@color/general__shared__c6"
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/share_copyright"/>
</LinearLayout>
