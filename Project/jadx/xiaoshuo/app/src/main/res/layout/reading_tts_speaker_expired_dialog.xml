<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:layout_gravity="bottom|center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/general__dialog_bg"
    android:paddingTop="@dimen/view_dimen_66"
    android:paddingBottom="@dimen/view_dimen_66"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_77"
    android:paddingEnd="@dimen/view_dimen_77"
    android:layout_marginStart="@dimen/view_dimen_45"
    android:layout_marginEnd="@dimen/view_dimen_45">
    <TextView
        android:textSize="@dimen/text_font_size_51"
        android:textColor="@color/general__day_night__000000_e5ffffff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reading__tts_speakers_tts_expired_title"
        android:textFontWeight="380"/>
    <TextView
        android:textSize="@dimen/text_font_size_45"
        android:textColor="@color/general__day_night__cc000000_ccFFFFFF"
        android:id="@+id/tv_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_44"
        android:textFontWeight="330"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/general__day_night__66000000_66ffffff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_44"
        android:text="@string/reading__tts_speakers_tts_expired_tips"/>
    <TextView
        android:textSize="@dimen/text_font_size_47"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_confirm"
        android:background="@drawable/shape_corner_44_solid_ff7433"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_138"
        android:layout_marginTop="@dimen/view_dimen_66"
        android:text="@string/general__shared__iknow"
        android:textFontWeight="380"/>
</LinearLayout>
