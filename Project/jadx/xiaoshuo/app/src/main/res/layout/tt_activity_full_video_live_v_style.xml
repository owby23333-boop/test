<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_reward_full_native_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/tt_live_video_reward_container"
        android:background="#000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <RelativeLayout
        android:layout_gravity="bottom"
        android:id="@+id/tt_live_video_btn_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="196dp">
        <TextView
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:id="@+id/tt_live_video_btn_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tt_live_full_reward_btn"
            android:shadowColor="#4d000000"
            android:shadowDx="0"
            android:shadowDy="0.5"
            android:shadowRadius="2"
            android:drawableLeft="@drawable/tt_live_ad_loading_btn_status"
            android:drawablePadding="8dp"
            android:layout_centerHorizontal="true"/>
        <ImageView
            android:background="#33ffffff"
            android:layout_width="61dp"
            android:layout_height="1dp"
            android:layout_marginRight="20dp"
            android:layout_toLeftOf="@+id/tt_live_video_btn_tv"
            android:layout_centerVertical="true"/>
        <ImageView
            android:background="#33ffffff"
            android:layout_width="61dp"
            android:layout_height="1dp"
            android:layout_marginLeft="12dp"
            android:layout_toRightOf="@+id/tt_live_video_btn_tv"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:layout_gravity="bottom"
        android:id="@+id/tt_live_video_reward_bar"
        android:background="@drawable/tt_reward_full_live_ad_bg"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="38dp">
        <RelativeLayout
            android:id="@+id/tt_live_ad_avatar_layout"
            android:background="@drawable/tt_live_avatar_bg"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_marginLeft="14dp"
            android:layout_centerVertical="true">
            <com.bytedance.sdk.openadsdk.widget.RoundImageView
                android:id="@+id/tt_full_reward_live_ad_avatar"
                android:layout_width="65dp"
                android:layout_height="65dp"/>
            <ImageView
                android:id="@+id/tt_live_ad_avatar_status"
                android:background="@drawable/tt_live_ad_status_icon"
                android:layout_width="42dp"
                android:layout_height="18dp"
                android:layout_alignParentBottom="true"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="15dp"
            android:layout_toRightOf="@+id/tt_live_ad_avatar_layout">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:ellipsize="end"
                android:id="@+id/tt_live_ad_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:singleLine="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bfffffff"
                android:gravity="center"
                android:id="@+id/tt_live_ad_fans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_below="@+id/tt_live_ad_name"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/tt_live_ad_img"
                android:background="#57ffffff"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginLeft="8dp"
                android:layout_toRightOf="@+id/tt_live_ad_fans"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bfffffff"
                android:gravity="center"
                android:id="@+id/tt_live_ad_watch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="2dp"
                android:layout_toRightOf="@+id/tt_live_ad_img"
                android:layout_below="@+id/tt_live_ad_name"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#bfffffff"
                android:ellipsize="end"
                android:id="@+id/tt_live_ad_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:layout_below="@+id/tt_live_ad_fans"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </RelativeLayout>
</FrameLayout>
