<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/view_dimen_36"
    android:layout_marginEnd="@dimen/view_dimen_36"
    app:cardCornerRadius="@dimen/view_dimen_36"
    app:cardElevation="0dp"
    app:cardMaxElevation="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_top_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_164"
            android:src="@drawable/reward_ad_notification_bg"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/iv_reward_ad_notification_icon"
            android:layout_width="@dimen/general__shared_dimen__30dp"
            android:layout_height="@dimen/general__shared_dimen__30dp"
            android:layout_marginLeft="@dimen/view_dimen_42"
            android:src="@drawable/reward_ad_notification_icon"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/iv_reward_ad_notification_get_reward_bg"
            android:layout_width="@dimen/view_dimen_212"
            android:layout_height="@dimen/view_dimen_98"
            android:src="@drawable/reward_ad_notification_icon_btn_bg"
            android:scaleType="centerCrop"
            android:layout_marginEnd="@dimen/view_dimen_47"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_45"
            android:textStyle="bold"
            android:textColor="@color/dkcommon__61331a"
            android:ellipsize="end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/reward_ad_notification_get_reward_hint"
            android:maxLines="2"
            android:layout_marginStart="@dimen/view_dimen_21"
            android:layout_marginEnd="@dimen/view_dimen_21"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_reward_ad_notification_get_reward_bg"
            app:layout_constraintStart_toEndOf="@+id/iv_reward_ad_notification_icon"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_36"
            android:textStyle="bold"
            android:textColor="@color/color_white"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reward_ad_notification_get_reward"
            app:layout_constraintBottom_toBottomOf="@+id/iv_reward_ad_notification_get_reward_bg"
            app:layout_constraintEnd_toEndOf="@+id/iv_reward_ad_notification_get_reward_bg"
            app:layout_constraintStart_toStartOf="@+id/iv_reward_ad_notification_get_reward_bg"
            app:layout_constraintTop_toTopOf="@+id/iv_reward_ad_notification_get_reward_bg"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
