<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_legal_support_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <Button
        android:textSize="@dimen/text_font_size_38"
        android:textColor="#99672e"
        android:gravity="center"
        android:id="@+id/reading__chapter_not_purchased_vip_btn"
        android:background="@drawable/reading__chapter_vip_rounded_button"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_96"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:drawableStart="@drawable/reading__chapter_not_purchased_view_vip"
        android:paddingStart="@dimen/view_dimen_21"
        android:paddingEnd="@dimen/view_dimen_21"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_monthly_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_15"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_others_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/view_dimen_15"
        android:text="或"/>
    <Button
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/reading__chapter_not_purchased_buy_btn"
        android:background="@drawable/general__shared__rounded_button_orange_normal"
        android:layout_width="@dimen/view_dimen_621"
        android:layout_height="@dimen/view_dimen_108"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_price_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_remaining_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_15"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/general__1A1A1A"
        android:id="@+id/reading__chapter_not_purchased_book_bean_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_30"/>
</LinearLayout>
