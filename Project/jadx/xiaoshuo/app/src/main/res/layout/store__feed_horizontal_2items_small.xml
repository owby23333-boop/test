<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground">
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <include
            android:layout_width="@dimen/view_dimen_118"
            android:layout_height="@dimen/view_dimen_159"
            layout="@layout/store__feed_shared_fiction_imageview"/>
        <ImageView
            android:id="@+id/store__feed_rank"
            android:layout_width="@dimen/view_dimen_42"
            android:layout_height="@dimen/view_dimen_52"/>
    </FrameLayout>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/general__day_night__e6333333"
        android:id="@+id/store__feed_rank_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/view_dimen_24"
        android:paddingEnd="@dimen/view_dimen_15"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_font_size_40"
            android:textColor="@color/general__day_night__e6333333"
            android:ellipsize="end"
            android:id="@+id/store__feed_book_common_title"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:maxLines="2"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/general__day_night__ff5666"
            android:ellipsize="end"
            android:id="@+id/store__feed_book_common_hot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"/>
    </LinearLayout>
</LinearLayout>
