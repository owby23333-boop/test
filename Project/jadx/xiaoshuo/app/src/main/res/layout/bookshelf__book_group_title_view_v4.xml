<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="7dp"
    android:baselineAligned="false">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/bookshelf__purchased_sort_group_view"
        android:layout_width="246dp"
        android:layout_height="29.33dp">
        <TextView
            android:textSize="@dimen/general_font__shared__g"
            android:textColor="@color/bookshelf__purchased_sort_group_view__item_text_color"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__purchased_sort_group_view__time"
            android:background="@drawable/bookshelf__purchased_sort_group_view__item_background_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/bookshelf__purchased_books_sort_view__date"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/general_font__shared__g"
            android:textColor="@color/bookshelf__purchased_sort_group_view__item_text_color"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__purchased_sort_group_view__name"
            android:background="@drawable/bookshelf__purchased_sort_group_view__item_background"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="-1px"
            android:text="@string/bookshelf__purchased_books_sort_view__name"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/general_font__shared__g"
            android:textColor="@color/bookshelf__purchased_sort_group_view__item_text_color"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__purchased_sort_group_view__group"
            android:background="@drawable/bookshelf__purchased_sort_group_view__item_background_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="-1px"
            android:text="@string/bookshelf__purchased_books_sort_view__group"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="13.3sp"
        android:textColor="@color/general__day_night__999999"
        android:layout_gravity="center"
        android:id="@+id/bookshelf__book_group_title_view_v4__lost"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.7dp"
        android:layout_marginBottom="16.7dp"
        android:text="@string/bookshelf__book_group_title_view_v4__lost_feedback"
        android:drawablePadding="7dp"
        android:drawableEnd="@drawable/bookshelf__book_group_title_view_v4__lost_more"/>
</LinearLayout>
