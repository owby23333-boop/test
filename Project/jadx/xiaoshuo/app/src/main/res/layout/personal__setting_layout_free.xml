<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.PageHeaderView
            android:id="@+id/personal__personal_settings_view__header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.duokan.core.ui.LinearScrollView
            android:orientation="vertical"
            android:id="@+id/personal__personal_settings_view__scrollerview"
            android:background="@color/general__day_night__f8f8f8_000000"
            android:scrollbars="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/general__day_night__ffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__text__day_night__666666"
                    android:gravity="center"
                    android:background="@color/general__day_night__f8f8f8_1c1c1c"
                    android:paddingLeft="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="@string/personal__personal_settings_view__like_msg"/>
                <RelativeLayout
                    android:id="@+id/personal__personal_settings_view__user_type"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__t1"
                        android:textColor="@color/general__text__day_night__333333"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="15dp"
                        android:text="@string/personal__personal_settings_view__user_free_type"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__more"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@null"/>
                </RelativeLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/personal__personal_settings_view__pushes"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="63dp">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__text__day_night__333333"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__personal_settings_view__pushes"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:src="@drawable/general__shared__switch"/>
                    </FrameLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/personal__personal_settings_view__subscription"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="63dp">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__text__day_night__333333"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/personal__personal_settings_view__subscription"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/personal__personal_settings_view__subscription_switcher"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:src="@drawable/general__shared__switch"/>
                    </FrameLayout>
                </LinearLayout>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__text__day_night__666666"
                    android:gravity="center"
                    android:background="@color/general__day_night__f8f8f8_1c1c1c"
                    android:paddingLeft="15dp"
                    android:paddingRight="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="@string/personal__personal_settings_view__others"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_developer_mode"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_view__developer_mode"
                    android:drawableRight="@drawable/general__shared__more_selector"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/personal__personal_settings_view__upload_mem_dump"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="63dp">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__text__day_night__333333"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__personal_settings_upload_mem_dump"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:src="@drawable/general__shared__switch"/>
                    </FrameLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/personal__personal_settings_view__dark_mode"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="63dp">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__text__day_night__333333"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__personal_settings_view__dark_mode"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:src="@drawable/general__shared__switch"/>
                    </FrameLayout>
                </LinearLayout>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_privacy_manager"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_privacy_manager"
                    android:drawableRight="@drawable/general__shared__more"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__privacy_view"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_privacy_view"
                    android:drawableRight="@drawable/general__shared__more"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__privacy_revoke"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_privacy_revoke"
                    android:drawableRight="@drawable/general__shared__more"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__feedback"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_view__feedback"
                    android:drawableRight="@drawable/general__shared__more"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t1"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__service_agreement"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_view__service_agreement"
                    android:drawableRight="@drawable/general__shared__more"/>
                <RelativeLayout
                    android:id="@+id/personal__personal_settings_view_teenager"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__t1"
                        android:textColor="@color/general__text__day_night__333333"
                        android:id="@+id/personal__personal_settings_view__teenager_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:text="@string/personal__user_type_view__teenager"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__t3"
                        android:textColor="@color/general__day_night__000000_60"
                        android:gravity="center"
                        android:id="@+id/personal__personal_settings_teenager_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="14dp"
                        android:text="@string/personal__user_type_view__teenager_close_status"
                        android:layout_toLeftOf="@+id/personal__personal_settings_view__teenager_more"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="14dp"
                        android:layout_toStartOf="@+id/personal__personal_settings_view__teenager_more"/>
                    <ImageView
                        android:id="@+id/personal__personal_settings_view__teenager_more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__more"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/personal__personal_settings_view__about"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__t1"
                        android:textColor="@color/general__text__day_night__333333"
                        android:id="@+id/personal__personal_settings_view__about_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:text="@string/personal__personal_settings_view__about"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <com.duokan.reader.ui.general.DkLabelView
                        android:textSize="@dimen/general_font__shared__e"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:id="@+id/personal__personal_settings_view__has_new_version"
                        android:background="@drawable/personal__personal_settings_view__new_version_bg"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="15dp"
                        android:text="@string/personal__personal_settings_view__has_new_version"
                        android:layout_toLeftOf="@+id/personal__personal_settings_view__about_more"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="15dp"
                        android:layout_toStartOf="@+id/personal__personal_settings_view__about_more"/>
                    <ImageView
                        android:id="@+id/personal__personal_settings_view__about_more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__more"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__t2"
                    android:textColor="@color/general__text__day_night__333333"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__diagnostics"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="57dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:text="@string/personal__personal_settings_view__diagnostics"
                    android:drawableRight="@drawable/general__shared__more"/>
                <View
                    android:background="@color/general__day_night__f8f8f8_000000"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/general__text__day_night__666666"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__logoff"
                    android:background="@color/general__day_night__ffffff"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:text="@string/personal__personal_settings_view__logoff"/>
                <TextView
                    android:textSize="12.6sp"
                    android:textColor="#ff4e23"
                    android:gravity="center"
                    android:id="@+id/personal__personal_settings_view__close_account"
                    android:background="@color/general__day_night__f8f8f8_000000"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="63dp"
                    android:text="@string/personal__personal_settings_view__close_account"/>
            </LinearLayout>
        </com.duokan.core.ui.LinearScrollView>
    </LinearLayout>
</FrameLayout>
