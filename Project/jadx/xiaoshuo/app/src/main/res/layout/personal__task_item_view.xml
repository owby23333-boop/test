<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="15dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PicView
        android:id="@+id/personal__task_item_view__icon"
        android:layout_width="33dp"
        android:layout_height="33dp"
        android:layout_centerVertical="true"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__cc26313a"
        android:id="@+id/personal__task_item_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_toRightOf="@+id/personal__task_item_view__icon"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__shared__888888"
        android:id="@+id/personal__task_item_view__description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_toRightOf="@+id/personal__task_item_view__icon"
        android:layout_below="@+id/personal__task_item_view__title"/>
    <ProgressBar
        android:id="@+id/personal__task_item_view__progress"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginLeft="25dp"
        android:layout_marginRight="25dp"
        android:progressDrawable="@drawable/general__shared__green_seek_bar"
        android:layout_toLeftOf="@+id/personal__task_item_view__more"
        android:layout_toRightOf="@+id/personal__task_item_view__title"
        android:layout_centerVertical="true"
        style="@android:style/Widget.ProgressBar.Horizontal"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__ffffff"
        android:gravity="center"
        android:id="@+id/personal__task_item_view__state"
        android:background="@drawable/personal__task_finish_prompt_view__award"
        android:paddingLeft="3dp"
        android:paddingTop="3dp"
        android:paddingRight="3dp"
        android:paddingBottom="3dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <ImageView
        android:id="@+id/personal__task_item_view__more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/personal__account_summary_view__detail"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
