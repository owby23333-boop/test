<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__shared__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:id="@+id/personal__account_summary_view__scroller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/personal__account_summary_view__my_shopping_cart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__585858"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="9dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_shopping_cart"
                    android:drawableTop="@drawable/personal__account_summary_view__my_shopping_cart"
                    android:drawablePadding="5dp"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/personal__account_summary_view__shopping_cart_dot"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="11dp"
                    android:layout_marginBottom="17dp"
                    android:src="@drawable/bookshelf__header_view__have_new_message"/>
            </FrameLayout>
            <TextView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__shared__585858"
                android:gravity="center"
                android:id="@+id/personal__account_summary_view__my_coupon"
                android:paddingTop="14dp"
                android:paddingBottom="9dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/personal__account_summary_view__my_coupon"
                android:drawableTop="@drawable/personal__account_summary_view__my_coupon"
                android:drawablePadding="5dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__shared__585858"
                android:gravity="center"
                android:id="@+id/personal__account_summary_view__my_cash"
                android:paddingTop="14dp"
                android:paddingBottom="9dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/personal__account_summary_view__my_cash"
                android:drawableTop="@drawable/personal__account_summary_view__my_cash"
                android:drawablePadding="5dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__shared__585858"
                android:gravity="center"
                android:id="@+id/personal__account_summary_view__my_reward"
                android:paddingTop="14dp"
                android:paddingBottom="9dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/personal__account_summary_view__my_reward"
                android:drawableTop="@drawable/personal__account_summary_view__my_reward"
                android:drawablePadding="5dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <View
            android:background="@color/general__shared__c9"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__c1"
            android:gravity="center"
            android:id="@+id/personal__account_summary_view__add_fund"
            android:background="@drawable/general__shared__text_pressed"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/personal__account_summary_view__add_fund"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/personal__account_summary_view__event"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <View
            android:id="@+id/personal__account_summary_view__event_placeholder"
            android:background="@color/general__shared__eeece9"
            android:layout_width="match_parent"
            android:layout_height="10dp"/>
        <LinearLayout
            android:id="@+id/personal__account_summary_view__task"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/personal__account_summary_view__task_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:src="@drawable/personal__account_summary_view__task"
                android:scaleType="center"/>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/personal__account_summary_view__task_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__task_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__checkin"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="#eb8077"
                    android:id="@+id/personal__account_summary_view__task_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__checkin_hint"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#e6ff6c00"
                android:layout_gravity="center_vertical"
                android:background="@drawable/personal__personal_center_view__task_background"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingRight="10dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf__sign_in_view__signed"/>
        </LinearLayout>
        <View
            android:background="@color/general__shared__cfcfcf"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:id="@+id/personal__account_summary_view__invite"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/personal__account_summary_view__invite_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="12dp"
                android:src="@drawable/personal__account_summary_view__invite"
                android:scaleType="center"/>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/personal__account_summary_view__invite_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__invite_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__invite"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="#eb8077"
                    android:id="@+id/personal__account_summary_view__invite_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__invite_hint"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#e6ff6c00"
                android:layout_gravity="center_vertical"
                android:background="@drawable/personal__personal_center_view__task_background"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingRight="10dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/personal__account_summary_view__go_invite"/>
        </LinearLayout>
        <View
            android:background="@color/general__shared__eeece9"
            android:layout_width="match_parent"
            android:layout_height="10dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/personal__account_summary_view__divider"
            android:showDividers="middle"
            android:dividerPadding="20dp">
            <RelativeLayout
                android:id="@+id/personal__account_summary_view__my_purchased"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__my_purchased_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_purchased_and_cloud"
                    android:drawableLeft="@drawable/personal__account_summary_view__my_purchased"
                    android:drawablePadding="12dp"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/personal__account_summary_view__purchased_dot"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"
                    android:src="@drawable/bookshelf__header_view__have_new_message"
                    android:scaleType="center"
                    android:layout_toRightOf="@+id/personal__account_summary_view__my_purchased_label"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__8d8d8d"
                    android:id="@+id/personal__account_summary_view__purchased_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/personal__account_summary_view__my_read_books"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__read_books_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_experience"
                    android:drawableLeft="@drawable/personal__account_summary_view__my_experience"
                    android:drawablePadding="12dp"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__8d8d8d"
                    android:id="@+id/personal__account_summary_view__read_books_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/personal__account_summary_view__my_notes"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__notes_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_notes"
                    android:drawableLeft="@drawable/personal__account_summary_view__my_notes"
                    android:drawablePadding="12dp"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__8d8d8d"
                    android:id="@+id/personal__account_summary_view__notes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/personal__account_summary_view__my_wish"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__my_wish_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_wish"
                    android:drawableLeft="@drawable/personal__account_summary_view__my_wish"
                    android:drawablePadding="12dp"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__8d8d8d"
                    android:id="@+id/personal__account_summary_view__wish_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/personal__account_summary_view__my_book_list"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__585858"
                    android:id="@+id/personal__account_summary_view__my_book_list_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__account_summary_view__my_book_list"
                    android:drawableLeft="@drawable/personal__account_summary_view__my_book_list"
                    android:drawablePadding="12dp"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__cacaca"
                    android:id="@+id/personal__account_summary_view__book_list_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </LinearLayout>
    </com.duokan.core.ui.LinearScrollView>
</FrameLayout>
