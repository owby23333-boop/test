<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/welcome__welcome_privacy_guide_view__bg"
        android:scaleType="centerCrop"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/surfing__anonymous_warning_view__logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="87.33dp"
            android:src="@drawable/welcome__welcome_privacy_guide_view__logo"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="32dp"
            android:textColor="#000000"
            android:id="@+id/surfing__anonymous_warning_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="多 看 阅 读"
            android:layout_below="@+id/surfing__anonymous_warning_view__logo"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#000000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="阅 读 - 从 多 看 开 始"
            android:layout_below="@+id/surfing__anonymous_warning_view__title"
            android:layout_centerHorizontal="true"/>
        <LinearLayout
            android:gravity="bottom|center_horizontal"
            android:orientation="vertical"
            android:background="@drawable/welcome__welcome_privacy_guide_view__content_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true">
            <TextView
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#ec5b44"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/surfing__surfing_guide_view__warning"/>
            <TextView
                android:textSize="11sp"
                android:textColor="#5f3012"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:text="@string/surfing__surfing_guide_view__hint"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/surfing__anonymous_warning_view__login"
                android:background="@drawable/surfing__anonymous_warning_view__login_bg"
                android:paddingLeft="114dp"
                android:paddingTop="10dp"
                android:paddingRight="114dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/account__mi_account_login_prompt__login"/>
            <TextView
                android:textSize="10sp"
                android:textColor="#5f3012"
                android:id="@+id/surfing__anonymous_warning_view__skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="25dp"
                android:text="@string/surfing__anonymous_warning_view__skip"/>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
