<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/store_rank_item_width"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/store_rank_item_bottom_margin"
    android:layout_marginStart="@dimen/store_rank_item_left_margin">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_book_cover"
        android:background="@color/general__day_night__f2f2f2_2a2a2a"
        android:layout_width="@dimen/store_rank_item_book_image_width"
        android:layout_height="@dimen/store_rank_item_book_image_height"
        android:scaleType="fitXY"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/BookCoverStyle"
        app:strokeColor="@color/general__day_night__0000001a"
        app:strokeWidth="@dimen/general__view__dimen__0_3dp"/>
    <TextView
        android:textSize="@dimen/store_rank_item_rank_size"
        android:id="@+id/iv_rank1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/store_rank_item_rank_height"
        android:fontFamily="@font/mi_type_mono_bold"
        android:layout_marginStart="@dimen/store_rank_item_book_rank_span"
        android:textFontWeight="900"
        app:layout_constraintStart_toEndOf="@+id/iv_book_cover"
        app:layout_constraintTop_toTopOf="@+id/iv_book_cover"/>
    <TextView
        android:textSize="@dimen/store_rank_item_title_size"
        android:textColor="@color/store_rank_selected__day_night__CC000000_CCFFFFFF"
        android:ellipsize="end"
        android:id="@+id/tv_book_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/general__view__dimen__118dp"
        android:maxLines="2"
        android:layout_marginStart="@dimen/store_rank_item_book_rank_span"
        app:layout_constraintStart_toEndOf="@+id/iv_rank1"
        app:layout_constraintTop_toTopOf="@+id/iv_rank1"/>
    <TextView
        android:textSize="@dimen/store_rank_item_label_size"
        android:textColor="@color/store_rank_item_label__day_night__C79D49__C79D49"
        android:ellipsize="end"
        android:id="@+id/tv_book_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__view__dimen__5_45dp"
        android:singleLine="true"
        app:layout_constraintStart_toStartOf="@+id/tv_book_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_book_title"/>
    <TextView
        android:textSize="@dimen/store_rank_item_label_size"
        android:textColor="@color/store_rank_item_count__day_night__66000000__66FFFFFF"
        android:ellipsize="end"
        android:id="@+id/tv_book_reader_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_book_label"
        app:layout_constraintTop_toTopOf="@+id/tv_book_label"/>
</androidx.constraintlayout.widget.ConstraintLayout>
