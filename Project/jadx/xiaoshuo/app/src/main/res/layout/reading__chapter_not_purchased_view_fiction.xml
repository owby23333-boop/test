<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="67">
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="17sp"
            android:id="@+id/reading__chapter_not_purchased_view__name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__c"
            android:ellipsize="end"
            android:gravity="fill"
            android:id="@+id/reading__chapter_not_purchased_view__tip"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="15">
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/reading__chapter_not_purchased_view__divider_v2"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <View
                android:background="#9b856d"
                android:layout_width="0dp"
                android:layout_height="1px"
                android:layout_weight="1"/>
            <TextView
                android:textSize="10sp"
                android:textColor="#9b856d"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__chapter_not_purchased_view__divider_text"/>
            <View
                android:background="#9b856d"
                android:layout_width="0dp"
                android:layout_height="1px"
                android:layout_weight="1"/>
        </LinearLayout>
        <View
            android:layout_gravity="center"
            android:id="@+id/reading__chapter_not_purchased_view__divider"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
    </FrameLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="100">
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/reading__chapter_not_purchased_view__login_or_buy"
            android:background="@drawable/general__shared__rounded_button_orange"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="150dp"/>
        <com.duokan.reader.ui.reading.ChapterNotPurchasedContainerView
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:id="@+id/reading__chapter_not_purchased_view__server_info"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
</LinearLayout>
