<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="#656670"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include
            android:id="@+id/reading__incentive_ad_loading"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            layout="@layout/reading__loading_dark"/>
        <ImageView
            android:id="@+id/reading__incentive_ad_error"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_682"
            android:layout_height="@dimen/view_dimen_478"
            android:src="@drawable/ic_ad_load_error"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:background="@drawable/bg_top_ad"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__100dp"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:background="@drawable/bg_bottom_ad"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen_336_66dp"
            app:layout_constraintBottom_toBottomOf="parent"/>
        <ImageView
            android:id="@+id/reading__incentive_insure"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_vip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintVertical_bias="0.2"
            app:layout_constraintVertical_chainStyle="packed"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/reading__incentive_ad_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/reading_ad_close_button_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_120"
        android:paddingStart="@dimen/view_dimen_15"
        android:layout_marginEnd="@dimen/view_dimen_42"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/reading__app_ad_view__close_ic"
            android:layout_width="@dimen/view_dimen_90"
            android:layout_height="@dimen/view_dimen_90"
            android:src="@drawable/ic_ad_close"
            android:layout_marginEnd="@dimen/view_dimen_15"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/reading__app_ad_view_line"
            android:background="#ffffff"
            android:layout_width="@dimen/view_dimen_1"
            android:layout_height="@dimen/view_dimen_36"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view__close_ic"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_36"
            android:textColor="#ffffff"
            android:id="@+id/reading__app_ad_view__close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_25"
            android:layout_marginBottom="@dimen/view_dimen_25"
            android:text="@string/general__shared__ad"
            android:layout_marginStart="@dimen/view_dimen_27"
            android:layout_marginEnd="@dimen/view_dimen_22"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/reading__app_ad_view__close_ic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
