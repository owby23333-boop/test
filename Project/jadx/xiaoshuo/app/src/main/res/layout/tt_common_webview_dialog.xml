<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:id="@+id/tt_common_status_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tt_back_tv"
            android:background="@drawable/tt_app_detail_back_btn"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="22dp"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:lineSpacingExtra="2sp"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#222222"
            android:gravity="center"
            android:id="@+id/tt_web_title"
            android:layout_width="70dp"
            android:layout_height="30dp"
            android:text="@string/tt_app_privacy_dialog_title"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <com.bytedance.sdk.component.widget.SSWebView
        android:id="@+id/tt_common_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
