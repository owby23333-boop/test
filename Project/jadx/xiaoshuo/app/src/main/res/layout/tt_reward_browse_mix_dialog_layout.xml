<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/tt_custom_dialog_browse_mix_bg"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="280dp"
            android:layout_centerInParent="true">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/tt_image"
                android:visibility="visible"
                android:layout_width="280dp"
                android:layout_height="100dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="-60dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="10dp"
                android:src="@drawable/tt_reward_browse_multi_icon"/>
            <TextView
                android:textSize="18sp"
                android:textColor="#b8431f"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tt_title"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="@string/tt_ensure_exit"
                android:layout_marginHorizontal="16dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#b8431f"
                android:gravity="center"
                android:id="@+id/tt_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp"
                android:text="@string/tt_retain_tips_message"
                android:lineSpacingExtra="3dp"
                android:layout_marginHorizontal="20dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp">
                <Button
                    android:textSize="16sp"
                    android:textColor="#ffffff"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tt_positive"
                    android:background="@drawable/tt_reward_browse_diglog_btn_bg"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"/>
                <Button
                    android:textSize="14sp"
                    android:textColor="#c97d50"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/tt_negtive"
                    android:background="@null"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:singleLine="true"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/tt_loading"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</FrameLayout>
