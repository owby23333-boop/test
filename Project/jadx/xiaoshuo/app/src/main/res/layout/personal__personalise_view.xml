<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__page_header_background"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/personal__personalise_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/personal__personalise_recommend"
        android:background="@drawable/personal__personal_settings_view__item_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_260"
        android:paddingStart="@dimen/personal__personal_settings_view__item_padding_start"
        android:paddingEnd="@dimen/personal__personal_settings_view__item_padding_end">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="start|center_vertical"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__f"
                    android:textColor="@color/general__day_night__000000"
                    android:layout_gravity="start|center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/personal__personalise_recommend"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__g"
                    android:textColor="@color/general__day_night__999999"
                    android:ellipsize="end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/personal__personalise_recommend_hint"
                    android:singleLine="true"/>
            </LinearLayout>
            <ImageView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/personal__personalise_recommend_switcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/general__shared__switch"
                android:layout_marginStart="10dp"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/personal__personalise_ad"
        android:background="@drawable/personal__personal_settings_view__item_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_260"
        android:paddingStart="@dimen/personal__personal_settings_view__item_padding_start"
        android:paddingEnd="@dimen/personal__personal_settings_view__item_padding_end">
        <LinearLayout
            android:layout_gravity="start|center_vertical"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__f"
                android:textColor="@color/general__day_night__000000"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/personal__personalise_ad"/>
            <TextView
                android:textSize="@dimen/general_font__shared__g"
                android:textColor="@color/general__day_night__999999"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/personal__personalise_ad_hint"/>
        </LinearLayout>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@+id/personal__personalise_ad_switcher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__shared__switch"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__t1"
        android:textColor="@color/general__day_night__000000"
        android:gravity="center"
        android:id="@+id/personal__permission_settings"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_160"
        android:layout_marginLeft="@dimen/personal__personal_settings_view__item_padding_start"
        android:layout_marginRight="@dimen/personal__personal_settings_view__item_padding_end"
        android:text="@string/personal__permission_settings"
        android:drawableRight="@drawable/general__shared__more"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__t1"
        android:textColor="@color/general__day_night__000000"
        android:gravity="center"
        android:id="@+id/personal__info_manager"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_160"
        android:layout_marginLeft="@dimen/personal__personal_settings_view__item_padding_start"
        android:layout_marginRight="@dimen/personal__personal_settings_view__item_padding_end"
        android:text="@string/personal_info_manager"
        android:drawableRight="@drawable/general__shared__more"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/personal__privacy_revoke"
        android:background="@drawable/personal__personal_settings_view__item_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/personal__personal_settings_view__item_padding_start"
        android:paddingEnd="@dimen/personal__personal_settings_view__item_padding_end">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__t1"
            android:textColor="@color/general__day_night__000000"
            android:gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="@dimen/personal__personal_settings_view__middle_height"
            android:text="@string/personal__personal_settings_privacy_revoke"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__shared__more"/>
    </LinearLayout>
</LinearLayout>
