<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/general__free_dialog_box__bg"
    android:paddingTop="@dimen/view_dimen_80"
    android:paddingBottom="@dimen/view_dimen_80"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/view_dimen_32"
    android:layout_marginHorizontal="@dimen/view_dimen_32"
    app:layout_constraintBottom_toBottomOf="parent">
    <TextView
        android:textSize="@dimen/text_font_size_50"
        android:textStyle="bold"
        android:textColor="@color/general__day_night__000000"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="打开可搜索项"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_desc"
        android:background="#f8f8f8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:src="@drawable/general_app_open_searchable"
        android:scaleType="fitXY"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__day_night__000000_80"
        android:id="@+id/tv_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_50"
        android:text="在全局搜索 中开启“多看”开关，即可直接搜到多看提供的书籍"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/iv_desc"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__day_night__CCCCCC_1C1C1C"
        android:id="@+id/tv_desc1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_50"
        android:text="可以前往搜索设置 - 搜索项：打开“多看”开关"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/tv_desc"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__ffffff"
        android:gravity="center"
        android:id="@+id/tv_cancel"
        android:background="@drawable/bg_youth_cancel_buttom"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:text="取消"
        android:layout_marginStart="@dimen/view_dimen_80"
        android:layout_marginEnd="@dimen/view_dimen_40"
        app:layout_constraintEnd_toStartOf="@+id/tv_agree"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_desc1"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__ffffff"
        android:gravity="center"
        android:id="@+id/tv_agree"
        android:background="@drawable/bg_youth_agree_button"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:text="前往打开"
        android:layout_marginStart="@dimen/view_dimen_40"
        android:layout_marginEnd="@dimen/view_dimen_80"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_cancel"
        app:layout_constraintTop_toBottomOf="@+id/tv_desc1"/>
</androidx.constraintlayout.widget.ConstraintLayout>
