<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/general__shared_phone_spirt_dialog_titlebar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_128"
        android:layout_marginTop="@dimen/view_dimen_30">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/general__shared__phone_spirt_dialog_back"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/view_dimen_60"/>
        <TextView
            android:layout_gravity="center"
            android:id="@+id/general__shared__phone_spirt_dialog_title"
            android:visibility="gone"
            android:layout_marginTop="0dp"
            style="@style/general__shared__dialog_title"/>
    </FrameLayout>
</LinearLayout>
