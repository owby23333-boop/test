<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__f7f7f7"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.HeaderView
        android:id="@+id/bookshelf__file_explorer_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general_shared__cccccc_enable_disabled"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__file_explorer_view__select"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:singleLine="true"/>
    </com.duokan.reader.ui.general.HeaderView>
    <FrameLayout
        android:id="@+id/bookshelf__file_explorer_view__tab"
        android:background="@color/general__day_night__ffffff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.dkbookshelf.ui.FileExplorerFlipperView
        android:id="@+id/bookshelf__file_explorer_view__content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
