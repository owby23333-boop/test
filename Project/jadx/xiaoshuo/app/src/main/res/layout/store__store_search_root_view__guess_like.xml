<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_font_size_46"
        android:textStyle="bold"
        android:textColor="@color/general__text__day_night__333333"
        android:id="@+id/store__store_search_root_view__guess_like__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_30"
        android:text="@string/store__search__guess_like"
        android:layout_marginStart="@dimen/view_dimen_50"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/store__store_search_root_view__guess_like__refresh"
        android:layout_width="@dimen/view_dimen_96"
        android:layout_height="@dimen/view_dimen_96"
        android:src="@drawable/store__store_search__refresh"
        android:scaleType="fitCenter"
        android:paddingEnd="@dimen/view_dimen_50"
        app:layout_constraintBottom_toBottomOf="@+id/store__store_search_root_view__guess_like__title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/store__store_search_root_view__guess_like__title"/>
    <com.duokan.reader.ui.general.FlowLayout
        android:id="@+id/store__store_search_root_view__guess_like__flow_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/view_dimen_35"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/store__store_search_root_view__guess_like__title"
        app:maxLineCount="2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
