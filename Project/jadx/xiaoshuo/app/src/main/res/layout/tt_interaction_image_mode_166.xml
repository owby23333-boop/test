<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:id="@+id/tt_reward_full_native_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/tt_ad_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <ImageView
        android:id="@+id/tt_live_ad_icon"
        android:background="@drawable/tt_live_ad_status_icon"
        android:layout_width="45dp"
        android:layout_height="16dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="52dp"
        android:layout_alignTop="@+id/tt_ad_container"/>
    <TextView
        android:id="@+id/tt_ad_logo"
        android:background="@drawable/tt_ad_logo_new"
        android:layout_width="36dp"
        android:layout_height="14dp"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="16dp"
        android:layout_alignParentBottom="true"/>
    <RelativeLayout
        android:id="@+id/tt_full_live_video_btn_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="196dp"
        android:layout_alignParentBottom="true">
        <TextView
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:id="@+id/tt_live_video_btn_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tt_live_full_reward_btn"
            android:drawableLeft="@drawable/tt_live_ad_loading_btn_status"
            android:drawablePadding="8dp"
            android:layout_centerHorizontal="true"/>
        <ImageView
            android:background="#33ffffff"
            android:layout_width="61dp"
            android:layout_height="1dp"
            android:layout_marginRight="20dp"
            android:layout_toLeftOf="@+id/tt_live_video_btn_tv"
            android:layout_centerVertical="true"/>
        <ImageView
            android:background="#33ffffff"
            android:layout_width="61dp"
            android:layout_height="1dp"
            android:layout_marginLeft="12dp"
            android:layout_toRightOf="@+id/tt_live_video_btn_tv"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</RelativeLayout>
