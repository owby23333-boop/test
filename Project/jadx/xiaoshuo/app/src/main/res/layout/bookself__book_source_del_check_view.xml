<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatCheckBox
            android:textSize="15.33sp"
            android:textColor="@color/general__day_night__b3000000"
            android:id="@+id/bookshelf__book_source_del_check__button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bookshelf__remove_books_dlg__del_cache_files"
            android:singleLine="false"
            style="@style/bookshelf_dialog_checkbox_style"/>
        <ImageView
            android:id="@+id/bookshelf__book_source_del_check__question"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_width="40dp"
            android:layout_height="20dp"
            android:src="@drawable/bookshelf__book_source_del_check__question"
            android:scaleType="fitStart"
            android:paddingStart="4.67dp"/>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__day_night__66000000"
        android:id="@+id/bookshelf__book_source_del_check__des"
        android:paddingTop="13dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bookshelf__remove_books_dlg__description"/>
</LinearLayout>
