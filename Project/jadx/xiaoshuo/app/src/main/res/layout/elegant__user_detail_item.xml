<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/elegant__user_detail_item__icon"
        android:layout_width="46.7dp"
        android:layout_height="46.7dp"
        android:layout_marginTop="13.33dp"
        android:layout_marginBottom="13.33dp"
        android:layout_marginStart="18.67dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/elegant__user_detail_item__title"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__14sp"
        android:textColor="@color/general__day_night__1f2226"
        android:ellipsize="end"
        android:id="@+id/elegant__user_detail_item__title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toTopOf="@+id/elegant__user_detail_item__info"
        app:layout_constraintEnd_toStartOf="@+id/elegant__user_detail_item__button"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/elegant__user_detail_item__icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/elegant__day_night__ABAEB3"
        android:ellipsize="end"
        android:id="@+id/elegant__user_detail_item__info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.67dp"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/elegant__user_detail_item__title"
        app:layout_constraintStart_toStartOf="@+id/elegant__user_detail_item__title"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_detail_item__title"/>
    <TextView
        android:textSize="12.67sp"
        android:textColor="@color/general__day_night__ffffff"
        android:gravity="center_horizontal"
        android:id="@+id/elegant__user_detail_item__button"
        android:background="@drawable/elegant__user_detail_item__button"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:layout_marginEnd="18.67dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/elegant__user_detail_item__title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_min="73.33dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
