<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/personal__readed_books_item_view__root"
    android:background="@color/general__day_night__page_header_background"
    android:paddingRight="15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.BookCoverView
        android:id="@+id/personal__readed_books_item_view__cover"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="@dimen/general__shared__cover_bottom_shadow_margin_15dip"
        android:layout_marginRight="@dimen/general__shared__cover_bottom_shadow_margin_15dip"
        android:layout_marginBottom="@dimen/general__shared__cover_bottom_shadow_margin_15dip"
        android:layout_alignParentLeft="true"
        style="@style/general__shared__cover_list"/>
    <com.duokan.reader.ui.bookshelf.BookActionView
        android:id="@+id/personal__readed_books_item_view__edit"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__day_night__343434"
        android:ellipsize="end"
        android:id="@+id/personal__readed_books_item_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_toLeftOf="@+id/personal__readed_books_item_view__edit"
        android:layout_toRightOf="@+id/personal__readed_books_item_view__cover"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__a3a3a3"
        android:ellipsize="end"
        android:id="@+id/personal__readed_books_item_view__author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_toLeftOf="@+id/personal__readed_books_item_view__edit"
        android:layout_toRightOf="@+id/personal__readed_books_item_view__cover"
        android:layout_below="@+id/personal__readed_books_item_view__title"/>
    <com.duokan.reader.ui.store.comment.DkCommentScoreView
        android:layout_gravity="center"
        android:id="@+id/personal__readed_books_item_view__rate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="5dp"
        android:layout_toRightOf="@+id/personal__readed_books_item_view__cover"
        android:layout_below="@+id/personal__readed_books_item_view__author"
        app:custom_operation="true"
        app:high_score="@drawable/general__shared__star_11dip_pressed"
        app:normal_score="@drawable/general__shared__star_11dip_normal"
        app:score_space="5dp"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__a3a3a3"
        android:id="@+id/personal__readed_books_item_view__comment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_toLeftOf="@+id/personal__readed_books_item_view__edit"
        android:layout_toRightOf="@+id/personal__readed_books_item_view__rate"
        android:layout_below="@+id/personal__readed_books_item_view__author"/>
</RelativeLayout>
