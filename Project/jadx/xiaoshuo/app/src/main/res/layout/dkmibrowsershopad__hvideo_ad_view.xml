<?xml version="1.0" encoding="utf-8"?>
<com.duokan.advertisement.ui.DkVideoAdView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__app_ad_view_constraint_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/page_ad_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.58">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/general__shared__corner_ad_bg"
            android:paddingLeft="@dimen/view_dimen_42"
            android:paddingTop="@dimen/view_dimen_50"
            android:paddingRight="@dimen/view_dimen_42"
            android:paddingBottom="@dimen/view_dimen_50"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp">
            <TextView
                android:textSize="@dimen/text_font_size_48"
                android:textStyle="bold"
                android:textColor="@color/dkcommon__day_night__000000"
                android:ellipsize="end"
                android:id="@+id/reading__app_ad_view__summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"/>
            <FrameLayout
                android:id="@+id/dkmibrowsershopad__ad_view_main"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/view_dimen_42">
                <com.duokan.advertisement.ui.DkVideoView
                    android:id="@+id/dkmibrowsershopad__ad_view_video"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:id="@+id/dkmibrowsershopad__ad_view_video_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/dkmibrowsershopad__ad_view_video_play_button"
                    android:visibility="gone"
                    android:layout_width="@dimen/view_dimen_120"
                    android:layout_height="@dimen/view_dimen_120"
                    android:src="@drawable/reading__ad_view_play"/>
                <ImageView
                    android:layout_gravity="end|bottom"
                    android:id="@+id/reading__app_ad_view__close"
                    android:layout_width="@dimen/view_dimen_77"
                    android:layout_height="@dimen/view_dimen_30"
                    android:layout_marginBottom="@dimen/view_dimen_20"
                    android:src="@drawable/reading__ad_view_close"
                    android:layout_marginEnd="@dimen/view_dimen_20"/>
            </FrameLayout>
            <include layout="@layout/bro_xout_frame"/>
        </LinearLayout>
        <include layout="@layout/dkmibrowsershopad__ad_big_button_view"/>
    </LinearLayout>
</com.duokan.advertisement.ui.DkVideoAdView>
