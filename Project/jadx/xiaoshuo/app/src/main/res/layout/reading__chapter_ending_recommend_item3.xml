<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="@dimen/main_padding_30"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/store__feed_book_common_cover"
        android:layout_width="@dimen/view_dimen_180"
        android:layout_height="@dimen/view_dimen_260"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"
        app:strokeWidth="@dimen/view_dimen_1"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp">
        <TextView
            android:textColor="#e6333333"
            android:ellipsize="end"
            android:id="@+id/store__feed_book_common_title"
            android:layout_width="@dimen/view_dimen_180"
            android:layout_height="wrap_content"
            android:text="极品上门女婿"
            android:maxLines="2"/>
        <TextView
            android:textSize="13sp"
            android:textColor="#66000000"
            android:id="@+id/store__feed_book_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>
        <TextView
            android:id="@+id/tv_add_book"
            android:layout_marginTop="4dp"
            style="@style/reading__recommend_add_bookshelf_text"/>
    </LinearLayout>
</LinearLayout>
