<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/reading__seek_page_view__line1"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__999999_selected"
            android:gravity="center"
            android:id="@+id/reading__seek_page_view__prev_chapter"
            android:background="@drawable/general__shared__button_light_29dip_ffffff33"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:text="@string/reading__seek_page_view__prev_chapter"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/reading__seek_page_view__prev_page"
            android:background="@drawable/general__shared__button_light_29dip_ffffff33"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:src="@drawable/general__shared__arrow_left1"
            android:scaleType="center"
            android:contentDescription="@null"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__ffffff"
            android:gravity="center"
            android:id="@+id/reading__seek_page_view__page_num"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/reading__seek_page_view__next_page"
            android:background="@drawable/general__shared__button_light_29dip_ffffff33"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:src="@drawable/general__shared__arrow_right1"
            android:scaleType="center"
            android:contentDescription="@null"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__999999_selected"
            android:gravity="center"
            android:id="@+id/reading__seek_page_view__next_chapter"
            android:background="@drawable/general__shared__button_light_29dip_ffffff33"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="@string/reading__seek_page_view__next_chapter"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/reading__seek_page_view__line2"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginRight="10dp">
        <SeekBar
            android:id="@+id/reading__seek_page_view__seek_bar"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:progressDrawable="@drawable/general__shared__seek_bar"
            android:thumb="@drawable/general__shared__seek_bar_thumb"
            android:thumbOffset="10dp"
            android:layout_weight="1"/>
        <ProgressBar
            android:id="@+id/reading__seek_page_view__paginating_progress"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:max="100"
            android:progressDrawable="@drawable/general__shared__seek_bar"
            android:layout_weight="1"
            style="@android:style/Widget.ProgressBar.Horizontal"/>
        <ImageView
            android:id="@+id/reading__seek_page_view__page_back"
            android:background="@drawable/reading__shared__page_back"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:contentDescription="@null"/>
    </LinearLayout>
</LinearLayout>
