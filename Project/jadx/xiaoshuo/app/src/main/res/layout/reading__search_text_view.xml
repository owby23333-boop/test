<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/reading__search_text_view__bar"
        android:background="@color/general__shared__141414f2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:textColor="@color/general__shared__ffffff"
            android:id="@+id/reading__search_text_view__input"
            android:background="@drawable/general__shared__search_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/reading__search_text_view__empty_hint"
            android:drawableLeft="@drawable/general__shared__search_icon"
            android:layout_weight="1"
            android:imeOptions="flagNoExtractUi|flagNoFullscreen"
            style="@style/general__shared__search_text"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:id="@+id/reading__search_text_view__cancel"
            android:layout_width="56dp"
            android:layout_marginLeft="10dp"
            android:text="@string/general__shared__cancel"
            style="@style/general__shared__button_light_29dip_c9c9c9"/>
        <View
            android:id="@+id/search__main_view__clear_icon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.duokan.core.ui.BoxView
        android:id="@+id/reading__search_text_view__result_box"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <com.duokan.reader.ui.general.DkListPager
            android:id="@+id/reading__search_text_view__result_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </com.duokan.core.ui.BoxView>
</LinearLayout>
