<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="@dimen/view_dimen_21"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/general__view__dimen__13_09dp">
    <View
        android:id="@+id/line"
        android:background="#ff7433"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/tv_title"
        app:layout_constraintStart_toStartOf="@+id/tv_title"/>
    <TextView
        android:textSize="@dimen/general__view__text_size__15_27sp"
        android:textStyle="bold"
        android:textColor="@color/store_rank_unselected__day_night__4D000000_99FFFFFF"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
