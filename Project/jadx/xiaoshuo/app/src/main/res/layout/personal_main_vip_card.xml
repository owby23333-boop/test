<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/personal_controller_vip_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_80">
        <ImageView
            android:id="@+id/personal__main__vip_view_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__0dp"
            android:src="@drawable/persona_vip_view_bg"
            app:layout_constraintDimensionRatio="6.4:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/personal__main__vip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/personal__main__vip_icon"
            android:contentDescription="vip"
            android:layout_marginStart="@dimen/view_dimen_60"
            app:layout_constraintBottom_toBottomOf="@+id/personal__main__vip_view_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/personal__main__vip_view_bg"/>
        <ImageView
            android:id="@+id/personal__main__vip_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/personal__main__vip_next_icon"
            android:layout_marginEnd="@dimen/view_dimen_60"
            app:layout_constraintBottom_toBottomOf="@+id/personal__main__vip_view_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/personal__main__vip_view_bg"/>
        <TextView
            android:id="@+id/personal_vip__tv_vip_open_state"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/general__shared_dimen__10_33dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__18dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@+id/personal__main__vip_view_bg"
            app:layout_constraintEnd_toStartOf="@+id/personal__main__vip_next"
            app:layout_constraintStart_toEndOf="@+id/personal__main__vip_view_divider"
            app:layout_constraintTop_toTopOf="@+id/personal__main__vip_view_bg"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__12sp"
            android:textColor="#e6fee5ce"
            android:ellipsize="end"
            android:id="@+id/personal_header_vip_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/elegant__personal__vip_tip"
            android:singleLine="true"
            android:layout_marginStart="@dimen/general__shared_dimen__10_33dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__18dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@+id/personal__main__vip_view_bg"
            app:layout_constraintEnd_toStartOf="@+id/personal__main__vip_next"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@+id/personal__main__vip_view_divider"
            app:layout_constraintTop_toTopOf="@+id/personal__main__vip_view_bg"/>
        <View
            android:id="@+id/personal__main__vip_view_divider"
            android:background="#33fbdbbb"
            android:layout_width="@dimen/general__shared_dimen__0_7dp"
            android:layout_height="@dimen/general__shared_dimen__12_67sp"
            android:layout_marginStart="@dimen/general__shared_dimen__10dp"
            app:layout_constraintBottom_toBottomOf="@+id/personal__main__vip_view_bg"
            app:layout_constraintStart_toEndOf="@+id/personal__main__vip"
            app:layout_constraintTop_toTopOf="@+id/personal__main__vip_view_bg"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
