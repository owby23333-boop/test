<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__navigation_read_book_top"
    android:background="@color/general__day_night__catalogue_head_bg"
    android:paddingTop="@dimen/view_dimen_10"
    android:paddingBottom="@dimen/view_dimen_70"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_60"
    android:paddingEnd="@dimen/view_dimen_60">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__navigation_current_book_cover"
        android:layout_width="@dimen/view_dimen_112"
        android:layout_height="@dimen/view_dimen_163"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"
        app:strokeWidth="@dimen/view_dimen_1"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__catalogue_head_title"
        android:ellipsize="end"
        android:id="@+id/reading__navigation_current_book_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_20"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/view_dimen_40"
        android:layout_marginEnd="@dimen/view_dimen_40"
        app:layout_constraintEnd_toStartOf="@+id/enter_view"
        app:layout_constraintStart_toEndOf="@+id/reading__navigation_current_book_cover"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/general__day_night__catalogue_head_content"
        android:id="@+id/reading__navigation_current_book_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_20"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/view_dimen_40"
        android:layout_toEndOf="@+id/reading__navigation_current_book_cover"
        app:layout_constraintStart_toEndOf="@+id/reading__navigation_current_book_cover"
        app:layout_constraintTop_toBottomOf="@+id/reading__navigation_current_book_name"/>
    <ImageView
        android:id="@+id/enter_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/reading__reading_navigation_header_enter"
        app:layout_constraintBottom_toBottomOf="@+id/reading__navigation_current_book_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/reading__navigation_current_book_cover"/>
</androidx.constraintlayout.widget.ConstraintLayout>
