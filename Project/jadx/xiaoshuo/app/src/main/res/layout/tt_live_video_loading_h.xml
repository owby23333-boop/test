<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_live_loading_root"
    android:background="#99000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/tt_live_ad_avatar_layout"
        android:background="@drawable/tt_live_avatar_bg"
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:layout_marginTop="100dp"
        android:layout_centerHorizontal="true">
        <com.bytedance.sdk.openadsdk.widget.RoundImageView
            android:id="@+id/tt_live_ad_avatar"
            android:layout_width="65dp"
            android:layout_height="65dp"/>
        <ImageView
            android:id="@+id/tt_live_ad_avatar_status"
            android:background="@drawable/tt_live_ad_status_icon"
            android:layout_width="42dp"
            android:layout_height="18dp"
            android:layout_alignParentBottom="true"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:id="@+id/tt_live_ad_studio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:layout_below="@+id/tt_live_ad_avatar_layout"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ffffff"
        android:id="@+id/tt_live_ad_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/tt_live_loading_text"
        android:layout_below="@+id/tt_live_ad_studio"
        android:layout_centerHorizontal="true"/>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/tt_live_ad_loading_btn"
        android:background="@drawable/tt_reward_full_live_ad_btn_bg"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="40dp"
        android:layout_marginRight="40dp"
        android:layout_marginBottom="70dp"
        android:layout_alignParentBottom="true">
        <ImageView
            android:id="@+id/tt_live_ad_loading_btn_status"
            android:background="@drawable/tt_live_ad_loading_btn_status"
            android:layout_width="14dp"
            android:layout_height="16dp"
            android:layout_marginRight="4dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:textColor="@android:color/white"
            android:gravity="center_vertical"
            android:id="@+id/tt_live_ad_loading_btn_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/tt_live_loading_btn"
            android:singleLine="true"
            android:layout_toRightOf="@+id/tt_live_ad_loading_btn_status"
            android:layout_toEndOf="@+id/tt_live_ad_loading_btn_status"/>
        <ImageView
            android:gravity="center"
            android:background="@drawable/tt_splash_click_bar_go"
            android:layout_width="14dp"
            android:layout_height="16dp"
            android:layout_toRightOf="@+id/tt_live_ad_loading_btn_text"
            android:layout_centerInParent="true"
            android:layout_toEndOf="@+id/tt_live_ad_loading_btn_text"/>
    </RelativeLayout>
</RelativeLayout>
