<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/store__dislike_menu_view"
    android:background="@drawable/reading__shared__white_background"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/view_dimen_40">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingTop="@dimen/view_dimen_65"
        android:paddingBottom="@dimen/view_dimen_35"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:src="@drawable/store__dislike_menu_view__uninterested_icon"
            android:layout_marginStart="@dimen/view_dimen_64"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__000000_90_ffffff_90"
            android:gravity="center_vertical"
            android:id="@+id/store__dislike_menu_view__uninterested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/store__add_dislike_menu_view__to_uninterested"
            android:includeFontPadding="false"
            android:layout_marginStart="@dimen/view_dimen_40"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/view_dimen_35">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:src="@drawable/store__dislike_menu_view__read_already_icon"
            android:layout_marginStart="@dimen/view_dimen_64"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__000000_90_ffffff_90"
            android:gravity="center_vertical"
            android:id="@+id/store__dislike_menu_view__read_already"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/store__add_dislike_menu_view__to_read_already"
            android:includeFontPadding="false"
            android:layout_marginStart="@dimen/view_dimen_40"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/view_dimen_35">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:src="@drawable/store__dislike_menu_view__low_quality_icon"
            android:layout_marginStart="@dimen/view_dimen_64"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__000000_90_ffffff_90"
            android:gravity="center_vertical"
            android:id="@+id/store__dislike_menu_view__low_quality"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/store__add_dislike_menu_view__to_low_quality"
            android:includeFontPadding="false"
            android:drawablePadding="@dimen/view_dimen_20"
            android:layout_marginStart="@dimen/view_dimen_40"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingTop="@dimen/view_dimen_35"
        android:paddingBottom="@dimen/view_dimen_65"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:src="@drawable/store__dislike_menu_view__dislike_topic_icon"
            android:layout_marginStart="@dimen/view_dimen_64"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__000000_90_ffffff_90"
            android:gravity="center_vertical"
            android:id="@+id/store__dislike_menu_view__dislike_topic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/store__add_dislike_menu_view__to_dislike_topic"
            android:includeFontPadding="false"
            android:layout_marginStart="@dimen/view_dimen_40"/>
    </LinearLayout>
</LinearLayout>
