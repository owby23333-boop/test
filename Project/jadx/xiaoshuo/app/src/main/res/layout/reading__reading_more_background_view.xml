<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/general__fdfdfd"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/reading__reading_more_background_back"
            android:padding="@dimen/view_dimen_65"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/reading__reading_options_down_arrow"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/black_80_transparent"
            android:id="@+id/reading__reading_more_background_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_more_background"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <com.duokan.reader.ui.general.RoundFrameLayout
        android:id="@+id/reading__reading_bg_pure_color"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_28"
        android:foreground="@drawable/reading__reading_more_background_selector_color0"
        android:layout_marginStart="@dimen/view_dimen_65"
        android:layout_marginEnd="@dimen/view_dimen_65"
        app:radius="@dimen/view_dimen_70">
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/black_70_transparent"
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__reading_bg_pure_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_default"
            android:layout_marginStart="@dimen/view_dimen_56"/>
    </com.duokan.reader.ui.general.RoundFrameLayout>
    <com.duokan.reader.ui.general.RoundFrameLayout
        android:id="@+id/reading__reading_bg_vine"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_45"
        android:foreground="@drawable/reading__reading_more_background_selector_color0"
        android:layout_marginStart="@dimen/view_dimen_65"
        android:layout_marginEnd="@dimen/view_dimen_65"
        app:radius="@dimen/view_dimen_70">
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/black_70_transparent"
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__reading_bg_vine_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_vine"
            android:layout_marginStart="@dimen/view_dimen_56"/>
    </com.duokan.reader.ui.general.RoundFrameLayout>
    <com.duokan.reader.ui.general.RoundFrameLayout
        android:id="@+id/reading__reading_bg_scene"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_45"
        android:layout_marginBottom="@dimen/view_dimen_80"
        android:foreground="@drawable/reading__reading_more_background_selector_color0"
        android:layout_marginStart="@dimen/view_dimen_65"
        android:layout_marginEnd="@dimen/view_dimen_65"
        app:radius="@dimen/view_dimen_70">
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/black_70_transparent"
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__reading_bg_scene_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_scene"
            android:layout_marginStart="@dimen/view_dimen_56"/>
    </com.duokan.reader.ui.general.RoundFrameLayout>
</LinearLayout>
