<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingTop="@dimen/view_dimen_30"
    android:paddingBottom="@dimen/view_dimen_30"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_50"
    android:paddingEnd="@dimen/view_dimen_50">
    <ImageView
        android:id="@+id/store__store_search__associate_bookshelf_item__cover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/general__shared__default_cover"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"/>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store__store_search__associate_bookshelf_item__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_22"
        android:lines="1"
        android:layout_below="@+id/store__store_search__associate_bookshelf_item__cover"/>
    <TextView
        android:textSize="@dimen/text_font_size_32"
        android:textColor="#59000000"
        android:id="@+id/store__store_search__associate_bookshelf_item__chapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_14"
        android:layout_below="@+id/store__store_search__associate_bookshelf_item__title"/>
    <TextView
        android:textSize="@dimen/text_font_size_30"
        android:textColor="@color/white"
        android:layout_gravity="end|top"
        android:id="@+id/store__store_search__associate_bookshelf_item__end"
        android:background="@drawable/bookshelf__gird_end_flg_bg"
        android:paddingTop="3dp"
        android:paddingBottom="2dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:text="完结"
        android:includeFontPadding="false"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_alignEnd="@+id/store__store_search__associate_bookshelf_item__cover"/>
</RelativeLayout>
