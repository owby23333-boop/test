<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/general__btn__bg"
    android:layout_width="140dp"
    android:layout_height="90dp">
    <FrameLayout
        android:layout_gravity="end|top"
        android:id="@+id/general__loading_view__close_btn"
        android:visibility="gone"
        android:layout_width="22dp"
        android:layout_height="22dp">
        <View
            android:layout_gravity="center"
            android:background="@drawable/general__loading_close__icon"
            android:layout_width="12dp"
            android:layout_height="12dp"/>
    </FrameLayout>
    <View
        android:layout_gravity="top|center_horizontal"
        android:id="@+id/general__loading_animation__view"
        android:layout_width="48dp"
        android:layout_height="7dp"
        android:layout_marginTop="30.5dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/general__loading_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="25dp"
        android:text="正在加载中..."/>
</FrameLayout>
