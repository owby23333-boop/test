<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="28.7dp"
    android:layout_marginTop="24.6dp"
    android:layout_marginEnd="0dp"
    style="@style/store__shared__item_parent">
    <TextView
        android:gravity="bottom"
        android:id="@+id/store_feed_book_list_title"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingEnd="5dp"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/store__feed_book_list_title_style"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/general__day_night__000000_40"
        android:id="@+id/store_feed_book_list_subtitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_4"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_list_title"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_list_title"/>
    <TextView
        android:textSize="13.3sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:gravity="center_vertical"
        android:layout_gravity="end"
        android:id="@+id/store_feed_book_list_exchange"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="@string/store_feed_book_list_exchange"
        android:drawablePadding="6.67dp"
        android:drawableEnd="@drawable/store__feed_book_list__change"
        android:paddingStart="20dp"
        android:paddingEnd="16.67dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:layout_gravity="end"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:visibility="gone"
        android:layout_width="211dp"
        android:layout_height="28.7dp"
        app:layout_constraintEnd_toEndOf="parent"
        layout="@layout/store__feed_fiction_announce_male"/>
</androidx.constraintlayout.widget.ConstraintLayout>
