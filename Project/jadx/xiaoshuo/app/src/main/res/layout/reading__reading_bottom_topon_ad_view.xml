<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__reading_bottom_ad_view"
    android:layout_width="match_parent"
    android:layout_height="@dimen/general__reading__bottom_ad_height">
    <FrameLayout
        android:id="@+id/reading__large_image_view__area"
        android:layout_width="@dimen/view_dimen_148"
        android:layout_height="@dimen/view_dimen_148"
        android:layout_marginStart="@dimen/view_dimen_30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_44"
        android:textStyle="bold"
        android:textColor="@color/black_70_transparent"
        android:ellipsize="end"
        android:id="@+id/reading__reading_bottom_ad_view__title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/view_dimen_27"
        android:layout_marginTop="@dimen/view_dimen_27"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintLeft_toRightOf="@+id/reading__large_image_view__area"
        app:layout_constraintRight_toLeftOf="@+id/reading__reading_bottom_ad_view__ad_label__square"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"/>
    <TextView
        android:textSize="@dimen/text_font_size_28"
        android:textColor="@color/general__ffffff_90"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/reading__reading_bottom_ad_view__ad_label__square"
        android:background="@drawable/general__page__close_ad_view_background"
        android:paddingLeft="@dimen/view_dimen_15"
        android:paddingRight="@dimen/view_dimen_10"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_40"
        android:layout_margin="@dimen/view_dimen_20"
        android:text="@string/reading__close_ad_view__close_text"
        android:drawableRight="@drawable/reading__app_ad_view__close_right_x_icon"
        android:drawablePadding="@dimen/view_dimen_12"
        app:layout_constraintBottom_toBottomOf="@+id/reading__reading_bottom_ad_view__title"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintLeft_toRightOf="@+id/reading__reading_bottom_ad_view__title"
        app:layout_constraintRight_toLeftOf="@+id/reading__app_ad_view__download"
        app:layout_constraintTop_toTopOf="@+id/reading__reading_bottom_ad_view__title"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/black_40_transparent"
        android:ellipsize="end"
        android:id="@+id/reading__reading_bottom_ad_view__summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/view_dimen_30"
        android:layout_marginBottom="@dimen/view_dimen_27"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintLeft_toLeftOf="@+id/reading__reading_bottom_ad_view__title"
        app:layout_constraintRight_toLeftOf="@+id/reading__app_ad_view__download"
        app:layout_constraintWidth_default="wrap"/>
    <TextView
        android:textSize="@dimen/text_font_size_32"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:id="@+id/reading__app_ad_view__download"
        android:background="@drawable/general__shared__rounded_button_yellow"
        android:visibility="visible"
        android:layout_width="@dimen/view_dimen_190"
        android:layout_height="@dimen/view_dimen_72"
        android:layout_marginRight="@dimen/view_dimen_60"
        android:text="@string/general__shared__ad_free_experience"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
