<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="bottom"
    android:orientation="horizontal"
    android:background="#cc000000"
    android:layout_width="match_parent"
    android:layout_height="40dp">
    <ImageView
        android:id="@+id/reading__notification_view__icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:scaleType="center"/>
    <TextView
        android:textSize="@dimen/general_font__shared__e"
        android:textColor="#ffeecc"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/reading__notification_view__msg"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="7dp"
        android:maxLines="1"
        android:layout_weight="1"/>
    <ImageView
        android:id="@+id/reading__notification_view__close"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/reading__notification_view__close"/>
</LinearLayout>
