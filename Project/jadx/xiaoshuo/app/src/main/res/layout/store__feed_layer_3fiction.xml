<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/store_feed_layer"
    android:background="@color/black_80_transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/store_feed_layer_wrapper"
        android:background="@drawable/store__feed_layer_3fic_bg"
        android:layout_width="@dimen/view_dimen_966"
        android:layout_height="@dimen/view_dimen_784"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textColor="@color/general__333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_70"
            android:layout_marginBottom="@dimen/view_dimen_49"
            android:text="@string/store__layer_3fiction_title"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <include
                android:id="@+id/store__feed_layer_item1"
                layout="@layout/store__feed_layer_one_item"/>
            <include
                android:id="@+id/store__feed_layer_item2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/view_dimen_40"
                layout="@layout/store__feed_layer_one_item"/>
            <include
                android:id="@+id/store__feed_layer_item3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/view_dimen_40"
                layout="@layout/store__feed_layer_one_item"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/store_feed_layer_to_self"
            android:background="@drawable/store__feed_layer_3fiction_bt_bg"
            android:layout_width="@dimen/view_dimen_468"
            android:layout_height="@dimen/view_dimen_100"
            android:layout_marginTop="@dimen/view_dimen_28"
            android:text="@string/store__layer_3fiction_bt"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/store_feed_layer_close"
        android:layout_width="@dimen/view_dimen_80"
        android:layout_height="@dimen/view_dimen_80"
        android:layout_marginTop="@dimen/view_dimen_90"
        android:src="@drawable/store__feed_layer_3fic_close"
        android:layout_below="@+id/store_feed_layer_wrapper"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
