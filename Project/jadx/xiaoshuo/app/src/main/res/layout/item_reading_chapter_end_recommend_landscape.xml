<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.DebugConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/view_dimen_717"
    android:layout_height="@dimen/view_dimen_254"
    android:paddingEnd="@dimen/view_dimen_51">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/item_reading_chapter_end_recommend_cover"
        android:layout_width="@dimen/view_dimen_176"
        android:layout_height="@dimen/view_dimen_254"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundCorner12"
        app:strokeColor="@color/black_10_transparent"
        app:strokeWidth="@dimen/view_dimen_1"/>
    <TextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="@color/general__1A1A1A"
        android:ellipsize="end"
        android:id="@+id/item_reading_chapter_end_recommend_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="@dimen/view_dimen_32"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_reading_chapter_end_recommend_cover"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="@color/general__1A1A1A_50"
        android:ellipsize="end"
        android:id="@+id/item_reading_chapter_end_recommend_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_21"
        android:maxLines="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/item_reading_chapter_end_recommend_title"
        app:layout_constraintTop_toBottomOf="@+id/item_reading_chapter_end_recommend_title"/>
    <TextView
        android:textSize="@dimen/text_font_size_39"
        android:textColor="@color/color_824812"
        android:gravity="center"
        android:id="@+id/item_reading_chapter_end_recommend_add_shelf"
        android:background="@drawable/shape_corner_100_solid_e1b483"
        android:layout_width="@dimen/view_dimen_216"
        android:layout_height="@dimen/view_dimen_64"
        android:text="@string/reading_start_reading"
        app:layout_constraintBottom_toBottomOf="@+id/item_reading_chapter_end_recommend_cover"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="@color/general__1A1A1A_50"
        android:ellipsize="end"
        android:id="@+id/item_reading_chapter_end_recommend_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_9"
        android:maxLines="1"
        android:layout_marginEnd="@dimen/view_dimen_12"
        app:layout_constraintBottom_toBottomOf="@+id/item_reading_chapter_end_recommend_cover"
        app:layout_constraintEnd_toStartOf="@+id/item_reading_chapter_end_recommend_add_shelf"
        app:layout_constraintStart_toStartOf="@+id/item_reading_chapter_end_recommend_title"/>
</com.duokan.reader.ui.DebugConstraintLayout>
