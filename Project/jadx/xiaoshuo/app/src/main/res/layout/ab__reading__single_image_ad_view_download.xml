<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.duokan.advertisement.ui.PageAdContainerView
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="@+id/page_ad_container"
                android:background="@drawable/ab__general__shared__rounded_corner_ad"
                android:paddingLeft="@dimen/view_dimen_40"
                android:paddingTop="@dimen/view_dimen_50"
                android:paddingRight="@dimen/view_dimen_40"
                android:paddingBottom="@dimen/view_dimen_50"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp">
                <com.duokan.reader.ui.general.RoundImageView
                    android:id="@+id/reading__single_image_view__image"
                    android:layout_width="@dimen/view_dimen_210"
                    android:layout_height="@dimen/view_dimen_210"
                    android:scaleType="centerCrop"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:radius="@dimen/view_dimen_20"/>
                <include
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintRight_toRightOf="@+id/reading__single_image_view__image"
                    app:layout_constraintTop_toTopOf="@+id/reading__single_image_view__image"
                    layout="@layout/general__page__close_ad_view_style3"/>
                <TextView
                    android:textSize="@dimen/view_dimen_48"
                    android:textColor="#000000"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:alpha="0.7"
                    android:layout_marginStart="@dimen/view_dimen_30"
                    app:layout_constraintLeft_toRightOf="@+id/reading__single_image_view__image"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <include
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_20"
                    app:layout_constraintLeft_toLeftOf="@+id/reading__app_ad_view__summary"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__summary"
                    layout="@layout/ad_yimi_privacy_information_style1"/>
                <com.duokan.reader.ui.general.FlowLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ab__reading__ad_view_title_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_29"
                    app:layout_constraintStart_toStartOf="@+id/reading__single_image_view__image"
                    app:layout_constraintTop_toBottomOf="@+id/reading__single_image_view__image">
                    <include
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        layout="@layout/ab__reading__ad_view_title_xout"/>
                    <include
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        layout="@layout/ad_yimi_privacy_version_style1"/>
                </com.duokan.reader.ui.general.FlowLayout>
            </com.duokan.advertisement.ui.PageAdContainerView>
            <include
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/view_dimen_20"
                android:layout_marginRight="@dimen/view_dimen_20"
                layout="@layout/general__close_ad_view"/>
        </FrameLayout>
        <TextView
            android:textSize="15.33sp"
            android:textColor="#000000"
            android:gravity="center"
            android:id="@+id/reading__app_ad_view__download"
            android:background="@drawable/general__shared__rounded_button_yellow"
            android:layout_width="216.67dp"
            android:layout_height="40dp"
            android:layout_marginTop="16.67dp"
            android:layout_marginBottom="26.67dp"
            android:text="@string/general__shared__click_download"/>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_ad_slide_tip"
        style="@style/reading__bottom_slide_click_tip_in_framelayout"/>
</FrameLayout>
