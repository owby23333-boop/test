<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@android:color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/tt_webview_container"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <include layout="@layout/tt_activity_landing_backup"/>
            <com.bytedance.sdk.openadsdk.widget.PlayableLoadingView
                android:id="@+id/tt_playable_loading"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:id="@+id/tt_playable_video_container"
                android:background="@color/tt_transparent"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <com.bytedance.sdk.openadsdk.core.playable.PlayableVideoContainer
                    android:layout_gravity="top|right"
                    android:id="@+id/tt_playable_video_container_vertical"
                    android:background="@color/tt_transparent"
                    android:visibility="gone"
                    android:layout_width="73dp"
                    android:layout_height="130dp"
                    android:layout_marginTop="55dp"
                    android:layout_marginEnd="30dp"/>
                <com.bytedance.sdk.openadsdk.core.playable.PlayableVideoContainer
                    android:layout_gravity="top|right"
                    android:id="@+id/tt_playable_video_container_horizontal"
                    android:background="@color/tt_transparent"
                    android:visibility="gone"
                    android:layout_width="156dp"
                    android:layout_height="87dp"
                    android:layout_marginTop="55dp"
                    android:layout_marginEnd="20dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/tt_playable_top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.bytedance.sdk.openadsdk.widget.ShadowImageView
                    android:gravity="center"
                    android:id="@+id/tt_playable_ad_mute"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/tt_unmute"
                    android:scaleType="center"
                    android:layout_marginStart="12dp"/>
                <com.bytedance.sdk.openadsdk.widget.ShadowTextView
                    android:textSize="14sp"
                    android:textColor="@color/tt_white"
                    android:gravity="center"
                    android:layout_gravity="end|top"
                    android:id="@+id/tt_playable_ad_dislike"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="80dp"
                    android:text="@string/tt_reward_feedback"
                    android:layout_marginEnd="80dp"/>
                <com.bytedance.sdk.openadsdk.widget.ShadowTextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:layout_gravity="end|top"
                    android:id="@+id/tt_playable_ad_count_down"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginEnd="16dp"/>
                <RelativeLayout
                    android:gravity="center"
                    android:layout_gravity="end|top"
                    android:id="@+id/tt_playable_ad_close_layout"
                    android:background="@drawable/tt_mute_btn_bg"
                    android:visibility="gone"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="24dp"
                    android:layout_marginEnd="24dp">
                    <ImageView
                        android:id="@+id/tt_playable_ad_close"
                        android:visibility="visible"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/tt_video_close_drawable"/>
                </RelativeLayout>
            </FrameLayout>
        </FrameLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:id="@+id/tt_pl_pre_5element_container"
            android:background="#161823"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"/>
    </LinearLayout>
</FrameLayout>
