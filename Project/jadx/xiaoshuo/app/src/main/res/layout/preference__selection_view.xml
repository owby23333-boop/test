<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="@dimen/general__shared_dimen__14sp"
        android:textColor="@color/general__day_night__801f1f1f"
        android:layout_gravity="right"
        android:id="@+id/preference__selection_view__skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__66_67dp"
        android:text="@string/preference__selection_view__skip"
        android:drawableEnd="@drawable/preference__selection_view__arrow_right"
        android:layout_marginEnd="@dimen/general__shared_dimen__19dp"/>
    <TextView
        android:textSize="@dimen/view_dimen_80"
        android:textColor="@color/general__day_night__1f2126"
        android:layout_gravity="center"
        android:id="@+id/preference__selection_view__title_first_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_90"
        android:text="@string/preference__selection_view__title_setting_preference"/>
    <TextView
        android:textSize="@dimen/view_dimen_80"
        android:textColor="@color/general__day_night__1f2126"
        android:layout_gravity="center"
        android:id="@+id/preference__selection_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/general__shared_dimen__4_33dp"
        android:text="@string/preference__selection_view__title"/>
    <TextView
        android:textSize="@dimen/view_dimen_50"
        android:textColor="@color/general__day_night__801f2126"
        android:layout_gravity="center"
        android:id="@+id/preference__selection_view__sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_120"
        android:text="@string/preference__selection_view__sub_title_preference"/>
    <include
        android:id="@+id/personal__setting_store_pref_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        layout="@layout/personal__setting_store_pref_content"/>
</androidx.appcompat.widget.LinearLayoutCompat>
