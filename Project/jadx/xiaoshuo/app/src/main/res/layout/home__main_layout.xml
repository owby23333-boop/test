<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:background="@color/general__day_night__ffffff_212121"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/home__main_layout__tab_store"/>
    <com.duokan.reader.main.home.ExtendTextView
        android:textColor="@color/general__day_night__4d4d4d_selected"
        android:gravity="center"
        android:id="@+id/home__main_layout__tab_store"
        android:text="@string/general__shared__store"
        android:drawableTop="@drawable/surfing__surfing_navigate_view__store"
        android:layout_marginStart="@dimen/view_dimen_99"
        app:imageSize="@dimen/general__shared_dimen__23_33dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/home__main_layout__tab_category"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/youth__main_layout__tab_text"/>
    <com.duokan.reader.main.home.ExtendTextView
        android:textColor="@color/general__day_night__4d4d4d_selected"
        android:gravity="center"
        android:id="@+id/home__main_layout__tab_category"
        android:text="@string/general__shared__category"
        android:drawableTop="@drawable/surfing__surfing_navigate_view__category"
        app:imageSize="@dimen/general__shared_dimen__23_33dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/home__main_layout__tab_shelf"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/home__main_layout__tab_store"
        style="@style/youth__main_layout__tab_text"/>
    <com.duokan.reader.main.home.ExtendTextView
        android:textColor="@color/general__day_night__4d4d4d_selected"
        android:gravity="center"
        android:id="@+id/home__main_layout__tab_shelf"
        android:text="@string/general__shared__bookshelf"
        android:drawableTop="@drawable/surfing__surfing_navigate_view__bookshelf"
        app:imageSize="@dimen/general__shared_dimen__23_33dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/home__main_layout__tab_personal"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/home__main_layout__tab_category"
        style="@style/youth__main_layout__tab_text"/>
    <com.duokan.reader.main.home.ExtendTextView
        android:textColor="@color/general__day_night__4d4d4d_selected"
        android:gravity="center"
        android:id="@+id/home__main_layout__tab_personal"
        android:text="@string/general__shared__personal"
        android:drawableTop="@drawable/surfing__surfing_navigate_view__personal"
        android:layout_marginEnd="@dimen/view_dimen_99"
        app:imageSize="@dimen/general__shared_dimen__23_33dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/home__main_layout__tab_shelf"
        style="@style/youth__main_layout__tab_text"/>
    <FrameLayout
        android:id="@+id/home__main_layout__tab_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/home__main_layout__tab_store"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/home__main_layout__shadow_bottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared_dimen__30dp"
        app:layout_constraintBottom_toBottomOf="@+id/home__main_layout__tab_content"/>
</androidx.constraintlayout.widget.ConstraintLayout>
