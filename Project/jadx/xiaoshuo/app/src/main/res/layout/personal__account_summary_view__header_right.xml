<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/personal__home_title_view__settings"
    android:paddingRight="10dp"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="center"
        android:layout_width="35dp"
        android:layout_height="match_parent"
        android:src="@drawable/personal__account_summary_view__settings"
        android:scaleType="center"/>
    <ImageView
        android:layout_gravity="top|right"
        android:id="@+id/personal__home_title_view__unread_feedback_count_image"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginRight="3dp"
        android:src="@drawable/bookshelf__header_view__have_new_message"/>
</FrameLayout>
