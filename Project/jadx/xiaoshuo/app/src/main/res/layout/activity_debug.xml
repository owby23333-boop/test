<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__f8f8f8_000000"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/developer_options_view_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:id="@+id/personal__personal_settings_view__scrollerview"
        android:background="@color/general__day_night__f8f8f8_000000"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:background="@color/general__day_night__ffffff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__text__day_night__666666"
                android:gravity="center"
                android:background="@color/general__day_night__f8f8f8_1c1c1c"
                android:paddingLeft="15dp"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="通用"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/pref_developer_options"
                android:layout_width="match_parent"
                android:layout_height="63dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp">
                        <com.duokan.reader.ui.general.DkLabelView
                            android:textSize="@dimen/general_font__shared__c"
                            android:textColor="@color/general__text__day_night__333333"
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="开发者选项"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__switch"/>
                </FrameLayout>
            </LinearLayout>
            <include layout="@layout/general__divider_1px_margin_15dp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/pref_caught_options"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="63dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp">
                        <com.duokan.reader.ui.general.DkLabelView
                            android:textSize="@dimen/general_font__shared__c"
                            android:textColor="@color/general__text__day_night__333333"
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="允许抓包"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__switch"/>
                </FrameLayout>
            </LinearLayout>
            <include layout="@layout/general__divider_1px_margin_15dp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/pref_allow_persist_log"
                android:layout_width="match_parent"
                android:layout_height="63dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="63dp">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp">
                        <com.duokan.reader.ui.general.DkLabelView
                            android:textSize="@dimen/general_font__shared__c"
                            android:textColor="@color/general__text__day_night__333333"
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="保存日志到本地"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="15dp"
                        android:src="@drawable/general__shared__switch"/>
                </FrameLayout>
            </LinearLayout>
            <include layout="@layout/general__divider_1px_margin_15dp"/>
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__t1"
                android:textColor="@color/general__text__day_night__333333"
                android:gravity="center"
                android:id="@+id/pref_dev_opt_key_mock_fc"
                android:layout_width="match_parent"
                android:layout_height="63dp"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:text="模拟崩溃"
                android:drawableRight="@drawable/general__shared__more_selector"/>
            <include layout="@layout/general__divider_1px_margin_15dp"/>
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__t1"
                android:textColor="@color/general__text__day_night__333333"
                android:gravity="center"
                android:id="@+id/pref_dev_opt_key_dump_traffic"
                android:layout_width="match_parent"
                android:layout_height="63dp"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:text="生成流量统计"
                android:drawableRight="@drawable/general__shared__more_selector"/>
            <include layout="@layout/general__divider_1px"/>
        </LinearLayout>
    </com.duokan.core.ui.LinearScrollView>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__t5"
        android:textColor="@color/general__day_night__9ca0a8"
        android:gravity="start|top"
        android:id="@+id/pref_dev_device_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/search__main_view__vertical_gap"
        android:textIsSelectable="true"/>
</LinearLayout>
