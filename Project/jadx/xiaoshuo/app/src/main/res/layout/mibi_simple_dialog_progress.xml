<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/mipay_progress_dialog_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:layout_alignParentBottom="true">
        <ImageView
            android:id="@+id/progress_circle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/mibi_progressbar_circle_light"
            android:layout_marginStart="15dp"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/mipay_text_color_black"
            android:id="@+id/mibi_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mibi_loading"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</RelativeLayout>
