<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__a"
            android:id="@+id/reading__chapter_not_purchased_view__name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__b"
            android:ellipsize="end"
            android:gravity="fill"
            android:id="@+id/reading__chapter_not_purchased_view__tip"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <View
        android:id="@+id/reading__chapter_not_purchased_view__divider"
        android:layout_width="1px"
        android:layout_height="match_parent"
        android:layout_marginTop="25dp"
        android:layout_marginBottom="25dp"/>
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/reading__chapter_not_purchased_view__login_or_buy"
            android:background="@drawable/general__shared__rounded_button_orange"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="150dp"/>
        <com.duokan.reader.ui.reading.ChapterNotPurchasedContainerView
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/reading__chapter_not_purchased_view__server_info"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
</LinearLayout>
