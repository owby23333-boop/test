<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#a6000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/general__shortcut_guide_controller__bg"
        android:layout_width="158dp"
        android:layout_height="263dp"
        android:src="@drawable/reading__add_book_to_launcher_controller__bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/general__shortcut_guide_controller__book_cover"
        android:layout_width="30dp"
        android:layout_height="40dp"
        android:layout_marginLeft="26dp"
        android:layout_marginTop="26dp"
        app:layout_constraintLeft_toLeftOf="@+id/general__shortcut_guide_controller__bg"
        app:layout_constraintTop_toTopOf="@+id/general__shortcut_guide_controller__bg"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="7.6dp"
        android:layout_marginTop="112dp"
        android:src="@drawable/general__shortcut_guide_controller__launch_guide"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/general__shortcut_guide_controller__bg"/>
    <TextView
        android:textSize="6sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/general__shortcut_guide_controller__book_title"
        android:layout_width="54dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="78dp"
        app:layout_constraintLeft_toLeftOf="@+id/general__shortcut_guide_controller__book_cover"
        app:layout_constraintRight_toRightOf="@+id/general__shortcut_guide_controller__book_cover"
        app:layout_constraintTop_toTopOf="@+id/general__shortcut_guide_controller__bg"/>
    <TextView
        android:textSize="9sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/general__shortcut_guide_controller__ok"
        android:background="@drawable/common_dialog_ok_btn_reader_bg"
        android:layout_width="79.2dp"
        android:layout_height="24dp"
        android:layout_marginBottom="14dp"
        android:text="@string/general__shortcut_guide_controller__ok"
        app:layout_constraintBottom_toBottomOf="@+id/general__shortcut_guide_controller__bg"
        app:layout_constraintLeft_toLeftOf="@+id/general__shortcut_guide_controller__bg"
        app:layout_constraintRight_toRightOf="@+id/general__shortcut_guide_controller__bg"/>
</androidx.constraintlayout.widget.ConstraintLayout>
