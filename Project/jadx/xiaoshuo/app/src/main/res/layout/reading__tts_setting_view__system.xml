<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:paddingLeft="15dp"
        android:paddingTop="16dp"
        android:paddingRight="15dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__c6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__tts_setting_view__system"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true">
            <CheckBox
                android:enabled="true"
                android:layout_gravity="center"
                android:id="@+id/reading__tts_setting_view__system_status"
                android:focusable="false"
                android:visibility="invisible"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:button="@drawable/general__shared__multi_checkbox_gray"/>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__c1"
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__tts_setting_view__system_select"
                android:background="@drawable/reading__tts_settings_button_orange_bg"
                android:paddingLeft="15dp"
                android:paddingTop="6dp"
                android:paddingRight="15dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__tts_setting_view__use"/>
        </FrameLayout>
    </RelativeLayout>
    <View
        android:background="@color/general__shared__e9e9e9"
        android:layout_width="match_parent"
        android:layout_height="10dp"/>
</LinearLayout>
