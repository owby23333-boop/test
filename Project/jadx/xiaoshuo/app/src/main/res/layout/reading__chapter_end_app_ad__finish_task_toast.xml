<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/reading__chapter_end_app_ad__finish_task_bg"
        android:background="@color/black_60_transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_gravity="bottom"
        android:id="@+id/reading__chapter_end_ad__task__content"
        android:background="@drawable/reading__chapter_end_app_ad__finish_task_front_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/reading__chapter_end_ad__task_coin"
            android:layout_width="@dimen/view_dimen_455"
            android:layout_height="@dimen/view_dimen_266"
            android:layout_marginTop="@dimen/view_dimen_12"
            android:src="@drawable/reading__chapter_end_app_ad__task_coin_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/general__333333"
            android:id="@+id/reading__chapter_end_app_ad__finish_task_coin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_45"
            android:text="@string/reading__chapter_end_app_ad__finish_task_coin_text"
            app:layout_constraintEnd_toStartOf="@+id/reading__chapter_end_app_ad__finish_task_coin_num"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_ad__task_coin"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/general__333333"
            android:id="@+id/reading__chapter_end_app_ad__finish_task_coin_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_45"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/reading__chapter_end_app_ad__finish_task_coin"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_ad__task_coin"/>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/general__333333"
            android:gravity="center"
            android:id="@+id/reading__chapter_end_app_ad__finish_task_btn"
            android:background="@drawable/reading__chapter_end_app_ad__finish_task_button_bg"
            android:layout_width="@dimen/view_dimen_920"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/view_dimen_120"
            android:layout_marginBottom="@dimen/view_dimen_80"
            android:text="@string/reading__chapter_end_app_ad__finish_task_button_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_app_ad__finish_task_coin_num"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
