<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#b3000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/bookshelf__discount_book_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="128dp"
        android:src="@drawable/bookshelf__discount_book_image_hint"/>
    <ImageView
        android:id="@+id/bookshelf__discount_book_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:src="@drawable/bookshelf__discount_hint_btn"
        android:layout_alignBottom="@+id/bookshelf__discount_book_image"
        android:layout_marginEnd="15dp"
        android:layout_alignEnd="@+id/bookshelf__discount_book_image"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="-60dp"
        android:src="@drawable/bookshelf__discount_point_image_hint"
        android:layout_toRightOf="@+id/bookshelf__discount_book_image"
        android:layout_below="@+id/bookshelf__discount_book_image"/>
    <TextView
        android:textSize="19sp"
        android:textColor="@color/general__shared__f8f8f8"
        android:gravity="center"
        android:id="@+id/bookshelf__discount_hint_btn"
        android:background="@drawable/bookshelf__bookshelf_discount_hint_btn_bg"
        android:layout_width="180dp"
        android:layout_height="37dp"
        android:layout_marginBottom="70dp"
        android:text="我知道了"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
