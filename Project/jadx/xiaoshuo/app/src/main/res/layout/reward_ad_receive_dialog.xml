<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/general__shared_dimen__32_33dp"
    android:layout_marginEnd="@dimen/general__shared_dimen__32_33dp"
    app:cardCornerRadius="@dimen/view_dimen_60">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/dkcommon__fff6dd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/view_dimen_884">
        <ImageView
            android:id="@+id/iv_top_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_486"
            android:src="@drawable/reward_ad_get_dialog_bg"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="@dimen/view_dimen_108"
            android:layout_height="@dimen/view_dimen_108"
            android:src="@drawable/reward_ad_dialog_close"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_60"
            android:textStyle="bold"
            android:textColor="@color/dkcommon__7e451b"
            android:id="@+id/tv_title1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_60"
            android:layout_marginTop="@dimen/view_dimen_176"
            android:text="@string/reward_ad_receive_dialog_receive_hint"
            android:layout_marginStart="@dimen/view_dimen_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_144"
            android:textStyle="bold"
            android:textColor="@color/dkcommon__f44127"
            android:gravity="bottom|left"
            android:id="@+id/reward_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_60"
            android:layout_marginTop="@dimen/view_dimen_12_minus"
            android:text="@string/reward_ad_receive_dialog_receive_time"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_title1"/>
        <TextView
            android:textSize="@dimen/view_dimen_36"
            android:textColor="@color/dkcommon__f44127"
            android:gravity="left"
            android:layout_gravity="center"
            android:id="@+id/tv_reward_total_time_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_528"
            android:text="@string/reward_ad_receive_dialog_receive_time_unit"
            app:layout_constraintBaseline_toBaselineOf="@+id/reward_time"
            app:layout_constraintBottom_toBottomOf="@+id/reward_time"
            app:layout_constraintStart_toEndOf="@+id/reward_time"/>
        <TextView
            android:textSize="@dimen/view_dimen_39"
            android:textColor="@color/general__000000_60"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_reward_max_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_48"
            android:layout_marginBottom="@dimen/view_dimen_48"
            app:layout_constraintBottom_toTopOf="@+id/iv_get_more_reward"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_top_bg"/>
        <ImageView
            android:id="@+id/iv_get_more_reward"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_156"
            android:layout_marginBottom="@dimen/view_dimen_60"
            android:src="@drawable/reward_ad_dialog_btn_bg"
            android:scaleType="centerCrop"
            android:layout_marginHorizontal="@dimen/view_dimen_72"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_51"
            android:textStyle="bold"
            android:textColor="@color/color_white"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reward_ad_receive_dialog_get_more_reward"
            app:layout_constraintBottom_toBottomOf="@+id/iv_get_more_reward"
            app:layout_constraintTop_toTopOf="@+id/iv_get_more_reward"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
