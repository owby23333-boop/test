<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/general__free_dialog_box__bg"
    android:paddingTop="@dimen/view_dimen_80"
    android:paddingBottom="@dimen/view_dimen_80"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_font_size_50"
        android:textStyle="bold"
        android:textColor="@color/general__day_night__000000"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_relay_dialog_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__day_night__000000_80"
        android:id="@+id/tv_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_50"
        android:text="@string/app_relay_different_account_tip_desc"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:src="@drawable/general__app_relay_different_account_tip"
        android:scaleType="fitXY"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/tv_desc"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__ffffff"
        android:gravity="center"
        android:id="@+id/tv_agree"
        android:background="@drawable/bg_youth_agree_button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_42"
        android:text="@string/app_relay_dialog_ok"
        android:layout_marginHorizontal="@dimen/view_dimen_80"
        app:layout_constraintTop_toBottomOf="@+id/iv_desc"/>
</androidx.constraintlayout.widget.ConstraintLayout>
