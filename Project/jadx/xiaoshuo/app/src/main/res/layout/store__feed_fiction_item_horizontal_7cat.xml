<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/store__feed_horizontal_fiction_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="0dp"
    android:layout_marginBottom="@dimen/view_dimen_60"
    android:layout_marginStart="@dimen/view_dimen_56"
    android:layout_marginEnd="@dimen/view_dimen_56"
    style="@style/store__shared__list_item">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/store__feed_book_common_cover"
        android:background="@color/general__day_night__f2f2f2_2a2a2a"
        android:layout_width="@dimen/store__feed_fiction_cover_width_single"
        android:layout_height="@dimen/store__feed_fiction_cover_height_single"
        android:scaleType="fitXY"
        android:radius="@dimen/general__shared_dimen__4dp"
        app:shapeAppearance="@style/RoundCorner12"/>
    <TextView
        android:textSize="@dimen/general_font__shared__e"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/store__feed_book_common_label"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/store__feed_book_vip_width"
        android:singleLine="true"
        android:layout_alignTop="@+id/store__feed_book_common_cover"
        android:layout_alignRight="@+id/store__feed_book_common_cover"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"/>
    <ImageView
        android:id="@+id/store__feed_book_common_img"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="center"
        android:radius="@dimen/general__shared_dimen__4dp"/>
    <TextView
        android:textSize="15.34dp"
        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_title"
        android:layout_width="@dimen/view_dimen_528"
        android:layout_height="@dimen/view_dimen_61"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_toRightOf="@+id/store__feed_book_common_cover"
        android:layout_marginStart="@dimen/view_dimen_30"
        android:layout_marginEnd="@dimen/view_dimen_52"
        app:layout_constraintHorizontal_bias="0"/>
    <TextView
        android:textSize="@dimen/view_dimen_38"
        android:textColor="@color/store__day_night__FF7433"
        android:id="@+id/store__feed_book_score_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/store__feed_book_score_unit"
        android:layout_alignBottom="@+id/store__feed_book_score"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="@dimen/view_dimen_38"
        android:textStyle="bold"
        android:textColor="@color/store__day_night__FF7433"
        android:id="@+id/store__feed_book_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_toLeftOf="@+id/store__feed_book_score_tv"
        android:layout_alignBaseline="@+id/store__feed_book_common_title"/>
    <TextView
        android:textSize="@dimen/view_dimen_34"
        android:textColor="@color/general__day_night__000000_40"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_summary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_90"
        android:layout_marginTop="@dimen/view_dimen_28"
        android:layout_marginRight="@dimen/view_dimen_56"
        android:maxLines="2"
        android:includeFontPadding="false"
        android:layout_below="@+id/store__feed_book_common_title"
        android:layout_alignStart="@+id/store__feed_book_common_title"/>
    <ImageView
        android:id="@+id/store__feed_book_dislike"
        android:paddingTop="@dimen/view_dimen_8"
        android:paddingBottom="@dimen/view_dimen_8"
        android:visibility="gone"
        android:layout_width="@dimen/view_dimen_101"
        android:layout_height="@dimen/view_dimen_51"
        android:layout_marginTop="@dimen/view_dimen_25"
        android:src="@drawable/store__feed_book_dislike_bg"
        android:layout_below="@+id/store__feed_book_common_summary"
        android:layout_alignParentRight="true"
        android:paddingStart="@dimen/view_dimen_50"/>
    <com.duokan.reader.ui.store.adapter.DrawableView
        android:id="@+id/store__feed_flow_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_48"
        android:layout_marginTop="@dimen/view_dimen_26"
        android:layout_toLeftOf="@+id/store__feed_book_dislike"
        android:layout_toRightOf="@+id/store__feed_book_common_cover"
        android:layout_below="@+id/store__feed_book_common_summary"
        android:layout_alignStart="@+id/store__feed_book_common_title"
        app:maxLineCount="1"/>
    <FrameLayout
        android:id="@+id/store__feed_guess_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_45"
        android:layout_below="@+id/store__feed_book_common_cover"/>
</RelativeLayout>
