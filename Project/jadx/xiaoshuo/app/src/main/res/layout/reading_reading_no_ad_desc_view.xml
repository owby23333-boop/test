<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reading_reading_no_ad_desc_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/reading__reading_no_ad_desc_bg"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="218.3dp">
        <TextView
            android:textSize="16.7sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7.7dp"
            android:text="@string/reading__shared__reward_video_desc_without_line"/>
        <TextView
            android:textSize="15.3sp"
            android:textColor="#b3000000"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="13.7dp"
            android:layout_marginBottom="13.7dp"
            android:text="@string/reading__shared__reward_video_desc_info"
            android:layout_weight="1"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"/>
        <TextView
            android:textSize="15.3sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:id="@+id/reading_reading_no_ad_desc_view_i_know"
            android:background="@drawable/reading__reading_no_ad_desc_i_konw_bg"
            android:layout_width="match_parent"
            android:layout_height="46.7dp"
            android:layout_marginBottom="23.3dp"
            android:text="@string/reading__shared__reward_video_desc_i_know"
            android:layout_marginStart="26.7dp"
            android:layout_marginEnd="26.7dp"/>
    </LinearLayout>
</FrameLayout>
