<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tt_reward_draw_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/tt_reward_draw_item_video_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:id="@+id/tt_reward_draw_item_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <FrameLayout
            android:id="@+id/tt_reward_draw_item_video_backup"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/tt_reward_draw_item_backup"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@+id/tt_reward_draw_item_dynamic"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.bytedance.sdk.openadsdk.widget.TTProgressBar
        android:layout_gravity="center"
        android:id="@+id/tt_reward_draw_item_progress"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminate="true"
        android:indeterminateDrawable="@drawable/tt_video_loading_progress_bar"
        android:progressDrawable="@drawable/tt_video_loading_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"/>
</FrameLayout>
