<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4.3dp"
    style="@style/store__shared__list_item">
    <LinearLayout
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/store_feed_new_user__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/store__feed_book_new_user"
            android:drawablePadding="5dp"
            android:drawableStart="@drawable/store__center_title_line"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/store_feed_new_user__month"
            android:background="@drawable/store_feed_new_user__time_background"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/store_feed_new_user__day"
            android:background="@drawable/store_feed_new_user__time_background"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/store__center_title_line"
            android:scaleType="center"
            android:layout_marginStart="5dp"/>
    </LinearLayout>
</FrameLayout>
