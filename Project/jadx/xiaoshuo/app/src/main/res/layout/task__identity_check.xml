<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/task__identity_check__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/task__identity_check__header"
        android:paddingStart="@dimen/view_dimen_80"
        android:paddingEnd="@dimen/view_dimen_80">
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/general__text__day_night__4d4d4d_b3ffffff"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="47.3dp"
            android:text="@string/task__identity_check__title"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/task__identity_check__divider"
            android:showDividers="end|middle">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="47.3dp"
                android:paddingStart="@dimen/view_dimen_8">
                <TextView
                    android:textSize="@dimen/text_font_size_44"
                    android:textStyle="normal"
                    android:textColor="@color/general__day_night__000000_ffffff"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task__identity_check__name"/>
                <EditText
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__000000_ffffff"
                    android:textColorHint="#cccccc"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/task__identity_check__name"
                    android:background="@android:color/transparent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="80dp"
                    android:hint="@string/task__identity_check__name_hint"
                    android:maxLines="1"
                    android:layout_weight="1"/>
            </FrameLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="47.3dp"
                android:paddingStart="@dimen/view_dimen_8">
                <TextView
                    android:textSize="@dimen/text_font_size_44"
                    android:textStyle="normal"
                    android:textColor="@color/general__day_night__000000_ffffff"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task__identity_check__id"/>
                <EditText
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__000000_ffffff"
                    android:textColorHint="#cccccc"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/task__identity_check__id"
                    android:background="@android:color/transparent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="80dp"
                    android:hint="@string/task__identity_check__id_hint"
                    android:maxLines="1"
                    android:layout_weight="1"/>
            </FrameLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textColor="@drawable/task_identity_check_next_selector"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/task__identity_check__submit"
            android:background="@drawable/bookshelf__bottom_delete_btn_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/view_dimen_80"
            android:text="@string/task__identity_check__submit"/>
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/general__text__day_night__4d4d4d_b3ffffff"
            android:id="@+id/task__identity_check__announcement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_48"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </com.duokan.core.ui.LinearScrollView>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/task__identity_check__submit_agreement_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_200"
        android:layout_alignParentBottom="true"
        android:keepScreenOn="true">
        <CheckBox
            android:theme="@style/IdentityCheck.CheckBox"
            android:id="@+id/task__identity_check__submit_agreement_check"
            android:background="@drawable/free_btn_checkbox_style_normal_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/general__day_night__000000_40_ffffff_90"
            android:id="@+id/task__identity_check_agreement_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task__identity_check__agreement_tip"
            android:layout_marginStart="@dimen/view_dimen_22"/>
    </LinearLayout>
</RelativeLayout>
