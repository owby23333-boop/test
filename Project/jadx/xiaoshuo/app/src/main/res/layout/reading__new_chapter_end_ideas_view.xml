<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/reading__chapter_end_ideas_view__background"
    android:paddingTop="@dimen/general__shared_dimen__16_67dp"
    android:paddingBottom="@dimen/general__shared_dimen__16_67dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/general__shared_dimen__18_7dp"
    android:paddingEnd="@dimen/general__shared_dimen__18_7dp">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general__shared_dimen__15_33sp"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__1f2126"
            android:id="@+id/reading__chapter_idea_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/reading__chapter_idea_title"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10_67sp"
            android:textColor="@color/general__day_night__626366_2"
            android:layout_gravity="center"
            android:id="@+id/reading__chapter_end_ideas__more_ideas_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__chapter_end_ideas_view__more"
            android:drawablePadding="@dimen/general__shared_dimen__3_33dp"
            android:drawableEnd="@drawable/reading__chapter_end_ideas_view__more_icon"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/reading__chapter_end_ideas_view__ideas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/reading__new_idea__view_base_edit_layout"
        android:background="@drawable/reading__new_idea_present_view__edittext_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__16_67dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__idea_present_view__anchor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__6dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__6dp"
            android:src="@drawable/reading__new_idea_present_view__idea_editor_anchor"
            android:contentDescription="@null"
            android:layout_marginStart="@dimen/general__shared_dimen__10dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__3_33dp"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__12_67sp"
            android:textColor="@color/general__day_night__abaeb3"
            android:textColorHint="@color/general__day_night__abaeb3"
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__idea_present_view__edittext"
            android:background="@null"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_menu_bottom_view__idea_editor_hint"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
