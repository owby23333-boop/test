<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="bottom"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/view_dimen_48">
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textColor="@color/white_80_transparent"
            android:id="@+id/tv_chapter_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:textFontWeight="450"/>
        <TextView
            android:textSize="@dimen/text_font_size_39"
            android:textColor="@color/white_80_transparent"
            android:id="@+id/tv_current_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_36"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/text_font_size_39"
            android:textColor="@color/white_40_transparent"
            android:id="@+id/tv_next_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_12"
            android:singleLine="true"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_72"
        android:layout_marginHorizontal="@dimen/view_dimen_48">
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_text_color"
            android:gravity="center"
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:text="@string/reading__tts_menu_view__timer"
            android:drawableTop="@drawable/ic_tts_player_timer_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_speed"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_text_color"
            android:gravity="center"
            android:id="@+id/tv_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:drawableTop="@drawable/ic_tts_player_speed_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_comment"
            app:layout_constraintStart_toEndOf="@+id/tv_timer"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_text_color"
            android:gravity="center"
            android:id="@+id/tv_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:text="@string/reading__reading_menu_top_book_comment"
            android:drawableTop="@drawable/ic_tts_player_comment_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_read"
            app:layout_constraintStart_toEndOf="@+id/tv_speed"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_text_color"
            android:gravity="center"
            android:id="@+id/tv_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:text="@string/reading__tts_go_to_detail"
            android:drawableTop="@drawable/ic_tts_player_read_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_comment"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/ll_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_84"
        android:layout_marginHorizontal="@dimen/view_dimen_48">
        <ImageButton
            android:id="@+id/ib_rewind"
            android:background="@color/transparent"
            android:padding="@dimen/view_dimen_12"
            android:layout_width="@dimen/view_dimen_108"
            android:layout_height="@dimen/view_dimen_108"
            android:src="@drawable/ic_tts_player_rewind_selector"
            android:scaleType="centerInside"
            android:contentDescription="@string/reading__tts_player_rewind"/>
        <com.duokan.reader.ui.reading.tts.TextThumbSeekBar
            android:id="@+id/sb_process"
            android:layout_width="0dp"
            android:layout_height="@dimen/view_dimen_84"
            android:max="1000"
            android:progressDrawable="@drawable/reading__tts_seekbar_progress_bg"
            android:thumb="@drawable/reading__tts_seek_bar_thumb"
            android:thumbOffset="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="0dp"
            app:tickMark="@null"/>
        <ImageButton
            android:id="@+id/ib_forward"
            android:background="@color/transparent"
            android:padding="@dimen/view_dimen_12"
            android:layout_width="@dimen/view_dimen_108"
            android:layout_height="@dimen/view_dimen_108"
            android:src="@drawable/ic_tts_player_forward_selector"
            android:scaleType="centerInside"
            android:contentDescription="@string/reading__tts_player_forward"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_player_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_84"
        android:layout_marginHorizontal="@dimen/view_dimen_48">
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_text_color"
            android:gravity="center"
            android:id="@+id/tv_toc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:text="@string/reading__reading_menu_view__navigation"
            android:drawableTop="@drawable/ic_tts_player_toc_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ib_prev"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageButton
            android:id="@+id/ib_prev"
            android:background="@color/transparent"
            android:layout_width="@dimen/view_dimen_84"
            android:layout_height="@dimen/view_dimen_84"
            android:src="@drawable/ic_tts_player_prev_selector"
            android:contentDescription="@string/reading__seek_page_view__prev_chapter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ib_play"
            app:layout_constraintStart_toEndOf="@+id/tv_toc"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageButton
            android:id="@+id/ib_play"
            android:background="@color/transparent"
            android:layout_width="@dimen/view_dimen_162"
            android:layout_height="@dimen/view_dimen_162"
            android:src="@drawable/ic_tts_player_play_selector"
            android:contentDescription="@string/audio__abk_view_play"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ib_next"
            app:layout_constraintStart_toEndOf="@+id/ib_prev"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageButton
            android:id="@+id/ib_next"
            android:background="@color/transparent"
            android:layout_width="@dimen/view_dimen_84"
            android:layout_height="@dimen/view_dimen_84"
            android:src="@drawable/ic_tts_player_next_selector"
            android:contentDescription="@string/reading__seek_page_view__next_chapter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_bookshelf"
            app:layout_constraintStart_toEndOf="@+id/ib_play"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:enabled="false"
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/reading_tts_player_bookshelf_text_color"
            android:gravity="center"
            android:id="@+id/tv_bookshelf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/view_dimen_136"
            android:text="@string/reading_add_shelf"
            android:drawableTop="@drawable/ic_tts_player_bookshelf_selector"
            android:drawablePadding="@dimen/view_dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ib_next"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="horizontal"
        android:id="@+id/ll_current_speaker"
        android:background="@drawable/reading__tts_speaker_picker_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginTop="@dimen/view_dimen_84"
        android:paddingStart="@dimen/view_dimen_48"
        android:paddingEnd="@dimen/view_dimen_48"
        android:layout_marginHorizontal="@dimen/view_dimen_48">
        <TextView
            android:textSize="@dimen/text_font_size_39"
            android:textColor="@color/white_80_transparent"
            android:id="@+id/tv_speaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/reading__tts_speaker_arrow"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
