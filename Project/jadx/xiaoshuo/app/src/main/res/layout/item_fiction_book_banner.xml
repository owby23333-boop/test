<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_banner"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/BookBannerStyle"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__16sp"
        android:textColor="@color/general__text__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/tv_banner_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="@+id/iv_banner"
        app:layout_constraintStart_toStartOf="@+id/iv_banner"
        app:layout_constraintTop_toBottomOf="@+id/iv_banner"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:ellipsize="end"
        android:id="@+id/tv_banner_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="@+id/iv_banner"
        app:layout_constraintStart_toStartOf="@+id/iv_banner"
        app:layout_constraintTop_toBottomOf="@+id/tv_banner_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
