<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reading__tts_floating_view"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/reading__tts_float_progress_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.duokan.ui.view.CircleProgressView
            android:id="@+id/reading__tts_float_progress"
            android:layout_width="@dimen/view_dimen_137"
            android:layout_height="@dimen/view_dimen_137"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/reading__tts_cover"
            android:layout_width="@dimen/view_dimen_110"
            android:layout_height="@dimen/view_dimen_110"/>
    </FrameLayout>
    <ImageView
        android:id="@+id/reading__tts_float_play"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/reading__tts_float_play"
        android:layout_marginStart="@dimen/view_dimen_40"/>
    <ImageView
        android:id="@+id/reading__tts_float_close"
        android:paddingTop="@dimen/view_dimen_12"
        android:paddingBottom="@dimen/view_dimen_12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/reading__tts_float_close"
        android:paddingStart="@dimen/view_dimen_12"
        android:paddingEnd="@dimen/view_dimen_40"
        android:layout_marginStart="@dimen/view_dimen_20"/>
</merge>
