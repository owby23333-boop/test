<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.access.StoreAccessBgPrefaceView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/store__access_book_preface_view"
    android:background="@drawable/reading__reading_bg_scene_blue"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__store_book_preface_view__book_cover"
        android:layout_width="@dimen/view_dimen_498"
        android:layout_height="@dimen/view_dimen_703"
        android:layout_marginTop="@dimen/view_dimen_158"
        android:scaleType="centerCrop"
        android:layout_centerHorizontal="true"
        app:radius="@dimen/view_dimen_34"/>
    <com.duokan.reader.ui.AutoFitTextView
        android:textSize="@dimen/text_font_size_60"
        android:textStyle="bold"
        android:textColor="@color/general__day_night__000000_ccffffff"
        android:ellipsize="end"
        android:id="@+id/reading__store_book_preface_view__book_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_50"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_below="@+id/reading__store_book_preface_view__book_cover"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/general__day_night__66000000_66ffffff"
        android:ellipsize="end"
        android:id="@+id/reading__store_book_preface_view__book_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        android:maxWidth="@dimen/view_dimen_1000"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_below="@+id/reading__store_book_preface_view__book_title"
        android:layout_centerHorizontal="true"/>
    <com.duokan.reader.ui.general.FlowLayout
        android:id="@+id/reading__store_book_preface_view__tag_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_75"
        android:layout_below="@+id/reading__store_book_preface_view__book_author"
        android:layout_centerHorizontal="true"
        app:maxLineCount="1"/>
    <RelativeLayout
        android:id="@+id/reading__store_book_preface_view__book_intro_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_63"
        android:layout_below="@+id/reading__store_book_preface_view__tag_layout"
        android:paddingHorizontal="@dimen/view_dimen_124">
        <LinearLayout
            android:id="@+id/reading__store_book_preface_view__score_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/view_dimen_100">
            <LinearLayout
                android:layout_gravity="left"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_font_size_62"
                        android:textStyle="bold"
                        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
                        android:id="@+id/reading__store_book_preface_view__score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_36"
                        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
                        android:id="@+id/reading__store_book_preface_view__score_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/view_dimen_9"
                        android:text="@string/reading__store_book_preface_view__score_tips"
                        android:layout_marginStart="@dimen/view_dimen_8"/>
                </LinearLayout>
                <com.duokan.reader.ui.store.view.StarView
                    android:id="@+id/reading__store_book_preface_view__score_star"
                    android:background="@drawable/reading__store_book_preface_view__star_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/view_dimen_30"
                    android:layout_marginTop="@dimen/view_dimen_12"
                    app:starDrawble="@drawable/reading__store_book_preface_view__star"/>
            </LinearLayout>
            <View
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__store_book_preface_view__separator"
                android:background="@color/general__979797"
                android:layout_width="@dimen/view_dimen_1"
                android:layout_height="@dimen/view_dimen_57"
                android:layout_marginLeft="@dimen/view_dimen_150"
                android:layout_marginRight="@dimen/view_dimen_130"/>
            <LinearLayout
                android:layout_gravity="left"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_font_size_62"
                        android:textStyle="bold"
                        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
                        android:id="@+id/reading__store_book_preface_view__read_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_36"
                        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
                        android:id="@+id/reading__store_book_preface_view__read_num_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/view_dimen_9"
                        android:text="@string/store__fiction_detail_num_tips"
                        android:layout_toRightOf="@+id/reading__store_book_preface_view__read_num"
                        android:layout_alignBottom="@+id/reading__store_book_preface_view__score"
                        android:layout_marginStart="@dimen/view_dimen_8"/>
                </LinearLayout>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__text__day_night__999999"
                    android:id="@+id/reading__store_book_preface_view__read_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/store__fiction_detail_reading"
                    android:layout_below="@+id/reading__store_book_preface_view__read_num"
                    android:layout_alignLeft="@+id/reading__store_book_preface_view__read_num"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_font_size_46"
            android:textColor="@color/general__day_night__000000_ccffffff"
            android:ellipsize="end"
            android:id="@+id/reading__store_book_preface_view__update_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/store_book_preface_view_summary"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_below="@+id/reading__store_book_preface_view__score_container"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/general__text__day_night__666666"
        android:ellipsize="end"
        android:id="@+id/reading__store_book_preface_view__book_intro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/text_font_size_30"
        android:maxLines="3"
        android:layout_below="@+id/reading__store_book_preface_view__book_intro_container"
        android:lineSpacingMultiplier="1.4"
        android:letterSpacing="0.02"
        android:layout_marginHorizontal="@dimen/view_dimen_124"/>
</com.duokan.reader.access.StoreAccessBgPrefaceView>
