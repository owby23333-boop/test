<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/store__search_result_list_horizontal_container"
    android:paddingTop="@dimen/view_dimen_40"
    android:paddingBottom="@dimen/view_dimen_59"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_50"
    android:paddingEnd="@dimen/view_dimen_50">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/store__search_result_list_horizontal__title_container"
        android:paddingBottom="@dimen/view_dimen_58"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/text_font_size_46"
            android:textColor="@color/general__FA5741"
            android:gravity="center"
            android:id="@+id/store__search_result_list_horizontal__search_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="女婿"
            android:includeFontPadding="false"/>
        <TextView
            android:textSize="@dimen/text_font_size_30"
            android:textColor="@color/general__text__day_night__333333"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__search_result_list_horizontal__search_text_category"
            android:background="@drawable/general__shared__button_4dip_f7f7f7"
            android:layout_width="@dimen/view_dimen_110"
            android:layout_height="@dimen/view_dimen_50"
            android:layout_marginLeft="@dimen/view_dimen_20"
            android:layout_marginTop="@dimen/view_dimen_2"
            android:text="分类"
            android:includeFontPadding="false"/>
        <com.duokan.reader.ui.view.FontTextView
            android:textSize="@dimen/text_font_size_50"
            android:textColor="@color/general__text__day_night__333333"
            android:id="@+id/store__search_result_list_horizontal__title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="5dp"/>
        <TextView
            android:textSize="@dimen/text_font_size_34"
            android:textColor="@color/general__text__day_night__999999"
            android:gravity="center_vertical"
            android:id="@+id/store__search_result_list_horizontal__more"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/store__shared__more"
            android:maxLines="2"
            android:includeFontPadding="false"
            android:drawablePadding="@dimen/view_dimen_6"
            android:drawableEnd="@drawable/store__feed_audio_more"/>
    </LinearLayout>
    <include
        android:id="@+id/store__search_result_list_horizontal_item1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/store__search_result_list_horizontal_item2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/store__search_result_list_horizontal__title_container"
        layout="@layout/store__feed_fiction_item_vertical_small"/>
    <include
        android:id="@+id/store__search_result_list_horizontal_item2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/store__search_result_list_horizontal_item3"
        app:layout_constraintStart_toEndOf="@+id/store__search_result_list_horizontal_item1"
        app:layout_constraintTop_toBottomOf="@+id/store__search_result_list_horizontal__title_container"
        layout="@layout/store__feed_fiction_item_vertical_small"/>
    <include
        android:id="@+id/store__search_result_list_horizontal_item3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/store__search_result_list_horizontal_item4"
        app:layout_constraintStart_toEndOf="@+id/store__search_result_list_horizontal_item2"
        app:layout_constraintTop_toBottomOf="@+id/store__search_result_list_horizontal__title_container"
        layout="@layout/store__feed_fiction_item_vertical_small"/>
    <include
        android:id="@+id/store__search_result_list_horizontal_item4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__search_result_list_horizontal_item3"
        app:layout_constraintTop_toBottomOf="@+id/store__search_result_list_horizontal__title_container"
        layout="@layout/store__feed_fiction_item_vertical_small"/>
</androidx.constraintlayout.widget.ConstraintLayout>
