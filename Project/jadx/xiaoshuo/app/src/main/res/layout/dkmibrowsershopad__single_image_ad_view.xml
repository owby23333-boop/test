<?xml version="1.0" encoding="utf-8"?>
<com.duokan.advertisement.ui.ConstraintLayoutEx xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/reading__app_ad_view_click"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.58">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@drawable/general__shared__corner_ad_bg"
            android:paddingLeft="@dimen/view_dimen_42"
            android:paddingTop="@dimen/view_dimen_50"
            android:paddingRight="@dimen/view_dimen_81"
            android:paddingBottom="@dimen/view_dimen_50"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_30"
            android:layout_marginRight="@dimen/view_dimen_30">
            <FrameLayout
                android:id="@+id/reading__single_image_view__container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/reading__single_image_view__image"
                    android:layout_width="@dimen/view_dimen_300"
                    android:layout_height="@dimen/view_dimen_300"
                    android:scaleType="centerCrop"/>
                <ImageView
                    android:layout_gravity="end|bottom"
                    android:id="@+id/dkmibrowsershopad__ad_view_x"
                    android:layout_width="@dimen/view_dimen_77"
                    android:layout_height="@dimen/view_dimen_30"
                    android:layout_marginBottom="@dimen/view_dimen_20"
                    android:src="@drawable/reading__ad_view_close"
                    android:layout_marginEnd="@dimen/view_dimen_20"/>
            </FrameLayout>
            <TextView
                android:textSize="@dimen/text_font_size_48"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="center_vertical"
                android:id="@+id/dkmibrowsershopad__ad_view_summary"
                android:paddingTop="3dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:layout_marginStart="@dimen/view_dimen_40"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/reading__single_image_view__container"
                app:layout_constraintTop_toTopOf="parent"/>
            <include
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/dkmibrowsershopad__ad_view_summary"
                app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_summary"
                layout="@layout/reading__opt_ad_view_info_icon_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <include layout="@layout/dkmibrowsershopad__ad_big_button_view"/>
    </LinearLayout>
</com.duokan.advertisement.ui.ConstraintLayoutEx>
