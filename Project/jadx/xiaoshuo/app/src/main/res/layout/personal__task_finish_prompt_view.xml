<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginLeft="60dp"
    android:layout_marginRight="60dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/personal__task_finish_prompt_view__content"
        android:background="@drawable/personal__task_finish_prompt_view__bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.deprecatedDkTextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__ffffff"
            android:id="@+id/personal__task_finish_prompt_view__label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="40dp"
            android:layout_marginRight="20dp"
            android:maxWidth="170dp"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__ffffff"
            android:gravity="center"
            android:id="@+id/personal__task_finish_prompt_view__award"
            android:background="@drawable/personal__task_finish_prompt_view__award"
            android:paddingLeft="25dp"
            android:paddingTop="3dp"
            android:paddingRight="25dp"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="35dp"
            android:text="@string/personal__task_finish_prompt_view__award"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/personal__task_finish_prompt_view__close"
        android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/personal__task_finish_prompt_view__close"
        android:layout_alignTop="@+id/personal__task_finish_prompt_view__content"
        android:layout_alignRight="@+id/personal__task_finish_prompt_view__content"/>
</RelativeLayout>
