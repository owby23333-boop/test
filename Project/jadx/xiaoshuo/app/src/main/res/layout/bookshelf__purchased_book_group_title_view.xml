<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@+id/bookshelf__purchased_book_group_title_view__layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false">
    <View
        android:id="@+id/bookshelf__purchased_book_group_title_view__top_line"
        android:background="@color/general__shared__bcbcbc"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__666666"
                android:gravity="center"
                android:id="@+id/bookshelf__purchased_book_group_title_view__shown_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="@color/general__shared__666666_pressed"
                android:gravity="center"
                android:id="@+id/bookshelf__purchased_book_group_title_view__edit"
                android:background="@drawable/general__shared__round_btn_2"
                android:paddingLeft="20dp"
                android:paddingTop="10dp"
                android:paddingRight="20dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:text="@string/bookshelf__shared__edit"
                android:singleLine="true"/>
            <FrameLayout
                android:id="@+id/bookshelf__purchased_book_group_title_view__content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@+id/bookshelf__purchased_book_group_title_view__bottom_line"
        android:background="@color/general__shared__bcbcbc"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
