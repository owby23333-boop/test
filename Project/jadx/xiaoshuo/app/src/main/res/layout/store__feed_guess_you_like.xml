<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:background="@drawable/store__feed_guess_like_path"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_16"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__text__day_night__333333"
            android:paddingTop="@dimen/view_dimen_40"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/view_dimen_40"
            android:text="@string/store__feed_guess_like"/>
        <ImageView
            android:layout_width="@dimen/view_dimen_27"
            android:layout_height="@dimen/view_dimen_52"
            android:layout_marginTop="@dimen/view_dimen_33"
            android:src="@drawable/store__feed_guess_like"
            android:scaleType="fitXY"
            android:layout_marginStart="@dimen/view_dimen_20"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_38">
        <include
            android:id="@+id/store__feed_item1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            layout="@layout/store__feed_guess_you_like_item"/>
        <include
            android:id="@+id/store__feed_item2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/view_dimen_138"
            layout="@layout/store__feed_guess_you_like_item"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_38"
        android:layout_marginBottom="@dimen/view_dimen_60">
        <include
            android:id="@+id/store__feed_item3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            layout="@layout/store__feed_guess_you_like_item"/>
        <include
            android:id="@+id/store__feed_item4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/view_dimen_138"
            layout="@layout/store__feed_guess_you_like_item"/>
    </LinearLayout>
    <View
        android:background="@color/general__day_night__ebebeb_2a2a2a"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_1"/>
</LinearLayout>
