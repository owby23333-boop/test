<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground"
    app:layout_constraintVertical_chainStyle="packed"
    style="@style/store__shared__list_item">
    <include
        android:id="@+id/store__feed_book_cover_card"
        android:layout_width="@dimen/store__feed_fiction_cover_width_single"
        android:layout_height="@dimen/store__feed_fiction_cover_height_single"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/store__feed_fiction_card"/>
    <TextView
        android:id="@+id/store__feed_book_common_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/store__share__interval_40"
        app:layout_constraintBottom_toTopOf="@+id/store__feed_book_common_summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_cover_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        style="@style/store__feed_book_title_style"/>
    <TextView
        android:id="@+id/store__feed_book_common_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/store__share__interval_40"
        app:layout_constraintBottom_toTopOf="@+id/store__feed_book_common_author"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_title"
        style="@style/store__feed_book_summary_style"/>
    <TextView
        android:id="@+id/store__feed_book_common_author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLength="15"
        android:layout_marginStart="@dimen/store__share__interval_40"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/store__feed_book_common_detail"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_summary"
        app:layout_constraintWidth_default="wrap"
        style="@style/store__feed_book_detail_style"/>
    <TextView
        android:gravity="end"
        android:id="@+id/store__feed_book_common_detail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/store__share__interval_20"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_common_author"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_summary"
        style="@style/store__feed_book_detail_style"/>
    <TextView
        android:textSize="@dimen/general_font__shared__g"
        android:textColor="@color/general__day_night__666666"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_reason"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/store__feed_book_reason_margin_top"
        android:maxLines="2"
        android:lineSpacingMultiplier="1.2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_detail"/>
</androidx.constraintlayout.widget.ConstraintLayout>
