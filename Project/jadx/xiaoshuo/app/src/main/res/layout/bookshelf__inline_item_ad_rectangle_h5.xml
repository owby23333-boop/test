<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/bookshelf__inline_item_ad__container"
        android:background="@android:color/transparent"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <ImageView
            android:id="@+id/reading__single_image_view__image"
            android:layout_width="70dp"
            android:layout_height="40dp"
            android:layout_marginRight="17dp"/>
        <RelativeLayout
            android:gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/reading__app_ad_view__title_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true">
                <TextView
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:ellipsize="end"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/reading__app_ad_view__title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:layout_weight="1"
                    android:layout_alignParentLeft="true"/>
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/reading__app_ad_view__ad_sign"
                    android:background="@drawable/bookshelf__inline_ad_view__ad_border"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="11dp"
                    android:paddingStart="3dp"
                    android:paddingEnd="3dp">
                    <TextView
                        android:textSize="8sp"
                        android:textColor="#cccccc"
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/general__shared__ad"
                        android:includeFontPadding="false"
                        android:contentDescription="@string/general__shared__ad"/>
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_marginLeft="2dp"
                        android:src="@drawable/bookshelf__inline_ad_view__close"
                        android:contentDescription="@string/general__shared__close"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="#a8a8a8"
                android:ellipsize="end"
                android:gravity="bottom"
                android:id="@+id/reading__app_ad_view__summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="1"
                android:layout_weight="1"
                android:layout_below="@+id/reading__app_ad_view__title_container"
                android:layout_alignParentLeft="true"/>
            <FrameLayout
                android:id="@+id/bookshelf__bottom_banner_ad__close"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignTop="@+id/reading__app_ad_view__title_container"
                android:layout_alignRight="@+id/reading__app_ad_view__title_container"/>
        </RelativeLayout>
        <TextView
            android:textSize="10sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bookshelf__inline_item_ad__icon_border"
            android:layout_width="50dp"
            android:layout_height="21dp"
            android:layout_marginLeft="10dp"
            android:text="@string/general__shared__view"/>
    </LinearLayout>
</FrameLayout>
