<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/personal__bookshelf_style_view__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        android:background="@color/general__day_night__f8f8f8"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/general_font__shared__a"
            android:textColor="@color/general__day_night__555555"
            android:gravity="center"
            android:id="@+id/personal__bookshelf_style_view__title"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/personal__bookshelf_style_view__title"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"/>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/view_dimen_30"
            android:layout_above="@+id/personal__bookshelf_style_view__receive"
            android:layout_below="@+id/personal__bookshelf_style_view__title">
            <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/view_dimen_45"
                android:layout_marginEnd="@dimen/view_dimen_45">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/personal__bookshelf_style_view__first"
                    android:background="@drawable/general__shared__layout_unselected_bg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/view_dimen_60"
                    app:layout_constraintEnd_toStartOf="@+id/personal__bookshelf_style_view__second"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__ffffff"
                        android:gravity="center"
                        android:id="@+id/personal__bookshelf_style_view__first_title"
                        android:background="@drawable/general__shared__title_unselected_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/personal__bookshelf_style_view__first_image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scaleType="fitXY"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/personal__bookshelf_style_view__second"
                    android:background="@drawable/general__shared__layout_selected_bg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/personal__bookshelf_style_view__first"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__ffffff"
                        android:gravity="center"
                        android:id="@+id/personal__bookshelf_style_view__second_title"
                        android:background="@drawable/general__shared__title_selected_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/personal__bookshelf_style_view__second_image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scaleType="fitXY"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/personal__bookshelf_style_view__third"
                    android:background="@drawable/general__shared__layout_unselected_bg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_60"
                    app:layout_constraintEnd_toEndOf="@+id/personal__bookshelf_style_view__first"
                    app:layout_constraintStart_toStartOf="@+id/personal__bookshelf_style_view__first"
                    app:layout_constraintTop_toBottomOf="@+id/personal__bookshelf_style_view__first">
                    <TextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__day_night__ffffff"
                        android:gravity="center"
                        android:id="@+id/personal__bookshelf_style_view__third_title"
                        android:background="@drawable/general__shared__title_unselected_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/personal__bookshelf_style_view__third_image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scaleType="fitXY"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
        <Button
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__day_night__ffffff"
            android:gravity="center"
            android:id="@+id/personal__bookshelf_style_view__receive"
            android:background="@color/general__day_night__5f9cc3"
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general__shared__ok"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</LinearLayout>
