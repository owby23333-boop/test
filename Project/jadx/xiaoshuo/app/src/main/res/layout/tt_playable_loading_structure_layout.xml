<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/tt_playable_app_info_structure_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ImageView
            android:id="@+id/tt_playable_structure_app_logo"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:adjustViewBounds="true"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/tt_white"
            android:gravity="center"
            android:id="@+id/tt_playable_structure_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/tt_playable_structure_tag_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/tt_white"
            android:gravity="center"
            android:id="@+id/tt_playable_structure_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <com.bytedance.sdk.openadsdk.widget.TTLoadingProgressBar
                android:id="@+id/tt_playable_structure_progress"
                android:layout_width="108dp"
                android:layout_height="18dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/tt_white"
                android:id="@+id/tt_playable_structure_progress_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="#d8fffefe"
            android:gravity="center"
            android:id="@+id/tt_playable_structure_placate_tip"
            android:background="@drawable/tt_playable_loading_tip_bg"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="119dp"
            android:maxLines="1"
            android:layout_marginHorizontal="16dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/tt_playable_structure_bottom_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/tt_playable_structure_data_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/tt_white"
            android:gravity="center"
            android:id="@+id/tt_playable_structure_play_btn"
            android:background="@drawable/tt_playable_structure_btn_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="31dp"
            android:text="@string/tt_playable_btn_play"
            android:layout_marginHorizontal="24dp"/>
    </LinearLayout>
</LinearLayout>
