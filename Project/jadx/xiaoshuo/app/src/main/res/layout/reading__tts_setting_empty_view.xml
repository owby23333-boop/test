<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__b3b3b3"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__tts_setting_empty_view__empty"
            android:drawableTop="@drawable/general__shared__empty_icon"
            android:drawablePadding="14dp"/>
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__ff8400_pressed"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/reading__tts_setting_empty_view__add_speaker"
            android:background="@drawable/personal__account_summary_view__add_fund"
            android:layout_width="160dp"
            android:layout_height="33dp"
            android:layout_marginTop="20dp"
            android:text="@string/reading__tts_setting_empty_view__add_speaker"/>
    </LinearLayout>
</FrameLayout>
