<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/general__shared__negative_shadow_margin_15dip"
    android:layout_marginRight="@dimen/general__shared__negative_shadow_margin_15dip">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="15dp">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@color/general__shared__333333"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__discript_view__name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <LinearLayout
            android:layout_gravity="right"
            android:orientation="horizontal"
            android:id="@+id/store__discript_view__more_root"
            android:paddingLeft="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__b"
                android:textColor="@color/general__shared__333333"
                android:layout_gravity="center_vertical"
                android:id="@+id/store__discript_view__more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:text="@string/store__shared__more"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/store__discript_view__more_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/general__shared__more"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/general__shared__bcbcbc"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="15dp"/>
</LinearLayout>
