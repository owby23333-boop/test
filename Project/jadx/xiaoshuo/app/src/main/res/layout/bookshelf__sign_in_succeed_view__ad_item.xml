<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="20dp"
    android:layout_weight="1">
    <TextView
        android:textSize="10sp"
        android:textColor="#fb4e53"
        android:layout_gravity="center_horizontal"
        android:id="@+id/bookshelf__sign_in_succeed_view__ad_item_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="8sp"
        android:textColor="#a7a7a7"
        android:layout_gravity="center_horizontal"
        android:id="@+id/bookshelf__sign_in_succeed_view__ad_item_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"/>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="@dimen/general__shared__cover_list_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <com.duokan.reader.ui.general.BookCoverView
            android:id="@+id/bookshelf__sign_in_succeed_view__ad_item_cover"
            android:background="@drawable/bookshelf__store_book_view__stroke"
            android:padding="1px"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared__cover_list_height"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/store__store_book_cover_view__shadow"
            android:scaleType="centerCrop"/>
    </LinearLayout>
</LinearLayout>
