<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/preference__selection_view__male_selection"
        android:background="@drawable/preference__selection__channel_bg_male"
        android:layout_width="0dp"
        android:layout_height="@dimen/general__shared_dimen__126dp"
        android:layout_marginBottom="@dimen/general__shared_dimen__11_67dp"
        android:layout_marginStart="@dimen/general__shared_dimen__26_67dp"
        android:layout_marginEnd="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintBottom_toTopOf="@+id/guideline2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/preference__selection_view__female_selection"
        android:background="@drawable/preference__selection__channel_bg_female"
        android:layout_width="0dp"
        android:layout_height="@dimen/general__shared_dimen__126dp"
        android:layout_marginTop="@dimen/general__shared_dimen__11_67dp"
        android:layout_marginStart="@dimen/general__shared_dimen__26_67dp"
        android:layout_marginEnd="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline2"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/guideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/preference__selection_view__male_selection_icon"
        android:layout_marginEnd="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintBottom_toBottomOf="@+id/preference__selection_view__male_selection"
        app:layout_constraintEnd_toEndOf="@+id/preference__selection_view__male_selection"
        app:layout_constraintTop_toTopOf="@+id/preference__selection_view__male_selection"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/preference__selection_view__female_selection_icon"
        android:layout_marginEnd="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintBottom_toBottomOf="@+id/preference__selection_view__female_selection"
        app:layout_constraintEnd_toEndOf="@+id/preference__selection_view__female_selection"
        app:layout_constraintTop_toTopOf="@+id/preference__selection_view__female_selection"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__20_67sp"
        android:textColor="@color/general__day_night__31353D"
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="男生"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintBottom_toTopOf="@+id/textView"
        app:layout_constraintStart_toStartOf="@+id/preference__selection_view__male_selection"
        app:layout_constraintTop_toBottomOf="@+id/preference__selection_view__male_selection"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/general__day_night__9931353D"
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__9_33dp"
        android:text="@string/preference__selection_view__channels_male"
        app:layout_constraintBottom_toTopOf="@+id/preference__selection_view__male_selection"
        app:layout_constraintStart_toStartOf="@+id/textView2"
        app:layout_constraintTop_toBottomOf="@+id/textView2"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__20_67sp"
        android:textColor="@color/general__day_night__31353D"
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="女生"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/general__shared_dimen__26_67dp"
        app:layout_constraintBottom_toTopOf="@+id/textView4"
        app:layout_constraintStart_toStartOf="@+id/preference__selection_view__female_selection"
        app:layout_constraintTop_toBottomOf="@+id/preference__selection_view__female_selection"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/general__day_night__9931353D"
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__9_33dp"
        android:text="@string/preference__selection_view__channels_female"
        app:layout_constraintBottom_toTopOf="@+id/preference__selection_view__female_selection"
        app:layout_constraintStart_toStartOf="@+id/textView3"
        app:layout_constraintTop_toBottomOf="@+id/textView3"/>
    <ImageView
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/general__shared_dimen__30dp"
        android:src="@drawable/preference_logo_free"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__15_33sp"
        android:textColor="@color/general__day_night__801f2126"
        android:id="@+id/preference__selection_view__sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/general__shared_dimen__26_67dp"
        android:text="开启你的专属小说世界"
        app:layout_constraintBottom_toTopOf="@+id/preference__selection_view__male_selection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__22_33dp"
        android:textColor="@color/general__day_night__1f2126"
        android:id="@+id/preference__selection_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/general__shared_dimen__4_33dp"
        android:text="@string/preference__selection_view__title"
        app:layout_constraintBottom_toTopOf="@+id/preference__selection_view__sub"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__14sp"
        android:textColor="@color/general__day_night__801f1f1f"
        android:id="@+id/preference__selection_view__skip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__66_67dp"
        android:text="@string/preference__selection_view__skip"
        android:drawableEnd="@drawable/preference__selection_view__arrow_right"
        android:layout_marginEnd="@dimen/general__shared_dimen__19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
