<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__store_book_preface_view__container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <View
            android:id="@+id/reading__store_book_preface_view__background_border"
            android:background="@drawable/reading__store_book_preface_view__background_border"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/view_dimen_100"
            android:layout_marginBottom="@dimen/general__shared_dimen__13_33dp"
            android:layout_marginHorizontal="@dimen/general__shared_dimen__13_33dp"/>
        <Button
            android:textSize="@dimen/text_font_size_39"
            android:textColor="#5b594d"
            android:id="@+id/btn_tts"
            android:background="@drawable/reading__store_book_preface_tts_bg"
            android:layout_width="@dimen/view_dimen_158"
            android:layout_height="@dimen/view_dimen_82"
            android:layout_marginTop="@dimen/view_dimen_148"
            android:text="@string/general__shared__audio"
            android:layout_marginEnd="@dimen/view_dimen_88"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/reading__store_book_preface_view__bookshelf"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/general__000000_03"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.duokan.reader.ui.general.RoundImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/reading__store_book_preface_view__book_cover"
                    android:layout_width="@dimen/general__shared_dimen__100dp"
                    android:layout_height="@dimen/general__shared_dimen__134dp"
                    android:layout_marginTop="@dimen/general__shared_dimen__50dp"
                    android:scaleType="centerCrop"
                    app:radius="@dimen/view_dimen_12"
                    app:strokeColor="@color/black_10_transparent"
                    app:strokeWidth="0.33dp"/>
                <com.duokan.reader.ui.AutoFitTextView
                    android:textSize="@dimen/general__shared_dimen__21_33sp"
                    android:textStyle="bold"
                    android:textColor="@color/general__000000_90"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:id="@+id/reading__store_book_preface_view__book_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/general__shared_dimen__13_33dp"
                    android:maxLines="2"
                    android:maxEms="13"
                    android:includeFontPadding="false"
                    android:layout_marginHorizontal="@dimen/view_dimen_100"
                    app:minTextSize="@dimen/text_font_size_48"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__000000_60"
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/reading__store_book_preface_view__book_author"
                    android:paddingBottom="@dimen/general__shared_dimen__16_67dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/general__shared_dimen__6_7dp"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:layout_marginHorizontal="@dimen/view_dimen_100"/>
            </LinearLayout>
            <RelativeLayout
                android:id="@+id/reading__store_book_preface_view__book_base_info_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general__shared_dimen__18_33dp"
                android:paddingHorizontal="@dimen/general__shared_dimen__33_33dp"
                app:layout_constraintTop_toBottomOf="@+id/reading__store_book_preface_view__top_area">
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/reading__store_book_preface_view__score_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/view_dimen_60"
                            android:textStyle="bold"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="@dimen/view_dimen_36"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__score_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/view_dimen_9"
                            android:text="@string/reading__store_book_preface_view__score_tips"
                            android:layout_marginStart="@dimen/view_dimen_8"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__11_3sp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__score_star"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/reading__store_book_preface_view__reading_num_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/view_dimen_60"
                            android:textStyle="bold"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__read_num"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="@dimen/view_dimen_36"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__read_num_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/view_dimen_9"
                            android:text="@string/store__fiction_detail_num_tips"
                            android:layout_marginStart="@dimen/view_dimen_8"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__11_3sp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__read_tip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store__fiction_detail_reading"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/reading__store_book_preface_view__status_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/view_dimen_60"
                            android:textStyle="bold"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__word_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="@dimen/view_dimen_36"
                            android:textColor="@color/general__000000_90"
                            android:id="@+id/reading__store_book_preface_view__word_count_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/view_dimen_9"
                            android:layout_marginStart="@dimen/view_dimen_8"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__11_3sp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/reading__store_book_preface_view__rank_container"
                    android:background="@drawable/bg_preface_rank_for_light"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/general__shared_dimen__56dp"
                    android:layout_marginTop="@dimen/general__shared_dimen__10dp"
                    android:layout_below="@+id/reading__store_book_preface_view__score_container"
                    android:layout_centerHorizontal="true">
                    <ImageView
                        android:id="@+id/reading__store_book_preface_view__rank_ic"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/general__shared_dimen__28dp"
                        android:src="@drawable/ic_preface_rank_for_light"
                        android:includeFontPadding="false"
                        app:layout_constraintBottom_toTopOf="@+id/rank_guide_line"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                    <androidx.constraintlayout.widget.Guideline
                        android:orientation="horizontal"
                        android:id="@+id/rank_guide_line"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintGuide_percent="0.6"/>
                    <TextView
                        android:textSize="@dimen/general__shared_dimen__11_3dp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__rank__info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_4"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/rank_guide_line"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <TextView
                    android:textSize="@dimen/text_font_size_46"
                    android:textColor="@color/general__000000_90"
                    android:id="@+id/reading__store_book_preface_view__intro_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/general__shared_dimen__14dp"
                    android:text="@string/reading__store_book_preface_view__intro_title"
                    android:layout_below="@+id/reading__store_book_preface_view__rank_container"/>
                <com.duokan.reader.ui.general.FlowLayout
                    android:id="@+id/reading__store_book_preface_view__tag_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignBottom="@+id/reading__store_book_preface_view__intro_title"
                    android:layout_centerHorizontal="true"
                    android:layout_marginStart="@dimen/view_dimen_16"
                    android:layout_toEndOf="@+id/reading__store_book_preface_view__intro_title"
                    app:maxLineCount="1"/>
            </RelativeLayout>
            <FrameLayout
                android:id="@+id/reading__store_book_preface_view_intro_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/general__shared_dimen__10dp"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/reading__store_book_preface_view_intro_content_container"
                    android:visibility="invisible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.duokan.reader.ui.general.ExpandableTextView
                        android:textSize="@dimen/general__shared_dimen__12_67sp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__book_intro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.4"
                        android:letterSpacing="0.02"
                        android:layout_marginHorizontal="@dimen/view_dimen_100"
                        app:expandTriggerText="@string/general__shared__more"
                        app:foldTriggerText="@string/reading_fold_trigger_text"
                        app:foldedLines="20"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:triggerTextColor="@color/general__shared__FF7433"/>
                    <com.duokan.reader.ui.general.ExpandableTextView
                        android:textSize="@dimen/general__shared_dimen__12_67sp"
                        android:textColor="@color/general__000000_50"
                        android:id="@+id/reading__store_book_preface_view__book_first_chapter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/general__shared_dimen__15dp"
                        android:lineSpacingMultiplier="1.4"
                        android:letterSpacing="0.02"
                        android:layout_marginHorizontal="@dimen/view_dimen_100"
                        app:expandTriggerText="@string/general__shared__more"
                        app:foldTriggerText="@string/reading_fold_trigger_text"
                        app:foldedLines="20"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:triggerTextColor="@color/general__shared__FF7433"/>
                </LinearLayout>
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/reading__store_book_preface_view__intro_loading"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:lottie_autoPlay="true"
                    app:lottie_fileName="recommend_book_info.json"
                    app:lottie_repeatCount="-1"/>
            </FrameLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/general__shared_dimen__15_33sp"
            android:textColor="@color/general__shared__ffffff"
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__store_book_preface_view__tips"
            android:background="@drawable/reading__store_book_preface_view__tips"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/general__shared_dimen__20dp"
            android:drawablePadding="5dp"
            android:paddingHorizontal="@dimen/general__shared_dimen__15dp"
            android:paddingVertical="@dimen/general__shared_dimen__8dp"
            app:layout_constraintBottom_toTopOf="@+id/reading__store_book_preface_view__bookshelf"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__14sp"
            android:textColor="@color/general__day_night__ff7433"
            android:layout_gravity="center_horizontal"
            android:id="@+id/reading__store_book_preface_view__bookshelf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/reading__store_book_preface__guide_bottom"
            android:text="@string/store__detail_add_bookshelf"
            android:paddingVertical="@dimen/general__shared_dimen__7dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:id="@+id/reading__store_book_preface_view__error_page"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/general__web_error_view"/>
</FrameLayout>
