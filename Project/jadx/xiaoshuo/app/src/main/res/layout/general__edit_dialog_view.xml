<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp">
    <EditText
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__shared__edit_text"
        android:textColorHint="@color/general__shared__edit_text_hint"
        android:gravity="top|left"
        android:id="@+id/general__edit_dialog_view__edit"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:singleLine="false"
        android:layout_weight="1"
        android:textCursorDrawable="@drawable/general__shared__edit_cursor"/>
    <TextView
        android:background="@color/general__shared__c9"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <TextView
            android:textSize="@dimen/general_font__shared__t3"
            android:textColor="@color/general__shared__c6"
            android:gravity="center"
            android:id="@+id/general__edit_dialog_view__cancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/general__shared__cancel"
            android:layout_weight="1"/>
        <View
            android:background="@color/general__shared__c9"
            android:layout_width="1px"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="@dimen/general_font__shared__t3"
            android:textColor="@color/general__shared__c1"
            android:gravity="center"
            android:id="@+id/general__edit_dialog_view__ok"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/general__shared__ok"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
