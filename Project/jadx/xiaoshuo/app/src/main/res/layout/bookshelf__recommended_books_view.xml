<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__b"
        android:textColor="@color/general__shared__333333"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bookshelf__recommended_books_view__recommended_books"
        android:includeFontPadding="false"/>
    <com.duokan.core.ui.HatGridView
        android:id="@+id/bookshelf__recommended_books_view_grid"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@+id/bookshelf__recommended_books_view__add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="5dp"
        android:text="@string/bookshelf__recommended_books_view__add"
        style="@style/general__shared__button_43dip_ffffff"/>
</LinearLayout>
