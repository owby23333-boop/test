<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__cccccc"
            android:gravity="center_vertical"
            android:layout_gravity="center"
            android:id="@+id/reading__translation_after_download"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginBottom="20dp"
            android:text="@string/reading__translation_view__no_result"
            android:drawableLeft="@drawable/reading__dict_book_not_found"
            android:drawablePadding="4dp"/>
        <com.duokan.core.ui.LinearScrollView
            android:orientation="vertical"
            android:id="@+id/reading__translation_view__scrollview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="50dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:paddingRight="30dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.duokan.reader.ui.general.DkTextView
                        android:textSize="@dimen/general_font__shared__a"
                        android:textColor="@color/general__shared__ed6c00"
                        android:id="@+id/reading__translation_view__word"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/reading__translation_view__voice"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/reading__translation_view__play_audio"/>
                </LinearLayout>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/reading__translation_view__settings"
                    android:paddingLeft="10dp"
                    android:paddingRight="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/reading__translation_view__settings"/>
            </FrameLayout>
            <FrameLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/reading__translation_view__dict_line"
                android:paddingBottom="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/reading__translation_view__meanings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </com.duokan.core.ui.LinearScrollView>
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/reading__translation_view__dict_list"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__ffffff"
                android:id="@+id/reading__translation_view__dict_baidu"
                android:paddingTop="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__translation_view__dict_baidu"/>
            <View
                android:layout_gravity="center_vertical"
                android:background="#ff909090"
                android:layout_width="1dp"
                android:layout_height="13dp"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"/>
            <com.duokan.reader.ui.general.DkLabelView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__ffffff"
                android:id="@+id/reading__translation_view__dict_search"
                android:paddingLeft="4dp"
                android:paddingTop="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__translation_view__dict_search"/>
        </LinearLayout>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="10sp"
            android:textColor="@color/general__shared__6d6c6c"
            android:layout_gravity="bottom|center_horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__translation_view__provided_by_iciba"/>
    </LinearLayout>
</FrameLayout>
