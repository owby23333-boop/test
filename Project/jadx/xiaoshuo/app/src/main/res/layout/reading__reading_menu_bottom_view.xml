<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/reading__reading_navigation_menu_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:id="@+id/reading__reading_menu_bottom_view__sub_menu_mask"
        android:background="@color/black_60_transparent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@+id/reading__reading_menu_bottom_view__seekbar_status_contain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/reading__reading_menu_bottom_view__main"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/reading__reading_menu_bottom_view__main"
        android:background="@color/reading__reading_menu_primary_background_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <FrameLayout
            android:enabled="false"
            android:id="@+id/reading__reading_menu_bottom_view__sub_menu_frame"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <include layout="@layout/reading__reading_menu_bottom_view__seek_bar"/>
        <include layout="@layout/reading__reading_menu_bottom_view__menu"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/reading__reading_menu_bottom_view_epub__tts_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_80"
        app:layout_constraintBottom_toTopOf="@+id/reading__reading_menu_bottom_view__main">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_float_bar"
            android:background="@drawable/reading__menu_float_bar_bg"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_387"
            android:layout_height="@dimen/view_dimen_144"
            android:layout_marginStart="@dimen/view_dimen_48">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/iv_book_cover"
                android:layout_width="@dimen/view_dimen_120"
                android:layout_height="@dimen/view_dimen_120"
                android:contentDescription="@string/reading__reading_options_view__tts_cover"
                android:layout_marginStart="@dimen/view_dimen_12"/>
            <ImageButton
                android:id="@+id/float_bar_play"
                android:background="@color/transparent"
                android:layout_width="@dimen/view_dimen_90"
                android:layout_height="@dimen/view_dimen_90"
                android:src="@drawable/reading__menu_float_bar_play"
                android:contentDescription="@string/reading__reading_options_view__tts_play"
                android:layout_marginStart="@dimen/view_dimen_36"/>
            <ImageButton
                android:id="@+id/float_bar_close"
                android:background="@color/transparent"
                android:layout_width="@dimen/view_dimen_80"
                android:layout_height="@dimen/view_dimen_80"
                android:src="@drawable/reading__menu_float_bar_close"
                android:contentDescription="@string/reading__reading_options_view__tts_close"
                android:layout_marginStart="@dimen/view_dimen_24"/>
        </LinearLayout>
        <ImageView
            android:layout_gravity="end|top"
            android:id="@+id/reading__reading_menu_bottom_view_epub__tts"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_150"
            android:layout_height="@dimen/view_dimen_150"
            android:src="@drawable/reading__reading_menu_bottom_view_epub__tts"
            android:contentDescription="@string/reading__reading_options_view__tts"
            android:layout_marginEnd="@dimen/view_dimen_48"/>
        <ImageView
            android:layout_gravity="start|top"
            android:id="@+id/reading__reading_menu_bottom_view_pdf__mode"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/reading__reading_menu_bottom_view_pdf__mode"
            android:scaleType="center"
            android:contentDescription="@string/reading__reading_menu_bottom_view_pdf__mode"
            android:layout_marginStart="@dimen/view_dimen_12"
            android:layout_marginEnd="@dimen/view_dimen_60"/>
    </FrameLayout>
    <FrameLayout
        android:enabled="false"
        android:id="@+id/reading__reading_menu_bottom_view__overlay_menu_frame"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
