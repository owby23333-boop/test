<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/reading__store_book_introduction_view__background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.duokan.core.ui.BoxView
        android:layout_gravity="bottom"
        android:id="@+id/reading__store_book_introduction_view__container"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="@dimen/view_dimen_1100">
        <RelativeLayout
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="@dimen/view_dimen_110">
            <ImageView
                android:id="@+id/reading__store_book_introduction_view__back"
                android:padding="@dimen/view_dimen_65"
                android:paddingLeft="@dimen/view_dimen_70"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_34"
                android:src="@drawable/reading__reading_options_down_arrow"/>
            <TextView
                android:textSize="@dimen/text_font_size_60"
                android:textStyle="bold"
                android:textColor="@color/general__000000"
                android:id="@+id/reading__store_book_introduction_view__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_80"
                android:text="@string/reading__reading_book_introduction"
                android:includeFontPadding="false"
                android:layout_centerHorizontal="true"/>
            <ScrollView
                android:scrollbarThumbVertical="@color/general__333333_70"
                android:scrollbarStyle="outsideOverlay"
                android:id="@+id/reading__store_book_introduction_view__content_container"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_70"
                android:layout_marginBottom="@dimen/view_dimen_80"
                android:layout_below="@+id/reading__store_book_introduction_view__title"
                android:paddingHorizontal="@dimen/view_dimen_70">
                <TextView
                    android:textSize="@dimen/text_font_size_46"
                    android:textColor="@color/general__000000"
                    android:id="@+id/reading__store_book_introduction_view__content"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="@dimen/view_dimen_25"/>
            </ScrollView>
            <View
                android:id="@+id/reading__store_book_introduction_view__content_shadow"
                android:background="@drawable/store__fiction_detail_view__shadow"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="@dimen/view_dimen_184"
                android:layout_alignBottom="@+id/reading__store_book_introduction_view__content_container"/>
        </RelativeLayout>
    </com.duokan.core.ui.BoxView>
</FrameLayout>
