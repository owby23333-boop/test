<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom"
        android:paddingTop="@dimen/view_dimen_33"
        android:paddingBottom="@dimen/view_dimen_33"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bookshelf__inline_item_ad__container"
            android:background="@android:color/transparent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.duokan.reader.ui.general.RoundImageView
                android:id="@+id/reading__single_image_view__image"
                android:layout_width="@dimen/view_dimen_148"
                android:layout_height="@dimen/view_dimen_148"
                android:scaleType="fitXY"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:radius="@dimen/view_dimen_12"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textSize="@dimen/text_font_size_46"
            android:textColor="@color/general__text__day_night__333333"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view__title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_40"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintBottom_toTopOf="@+id/reading__app_ad_view__summary"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toRightOf="@+id/bookshelf__inline_item_ad__container"
            app:layout_constraintRight_toLeftOf="@+id/bookshelf__bottom_banner_ad__close"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintWidth_default="wrap"/>
        <include
            android:layout_gravity="top|right"
            android:id="@+id/bookshelf__bottom_banner_ad__close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/reading__app_ad_view__title"
            app:layout_constraintLeft_toRightOf="@+id/reading__app_ad_view__title"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view__title"
            layout="@layout/general__page__close_ad_view"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__text__day_night__999999"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view__summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_36"
            android:maxLines="1"
            android:singleLine="true"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toLeftOf="@+id/reading__app_ad_view__title"
            app:layout_constraintRight_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__app_ad_view__title"
            app:layout_constraintWidth_default="wrap"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__close_ad_view___container"
        android:background="@drawable/bookshelf__close_ad_view_list_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/reading__close_ad_view__title_container"
            android:background="@drawable/general__shared__rounded_button_white_ffffff_17"
            android:layout_width="@dimen/view_dimen_341"
            android:layout_height="@dimen/view_dimen_79"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/reading__close_ad_view__title_left_icon_iv"
                android:layout_width="@dimen/view_dimen_32"
                android:layout_height="@dimen/view_dimen_32"
                android:src="@drawable/reading__close_ad_view__title_left_icon"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/reading___close_ad_view__title"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/text_font_size_32"
                android:textColor="@color/general__ffffff"
                android:id="@+id/reading___close_ad_view__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/view_dimen_10"
                android:text="@string/reading__close_ad_view__title_text"
                android:includeFontPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/reading__close_ad_view__title_left_icon_iv"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            android:id="@+id/reading__close_ad_view__close_ad_icon_iv"
            android:padding="@dimen/view_dimen_20"
            android:layout_width="@dimen/view_dimen_64"
            android:layout_height="@dimen/view_dimen_64"
            android:src="@drawable/reading__close_ad_view__close_icon"
            android:scaleType="centerCrop"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_18"
            android:textColor="@color/general__666666"
            android:id="@+id/reading__close_ad_view__subtitle_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/view_dimen_4"
            android:layout_marginBottom="@dimen/view_dimen_15"
            android:text="@string/reading__close_ad_view__subtitle_text"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toLeftOf="@+id/reading__close_ad_view__title_container"
            app:layout_constraintRight_toLeftOf="@+id/reading__close_ad_view_subtitle_right_icon"/>
        <ImageView
            android:id="@+id/reading__close_ad_view_subtitle_right_icon"
            android:layout_width="@dimen/view_dimen_8"
            android:layout_height="@dimen/view_dimen_16"
            android:src="@drawable/bookshelf__close_ad_view__subtitle_icon"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/reading__close_ad_view__subtitle_tv"
            app:layout_constraintLeft_toRightOf="@+id/reading__close_ad_view__subtitle_tv"
            app:layout_constraintRight_toRightOf="@+id/reading__close_ad_view__title_container"
            app:layout_constraintTop_toTopOf="@+id/reading__close_ad_view__subtitle_tv"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
