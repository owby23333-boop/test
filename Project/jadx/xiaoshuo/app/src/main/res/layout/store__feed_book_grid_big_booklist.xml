<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/store__grid_book_grid_big_height"
    android:foreground="?android:attr/selectableItemBackground">
    <TextView
        android:id="@+id/store__feed_book_grid_booklist_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/store__feed_book_grid_title_style"/>
    <TextView
        android:id="@+id/store__feed_book_grid_booklist_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="1.7dp"
        android:layout_marginBottom="6.3dp"
        app:layout_constraintBottom_toTopOf="@+id/store__feed_book_grid_booklist_cover1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_grid_booklist_title"
        style="@style/store__feed_book_grid_desc_style"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/store__feed_book_grid_booklist_cover1"
        android:layout_width="@dimen/store__grid_book_grid_booklist_big_width"
        android:layout_height="@dimen/store__grid_book_grid_booklist_big_height"
        android:layout_marginBottom="3dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/store__feed_book_grid_booklist_cover2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:radius="@dimen/general__shared_dimen__4dp"
        app:shapeAppearance="@style/RoundCorner12"
        style="@style/store_feed_book_cover_frame_style"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/store__feed_book_grid_booklist_cover2"
        android:layout_width="@dimen/store__grid_book_grid_booklist_big_width"
        android:layout_height="@dimen/store__grid_book_grid_booklist_big_height"
        android:layout_marginBottom="3dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/store__feed_book_grid_booklist_cover3"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_grid_booklist_cover1"
        app:radius="@dimen/general__shared_dimen__4dp"
        app:shapeAppearance="@style/RoundCorner12"
        style="@style/store_feed_book_cover_frame_style"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/store__feed_book_grid_booklist_cover3"
        android:layout_width="@dimen/store__grid_book_grid_booklist_big_width"
        android:layout_height="@dimen/store__grid_book_grid_booklist_big_height"
        android:layout_marginRight="3dp"
        android:layout_marginBottom="3dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_grid_booklist_cover2"
        app:radius="@dimen/general__shared_dimen__4dp"
        app:shapeAppearance="@style/RoundCorner12"
        style="@style/store_feed_book_cover_frame_style"/>
</androidx.constraintlayout.widget.ConstraintLayout>
