<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/item_select_category_0"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_130"
    android:layout_margin="@dimen/view_dimen_18">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_cover"
        android:tag="binding_1"
        android:layout_width="@dimen/view_dimen_105"
        android:layout_height="@dimen/view_dimen_105"
        android:scaleType="centerCrop"
        android:layout_marginStart="@dimen/view_dimen_18"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/CircleStyle"/>
    <TextView
        android:textSize="@dimen/view_dimen_42"
        android:textColor="@color/dkcommon__day_night__1a1a1a"
        android:gravity="center_vertical"
        android:id="@+id/tv_label"
        android:tag="binding_2"
        android:layout_width="@dimen/view_dimen_200"
        android:layout_height="wrap_content"
        android:lines="2"
        android:layout_marginStart="@dimen/view_dimen_30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_cover"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/iv_selected"
        android:tag="binding_3"
        android:layout_width="@dimen/view_dimen_60"
        android:layout_height="@dimen/view_dimen_60"
        android:src="@drawable/ic_category_selected"
        android:scaleType="center"
        android:layout_marginEnd="@dimen/view_dimen_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
