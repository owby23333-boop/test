<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__large_image_view__image_multi"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/view_dimen_42">
    <ImageView
        android:id="@+id/reading__multi_image_view__img1"
        android:layout_width="0dp"
        android:layout_height="100.33dp"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/reading__multi_image_view__img2"
        android:layout_width="0dp"
        android:layout_height="100.33dp"
        android:scaleType="fitXY"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img1"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/reading__multi_image_view__img3"
        android:layout_width="0dp"
        android:layout_height="100.33dp"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/general__page__close_ad_view"/>
    <TextView
        android:textSize="@dimen/text_font_size_24"
        android:textColor="@color/general__ffffff_90"
        android:id="@+id/reading__app_ad_view__ad_icon"
        android:background="@drawable/general__page__close_ad_view_background"
        android:paddingLeft="@dimen/view_dimen_11"
        android:paddingTop="@dimen/view_dimen_3"
        android:paddingRight="@dimen/view_dimen_11"
        android:paddingBottom="@dimen/view_dimen_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/view_dimen_20"
        android:layout_marginBottom="@dimen/view_dimen_20"
        android:text="@string/general__shared__ad"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
