<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reading__toc_header_view"
    android:background="@color/general__day_night__catalogue_app_dark_head_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_105">
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="@color/general__day_night__catalogue_app_dark_catalogue"
        android:id="@+id/reading__navigation_current_book_chapter_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_7"
        android:layout_marginStart="@dimen/view_dimen_60"/>
    <TextView
        android:textSize="@dimen/text_font_size_36"
        android:textColor="@color/general__day_night__catalogue_app_dark_catalogue"
        android:id="@+id/reading__navigation_tab_free_view__current"
        android:paddingTop="@dimen/view_dimen_7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reading__shared__toc_current"
        android:contentDescription="@string/reading__shared__toc_current"
        android:layout_toStartOf="@+id/reading__navigation_tab_free_view__sort"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/reading__navigation_tab_free_view__sort"
        android:paddingTop="@dimen/view_dimen_7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/reading__shared__toc_reverse"
        android:layout_marginStart="@dimen/view_dimen_67"
        android:layout_marginEnd="@dimen/view_dimen_60"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/reading__navigation_tab_free_view__sort_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/reading__navigation_tab_view__reverse_sort_dark"/>
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/general__999999"
            android:id="@+id/reading__navigation_tab_free_view__sort_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reading__shared__toc_reverse"
            android:paddingStart="@dimen/view_dimen_20"/>
    </LinearLayout>
</RelativeLayout>
