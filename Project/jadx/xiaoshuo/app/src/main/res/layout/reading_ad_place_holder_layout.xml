<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__app_ad_view_constraint_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="@dimen/general__shared_dimen__15dp">
    <TextView
        android:textSize="@dimen/text_font_size_33"
        android:textColor="@color/black_30_transparent"
        android:id="@+id/reading__ad_bottom_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__33_33dp"
        android:text="@string/reading__ad_view__user_tip_new"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="@dimen/general__shared_dimen__11dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/reading__opt_ad_view__clickable_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__32_33dp"
        android:layout_marginBottom="@dimen/general__shared_dimen__15dp"
        android:contentDescription="@string/ad_appstore_card"
        app:cardBackgroundColor="@color/black_05_transparent"
        app:cardCornerRadius="@dimen/general__shared_dimen__20dp"
        app:cardElevation="@dimen/general__shared_dimen__0dp"
        app:layout_constraintTop_toBottomOf="@+id/reading__ad_bottom_tips"
        app:layout_goneMarginBottom="@dimen/general__shared_dimen__15dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/page_ad_container"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__586_66dp">
            <ImageView
                android:id="@+id/iv_image"
                android:layout_width="@dimen/general__shared_dimen__200dp"
                android:layout_height="@dimen/general__shared_dimen__200dp"
                android:src="@drawable/reading__ad_page_place_holder_bg"
                android:scaleType="fitXY"
                app:layout_constraintBottom_toTopOf="@+id/tv_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textSize="@dimen/general__shared_dimen__17dp"
                android:textStyle="bold"
                android:textColor="@color/black_80_transparent"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general__shared_dimen__12dp"
                android:text="@string/reading__chapter_ad_place_holder_title"
                app:layout_constraintBottom_toTopOf="@+id/tv_subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_image"/>
            <TextView
                android:textSize="@dimen/general__shared_dimen__14dp"
                android:textColor="@color/black_40_transparent"
                android:gravity="center"
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general__shared_dimen__12dp"
                android:text="@string/reading__chapter_ad_place_holder_subtitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
