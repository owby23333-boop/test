<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adView"
    android:background="@drawable/ad_top_round_corner_bg"
    android:paddingTop="6.67dp"
    android:paddingBottom="6.67dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.xiaomi.polymer.ad.wiget.Image.ShapeImageView
        android:id="@+id/sdk_ad_app_logo"
        android:layout_width="46.67dp"
        android:layout_height="46.67dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:siv_round_radius="10dp"
        app:siv_shape="rect"/>
    <TextView
        android:textSize="12.67sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:id="@+id/sdk_ad_app_download"
        android:background="@drawable/reading__bottom_ad_view__download_bg"
        android:visibility="visible"
        android:layout_width="74.67dp"
        android:layout_height="30dp"
        android:text="@string/general__shared__ad_free_experience"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="15.32sp"
        android:textColor="@color/general__day_night__ad_tips_color_1A1A1A"
        android:ellipsize="end"
        android:id="@+id/sdk_ad_app_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toTopOf="@+id/sdk_ad_app_desc"
        app:layout_constraintEnd_toStartOf="@+id/sdk_ad_close"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@+id/sdk_ad_app_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintWidth_default="wrap"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/general__day_night__ad_tips_color_1A1A1A"
        android:ellipsize="end"
        android:id="@+id/sdk_ad_app_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@+id/sdk_ad_app_title"
        app:layout_constraintRight_toLeftOf="@+id/sdk_ad_app_download"
        app:layout_constraintTop_toBottomOf="@+id/sdk_ad_app_title"/>
    <ImageView
        android:id="@+id/sdk_ad_close"
        android:layout_width="38.7dp"
        android:layout_height="16dp"
        android:layout_marginBottom="2dp"
        android:src="@drawable/reading__opt_ad_view__ad_cancel_icon_black"
        android:scaleType="fitXY"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/sdk_ad_app_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sdk_ad_app_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
