<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.general.RoundLinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:visibility="invisible"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/view_dimen_30"
    app:radius="@dimen/view_dimen_14">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__chapter_end_app_ad"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_423">
        <com.duokan.reader.ui.general.RoundImageView
            android:id="@+id/reading__chapter_end_app_ad__logo"
            android:layout_width="@dimen/view_dimen_148"
            android:layout_height="@dimen/view_dimen_148"
            android:layout_marginTop="@dimen/view_dimen_50"
            android:scaleType="centerCrop"
            android:layout_marginStart="@dimen/view_dimen_40"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:radius="@dimen/view_dimen_14"/>
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textStyle="bold"
            android:textColor="@color/black_70_transparent"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/reading__chapter_end_app_ad__title"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/view_dimen_60"
            android:layout_marginLeft="@dimen/view_dimen_42"
            android:layout_marginTop="@dimen/view_dimen_67"
            android:maxWidth="@dimen/view_dimen_500"
            android:maxLines="1"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toStartOf="@+id/reading__chapter_end_app_ad__coin"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/reading__chapter_end_app_ad__logo"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_40"
            android:textColor="@color/general__ff8d00"
            android:gravity="center_vertical"
            android:id="@+id/reading__chapter_end_app_ad__coin"
            android:layout_width="@dimen/view_dimen_180"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:drawableLeft="@drawable/reading__chapter_end_app_ad__coin_icon"
            android:drawablePadding="@dimen/view_dimen_10"
            android:layout_marginStart="@dimen/view_dimen_16"
            android:layout_marginEnd="@dimen/view_dimen_16"
            app:layout_constraintBottom_toBottomOf="@+id/reading__chapter_end_app_ad__title"
            app:layout_constraintEnd_toStartOf="@+id/reading__chapter_end_app_ad__close"
            app:layout_constraintStart_toEndOf="@+id/reading__chapter_end_app_ad__title"
            app:layout_constraintTop_toTopOf="@+id/reading__chapter_end_app_ad__title"/>
        <ImageView
            android:id="@+id/reading__chapter_end_app_ad__close"
            android:paddingTop="@dimen/view_dimen_20"
            android:layout_width="@dimen/view_dimen_58"
            android:layout_height="@dimen/view_dimen_58"
            android:layout_marginTop="@dimen/view_dimen_30"
            android:src="@drawable/reading__chapter_end_app_ad__close_bg_dark"
            android:scaleType="centerInside"
            android:paddingEnd="@dimen/view_dimen_20"
            android:layout_marginEnd="@dimen/view_dimen_30"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/black_40_transparent"
            android:ellipsize="end"
            android:id="@+id/reading__chapter_end_app_ad__summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_10"
            android:layout_marginRight="@dimen/view_dimen_50"
            android:layout_marginBottom="@dimen/view_dimen_27"
            android:text="@string/reading__chapter_end_app_ad__summary_title"
            android:maxLines="1"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@+id/reading__chapter_end_app_ad__rule"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_app_ad__title"/>
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/black_70_transparent"
            android:id="@+id/reading__chapter_end_app_ad__rule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_10"
            android:text="@string/reading__chapter_end_app_ad__summary_rule"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="@+id/reading__chapter_end_app_ad__title"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_app_ad__title"/>
        <TextView
            android:textSize="@dimen/text_font_size_46"
            android:textColor="#000000"
            android:gravity="center"
            android:id="@+id/reading__app_ad_view__play"
            android:background="@drawable/general__shared__rounded_button_yellow"
            android:layout_width="@dimen/view_dimen_874"
            android:layout_height="@dimen/view_dimen_120"
            android:layout_marginTop="@dimen/view_dimen_45"
            android:text="@string/reading__app_ad_view__download_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__chapter_end_app_ad__logo"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.duokan.reader.ui.general.RoundLinearLayout>
