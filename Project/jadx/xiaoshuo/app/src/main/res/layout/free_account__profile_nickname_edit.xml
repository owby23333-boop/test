<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="192dp"
    android:layout_margin="8dp">
    <TextView
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/free_account__profile_nickname_edit__title"/>
    <EditText
        android:textSize="14sp"
        android:id="@+id/free_account__profile_nickname_edit__nickname"
        android:background="@drawable/free_account__profile_nickname_edit__edittext_bg"
        android:paddingLeft="17dp"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginLeft="22dp"
        android:layout_marginTop="21dp"
        android:layout_marginRight="22dp"
        android:layout_marginBottom="27dp"
        android:hint="@string/free_account__profile_nickname_edit__hint"
        android:textCursorDrawable="@drawable/free__edittext_cursor"/>
    <View
        android:background="#cccccc"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="#999999"
            android:gravity="center"
            android:id="@+id/free_account__profile_nickname_edit__cancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/free_account__profile_nickname_edit__cancel"
            android:layout_weight="1"/>
        <View
            android:background="#cccccc"
            android:layout_width="1px"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ff942b"
            android:gravity="center"
            android:id="@+id/free_account__profile_nickname_edit__save"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/free_account__profile_nickname_edit__save"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
