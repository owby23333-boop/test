<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.sdk.component.widget.SSWebView
        android:id="@+id/tt_reward_browser_webview"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layerType="hardware"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.bytedance.sdk.openadsdk.core.component.reward.view.PlayableEndcardFrameLayout
            android:id="@+id/tt_reward_browser_fl"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <com.bytedance.sdk.component.widget.SSWebView
                android:id="@+id/tt_reward_browser_webview_playable"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layerType="hardware"/>
            <FrameLayout
                android:id="@+id/tt_reward_ugeno_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <include layout="@layout/tt_activity_reward_and_full_endcard"/>
            <com.bytedance.sdk.openadsdk.widget.PlayableLoadingView
                android:id="@+id/tt_reward_playable_loading"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.bytedance.sdk.openadsdk.core.component.reward.view.lp.RewardLpBottomView
                android:layout_gravity="bottom"
                android:id="@+id/tt_reward_lp_bottom"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.bytedance.sdk.openadsdk.core.component.reward.view.PlayableEndcardFrameLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:id="@+id/tt_pl_pre_5element_end_card_container"
            android:background="#161823"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/tt_playable_video_container"
        android:background="@color/tt_transparent"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.bytedance.sdk.openadsdk.core.playable.PlayableVideoContainer
            android:layout_gravity="top|right"
            android:id="@+id/tt_playable_video_container_vertical"
            android:background="@color/tt_transparent"
            android:visibility="gone"
            android:layout_width="73dp"
            android:layout_height="130dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="30dp"/>
        <com.bytedance.sdk.openadsdk.core.playable.PlayableVideoContainer
            android:layout_gravity="top|right"
            android:id="@+id/tt_playable_video_container_horizontal"
            android:background="@color/tt_transparent"
            android:visibility="gone"
            android:layout_width="156dp"
            android:layout_height="87dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="20dp"/>
    </FrameLayout>
</FrameLayout>
