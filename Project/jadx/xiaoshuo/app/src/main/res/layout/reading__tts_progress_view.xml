<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/general__shared__999999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:text="@string/general__shared__downloading"
            android:includeFontPadding="false"/>
        <View
            android:background="#949494"
            android:layout_width="1px"
            android:layout_height="18dp"
            android:layout_marginLeft="7dp"
            android:layout_marginTop="32dp"
            android:layout_marginRight="7dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/general__shared__c1"
            android:id="@+id/reading__tts_progress_view__progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:includeFontPadding="false"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/reading__tts_progress_view__progress_bar"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginLeft="27dp"
        android:layout_marginRight="27dp"
        android:layout_marginBottom="30dp"
        android:progress="55"
        android:progressDrawable="@drawable/reading__tts_progress_view__progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"/>
</LinearLayout>
