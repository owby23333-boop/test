<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <Button
        android:gravity="center"
        android:id="@+id/query_skip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:text="@string/passport_skip_query_account"
        android:layout_alignParentBottom="true"
        style="@style/PassportWidget.NormalRoundButton"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/query_skip">
        <TextView
            android:textSize="15sp"
            android:gravity="center"
            android:id="@+id/tv_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/passport_account_login_margin_normal"
            android:text="@string/passport_doing_query_account"
            android:layout_centerInParent="true"/>
        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_above="@+id/tv_loading"
            android:layout_centerHorizontal="true"
            style="@style/PassportWidget.ProgressBar"/>
    </RelativeLayout>
</RelativeLayout>
