<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.PageHeaderView
            android:id="@+id/personal__personal_settings_view__header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.duokan.core.ui.LinearScrollView
            android:orientation="vertical"
            android:id="@+id/personal__personal_settings_view__scrollerview"
            android:background="@color/general__day_night__ffffff"
            android:scrollbars="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/permission_settings_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/view_dimen_30">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__day_night__000000"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__permission_settings_info"/>
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__d"
                                android:textColor="@color/general__day_night__999999"
                                android:ellipsize="end"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/personal__permission_settings_location_summary"
                                android:layout_marginEnd="100dp"/>
                        </LinearLayout>
                        <TextView
                            android:textColor="@color/general__day_night__000000"
                            android:layout_gravity="center"
                            android:id="@+id/permission_settings_info_right"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="32.33dp"
                            android:text="@string/personal__permission_settings_off"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/general__shared__more"/>
                    </FrameLayout>
                </LinearLayout>
                <View
                    android:background="@color/general__shared__FFD8D8D8"
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginHorizontal="20dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/permission_settings_camera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/view_dimen_30">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__day_night__000000"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__permission_settings_camera"/>
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__d"
                                android:textColor="@color/general__day_night__999999"
                                android:ellipsize="end"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/personal__permission_settings_camera_summary"
                                android:layout_marginEnd="100dp"/>
                        </LinearLayout>
                        <TextView
                            android:textColor="@color/general__day_night__000000"
                            android:layout_gravity="center"
                            android:id="@+id/permission_settings_camera_right"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="32.33dp"
                            android:text="@string/personal__permission_settings_off"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/general__shared__more"/>
                    </FrameLayout>
                </LinearLayout>
                <View
                    android:background="@color/general__shared__FFD8D8D8"
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginHorizontal="20dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/permission_settings_app_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/view_dimen_30">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__day_night__000000"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__permission_settings_app_list"/>
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__d"
                                android:textColor="@color/general__day_night__999999"
                                android:ellipsize="end"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/personal__permission_settings_app_list_summary"
                                android:layout_marginEnd="100dp"/>
                        </LinearLayout>
                        <TextView
                            android:textColor="@color/general__day_night__000000"
                            android:layout_gravity="center"
                            android:id="@+id/permission_settings_app_list_right"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="32.33dp"
                            android:text="@string/personal__permission_settings_off"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/general__shared__more"/>
                    </FrameLayout>
                </LinearLayout>
                <View
                    android:background="@color/general__shared__FFD8D8D8"
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginHorizontal="20dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/permission_settings_calendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/view_dimen_30">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp">
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__t1"
                                android:textColor="@color/general__day_night__000000"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/personal__permission_settings_calendar"/>
                            <com.duokan.reader.ui.general.DkLabelView
                                android:textSize="@dimen/general_font__shared__d"
                                android:textColor="@color/general__day_night__999999"
                                android:ellipsize="end"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/personal__permission_settings_calendar_summary"
                                android:layout_marginEnd="100dp"/>
                        </LinearLayout>
                        <TextView
                            android:textColor="@color/general__day_night__000000"
                            android:layout_gravity="center"
                            android:id="@+id/permission_settings_calendar_right"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="32.33dp"
                            android:text="@string/personal__permission_settings_off"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/general__shared__more"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </com.duokan.core.ui.LinearScrollView>
    </LinearLayout>
</FrameLayout>
