<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/view_dimen_50"
    style="@style/store__shared__item_parent">
    <include
        android:id="@+id/store_feed_book_audio_card1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/store__feed_audio_big_cover"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12_67sp"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store_feed_book_audio_title1"
        android:layout_width="@dimen/store__grid_audio_cover_size"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="@+id/store_feed_book_audio_card1"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_card1"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_audio_card1"/>
    <include
        android:id="@+id/store_feed_book_audio_card2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/store__feed_audio_big_cover"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12_67sp"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store_feed_book_audio_title2"
        android:layout_width="@dimen/store__grid_audio_cover_size"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="@+id/store_feed_book_audio_card2"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_card2"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_audio_card2"/>
    <include
        android:id="@+id/store_feed_book_audio_card3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/store__feed_audio_big_cover"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12_67sp"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store_feed_book_audio_title3"
        android:layout_width="@dimen/store__grid_audio_cover_size"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="@+id/store_feed_book_audio_card3"
        app:layout_constraintStart_toStartOf="@+id/store_feed_book_audio_card3"
        app:layout_constraintTop_toBottomOf="@+id/store_feed_book_audio_card3"/>
</androidx.constraintlayout.widget.ConstraintLayout>
