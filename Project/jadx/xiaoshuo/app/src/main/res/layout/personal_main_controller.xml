<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/duokan_new_home_background"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/personal__main__refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:id="@+id/personal__main__page_header"
                android:background="@color/general__day_night__f2f2f2"
                android:layout_width="match_parent"
                android:layout_height="@dimen/general__shared_dimen__50dp">
                <ImageView
                    android:id="@+id/personal__main__header_qr_login_icon"
                    android:layout_width="@dimen/general__shared_dimen__32_33dp"
                    android:layout_height="@dimen/general__shared_dimen__32_33dp"
                    android:layout_marginBottom="@dimen/general__shared_dimen__10_7dp"
                    android:src="@drawable/personal__main__scan_icon"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="@string/personal__personal_scan"
                    android:layout_marginStart="@dimen/general__shared_dimen__17_67dp"
                    android:layout_alignParentStart="true"/>
                <ImageView
                    android:id="@+id/personal__main__header_dark_mode_icon"
                    android:layout_width="@dimen/general__shared_dimen__32_33dp"
                    android:layout_height="@dimen/general__shared_dimen__32_33dp"
                    android:layout_marginBottom="@dimen/general__shared_dimen__10_7dp"
                    android:src="@drawable/personal__main__night_mode_icon"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="@dimen/general__shared_dimen__13_33dp"
                    android:layout_toEndOf="@+id/personal__main__header_qr_login_icon"/>
                <ImageView
                    android:id="@+id/personal__main__setting_layout_icon"
                    android:layout_width="@dimen/general__shared_dimen__32_33dp"
                    android:layout_height="@dimen/general__shared_dimen__32_33dp"
                    android:layout_marginBottom="@dimen/general__shared_dimen__10_7dp"
                    android:src="@drawable/personal__main__setting_icon"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="@string/personal__account_summary_view__settings"
                    android:layout_marginEnd="@dimen/general__shared_dimen__15_33dp"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <include
                android:id="@+id/personal__vip_notice_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/view_dimen_108"
                android:layout_marginBottom="@dimen/view_dimen_60"
                android:layout_below="@+id/personal__main__page_header"
                android:layout_marginStart="@dimen/view_dimen_46"
                android:layout_marginEnd="@dimen/view_dimen_46"
                layout="@layout/personal_vip_notice_layout"/>
            <ScrollView
                android:id="@+id/personal__main__scroll_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/personal__vip_notice_container">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/view_dimen_46"
                    android:paddingEnd="@dimen/view_dimen_46">
                    <include layout="@layout/personal_main_login_card"/>
                    <include layout="@layout/personal_main_vip_card"/>
                    <include layout="@layout/personal_main_features_card"/>
                    <include layout="@layout/personal_main_functions_card"/>
                </LinearLayout>
            </ScrollView>
            <View
                android:background="@color/general__day_night__personal__main_bg_ffffff"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/personal__main__scroll_view"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</FrameLayout>
