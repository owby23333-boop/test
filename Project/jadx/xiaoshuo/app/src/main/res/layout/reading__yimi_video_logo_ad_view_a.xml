<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reading__app_ad_view_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/reading__app_ad_view_click"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.58">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:orientation="vertical"
                    android:background="@drawable/general__shared__corner_ad_bg"
                    android:paddingLeft="@dimen/view_dimen_42"
                    android:paddingTop="@dimen/view_dimen_50"
                    android:paddingRight="@dimen/view_dimen_42"
                    android:paddingBottom="@dimen/view_dimen_50"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="@dimen/text_font_size_48"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:ellipsize="end"
                        android:id="@+id/reading__app_ad_view__summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="2"/>
                    <FrameLayout
                        android:id="@+id/reading__video_view__video_container"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="@dimen/view_dimen_42"
                        android:layout_below="@+id/reading__app_ad_view__summary">
                        <ImageView
                            android:id="@+id/reading__video_view__preview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitXY"/>
                        <com.duokan.advertisement.ui.AdVideoView
                            android:id="@+id/reading__video_view__video"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/reading__app_ad_view__video_play"
                            android:visibility="gone"
                            android:layout_width="@dimen/view_dimen_120"
                            android:layout_height="@dimen/view_dimen_120"
                            android:src="@drawable/reading__ad_view_play"/>
                        <include
                            android:layout_gravity="end|top"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            layout="@layout/general__page__close_ad_view"/>
                    </FrameLayout>
                    <include
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_30"
                        android:layout_below="@+id/reading__video_view__video_container"
                        layout="@layout/reading__ad_view_title_icon_xout_a"/>
                </RelativeLayout>
                <include
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/view_dimen_30"
                    android:layout_marginRight="@dimen/view_dimen_30"
                    layout="@layout/general__close_ad_view"/>
            </FrameLayout>
            <include layout="@layout/reading__ad_view_download_view_a"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
