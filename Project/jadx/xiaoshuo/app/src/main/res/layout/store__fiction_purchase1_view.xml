<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@drawable/general__shared__menu_item_view__textcolor"
            android:id="@+id/store__fiction_purchase_view__name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@drawable/general__shared__menu_item_view__textcolor"
        android:id="@+id/store__fiction_purchase_view__chapter_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@drawable/general__shared__menu_item_view__textcolor"
        android:id="@+id/store__fiction_purchase_view__chapter_cmread_prompt"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/store__fiction_purchase_view__cmread"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:id="@+id/store__fiction_purchase_view__purchase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/store__fiction_purchase_view__purchase"
        style="@style/general__shared__button_43dip_ff6518"/>
    <RelativeLayout
        android:id="@+id/store__fiction_purchase_view__more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">
        <View
            android:background="#cccccc"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_alignParentTop="true"/>
        <TableLayout
            android:id="@+id/store__fiction_purchase_view__table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</LinearLayout>
