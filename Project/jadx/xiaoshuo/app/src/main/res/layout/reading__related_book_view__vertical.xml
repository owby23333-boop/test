<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="15dp"
    android:paddingTop="8dp"
    android:paddingRight="15dp"
    android:paddingBottom="8dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/reading__related_book_view__cover"
        style="@style/general__shared__cover_detail"/>
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="5dp"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__343434"
            android:ellipsize="end"
            android:id="@+id/reading__related_book_view__name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:includeFontPadding="false"/>
        <TextView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__shared__585858"
            android:ellipsize="end"
            android:id="@+id/reading__related_book_view__summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:maxLines="3"
            android:includeFontPadding="false"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/general_font__shared__e"
                android:textColor="@color/general__shared__8d8d8d"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/reading__related_book_view__tag"
                android:background="@drawable/reading__related_book_view__rate"
                android:paddingLeft="7dp"
                android:paddingTop="3dp"
                android:paddingRight="7dp"
                android:paddingBottom="3dp"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"/>
            <TextView
                android:textSize="@dimen/general_font__shared__e"
                android:textColor="@color/general__shared__8d8d8d"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/reading__related_book_view__rate"
                android:background="@drawable/reading__related_book_view__rate"
                android:paddingLeft="7dp"
                android:paddingTop="3dp"
                android:paddingRight="7dp"
                android:paddingBottom="3dp"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_toLeftOf="@+id/reading__related_book_view__tag"
                android:layout_alignBaseline="@+id/reading__related_book_view__tag"
                android:layout_alignParentBottom="true"/>
            <TextView
                android:textSize="@dimen/general_font__shared__e"
                android:textColor="#368ecb"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@+id/reading__related_book_view__author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_toLeftOf="@+id/reading__related_book_view__rate"
                android:layout_alignBaseline="@+id/reading__related_book_view__tag"
                android:layout_alignParentLeft="true"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
