<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__reading_bottom_ad_view"
    android:background="@drawable/ad_top_round_corner_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/general__shared_dimen__68_36dp">
    <com.duokan.advertisement.ui.BottomAdContainerView
        android:id="@+id/reading_reading_bottom_ad_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/ad_appstore_card">
        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@+id/reading__bottom_image_view__image"
            android:layout_width="@dimen/general__shared_dimen__50_91dp"
            android:layout_height="@dimen/general__shared_dimen__50_91dp"
            android:layout_marginLeft="@dimen/general__shared_dimen__15_33dp"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/reading__bottom_image_view__image_mask"
            android:visibility="gone"
            android:layout_width="@dimen/general__shared_dimen__0dp"
            android:layout_height="@dimen/general__shared_dimen__0dp"
            android:src="@drawable/ad_bottom_iv_night_mask"
            app:layout_constraintBottom_toBottomOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintLeft_toLeftOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintRight_toRightOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintTop_toTopOf="@+id/reading__bottom_image_view__image"/>
        <FrameLayout
            android:id="@+id/reading__app_ad_view__download_fl"
            android:layout_width="@dimen/general__shared_dimen__66_67dp"
            android:layout_height="@dimen/general__shared_dimen__32_33dp"
            android:layout_marginRight="@dimen/general__shared_dimen__20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/reading__app_ad_view__download_anim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:lottie_fileName="reading_button_ad_action_lottie.json"/>
            <TextView
                android:textSize="@dimen/general__shared_dimen__10_67sp"
                android:textColor="@color/dkcommon__ffffff"
                android:gravity="center"
                android:id="@+id/reading__app_ad_view__download"
                android:paddingBottom="@dimen/general__shared_dimen__1dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/general__shared__ad_free_experience"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/reading__app_ad_view__close"
            android:layout_width="@dimen/general__shared_dimen__23dp"
            android:layout_height="0dp"
            android:contentDescription="@string/ad_appstore_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_gravity="center_horizontal"
                android:id="@+id/reading__app_ad_view__close_iv"
                android:layout_width="@dimen/general__shared_dimen__9dp"
                android:layout_height="@dimen/general__shared_dimen__9dp"
                android:layout_marginTop="@dimen/general__shared_dimen__7dp"
                android:src="@drawable/ic_bottom_ad_close"/>
        </FrameLayout>
        <TextView
            android:textSize="@dimen/general__shared_dimen__15_27sp"
            android:textColor="@color/dkcommon__000000_90"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view__title"
            android:layout_width="@dimen/general__shared_dimen__0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__6dp"
            android:singleLine="true"
            android:layout_marginStart="@dimen/general__shared_dimen__10dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__100dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/tv_ad_tag"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_60"
            android:layout_height="@dimen/view_dimen_38"
            android:src="@drawable/icon_ad"
            android:layout_marginStart="@dimen/general__shared_dimen__2dp"
            app:layout_constraintBottom_toBottomOf="@+id/reading__app_ad_view__title"
            app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__title"
            app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view__title"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10sp"
            android:textColor="@color/dkcommon__000000_30"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view__developer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__6dp"
            android:singleLine="true"
            android:layout_marginEnd="@dimen/general__shared_dimen__10dp"
            app:layout_constraintBottom_toBottomOf="@+id/reading__app_ad_view__version"
            app:layout_constraintEnd_toStartOf="@+id/reading__app_ad_view__download_fl"
            app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view__title"
            app:layout_constraintTop_toTopOf="@+id/reading__app_ad_view__title"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__15_27sp"
            android:textColor="@color/dkcommon__000000_90"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view_desc__title"
            android:visibility="gone"
            android:layout_width="@dimen/general__shared_dimen__0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__12dp"
            android:singleLine="true"
            android:layout_marginStart="@dimen/general__shared_dimen__10dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__100dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10sp"
            android:textColor="@color/dkcommon__000000_30"
            android:ellipsize="end"
            android:id="@+id/reading__app_ad_view__summary"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/general__shared_dimen__14dp"
            android:singleLine="true"
            android:layout_marginEnd="@dimen/general__shared_dimen__10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/reading__app_ad_view__download_fl"
            app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view_desc__title"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10sp"
            android:textColor="@color/dkcommon__000000_30"
            android:id="@+id/reading__app_ad_view__version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/general__shared_dimen__6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@+id/reading__app_ad_view__title"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10sp"
            android:textColor="@color/dkcommon__000000_30"
            android:id="@+id/divider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" | "
            app:layout_constraintBaseline_toBaselineOf="@+id/reading__app_ad_view__version"
            app:layout_constraintStart_toEndOf="@+id/reading__app_ad_view__version"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__10sp"
            android:textColor="@color/dkcommon__000000_30"
            android:id="@+id/reading__app_ad_view__permission_privacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/general__shared__permission_privacy"
            app:layout_constraintBaseline_toBaselineOf="@+id/divider"
            app:layout_constraintStart_toEndOf="@+id/divider"/>
        <TextView
            android:textSize="8dp"
            android:textColor="#ccffffff"
            android:id="@+id/tv_ad_tag_two"
            android:background="@drawable/ad_tag_round_corner_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/view_dimen_12"
            android:paddingVertical="@dimen/view_dimen_4"
            app:layout_constraintStart_toStartOf="@+id/reading__bottom_image_view__image"
            app:layout_constraintTop_toTopOf="@+id/reading__bottom_image_view__image"/>
    </com.duokan.advertisement.ui.BottomAdContainerView>
</FrameLayout>
