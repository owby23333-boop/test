<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/error_view"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/general__empty_view__image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/general__shared__empty_icon"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__b3b3b3"
        android:id="@+id/general__empty_view__line_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/general__shared__web_error"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__day_night__b3b3b3"
        android:id="@+id/general__empty_view__line_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/error_retry_view"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/general__shared__web_refresh"
        style="@style/general__shared__button_light_29dip_c9c9c9"/>
</LinearLayout>
