<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/general__view__selector"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__text__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store__fiction_detail_view_item__tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_45"
        android:layout_marginBottom="@dimen/view_dimen_45"
        android:maxLines="2"
        android:lineSpacingExtra="@dimen/view_dimen_50"
        android:layout_marginStart="@dimen/view_dimen_50"
        android:layout_marginEnd="@dimen/view_dimen_50"
        android:layout_toStartOf="@+id/store__fiction_detail_view_item__tv_page"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__text__day_night__999999"
        android:id="@+id/store__fiction_detail_view_item__tv_page"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/store__fiction_detail_view_item__tv"
        android:layout_marginEnd="@dimen/view_dimen_50"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
