<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:paddingBottom="@dimen/view_dimen_42"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_42"
    android:paddingEnd="@dimen/view_dimen_42">
    <com.duokan.reader.ui.DebugConstraintLayout
        android:id="@+id/book1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_book_cover1"
            android:layout_width="@dimen/view_dimen_132"
            android:layout_height="@dimen/view_dimen_186"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toStartOf="@+id/iv_rank1"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/BookCoverStyle"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_top1"
            android:layout_width="@dimen/view_dimen_80"
            android:layout_height="@dimen/view_dimen_36"
            app:layout_constraintStart_toStartOf="@+id/iv_book_cover1"
            app:layout_constraintTop_toTopOf="@+id/iv_book_cover1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank1"
            android:layout_width="@dimen/view_dimen_23"
            android:layout_height="@dimen/view_dimen_50"
            android:layout_marginStart="@dimen/view_dimen_21"
            app:layout_constraintEnd_toStartOf="@+id/tv_title1"
            app:layout_constraintStart_toEndOf="@+id/iv_book_cover1"
            app:layout_constraintTop_toTopOf="@+id/iv_book_cover1"/>
        <TextView
            android:textSize="@dimen/view_dimen_38"
            android:textColor="@color/general__day_night__1a1a1a"
            android:ellipsize="end"
            android:id="@+id/tv_title1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:layout_marginStart="@dimen/view_dimen_6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_rank1"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_30"
            android:textColor="@color/general__day_night__000000_40"
            android:ellipsize="end"
            android:id="@+id/tv_sub_title1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_9"
            android:maxLines="2"
            app:layout_constraintStart_toStartOf="@+id/tv_title1"
            app:layout_constraintTop_toBottomOf="@+id/tv_title1"/>
    </com.duokan.reader.ui.DebugConstraintLayout>
    <com.duokan.reader.ui.DebugConstraintLayout
        android:id="@+id/book2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/view_dimen_60">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_book_cover2"
            android:layout_width="@dimen/view_dimen_132"
            android:layout_height="@dimen/view_dimen_186"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toStartOf="@+id/iv_rank2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/BookCoverStyle"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_top2"
            android:layout_width="@dimen/view_dimen_80"
            android:layout_height="@dimen/view_dimen_36"
            app:layout_constraintStart_toStartOf="@+id/iv_book_cover2"
            app:layout_constraintTop_toTopOf="@+id/iv_book_cover2"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank2"
            android:layout_width="@dimen/view_dimen_23"
            android:layout_height="@dimen/view_dimen_50"
            android:layout_marginStart="@dimen/view_dimen_21"
            app:layout_constraintEnd_toStartOf="@+id/tv_title2"
            app:layout_constraintStart_toEndOf="@+id/iv_book_cover2"
            app:layout_constraintTop_toTopOf="@+id/iv_book_cover2"/>
        <TextView
            android:textSize="@dimen/view_dimen_38"
            android:textColor="@color/general__day_night__1a1a1a"
            android:ellipsize="end"
            android:id="@+id/tv_title2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:layout_marginStart="@dimen/view_dimen_6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_rank2"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/view_dimen_30"
            android:textColor="@color/general__day_night__000000_40"
            android:ellipsize="end"
            android:id="@+id/tv_sub_title2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_9"
            android:maxLines="2"
            app:layout_constraintStart_toStartOf="@+id/tv_title2"
            app:layout_constraintTop_toBottomOf="@+id/tv_title2"/>
    </com.duokan.reader.ui.DebugConstraintLayout>
</LinearLayout>
