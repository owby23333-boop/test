<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__f2f2f2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:layout_marginBottom="15dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__666666"
            android:textColorHint="@color/general__000000_30"
            android:gravity="center"
            android:id="@+id/discovery__edit_feed_item_view__desc"
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/discovery__edit_feed_item_view__desc_hint"/>
        <com.duokan.reader.ui.general.BookCoverView
            android:id="@+id/discovery__edit_feed_item_view__cover"
            android:background="@color/general__dddddd"
            android:layout_width="150dp"
            android:layout_height="200dp"/>
        <TextView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__666666"
            android:id="@+id/discovery__edit_feed_item_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="25dp"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="bottom|right"
        android:id="@+id/discovery__edit_feed_item_view__delete"
        android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/welcome__discovery_view__delete"
        android:contentDescription="@string/bookshelf__general_shared__delete"/>
</FrameLayout>
