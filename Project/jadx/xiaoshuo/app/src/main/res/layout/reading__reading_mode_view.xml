<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="bottom"
    android:orientation="vertical"
    android:background="@color/general__shared__141414f2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:enabled="false"
        android:padding="20dp"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.core.ui.BoxView
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="360dp">
            <LinearLayout
                android:orientation="vertical"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__ffffff_80"
                    android:gravity="center"
                    android:paddingBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_mode_view__hint"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__shared__ffffffcc_enabled"
                        android:gravity="center"
                        android:id="@+id/reading__reading_mode_view__tts"
                        android:background="@drawable/reading__reading_options_view__text_background"
                        android:visibility="gone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/reading__reading_mode_view__tts"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="@dimen/general_font__shared__c"
                        android:textColor="@color/general__ffffff_80"
                        android:gravity="center"
                        android:id="@+id/reading__reading_mode_view__auto_pagedown"
                        android:background="@drawable/reading__reading_options_view__text_background"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:text="自动翻页"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
        </com.duokan.core.ui.BoxView>
    </FrameLayout>
</LinearLayout>
