<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/general__notification_toolbar__container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="55.67dp"
        android:layout_marginLeft="5dp">
        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/general__notification_toolbar__second_image"
            android:background="@drawable/general__notification_toolbar__image_bg"
            android:padding="1px"
            android:layout_width="34.3dp"
            android:layout_height="45.7dp"
            android:layout_marginLeft="25dp"
            android:scaleType="fitXY"/>
        <ImageView
            android:layout_gravity="bottom"
            android:background="@drawable/general__notification_toolbar__image_shadow"
            android:layout_width="24dp"
            android:layout_height="45.7dp"
            android:layout_marginLeft="25dp"/>
        <ImageView
            android:id="@+id/general__notification_toolbar__image"
            android:background="@drawable/general__notification_toolbar__image_bg"
            android:padding="1px"
            android:layout_width="42dp"
            android:layout_height="55.67dp"
            android:scaleType="fitXY"/>
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="11dp"
        android:layout_marginRight="11dp"
        android:layout_weight="1">
        <TextView
            android:textAppearance="@android:style/TextAppearance.StatusBar.EventContent.Title"
            android:textSize="13sp"
            android:ellipsize="end"
            android:id="@+id/general__notification_toolbar__title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <TextView
            android:textAppearance="@android:style/TextAppearance.StatusBar.EventContent"
            android:textSize="13sp"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@+id/general__notification_toolbar__subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.3dp"
            android:singleLine="true"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/general__notification_toolbar__action"
        android:background="@drawable/general__notification_serial_update_read_bg"
        android:layout_width="wrap_content"
        android:layout_height="27.67dp"
        android:minWidth="77dp"
        android:text="@string/bookshelf__serial_update_first_read"
        android:singleLine="true"/>
</LinearLayout>
