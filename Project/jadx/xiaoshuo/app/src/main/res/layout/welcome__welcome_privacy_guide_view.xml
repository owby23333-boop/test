<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/welcome__welcome_privacy_guide_view__container"
        android:background="@drawable/welcome__privacy__dialog_bg"
        android:layout_width="@dimen/view_dimen_780"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginVertical="@dimen/view_dimen_200">
        <TextView
            android:textSize="@dimen/text_font_size_50"
            android:textColor="@color/general__day_night__000000"
            android:layout_gravity="center_horizontal"
            android:id="@+id/welcome__welcome_privacy_guide_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_80"
            android:layout_marginBottom="@dimen/view_dimen_40"
            android:text="@string/welcome__easy_web_access_view__privacy_guide_title"
            android:fontFamily="sans-serif-medium"/>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:paddingStart="@dimen/view_dimen_70"
            android:paddingEnd="@dimen/view_dimen_70">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_font_size_38"
                    android:textColor="@color/general__day_night__ff1a1a1a_ccffffff"
                    android:id="@+id/welcome__welcome_privacy_guide_view__prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome__privacy__content"
                    android:lineSpacingExtra="6sp"
                    android:lineSpacingMultiplier="1"
                    android:lineHeight="@dimen/view_dimen_60"/>
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/general__day_night__000000_40"
                    android:id="@+id/welcome__privacy__prompt_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_16"
                    android:text="@string/welcome__privacy__prompt_title_new"
                    android:lineSpacingExtra="6sp"
                    android:lineHeight="@dimen/view_dimen_50"/>
            </LinearLayout>
        </ScrollView>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/general__day_night__000000_ffffff"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/welcome__welcome_privacy_guide_view__read_only"
            android:layout_width="@dimen/view_dimen_300"
            android:layout_height="@dimen/view_dimen_110"
            android:text="@string/welcome__privacy__forbid"
            android:alpha="0.3"/>
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textStyle="bold"
            android:textColor="@color/general__shared__ffffff"
            android:gravity="center"
            android:id="@+id/welcome__welcome_privacy_guide_view__agree"
            android:background="@drawable/welcome__privacy__dialog_bottom_cta"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_140"
            android:text="@string/welcome__privacy__agree"/>
    </LinearLayout>
</RelativeLayout>
