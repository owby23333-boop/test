<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingTop="20dp"
    android:layout_width="95dp"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/reading__taobao_item_ad_view__image"
        android:background="@drawable/reading__taobao_item_ad_view__small_image_bg"
        android:padding="1px"
        android:layout_width="match_parent"
        android:layout_height="101dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#1a1a1a"
        android:ellipsize="end"
        android:id="@+id/reading__taobao_item_ad_view__title"
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:layout_below="@+id/reading__taobao_item_ad_view__image"
        android:layout_marginStart="0dp"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textSize="10sp"
        android:textColor="#ee6e00"
        android:id="@+id/reading__taobao_item_ad_view__sign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/store__shared__yuan"
        android:layout_below="@+id/reading__taobao_item_ad_view__title"/>
    <TextView
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#ee6e00"
        android:id="@+id/reading__taobao_item_ad_view__price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_below="@+id/reading__taobao_item_ad_view__title"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__sign"/>
    <TextView
        android:textSize="10sp"
        android:textColor="#bebebe"
        android:id="@+id/reading__taobao_item_ad_view__old_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:layout_below="@+id/reading__taobao_item_ad_view__title"
        android:layout_marginStart="3dp"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__price"/>
</RelativeLayout>
