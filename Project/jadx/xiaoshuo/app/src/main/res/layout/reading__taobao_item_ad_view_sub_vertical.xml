<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="70dp">
    <ImageView
        android:id="@+id/reading__taobao_item_ad_view__image"
        android:background="@drawable/reading__taobao_item_ad_view__small_image_bg"
        android:padding="1px"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginEnd="10dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#1a1a1a"
        android:ellipsize="end"
        android:id="@+id/reading__taobao_item_ad_view__title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:layout_toStartOf="@+id/reading__taobao_item_ad_view__purchase"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__image"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ee6e00"
        android:id="@+id/reading__taobao_item_ad_view__sign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="@string/store__shared__yuan"
        android:layout_alignBottom="@+id/reading__taobao_item_ad_view__image"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__image"/>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#ee6e00"
        android:id="@+id/reading__taobao_item_ad_view__price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/reading__taobao_item_ad_view__image"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__sign"/>
    <TextView
        android:textSize="11sp"
        android:textColor="#bebebe"
        android:id="@+id/reading__taobao_item_ad_view__old_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/reading__taobao_item_ad_view__price"
        android:layout_marginStart="2dp"
        android:layout_toEndOf="@+id/reading__taobao_item_ad_view__price"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ee6e00"
        android:gravity="center"
        android:id="@+id/reading__taobao_item_ad_view__purchase"
        android:background="@drawable/reading__taobao_item_ad_view__buy_button_bg"
        android:layout_width="63dp"
        android:layout_height="28dp"
        android:text="@string/reading__taobao_item_ad_view_purchase"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
