<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.sdk.openadsdk.widget.TopProxyLayout
        android:id="@+id/tt_top_layout_proxy"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.bytedance.sdk.openadsdk.core.component.reward.view.RewardChestView
        android:id="@+id/tt_reward_chest_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <TextView
        android:gravity="center"
        android:layout_gravity="start|bottom"
        android:id="@+id/tt_ad_logo"
        android:background="@drawable/tt_ad_logo_new"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="100dp"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tt_center_tip"
        android:background="@drawable/tt_reward_chest_finish_tip_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
