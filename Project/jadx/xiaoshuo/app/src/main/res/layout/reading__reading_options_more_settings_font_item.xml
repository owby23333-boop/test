<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__custom_font_view_btn"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/reading__custom_font_view__progress_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginBottom="@dimen/view_dimen_45"
        android:layout_marginEnd="@dimen/view_dimen_16">
        <ProgressBar
            android:id="@+id/reading__custom_font_view__progress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:progressDrawable="@drawable/reading__reading_menu_options_font_download_progress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/reading__reading_options_view__text_selector"
            android:gravity="center_vertical"
            android:id="@+id/reading__custom_font_view__font_download_status"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginStart="@dimen/view_dimen_56"
            android:layout_marginEnd="@dimen/view_dimen_10"/>
    </FrameLayout>
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/reading__custom_font_view__container"
        android:background="@drawable/reading__reading_options_view___corner70_selector"
        android:duplicateParentState="true"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_140"
        android:layout_marginBottom="@dimen/view_dimen_45"
        android:paddingStart="@dimen/view_dimen_60"
        android:paddingEnd="@dimen/view_dimen_60"
        android:layout_marginEnd="@dimen/view_dimen_32">
        <TextView
            android:textSize="@dimen/text_font_size_44"
            android:textColor="@color/reading__reading_options_view__text_selector"
            android:id="@+id/reading__custom_font_view__font_name"
            android:duplicateParentState="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/view_dimen_10"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/reading__custom_font_view__font_name_label"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/view_dimen_70"
            android:scaleType="center"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/text_font_size_38"
            android:textColor="@color/black_40_transparent"
            android:gravity="end"
            android:id="@+id/reading__custom_font_view__font_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</FrameLayout>
