<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:textColor="@color/general__day_night__1a1a1a"
        android:id="@+id/store__sug_item_view__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="7dp"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/general__day_night__ffffff"
        android:id="@+id/store__sug_item_view__author_category"
        android:background="@drawable/store__sug_author_item_view__category_bg"
        android:paddingLeft="7dp"
        android:paddingTop="0.5dp"
        android:paddingRight="7dp"
        android:paddingBottom="0.5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
