<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.DebugConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="@dimen/general__view__dimen__13_09dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/general__view__dimen__2_5dp">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_book_cover"
        android:background="@color/general__day_night__f2f2f2_2a2a2a"
        android:layout_width="@dimen/general__view__dimen__75_27dp"
        android:layout_height="@dimen/general__view__dimen__106_18dp"
        android:scaleType="fitXY"
        app:layout_constraintDimensionRatio="h,97:135"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearance="@style/BookCoverStyle"
        app:strokeColor="@color/general__day_night__0000001a"
        app:strokeWidth="0.3dp"/>
    <TextView
        android:textSize="@dimen/text_font_size_30"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/tv_book_label"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/view_dimen_84"
        android:singleLine="true"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintEnd_toEndOf="@+id/iv_book_cover"
        app:layout_constraintTop_toTopOf="@+id/iv_book_cover"/>
    <TextView
        android:textSize="@dimen/general__view__text_size__13_09sp"
        android:textColor="@color/general__text__day_night__cc000000_ccffffff"
        android:ellipsize="end"
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__view__dimen__6_54dp"
        android:lines="2"
        app:layout_constraintEnd_toEndOf="@+id/iv_book_cover"
        app:layout_constraintStart_toStartOf="@+id/iv_book_cover"
        app:layout_constraintTop_toBottomOf="@+id/iv_book_cover"/>
    <TextView
        android:textSize="@dimen/general__shared_dimen__12sp"
        android:textColor="@color/store_epub_score_count__day_night__FF9000_FF9000"
        android:ellipsize="end"
        android:id="@+id/tv_sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="@+id/iv_book_cover"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
</com.duokan.reader.ui.DebugConstraintLayout>
