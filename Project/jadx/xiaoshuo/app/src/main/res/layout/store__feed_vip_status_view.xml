<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="20dp"
    android:layout_marginRight="20dp">
    <LinearLayout
        android:id="@+id/store__feed__vip_user_info"
        android:background="@drawable/store__feed__vip_status_background"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/store__feed__vip_icon"
            android:scaleType="center"/>
        <TextView
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="8dp"
            android:singleLine="true"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#ca912c"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:drawablePadding="5dp"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/store__feed__vip_ad_info"
        android:background="@drawable/store__feed__vip_status_background"
        android:paddingLeft="14dp"
        android:paddingRight="6dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <TextView
            android:textSize="11sp"
            android:textColor="#000000"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_ad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/store__feed_vip__ad"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#333333"
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_subscribe"
            android:background="@drawable/store__feed__vip_subscribe"
            android:paddingLeft="14dp"
            android:paddingTop="4dp"
            android:paddingRight="14dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="8dp"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_close"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/store__feed__vip_close"
            android:scaleType="center"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/store__feed__vip_coupon"
        android:background="@drawable/store__feed__vip_status_background"
        android:paddingLeft="14dp"
        android:paddingRight="6dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/store__feed__vip_coupon"
            android:scaleType="center"/>
        <TextView
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="8dp"
            android:text="@string/store__feed_vip__coupon"
            android:singleLine="true"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#ca912c"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:text="@string/store__feed_vip__redeem"
            android:drawablePadding="5dp"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/store__feed__vip_coupon_close"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/store__feed__vip_close"
            android:scaleType="center"/>
    </LinearLayout>
</FrameLayout>
