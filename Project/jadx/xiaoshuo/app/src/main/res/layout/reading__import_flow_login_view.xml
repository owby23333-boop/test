<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_120"
    android:paddingEnd="@dimen/view_dimen_120">
    <TextView
        android:id="@+id/reading__flow_login_title"
        android:text="@string/reading__import_flow_login_title_music"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/importFlow__dialog_title"/>
    <TextView
        android:id="@+id/reading__flow_login_sub_title"
        android:layout_marginTop="@dimen/view_dimen_20"
        android:text="@string/reading__import_flow_login_summary_music"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_login_title"
        style="@style/importFlow__dialog_sub_title"/>
    <TextView
        android:textSize="@dimen/text_font_size_48"
        android:textColor="@color/general__1A1A1A_70"
        android:id="@+id/reading__flow_receive_event_5minute_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:text="@string/reading__import_flow_login_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/reading__flow_login_sub_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
