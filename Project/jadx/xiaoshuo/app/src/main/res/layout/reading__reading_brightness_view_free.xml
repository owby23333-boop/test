<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@color/general__fdfdfd"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.reading.BubbleSeekBar
        android:id="@+id/reading__reading_brightness_view__seek_brightness"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:layout_marginBottom="@dimen/view_dimen_40"
        android:contentDescription="@string/reading__reading_menu_bottom_view__brightness_bar"
        android:layout_marginStart="@dimen/view_dimen_55"
        android:layout_marginEnd="@dimen/view_dimen_55"
        app:bsb_drawable_padding="@dimen/view_dimen_24"
        app:bsb_end_drawable="@drawable/reading__reading_menu_bottom_view__daytime_high"
        app:bsb_end_drawable_size="@dimen/view_dimen_80"
        app:bsb_hide_bubble="true"
        app:bsb_max="1000"
        app:bsb_min="0"
        app:bsb_second_track_color="@color/black_04_transparent"
        app:bsb_second_track_size="@dimen/view_dimen_100"
        app:bsb_start_drawable="@drawable/reading__reading_menu_bottom_view__daytime_low"
        app:bsb_start_drawable_size="@dimen/view_dimen_80"
        app:bsb_thumb_color="@color/white"
        app:bsb_thumb_radius="@dimen/view_dimen_50"
        app:bsb_thumb_radius_on_dragging="@dimen/view_dimen_50"
        app:bsb_touch_to_seek="true"
        app:bsb_track_color="@color/black_04_transparent"
        app:bsb_track_size="@dimen/view_dimen_100"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/view_dimen_77">
            <com.duokan.reader.ui.general.DkLabelView
                android:layout_gravity="start|center_vertical"
                android:id="@+id/reading__bottom_menu_option_auto_brightness_label"
                android:text="@string/reading__reading_options_view__brightness_auto"
                style="@style/reading__bottom_menu_option_text"/>
            <CheckBox
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_brightness_view__auto_brightness"
                android:padding="@dimen/view_dimen_41"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/reading__reading_options_view__brightness_auto"
                android:drawableStart="@drawable/reading__reading_menu_options_switch_button_color0"
                style="@style/reading__option_checkbox"/>
        </LinearLayout>
        <View
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__bottom_menu_option_vertical_divider"
            android:background="@color/general__979797_30"
            android:layout_width="2px"
            android:layout_height="@dimen/view_dimen_48"
            android:layout_marginStart="@dimen/view_dimen_63"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/view_dimen_84">
            <TextView
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__bottom_menu_option_eyes_saving_label"
                android:text="@string/reading__reading_brightness_view__eyes_saving"
                style="@style/reading__bottom_menu_option_text"/>
            <CheckBox
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__reading_brightness_view__eyes_saving"
                android:padding="@dimen/view_dimen_41"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/reading__reading_brightness_view__eyes_saving"
                android:drawableStart="@drawable/reading__reading_menu_options_switch_button_color0"
                style="@style/reading__option_checkbox"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        android:layout_marginBottom="@dimen/view_dimen_31">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/reading__reading_options_view__theme_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/view_dimen_66"/>
        <ImageView
            android:id="@+id/reading__reading_menu_night_theme_btn"
            android:background="@drawable/reading__reading_options_night_theme_button_background"
            android:layout_width="@dimen/view_dimen_100"
            android:layout_height="@dimen/view_dimen_100"
            android:src="@drawable/reading__reading_brightness_daynight"
            android:scaleType="centerInside"
            android:layout_marginEnd="@dimen/view_dimen_51"/>
        <com.duokan.reader.ui.general.RoundFrameLayout
            android:id="@+id/reading__reading_more_theme_bg"
            android:layout_width="@dimen/view_dimen_192"
            android:layout_height="@dimen/view_dimen_100"
            android:layout_marginEnd="@dimen/view_dimen_65"
            app:radius="@dimen/view_dimen_55">
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/black_60_transparent"
                android:layout_gravity="center"
                android:id="@+id/reading__reading_more_theme_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__reading_menu_view__brightness"
                android:includeFontPadding="false"
                android:drawablePadding="@dimen/view_dimen_21"
                android:drawableEnd="@drawable/reading__reading_menu_options_arrow"/>
        </com.duokan.reader.ui.general.RoundFrameLayout>
    </LinearLayout>
</LinearLayout>
