<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/personal__fav_book_list_item_view__root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__a"
            android:textColor="@color/general__shared__181817"
            android:id="@+id/personal__fav_book_list_item_view__title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__shared__7c7975"
            android:id="@+id/personal__fav_book_list_item_view__summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="7dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="7dp"
            android:maxLines="3"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/personal__fav_book_list_item_view__count_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/personal__fav_book_list_item_view__creator_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <com.duokan.reader.ui.general.DkTinyFaceView
                    android:layout_gravity="center"
                    android:id="@+id/personal__fav_book_list_item_view__avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__a3a3a3"
                    android:gravity="center"
                    android:id="@+id/personal__fav_book_list_item_view__creator"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.6">
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__a3a3a3"
                    android:gravity="center"
                    android:id="@+id/personal__fav_book_list_item_view__fav_count"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:drawableLeft="@drawable/store_comment__comment_item_view__like_pressed"
                    android:drawablePadding="5dp"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__d"
                    android:textColor="@color/general__shared__a3a3a3"
                    android:gravity="center"
                    android:id="@+id/personal__fav_book_list_item_view__comment_count"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:drawableLeft="@drawable/store_comment__comment_item_view__reply"
                    android:drawablePadding="5dp"
                    android:layout_weight="0.75"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:layout_gravity="bottom"
            android:background="@color/general__shared__e6e6e6"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</LinearLayout>
