<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/general__shared__common_dialog_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/reading__chapter_not_purchased_view_coupon__layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="43.33dp">
        <RelativeLayout
            android:background="@drawable/reading__chapter_not_purchased_view_coupon__bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/reading__chapter_not_purchased_view_coupon__icon"
                android:layout_width="19dp"
                android:layout_height="16dp"
                android:src="@drawable/audio__audio_player_view__audio_money"
                android:layout_centerVertical="true"
                android:layout_marginStart="37.67dp"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="7.67dp"
                android:layout_toEndOf="@+id/reading__chapter_not_purchased_view_coupon__icon"/>
            <TextView
                android:textSize="13.33sp"
                android:textColor="#f16651"
                android:background="@drawable/reading__chapter_not_purchased_view_coupon_text__bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="33dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="17sp"
            android:gravity="center"
            android:id="@+id/reading__chapter_not_purchased_view__name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>
        <com.duokan.reader.ui.general.DkTextView
            android:textSize="@dimen/general_font__shared__c"
            android:ellipsize="end"
            android:gravity="fill"
            android:id="@+id/reading__chapter_not_purchased_view__tip"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__b"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/reading__chapter_not_purchased_view__login_or_buy"
            android:background="@drawable/general__shared__rounded_button_orange"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="150dp"/>
        <com.duokan.reader.ui.reading.ChapterNotPurchasedContainerView
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:id="@+id/reading__chapter_not_purchased_view__server_info"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
</LinearLayout>
