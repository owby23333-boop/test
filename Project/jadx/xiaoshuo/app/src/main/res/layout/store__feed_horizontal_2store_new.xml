<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/view_dimen_30"
    android:layout_marginStart="@dimen/view_dimen_42"
    android:layout_marginEnd="@dimen/view_dimen_42">
    <include
        android:id="@+id/store_feed_book_item1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/store_feed_book_item2"
        layout="@layout/store__feed_horizontal_2store_item_new"/>
    <include
        android:id="@+id/store_feed_book_item2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/store__share__interval_60"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/store_feed_book_item1"
        app:layout_constraintRight_toRightOf="parent"
        layout="@layout/store__feed_horizontal_2store_item_new"/>
</androidx.constraintlayout.widget.ConstraintLayout>
