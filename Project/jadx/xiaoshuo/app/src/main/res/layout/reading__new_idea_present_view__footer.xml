<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:background="#26000000"
        android:layout_width="match_parent"
        android:layout_height="@dimen/general__shared_dimen__0_33dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/reading__new_idea_present_view__edittext_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/general__shared_dimen__10dp"
        android:layout_marginBottom="@dimen/general__shared_dimen__10dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__idea_present_view__anchor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__8dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__8dp"
            android:src="@drawable/reading__new_idea_present_view__idea_editor_anchor"
            android:contentDescription="@null"
            android:layout_marginStart="@dimen/general__shared_dimen__10dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__3_33dp"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__12_67sp"
            android:textColor="#abaeb3"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/reading__idea_present_view__edittext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/reading__reading_menu_bottom_view__idea_editor_hint"
            android:maxLines="1"
            android:layout_weight="1"
            android:paddingEnd="@dimen/general__shared_dimen__10dp"/>
    </LinearLayout>
</LinearLayout>
