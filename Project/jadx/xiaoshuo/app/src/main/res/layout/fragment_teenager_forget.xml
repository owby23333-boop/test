<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_title_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_154"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__000000"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/teenager_forget_password"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__shared__back"
            android:layout_marginStart="@dimen/view_dimen_70"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/divider"
            android:background="@color/general__day_night__000000_10"
            android:layout_width="0dp"
            android:layout_height="@dimen/view_dimen_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="@dimen/text_font_size_60"
        android:textColor="@color/general__day_night__000000_80"
        android:id="@+id/tv_user_id_prefix"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        android:text="@string/teenager_user_id_prefix"
        android:layout_marginHorizontal="@dimen/view_dimen_75"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_title_bar"/>
    <TextView
        android:textSize="@dimen/text_font_size_87"
        android:textColor="@color/teenager_user_id"
        android:id="@+id/tv_user_id"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_30"
        app:layout_constraintEnd_toEndOf="@+id/tv_user_id_prefix"
        app:layout_constraintStart_toStartOf="@+id/tv_user_id_prefix"
        app:layout_constraintTop_toBottomOf="@+id/tv_user_id_prefix"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__000000_90_ffffff_90"
        android:id="@+id/tv_send_email_tip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_110"
        android:text="@string/teenager_send_email_tip"
        app:layout_constraintEnd_toEndOf="@+id/tv_user_id_prefix"
        app:layout_constraintStart_toStartOf="@+id/tv_user_id_prefix"
        app:layout_constraintTop_toBottomOf="@+id/tv_user_id"/>
    <TextView
        android:textColor="@color/general__day_night__000000_90_ffffff_90"
        android:id="@+id/tv_forget_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        android:text="@string/teenager_forget_password_desc"
        android:includeFontPadding="false"
        android:lineSpacingExtra="@dimen/view_dimen_18"
        app:layout_constraintEnd_toEndOf="@+id/tv_user_id_prefix"
        app:layout_constraintStart_toStartOf="@+id/tv_user_id_prefix"
        app:layout_constraintTop_toBottomOf="@+id/tv_send_email_tip"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/general__day_night__000000_60"
        android:id="@+id/tv_user_info_tip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        android:text="@string/teenager_user_info_tip"
        app:layout_constraintEnd_toEndOf="@+id/tv_user_id_prefix"
        app:layout_constraintStart_toStartOf="@+id/tv_user_id_prefix"
        app:layout_constraintTop_toBottomOf="@+id/tv_forget_desc"/>
</androidx.constraintlayout.widget.ConstraintLayout>
