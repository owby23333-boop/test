<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_title_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/view_dimen_154"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__shared__back"
            android:layout_marginStart="@dimen/view_dimen_70"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/divider"
            android:background="@color/general__day_night__000000_10"
            android:layout_width="0dp"
            android:layout_height="@dimen/view_dimen_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="@dimen/text_font_size_60"
        android:textStyle="bold"
        android:textColor="@color/general__day_night__000000"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_180"
        android:text="@string/teenager_input_password"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_title_bar"/>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/general__day_night__000000_60"
        android:id="@+id/tv_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_18"
        android:text="@string/teenager_input_password_tip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <com.duokan.reader.teenager.view.CodeEditText
        android:textSize="@dimen/view_dimen_72"
        android:textStyle="bold"
        android:id="@+id/et_password"
        android:paddingTop="@dimen/view_dimen_6"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/view_dimen_150"
        android:layout_marginTop="@dimen/view_dimen_144"
        android:inputType="numberPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_desc"
        app:strokeBackground="@drawable/shape_code_input"
        app:strokeBackgroundSelected="@drawable/shape_code_input_selected"
        app:strokeHeight="@dimen/view_dimen_150"
        app:strokeLength="4"
        app:strokePadding="@dimen/view_dimen_33"
        app:strokeWidth="@dimen/view_dimen_142"/>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/general__day_night__000000_60"
        android:id="@+id/tv_forget_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_60"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_password"/>
</androidx.constraintlayout.widget.ConstraintLayout>
