<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:paddingBottom="@dimen/view_dimen_42"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/view_dimen_42"
    android:paddingEnd="@dimen/view_dimen_42">
    <com.duokan.reader.ui.DebugConstraintLayout
        android:id="@+id/book1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_book_cover1"
            android:layout_width="@dimen/store_hot_category_fiction_item_image_width"
            android:layout_height="@dimen/store_hot_category_fiction_item_image_height"
            android:scaleType="fitXY"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/BookCoverStyle"/>
        <TextView
            android:textSize="@dimen/store_hot_category_fiction_item_title_size"
            android:textColor="@color/store_rank_selected__day_night__CC000000_CCFFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_title1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/general__view__dimen__106_9dp"
            android:maxLines="2"
            android:layout_marginStart="@dimen/store_hot_category_fiction_item_title_left_margin"
            app:layout_constraintStart_toEndOf="@+id/iv_book_cover1"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/store_rank_item_label_size"
            android:textColor="@color/store_hot_category_tab__day_night__text_selected__F27508_F27508"
            android:ellipsize="end"
            android:id="@+id/tv_score1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/store_hot_category_fiction_item_score_top_margin"
            android:maxLines="1"
            android:maxLength="4"
            app:layout_constraintStart_toStartOf="@+id/tv_title1"
            app:layout_constraintTop_toBottomOf="@+id/tv_title1"/>
        <TextView
            android:textSize="@dimen/store_rank_item_label_size"
            android:textColor="@color/store_rank_item_count__day_night__66000000__66FFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_label1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxLength="4"
            android:layout_marginStart="@dimen/store_hot_category_fiction_item_label_left_margin"
            app:layout_constraintStart_toEndOf="@+id/tv_score1"
            app:layout_constraintTop_toTopOf="@+id/tv_score1"/>
    </com.duokan.reader.ui.DebugConstraintLayout>
    <com.duokan.reader.ui.DebugConstraintLayout
        android:id="@+id/book2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/store_hot_category_fiction_item_between_margin">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_book_cover2"
            android:layout_width="@dimen/store_hot_category_fiction_item_image_width"
            android:layout_height="@dimen/store_hot_category_fiction_item_image_height"
            android:scaleType="fitXY"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/BookCoverStyle"/>
        <TextView
            android:textSize="@dimen/store_hot_category_fiction_item_title_size"
            android:textColor="@color/store_rank_selected__day_night__CC000000_CCFFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_title2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/general__view__dimen__106_9dp"
            android:maxLines="2"
            android:layout_marginStart="@dimen/store_hot_category_fiction_item_title_left_margin"
            app:layout_constraintStart_toEndOf="@+id/iv_book_cover2"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/store_rank_item_label_size"
            android:textColor="@color/store_hot_category_tab__day_night__text_selected__F27508_F27508"
            android:ellipsize="end"
            android:id="@+id/tv_score2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/store_hot_category_fiction_item_score_top_margin"
            android:maxLines="1"
            android:maxLength="4"
            app:layout_constraintStart_toStartOf="@+id/tv_title2"
            app:layout_constraintTop_toBottomOf="@+id/tv_title2"/>
        <TextView
            android:textSize="@dimen/store_rank_item_label_size"
            android:textColor="@color/store_rank_item_count__day_night__66000000__66FFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_label2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxLength="4"
            android:layout_marginStart="@dimen/store_hot_category_fiction_item_label_left_margin"
            app:layout_constraintStart_toEndOf="@+id/tv_score2"
            app:layout_constraintTop_toTopOf="@+id/tv_score2"/>
    </com.duokan.reader.ui.DebugConstraintLayout>
</LinearLayout>
