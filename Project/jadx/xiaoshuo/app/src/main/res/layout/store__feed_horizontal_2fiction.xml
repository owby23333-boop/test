    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/store__shared__list_item">
    <include
        android:id="@+id/store_feed_book_item1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        layout="@layout/store__feed_fiction_item_horizontal_small"/>
    <include
        android:id="@+id/store_feed_book_item2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/store__share__interval_40"
        android:layout_weight="1"
        layout="@layout/store__feed_fiction_item_horizontal_small"/>
</LinearLayout>
