<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingTop="@dimen/miuix_appcompat_dialog_progress_title_vertical_padding_top"
    android:paddingBottom="@dimen/miuix_appcompat_dialog_progress_title_vertical_padding_bottom"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/miuix_appcompat_dialog_progress_horizontal_padding"
    android:paddingEnd="@dimen/miuix_appcompat_dialog_progress_horizontal_padding">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/message_container"
        android:paddingTop="@dimen/miuix_appcompat_dialog_progress_message_padding_vertical"
        android:paddingBottom="@dimen/miuix_appcompat_dialog_progress_message_padding_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <TextView
            android:textSize="@dimen/miuix_appcompat_dialog_progress_message_text_size"
            android:gravity="center_vertical"
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="viewStart"
            style="?attr/dialogPrimaryTextAppearance"/>
        <TextView
            android:textSize="@dimen/miuix_appcompat_dialog_progress_message_text_size"
            android:gravity="center_vertical"
            android:id="@+id/progress_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/miuix_appcompat_dialog_progress_percent_margin_top"
            android:maxLines="1"
            style="?attr/dialogPrimaryTextAppearance"/>
    </LinearLayout>
    <miuix.androidbasewidget.widget.ProgressBar
        android:id="@android:id/progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/message_container"
        style="?attr/progressBarHorizontalStyle"/>
</RelativeLayout>
