<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/view_dimen_80"
        android:paddingBottom="@dimen/view_dimen_80"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__000000"
            android:id="@+id/bookshelf__wifi_book_transfer_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/view_dimen_30"
            android:fontFamily="sans-serif-medium"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__day_night__999999"
            android:id="@+id/bookshelf__wifi_book_transfer_view__subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/general__day_night__4d4d4d_b2ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__wifi_book_transfer_view__wifi_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_30"
            android:drawableTop="@drawable/bookshelf__shared__wifi"
            android:drawablePadding="@dimen/view_dimen_40"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/general__day_night__4d4d4d_b2ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/bookshelf__wifi_book_transfer_view__address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_22"
            android:layout_marginBottom="10dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_130"
            android:layout_marginTop="@dimen/view_dimen_80"
            android:layout_marginStart="@dimen/view_dimen_70"
            android:layout_marginEnd="@dimen/view_dimen_70">
            <TextView
                android:textSize="@dimen/text_font_size_42"
                android:textStyle="bold"
                android:textColor="@color/general__day_night__cc000000"
                android:gravity="center"
                android:id="@+id/bookshelf__wifi_book_transfer_view__cancel"
                android:background="@drawable/bookshelf__shared__wifi_cancel_btn_background"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/general__shared__cancel"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textSize="@dimen/general_font__shared__b"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/bookshelf__wifi_book_transfer_view__setting"
                android:background="@drawable/common_dialog_ok_btn_reader_bg"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/bookshelf__wifi_book_transfer_view__wifi_setting"
                android:singleLine="true"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="@dimen/view_dimen_40"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
