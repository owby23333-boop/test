<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/store__feed_book_grid_book_detail_count_down"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp">
    <TextView
        android:textSize="8.67dp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/store__feed_book_grid_book_detail_hours"
        android:background="@drawable/book__grid_book_detail_time_counter"
        android:layout_width="16.67dp"
        android:layout_height="16.67dp"
        android:text="05"
        android:maxLines="1"/>
    <TextView
        android:textSize="8.67sp"
        android:textColor="#9ca0a8"
        android:padding="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=":"/>
    <TextView
        android:textSize="8.67dp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/store__feed_book_grid_book_detail_minutes"
        android:background="@drawable/book__grid_book_detail_time_counter"
        android:layout_width="16.67dp"
        android:layout_height="16.67dp"
        android:text="02"
        android:maxLines="1"/>
    <TextView
        android:textSize="8.67sp"
        android:textColor="#9ca0a8"
        android:padding="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=":"/>
    <TextView
        android:textSize="8.67dp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/store__feed_book_grid_book_detail_seconds"
        android:background="@drawable/book__grid_book_detail_time_counter"
        android:layout_width="16.67dp"
        android:layout_height="16.67dp"
        android:text="10"
        android:maxLines="1"/>
</LinearLayout>
