<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__day_night__666666"
            android:gravity="center"
            android:id="@+id/bookshelf__update_book_group_title_view__count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:singleLine="true"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__day_night__ff8400"
            android:gravity="center"
            android:id="@+id/bookshelf__update_book_group_title_view__upgrade_all"
            android:background="@drawable/general__shared__button_ff8400_rectangle"
            android:layout_width="77dp"
            android:layout_height="28dp"
            android:layout_marginRight="15dp"
            android:text="@string/bookshelf__shared__update_all"
            android:singleLine="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <View
            android:id="@+id/bookshelf__purchased_book_group_title_view__bottom_line"
            android:background="@color/general__day_night__list_line_bcbcbc"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</LinearLayout>
