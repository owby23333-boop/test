<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/reading__tts_setting_view__divider_top"
        android:background="@color/general__day_night__f2f2f2"
        android:layout_width="match_parent"
        android:layout_height="10dp"/>
    <TextView
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__day_night__999999"
        android:id="@+id/reading__tts_setting_view__label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"/>
    <View
        android:background="@color/general__day_night__e9e9e9"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
