<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/tt_top_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.bytedance.sdk.openadsdk.widget.ShadowImageView
            android:gravity="center"
            android:id="@+id/tt_top_back"
            android:visibility="gone"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/tt_close_arrow_btn"
            android:layout_marginStart="12dp"/>
        <com.bytedance.sdk.openadsdk.widget.ShadowImageView
            android:gravity="center"
            android:id="@+id/tt_top_mute"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/tt_unmute"
            android:scaleType="center"
            android:layout_marginStart="12dp"/>
        <com.bytedance.sdk.openadsdk.widget.ShadowTextView
            android:textSize="14sp"
            android:textColor="@color/tt_white"
            android:gravity="center"
            android:id="@+id/tt_top_dislike"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="16dp"
            android:text="@string/tt_reward_feedback"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.bytedance.sdk.openadsdk.widget.ShadowTextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/tt_top_skip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="16dp"
                android:layout_marginEnd="16dp"/>
            <RelativeLayout
                android:gravity="center"
                android:layout_gravity="end|top"
                android:id="@+id/tt_video_ad_close_layout"
                android:background="@drawable/tt_mute_btn_bg"
                android:visibility="invisible"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="24dp"
                android:layout_marginEnd="24dp">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/tt_video_close_drawable"/>
            </RelativeLayout>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/tt_top_again"
        android:background="@drawable/ic_top_again_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="38dp"
        android:layout_below="@+id/tt_top_area"
        android:layout_centerHorizontal="true">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/tt_gift_box"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tt_top_again_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_top_arrow_right"
            android:layout_marginEnd="12dp"/>
    </LinearLayout>
</RelativeLayout>
