<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:reader="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/general__day_night__ffffff"
    android:paddingTop="13dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:padding="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.reader.ui.general.DkLabelView
            android:id="@+id/general__multiline_input_dialog__cancel"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/general__shared__cancel"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            style="@style/general__shared__button_light_29dip_c9c9c9"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__333333"
            android:id="@+id/general__multiline_input_dialog__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
        <com.duokan.reader.ui.general.DkLabelView
            android:id="@+id/general__multiline_input_dialog__save"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            style="@style/general__shared__button_29dip_e9622d"/>
    </RelativeLayout>
    <View
        android:background="@color/general__day_night__list_line_bcbcbc"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <EditText
        android:textSize="@dimen/general_font__shared__c"
        android:textColor="@color/general__day_night__333333"
        android:gravity="top|left"
        android:id="@+id/general__multiline_input_dialog__editor"
        android:background="@android:color/transparent"
        android:padding="15dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:singleLine="false"
        android:textCursorDrawable="@null"/>
</LinearLayout>
