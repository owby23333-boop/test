<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/general__free_dialog_box__container"
    android:background="@drawable/general__free_dialog_box__bg"
    android:paddingTop="@dimen/view_dimen_80"
    android:paddingBottom="@dimen/view_dimen_80"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/general__free_dialog_box__title"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:drawablePadding="@dimen/view_dimen_30"
        android:layout_marginStart="@dimen/view_dimen_80"
        android:layout_marginEnd="@dimen/view_dimen_80"
        style="@style/DialogTitle"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/general__common_dialog_contentPanel"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:layout_marginStart="@dimen/view_dimen_80"
        android:layout_marginEnd="@dimen/view_dimen_80">
        <TextView
            android:id="@+id/general__free_dialog_box__desc"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/view_dimen_40"
            android:layout_marginEnd="@dimen/view_dimen_40"
            android:lineHeight="23.3sp"
            style="@style/DialogMessage"/>
        <FrameLayout
            android:id="@+id/general__common_dialog_view__check_frame"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_30"
            android:layout_marginStart="@dimen/view_dimen_40"
            android:layout_marginEnd="@dimen/view_dimen_40"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/general__common_dialog_customPanel"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/view_dimen_50"
        android:layout_weight="1"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        android:layout_marginStart="@dimen/view_dimen_80"
        android:layout_marginEnd="@dimen/view_dimen_80">
        <Button
            android:textColor="@color/general__ffffff"
            android:id="@+id/general__free_dialog_box__count_down_cancel"
            android:background="@drawable/reading__add_book_to_launcher_controller__grey_button_count_down"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/view_dimen_40"
            style="@style/DkReader.Widget.Button"/>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/general__free_dialog_box__cancel"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/view_dimen_40"
            style="@style/DkReader.Widget.Button"/>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/general__free_dialog_box__ok"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/DkReader.Widget.Button.DkPrimary"/>
    </LinearLayout>
</LinearLayout>
