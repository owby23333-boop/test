<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:background="@color/general__shared__f2f2f2"
        android:layout_width="match_parent"
        android:layout_height="10dp"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/general__shared__343434"
        android:id="@+id/reading__comment_view__related_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="15dp"
        android:layout_marginBottom="12dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/reading__comment_view__related_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:scaleType="fitCenter"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/reading__comment_view__related_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>
    <FrameLayout
        android:id="@+id/reading__comment_view__view_topic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:background="#e5e5e5"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#6fa8d9"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reading__comment_view__view_topic"/>
    </FrameLayout>
</LinearLayout>
