<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#66000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/dkmibrowsershopad__ad_view_icon"
        android:layout_width="58.66dp"
        android:layout_height="58.66dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4"
        app:radius="@dimen/view_dimen_20"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="@color/dkcommon__day_night__ffffff"
        android:gravity="center"
        android:id="@+id/dkmibrowsershopad__ad_view_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/view_dimen_50"
        android:layout_marginTop="@dimen/view_dimen_30"
        android:layout_marginRight="@dimen/view_dimen_50"
        android:maxWidth="165dp"
        android:singleLine="true"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_icon"/>
    <TextView
        android:textSize="@dimen/view_dimen_36"
        android:textColor="@color/dkcommon__day_night__ffffff"
        android:ellipsize="end"
        android:id="@+id/dkmibrowsershopad__ad_view_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_37"
        android:maxWidth="165dp"
        android:maxLines="2"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_title"/>
    <include
        android:textColor="@color/dkcommon__day_night__333333"
        android:gravity="center"
        android:id="@+id/dkmibrowsershopad__ad_view_big_button_area"
        android:background="@drawable/general__shared__rounded_button_yellow"
        android:layout_width="166dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_summary"
        layout="@layout/dkmibrowsershopad__ad_big_button_view2"/>
    <TextView
        android:textSize="@dimen/text_font_size_40"
        android:textColor="#ffd014"
        android:id="@+id/dkmibrowsershopad__yimi_video_end_view_replay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/dkmibrowsershopad__ad_view_video_replay"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_big_button_area"/>
</androidx.constraintlayout.widget.ConstraintLayout>
