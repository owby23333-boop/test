<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="44dp">
        <ImageView
            android:id="@+id/tt_titlebar_back"
            android:paddingLeft="5dp"
            android:paddingTop="5dp"
            android:paddingRight="5dp"
            android:paddingBottom="5dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/tt_leftbackicon_selector"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/tt_titlebar_close"
            android:paddingLeft="5dp"
            android:paddingTop="5dp"
            android:paddingRight="5dp"
            android:paddingBottom="5dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/tt_titlebar_close_seletor"
            android:layout_toRightOf="@+id/tt_titlebar_back"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/tt_titlebar_back"/>
        <RelativeLayout
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp">
                <ImageView
                    android:id="@+id/tt_titlebar_gift_icon"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_marginRight="6dp"
                    android:src="@drawable/tt_gift_box"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:gravity="center"
                    android:id="@+id/tt_titlebar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请稍后..."
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
        <TextView
            android:textColor="@drawable/tt_feedback_text_color"
            android:ellipsize="marquee"
            android:gravity="end"
            android:id="@+id/tt_titlebar_dislike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:text="@string/tt_feedback"
            android:singleLine="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="15dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/tt_titlebar_detail_layout"
        android:background="#ffffff"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="77dp">
        <ImageView
            android:background="#f2f2f2"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#999999"
            android:ellipsize="end"
            android:id="@+id/tt_titlebar_developer"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="16dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#999999"
            android:ellipsize="end"
            android:id="@+id/tt_titlebar_app_name"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="7dp"
            android:layout_marginRight="16dp"
            android:singleLine="true"/>
        <RelativeLayout
            android:background="#26c4c4c4"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp">
            <TextView
                android:textSize="12sp"
                android:textColor="#1a73e8"
                android:gravity="center"
                android:id="@+id/tt_titlebar_app_detail"
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="64dp"
                android:text="@string/tt_common_download_app_detail"
                android:layout_alignParentLeft="true"
                android:layout_marginStart="64dp"
                android:layout_alignParentStart="true"/>
            <ImageView
                android:background="#d8d8d8"
                android:layout_width="0.5dp"
                android:layout_height="9dp"
                android:layout_centerInParent="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#1a73e8"
                android:gravity="center"
                android:id="@+id/tt_titlebar_app_privacy"
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:layout_marginRight="64dp"
                android:text="@string/tt_common_download_app_privacy"
                android:layout_alignParentRight="true"
                android:layout_marginEnd="64dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
