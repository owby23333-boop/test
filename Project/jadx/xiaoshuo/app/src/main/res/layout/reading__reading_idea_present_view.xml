<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/general__shared__ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="77dp">
        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/reading__reading_idea_present_view__back"
            android:paddingLeft="25dp"
            android:paddingTop="15dp"
            android:paddingRight="25dp"
            android:paddingBottom="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/general__day_night__back"
            android:scaleType="center"/>
        <TextView
            android:textSize="18sp"
            android:textColor="#000000"
            android:ellipsize="end"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:text="@string/reading__reading_idea_present_view__header"
            android:singleLine="true"/>
        <View
            android:layout_gravity="bottom"
            android:background="#000000"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
    </FrameLayout>
    <TextView
        android:textSize="15sp"
        android:textColor="#000000"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/reading__reading_idea_present_view__sample"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginLeft="25dp"
        android:layout_marginRight="25dp"
        android:singleLine="true"/>
    <View
        android:background="@color/general__shared__eeeeee"
        android:layout_width="match_parent"
        android:layout_height="10dp"/>
    <com.duokan.reader.ui.general.DkListPager
        android:id="@+id/reading__reading_idea_present_view__page_seeker"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <View
        android:background="@color/general__shared__e2e2e2"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <include
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        layout="@layout/reading__shared_input_view"/>
</LinearLayout>
