<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__shared__ffffff"
    android:layout_width="match_parent"
    android:layout_height="83.5dp">
    <FrameLayout
        android:id="@+id/general__page_back"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true">
        <ImageView
            android:layout_gravity="bottom"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginBottom="17dp"
            android:src="@drawable/general__shared__icon_header_back"
            android:layout_marginStart="24.5dp"/>
    </FrameLayout>
    <TextView
        android:textSize="21sp"
        android:textColor="@android:color/black"
        android:ellipsize="end"
        android:id="@+id/general__page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:maxWidth="390dp"
        android:maxLines="1"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:id="@+id/general__page_sub_title"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_alignTop="@+id/general__page_title"
        android:layout_marginEnd="22.7dp"
        android:layout_alignParentEnd="true"/>
    <View
        android:id="@+id/general__shared__simple_header_bottom_line"
        android:background="@android:color/black"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
