<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__shared__fefaf8"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/reading__addnotedlg_view__btns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.duokan.reader.ui.general.DkLabelView
                    android:layout_gravity="center"
                    android:id="@+id/reading__addnotedlg_view__cancel"
                    android:layout_width="56dp"
                    android:text="@string/reading__addnotedlg_view__cancel"
                    style="@style/general__shared__button_light_29dip_c9c9c9"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__b"
                    android:textColor="@android:color/black"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__addnotedlg_view__note"
                    android:layout_weight="1"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:layout_gravity="center"
                    android:id="@+id/reading__addnotedlg_view__save"
                    android:layout_width="56dp"
                    android:text="@string/reading__addnotedlg_view__save"
                    style="@style/general__shared__button_29dip_257fd2"/>
            </LinearLayout>
            <View
                android:background="@color/general__shared__eed1d0"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <View
                android:background="@color/general__shared__eed1d0"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="1.5dp"/>
            <com.duokan.core.ui.LinearScrollView
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <com.duokan.reader.ui.general.PinView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__8d6752"
                    android:ellipsize="end"
                    android:id="@+id/reading__addnotedlg_view__sample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginRight="15dp"
                    android:maxLines="4"/>
                <EditText
                    android:scrollbarStyle="insideOverlay"
                    android:textSize="@dimen/general_font__shared__c"
                    android:gravity="top"
                    android:id="@+id/reading__addnotedlg_view__note"
                    android:background="@android:color/transparent"
                    android:paddingLeft="18dp"
                    android:paddingTop="10dp"
                    android:paddingRight="18dp"
                    android:paddingBottom="15dp"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:singleLine="false"
                    android:lineSpacingMultiplier="1.2"/>
            </com.duokan.core.ui.LinearScrollView>
        </LinearLayout>
    </LinearLayout>
</com.duokan.core.ui.BoxView>
