<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/store__selected_feed_item__center_shadow"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="17sp"
        android:textColor="#6c737e"
        android:ellipsize="end"
        android:id="@+id/store__selected_feed_item__center_summary"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="58dp"
        android:maxLines="5"
        android:drawablePadding="10dp"
        android:layout_alignParentTop="true"
        android:lineSpacingExtra="8dp"/>
    <TextView
        android:textSize="17sp"
        android:textColor="#6c737e"
        android:ellipsize="end"
        android:id="@+id/store__selected_feed_item__center_summary_type1"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="18dp"
        android:maxLines="5"
        android:drawablePadding="10dp"
        android:lineSpacingExtra="7.67dp"
        android:layout_marginStart="15.33dp"
        android:layout_marginEnd="15.33dp"/>
    <View
        android:id="@+id/store__selected_feed_item__center_bottom_shadow"
        android:background="@drawable/store__selected_feed_item__center_mask"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"/>
    <TextView
        android:textSize="16sp"
        android:textColor="#ff8400"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/store__selected_feed_item__center_bottom_more"
        android:background="@drawable/store__selected_feed_item__center_btn_bg"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:text="@string/store__selected_feed_item__center_bottom_more_text"
        android:maxLines="5"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="15.33dp"
        android:layout_marginEnd="15.33dp"/>
</RelativeLayout>
