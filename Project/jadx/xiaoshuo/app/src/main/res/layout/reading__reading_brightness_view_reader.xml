<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__shared__141414f2"
    android:paddingTop="25dp"
    android:paddingBottom="25dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">
    <com.duokan.core.ui.BoxView
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="400dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__ffffffcc"
                    android:gravity="center"
                    android:id="@+id/reading__reading_brightness_view__eyes_saving"
                    android:background="@drawable/reading__reading_options_view__text_background"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_brightness_view__eyes_saving"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__ffffffcc"
                    android:gravity="center"
                    android:id="@+id/reading__reading_brightness_view__night_mode"
                    android:background="@drawable/reading__reading_options_view__text_background"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:text="@string/reading__reading_brightness_view__night_mode"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="#999999"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_brightness_view__brightness"
                    android:layout_marginEnd="12dp"/>
                <SeekBar
                    android:id="@+id/reading__reading_brightness_view__seek_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:max="1000"
                    android:progressDrawable="@drawable/reading__reading_options_view__seek_brightness_normal"
                    android:thumb="@drawable/general__shared__seek_bar_thumb"
                    android:thumbOffset="10dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/reading__reading_brightness_view__brightness_seek_bar"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>
                <com.duokan.reader.ui.general.DkLabelView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__ffffffcc_pressed_selected_checked"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/reading__reading_brightness_view__auto_brightness"
                    android:background="@drawable/reading__reading_options_view__text_background"
                    android:paddingLeft="15dp"
                    android:paddingRight="15dp"
                    android:layout_width="81dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_options_view__brightness_auto"/>
            </LinearLayout>
        </LinearLayout>
    </com.duokan.core.ui.BoxView>
</FrameLayout>
