<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="@color/general__text__day_night__999999"
        android:id="@+id/personal__read_history_item_view__time_flag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_52"
        android:layout_marginBottom="@dimen/view_dimen_15"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/view_dimen_42"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingTop="@dimen/view_dimen_25"
        android:paddingBottom="@dimen/view_dimen_25"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackground"
        android:paddingStart="@dimen/view_dimen_42">
        <com.duokan.dkbookshelf.ui.drawable.DkShelfCoverView
            android:layout_gravity="center_vertical"
            android:id="@+id/personal__read_history_item_view__image"
            android:background="@drawable/personal__read_history_item_view__image_bg"
            android:padding="1px"
            android:layout_width="@dimen/view_dimen_159"
            android:layout_height="@dimen/view_dimen_225"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:radius="@dimen/view_dimen_12"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/personal__read_history_item_view__container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/view_dimen_24"
            android:layout_marginEnd="@dimen/view_dimen_22"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/personal__read_history__add_bookshelf"
            app:layout_constraintStart_toEndOf="@+id/personal__read_history_item_view__image"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__day_night__333333_ffffff"
                android:id="@+id/personal__read_history_item_view__name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textSize="@dimen/text_font_size_34"
                android:textColor="@color/general__text__day_night__999999"
                android:id="@+id/personal__read_history_item_view__position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_20"
                android:singleLine="true"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/view_dimen_36"
            android:gravity="center"
            android:id="@+id/personal__read_history__add_bookshelf"
            android:visibility="visible"
            android:layout_width="@dimen/view_dimen_212"
            android:layout_height="@dimen/view_dimen_80"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="@dimen/view_dimen_42"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/personal__read_history_item_view__container"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <CheckBox
            android:enabled="true"
            android:id="@+id/elegant__mine_book_item__select"
            android:focusable="false"
            android:visibility="gone"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@drawable/general__shared__multi_checkbox"
            app:layout_constraintBottom_toBottomOf="@+id/personal__read_history__add_bookshelf"
            app:layout_constraintLeft_toLeftOf="@+id/personal__read_history__add_bookshelf"
            app:layout_constraintRight_toRightOf="@+id/personal__read_history__add_bookshelf"
            app:layout_constraintTop_toTopOf="@+id/personal__read_history__add_bookshelf"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
