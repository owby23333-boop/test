<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__day_night__dialog_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="@dimen/general__shared_dimen__16_67sp"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__000000"
            android:layout_gravity="center_horizontal"
            android:id="@+id/general__common_dialog_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__26_67dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__16_67dp"
            android:text="@string/privacy__privacy_vesion_update_title"/>
        <ScrollView
            android:id="@+id/general__common_dialog_view__prompt_scroll"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">
            <TextView
                android:textSize="@dimen/general__shared_dimen__16sp"
                android:textColor="@color/general__day_night__000000cc"
                android:id="@+id/general__common_dialog_view__prompt"
                android:scrollbars="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxHeight="@dimen/view_dimen_910"
                android:text="@string/privacy__privacy_vesion_update_content"
                android:paddingHorizontal="@dimen/general__shared_dimen__23_33dp"
                android:justificationMode="inter_word"/>
        </ScrollView>
        <TextView
            android:textSize="@dimen/general__shared_dimen__12_67sp"
            android:textStyle="bold"
            android:textColor="@color/general__day_night__0000004d"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/general__common_dialog_view__cancel"
            android:paddingTop="@dimen/general__shared_dimen__13dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/general__shared__app_exit"/>
        <TextView
            android:textSize="@dimen/text_font_size_48"
            android:textColor="@color/general__shared__ffffff"
            android:gravity="center"
            android:id="@+id/general__common_dialog_view__ok"
            android:background="@color/general__shared_primary_color"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/general__shared_dimen__10dp"
            android:text="@string/welcome__privacy_notify__ok"/>
    </LinearLayout>
</com.duokan.core.ui.BoxView>
