<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/reading__tts_ad_bottom_sheet_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/view_dimen_1272">
    <View
        android:layout_gravity="center_horizontal"
        android:background="@drawable/reading__tts_speaker_dash_line"
        android:layout_width="@dimen/view_dimen_165"
        android:layout_height="@dimen/view_dimen_8"
        android:layout_marginTop="@dimen/view_dimen_25"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/view_dimen_90">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/text_font_size_44"
                android:textStyle="bold"
                android:textColor="@color/color_6B2200"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reading__tts_ad_title"
                android:fontFamily="mipro-semibold"
                android:textFontWeight="520"/>
            <ImageButton
                android:layout_gravity="end"
                android:id="@+id/bt_tts_ad_tips"
                android:background="@null"
                android:layout_width="@dimen/view_dimen_54"
                android:layout_height="@dimen/view_dimen_54"
                android:src="@drawable/ic_tts_ad_tips"
                android:scaleType="fitCenter"
                android:contentDescription="@string/free_reading__auto_scroll_tips"
                android:layout_marginEnd="@dimen/view_dimen_48"/>
        </FrameLayout>
        <com.duokan.reader.ui.reading.view.CircleFrameLayout
            android:layout_gravity="center_horizontal"
            android:layout_width="@dimen/view_dimen_462"
            android:layout_height="@dimen/view_dimen_462"
            android:layout_marginTop="@dimen/view_dimen_68">
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lav_progress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:translationY="@dimen/view_dimen_462"
                app:lottie_autoPlay="true"
                app:lottie_fileName="wave.json"
                app:lottie_repeatCount="-1"/>
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/reading__tts_ad_progress_bg"
                android:scaleType="centerCrop"/>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_font_size_36"
                    android:textColor="@color/color_6B2200"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__tts_ad_time_title"/>
                <TextView
                    android:textSize="@dimen/text_font_size_72"
                    android:textStyle="bold"
                    android:textColor="@color/color_6B2200"
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </com.duokan.reader.ui.reading.view.CircleFrameLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_77"
            android:layout_marginTop="@dimen/view_dimen_23"
            android:layout_marginBottom="@dimen/view_dimen_12"
            android:layout_marginEnd="@dimen/view_dimen_48">
            <TextView
                android:textSize="@dimen/view_dimen_30"
                android:textColor="@color/black_60_transparent"
                android:gravity="center"
                android:layout_gravity="start|top"
                android:id="@+id/tv_item_enable_tips"
                android:background="@drawable/bg_tts_ad_item_enable_tips"
                android:paddingBottom="@dimen/view_dimen_16"
                android:visibility="gone"
                android:layout_width="@dimen/view_dimen_550"
                android:layout_height="@dimen/view_dimen_77"
                android:layout_marginStart="@dimen/view_dimen_48"
                android:paddingHorizontal="@dimen/view_dimen_12"/>
            <TextView
                android:textSize="@dimen/view_dimen_30"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="end|top"
                android:id="@+id/tv_all_day_free_tips_click"
                android:background="@drawable/bg_tts_ad_all_day_free_tips_click"
                android:visibility="gone"
                android:layout_width="@dimen/view_dimen_260"
                android:layout_height="@dimen/view_dimen_64"
                android:text="@string/reading__tts_ad_all_day_free_tips_click"
                android:paddingEnd="@dimen/view_dimen_16"/>
            <TextView
                android:textSize="@dimen/view_dimen_30"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="end|top"
                android:id="@+id/tv_all_day_free_tips"
                android:background="@drawable/bg_tts_ad_all_day_free_tips"
                android:paddingBottom="@dimen/view_dimen_16"
                android:visibility="gone"
                android:layout_width="@dimen/view_dimen_338"
                android:layout_height="@dimen/view_dimen_77"/>
        </FrameLayout>
        <miuix.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ad"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_206"
            android:paddingHorizontal="@dimen/view_dimen_42"/>
        <TextView
            android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/white_95_transparent"
            android:gravity="center"
            android:id="@+id/tv_jump"
            android:background="@drawable/elegant__personal_login__dialog_btn_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/view_dimen_140"
            android:layout_marginTop="@dimen/view_dimen_48"
            android:fontFamily="sans-serif-medium"
            android:layout_marginHorizontal="@dimen/view_dimen_48"
            android:textFontWeight="450"/>
    </LinearLayout>
</FrameLayout>
