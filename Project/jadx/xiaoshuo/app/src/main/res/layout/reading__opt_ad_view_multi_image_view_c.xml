<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading__large_image_view__image_multi"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/view_dimen_50"
    android:layout_marginStart="@dimen/view_dimen_40"
    android:layout_marginEnd="@dimen/view_dimen_40">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__multi_image_view__img1"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"/>
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__multi_image_view__img2"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        android:layout_marginStart="@dimen/view_dimen_12"
        android:layout_marginEnd="@dimen/view_dimen_12"
        app:layout_constraintEnd_toStartOf="@+id/reading__multi_image_view__img3"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img1"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"/>
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/reading__multi_image_view__img3"
        android:layout_width="0dp"
        android:layout_height="@dimen/view_dimen_204"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/reading__multi_image_view__img2"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"/>
    <ImageView
        android:layout_gravity="end|bottom"
        android:id="@+id/reading__app_ad_view__close"
        android:layout_width="@dimen/view_dimen_77"
        android:layout_height="@dimen/view_dimen_30"
        android:layout_marginBottom="@dimen/view_dimen_20"
        android:src="@drawable/reading__ad_view_close_c"
        android:layout_marginEnd="@dimen/view_dimen_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
