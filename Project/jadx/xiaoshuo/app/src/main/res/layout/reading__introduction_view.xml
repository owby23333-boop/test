<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.view.FontTextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="@color/general__text__day_night__333333"
        android:id="@+id/reading__introduction_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="男主角身份之一是爸爸，为女儿儿子保驾护航，且独得萌宝偏爱男主角身份之一是爸爸，为女儿…"
        android:maxLines="2"
        app:setNormalBold="true"/>
    <ImageView
        android:layout_gravity="bottom|right"
        android:id="@+id/reading__introduction_expand"
        android:paddingLeft="@dimen/view_dimen_40"
        android:paddingTop="@dimen/view_dimen_20"
        android:paddingBottom="@dimen/view_dimen_20"
        android:layout_width="@dimen/view_dimen_110"
        android:layout_height="@dimen/view_dimen_60"
        android:src="@drawable/store__fiction_detail_view_intro_arrow"
        android:scaleType="fitCenter"
        android:layout_alignParentEnd="true"/>
</FrameLayout>
