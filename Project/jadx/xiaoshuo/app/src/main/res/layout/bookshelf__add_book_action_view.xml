<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/bookshelf__add_book_action_view__background"
        android:background="@color/black_60_transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/bookshelf__add_book_action_view__content"
        android:background="@color/general__day_night__ffffff_212121"
        android:paddingTop="@dimen/view_dimen_65"
        android:paddingBottom="@dimen/view_dimen_70"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/view_dimen_55"
        android:paddingEnd="@dimen/view_dimen_60">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bookshelf__import_local_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/bookshelf__import_local_books__image"
                android:layout_width="20dp"
                android:layout_height="23dp"
                android:src="@drawable/bookshelf__import_local_books__icon"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="@+id/bookshelf__import_local_books__title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/bookshelf__import_local_books__title"/>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_local_books__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf__add_book__import_local_books__title"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_local_books__image"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__text__day_night__999999"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_local_books__description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_20"
                android:text="@string/bookshelf__add_book__import_local_books__description"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_local_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_local_books__title"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__text__day_night__999999"
                android:ellipsize="end"
                android:id="@+id/bookshelf__view__close"
                android:paddingBottom="@dimen/view_dimen_55"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf__add_books_view__close"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:paddingStart="@dimen/view_dimen_55"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/bookshelf__import_local_books__title"
                app:layout_constraintVertical_bias="0"/>
            <View
                android:background="@color/general__day_night__ebebeb_2a2a2a"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="@dimen/view_dimen_55"
                app:layout_constraintStart_toStartOf="@+id/bookshelf__import_local_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_local_books__description"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bookshelf__import_hot_list_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_55">
            <ImageView
                android:id="@+id/bookshelf__import_hot_list_books__image"
                android:layout_width="20dp"
                android:layout_height="23dp"
                android:src="@drawable/bookshelf__import_hot_list_books__icon"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="@+id/bookshelf__import_hot_list_books__title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/bookshelf__import_hot_list_books__title"/>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_hot_list_books__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf__add_book__import_hot_list_books__title"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_hot_list_books__image"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__text__day_night__999999"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_hot_list_books__description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_20"
                android:text="@string/bookshelf__add_book__import_hot_list_books__description"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_hot_list_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_hot_list_books__title"/>
            <View
                android:background="@color/general__day_night__ebebeb_2a2a2a"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="@dimen/view_dimen_55"
                app:layout_constraintStart_toStartOf="@+id/bookshelf__import_hot_list_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_hot_list_books__description"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bookshelf__import_library_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_55">
            <ImageView
                android:id="@+id/bookshelf__import_library_books__image"
                android:layout_width="20dp"
                android:layout_height="23dp"
                android:src="@drawable/bookshelf__import_library_books__icon"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="@+id/bookshelf__import_library_books__title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/bookshelf__import_library_books__title"/>
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_library_books__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf__add_book__import_library_books__title"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_library_books__image"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__text__day_night__999999"
                android:ellipsize="end"
                android:id="@+id/bookshelf__import_library_books__description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_20"
                android:text="@string/bookshelf__add_book__import_library_books__description"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/view_dimen_28"
                app:layout_constraintStart_toEndOf="@+id/bookshelf__import_library_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_library_books__title"/>
            <View
                android:background="@color/general__day_night__ebebeb_2a2a2a"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="@dimen/view_dimen_55"
                app:layout_constraintStart_toStartOf="@+id/bookshelf__import_library_books__image"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__import_library_books__description"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bookshelf__recommend_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_55">
            <TextView
                android:textSize="@dimen/text_font_size_46"
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:id="@+id/bookshelf__recommend_books__title"
                android:layout_width="76dp"
                android:layout_height="30dp"
                android:text="@string/bookshelf__add_book__recommend_books__title"
                android:maxLines="1"
                android:includeFontPadding="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/general__text__day_night__999999"
                android:ellipsize="end"
                android:id="@+id/bookshelf__recommend_books__description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_16"
                android:text="@string/bookshelf__add_book__recommend_books__description_personal"
                android:maxLines="1"
                android:includeFontPadding="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__recommend_books__title"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bookshelf__recommend_books__list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_45"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__recommend_books__description">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/bookshelf__recommend_books__first_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.duokan.reader.ui.general.RoundImageView
                        android:id="@+id/bookshelf__recommend_books__first"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="@dimen/view_dimen_244"
                        android:scaleType="centerCrop"
                        app:radius="@dimen/view_dimen_12"
                        app:strokeWidth="@dimen/view_dimen_1"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_38"
                        android:textColor="@color/general__text__day_night__333333"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/bookshelf__recommend_books_title__first"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_24"
                        android:lines="2"
                        android:includeFontPadding="false"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/bookshelf__recommend_books__second_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toStartOf="@+id/bookshelf__recommend_books__third_view"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toEndOf="@+id/bookshelf__recommend_books__first_view"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.duokan.reader.ui.general.RoundImageView
                        android:id="@+id/bookshelf__recommend_books__second"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="@dimen/view_dimen_244"
                        android:scaleType="centerCrop"
                        app:radius="@dimen/view_dimen_12"
                        app:strokeWidth="@dimen/view_dimen_1"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_38"
                        android:textColor="@color/general__text__day_night__333333"
                        android:ellipsize="end"
                        android:id="@+id/bookshelf__recommend_books_title__second"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_24"
                        android:lines="2"
                        android:includeFontPadding="false"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/bookshelf__recommend_books__third_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toStartOf="@+id/bookshelf__recommend_books__fourth_view"
                    app:layout_constraintStart_toEndOf="@+id/bookshelf__recommend_books__second_view"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.duokan.reader.ui.general.RoundImageView
                        android:id="@+id/bookshelf__recommend_books__third"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="@dimen/view_dimen_244"
                        android:scaleType="centerCrop"
                        app:radius="@dimen/view_dimen_12"
                        app:strokeWidth="@dimen/view_dimen_1"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_38"
                        android:textColor="@color/general__text__day_night__333333"
                        android:ellipsize="end"
                        android:id="@+id/bookshelf__recommend_books_title__third"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_24"
                        android:lines="2"
                        android:includeFontPadding="false"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/bookshelf__recommend_books__fourth_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.duokan.reader.ui.general.RoundImageView
                        android:id="@+id/bookshelf__recommend_books__fourth"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="@dimen/view_dimen_244"
                        android:scaleType="centerCrop"
                        app:radius="@dimen/view_dimen_12"
                        app:strokeWidth="@dimen/view_dimen_1"/>
                    <TextView
                        android:textSize="@dimen/text_font_size_38"
                        android:textColor="@color/general__text__day_night__333333"
                        android:ellipsize="end"
                        android:id="@+id/bookshelf__recommend_books_title__fourth"
                        android:layout_width="@dimen/view_dimen_183"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_24"
                        android:lines="2"
                        android:includeFontPadding="false"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textColor="@color/general__text__day_night__333333"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/bookshelf__recommend_books__change"
                android:background="@drawable/store__feed_corner55_f7f7f7"
                android:layout_width="match_parent"
                android:layout_height="@dimen/view_dimen_110"
                android:layout_marginTop="@dimen/view_dimen_45"
                android:maxWidth="@dimen/view_dimen_183"
                android:text="@string/bookshelf__add_book__recommend_books__change"
                android:maxLines="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bookshelf__recommend_books__list"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</FrameLayout>
