<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="56dp"
    android:paddingTop="12dp"
    android:paddingRight="56dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/general__choose_user_channel_view__content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/general__choose_user_channel_view__image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="center"/>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#e6000000"
                android:id="@+id/general__choose_user_channel_view__title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/personal__user_type_view__pub"
                android:includeFontPadding="false"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#80000000"
                android:ellipsize="end"
                android:id="@+id/general__choose_user_channel_view__description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>
    <CheckBox
        android:layout_gravity="center"
        android:id="@+id/general__choose_user_channel_view__checkbox"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="false"
        android:button="@drawable/general__choose_user_channel_view__checkbox"/>
</FrameLayout>
