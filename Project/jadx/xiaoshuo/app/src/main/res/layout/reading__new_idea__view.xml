<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/general__shared__idea_dialog_background"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.83"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1">
        <ImageView
            android:id="@+id/reading__new_idea__view_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__20_67dp"
            android:src="@drawable/reading__new_idea__view_back"
            android:layout_marginStart="@dimen/general__shared_dimen__23_33dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/general__shared_dimen__15_33sp"
            android:textColor="@color/general__day_night__1f2126"
            android:id="@+id/reading__new_idea__view_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/reading__new_idea__view_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reading__new_idea__view_back"/>
        <View
            android:id="@+id/reading__new_idea__view_base_line"
            android:background="@color/general__day_night__dfe2e6"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__0_33dp"
            android:layout_marginTop="@dimen/general__shared_dimen__20dp"
            app:layout_constraintTop_toBottomOf="@+id/reading__new_idea__view_back"/>
        <com.duokan.reader.ui.general.DkWebListView
            android:id="@+id/reading__new_idea__view_list_view"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/general__shared_dimen__18_7dp"
            app:layout_constraintBottom_toTopOf="@+id/reading__new_idea__view_base_line2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__new_idea__view_base_line"/>
        <View
            android:id="@+id/reading__new_idea__view_base_line2"
            android:background="@color/general__day_night__dfe2e6"
            android:layout_width="match_parent"
            android:layout_height="@dimen/general__shared_dimen__0_33dp"
            android:layout_marginTop="@dimen/general__shared_dimen__30dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__60dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/reading__new_idea__view_base_edit_layout"
            android:background="@drawable/reading__new_idea_present_view__edittext_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/general__shared_dimen__10dp"
            android:layout_marginBottom="@dimen/general__shared_dimen__10dp"
            android:layout_marginStart="@dimen/general__shared_dimen__18_7dp"
            android:layout_marginEnd="@dimen/general__shared_dimen__18_7dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reading__new_idea__view_base_line2"
            app:layout_constraintVertical_bias="1">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__idea_present_view__anchor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/general__shared_dimen__6dp"
                android:layout_marginBottom="@dimen/general__shared_dimen__6dp"
                android:src="@drawable/reading__new_idea_present_view__idea_editor_anchor"
                android:contentDescription="@null"
                android:layout_marginStart="@dimen/general__shared_dimen__10dp"
                android:layout_marginEnd="@dimen/general__shared_dimen__3_33dp"/>
            <TextView
                android:textSize="@dimen/general__shared_dimen__12_67sp"
                android:textColor="@color/general__day_night__abaeb3"
                android:textColorHint="@color/general__day_night__abaeb3"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__idea_present_view__edittext"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/reading__reading_menu_bottom_view__idea_editor_hint"
                android:layout_weight="1"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
