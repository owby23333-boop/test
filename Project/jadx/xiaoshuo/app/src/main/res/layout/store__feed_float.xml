<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/store_feed_layer_image"
            android:layout_width="@dimen/store__feed_float_image_width"
            android:layout_height="@dimen/store__feed_float_image_height"
            android:layout_margin="@dimen/store__feed_float_layer_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/store_feed_layer_close"
            android:visibility="gone"
            android:layout_width="@dimen/store__feed_float_close_width"
            android:layout_height="@dimen/store__feed_float_close_width"
            android:src="@drawable/reading__float_view__close"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toTopOf="@+id/store_feed_layer_image"
            app:layout_constraintEnd_toEndOf="@+id/store_feed_layer_image"
            app:layout_constraintStart_toEndOf="@+id/store_feed_layer_image"
            app:layout_constraintTop_toTopOf="@+id/store_feed_layer_image"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>
