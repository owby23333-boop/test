<?xml version="1.0" encoding="utf-8"?>
<com.duokan.reader.ui.reading.ChaptersView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/reading__navigation_free_chapter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@string/store__book_toc_view__title">
    <include layout="@layout/reading__navigation_free_chapter_top_view"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/reading__navigation_chapters"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <com.duokan.reader.ui.store.view.ScrollBarView
            android:layout_gravity="end"
            android:id="@+id/reading__navigation_scrollbar"
            android:visibility="gone"
            android:layout_width="@dimen/view_dimen_80"
            android:layout_height="@dimen/view_dimen_800">
            <View
                android:id="@+id/general__scroll_bar_view"
                android:background="@drawable/store__fiction_detail__scroll_bar"
                android:visibility="gone"
                android:layout_width="@dimen/view_dimen_60"
                android:layout_height="@dimen/view_dimen_105"/>
        </com.duokan.reader.ui.store.view.ScrollBarView>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/reading__toc_empty_view__no_toc_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/reading__toc_empty_view__icon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/reading__toc_empty_view__icon"
                android:contentDescription="@null"/>
            <TextView
                android:textSize="28dp"
                android:id="@+id/reading__toc_empty_view__no_toc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="@string/reading__toc_empty_view__no_toc"/>
        </LinearLayout>
    </FrameLayout>
</com.duokan.reader.ui.reading.ChaptersView>
