<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/general__shared__ffffff"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.HeaderView
        android:id="@+id/reading__translation_settings__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:center_title="@string/reading__translation_settings__header"/>
    <com.duokan.core.ui.HatGridView
        android:id="@+id/reading__translation_settings__dict_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <com.duokan.reader.ui.general.DkLabelView
        android:textSize="@dimen/general_font__shared__d"
        android:textColor="@color/general__shared__8d8a88"
        android:layout_gravity="center_horizontal"
        android:padding="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reading__translation_settings__provided_by_iciba"/>
</LinearLayout>
