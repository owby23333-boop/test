<?xml version="1.0" encoding="utf-8"?>
<com.duokan.core.ui.BoxView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/reading__reading_ad_free_reward_dialog_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_100"
            android:src="@drawable/reading__reading_ad_free_reward_bg"
            android:scaleType="centerCrop"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textColor="#f8e2c5"
            android:id="@+id/reading__reading_ad_free_reward_dialog_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.3"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.63"/>
        <TextView
            android:textSize="@dimen/text_font_size_60"
            android:textColor="#f8e2c5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/view_dimen_38"
            android:text="VIP免广告"
            android:drawableRight="@drawable/reading__reading_ad_free_reward_dialog_icon"
            android:drawablePadding="@dimen/main_padding_28"
            app:layout_constraintBottom_toTopOf="@+id/reading__reading_ad_free_reward_dialog_detail"
            app:layout_constraintLeft_toLeftOf="@+id/reading__reading_ad_free_reward_dialog_detail"/>
        <ImageView
            android:id="@+id/reading__reading_ad_free_reward_dialog_xout"
            android:layout_width="@dimen/view_dimen_40"
            android:layout_height="@dimen/view_dimen_40"
            android:layout_marginTop="@dimen/view_dimen_160"
            android:layout_marginRight="@dimen/view_dimen_60"
            android:src="@drawable/reading__reading_ad_free_reward_close"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reading__reading_ad_free_reward_dialog_container"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.duokan.core.ui.BoxView>
