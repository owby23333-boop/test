<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:paddingBottom="15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/personal__message_push_item_view__state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:src="@drawable/personal__message_push_item_view__icon"/>
    <RelativeLayout
        android:paddingLeft="10dp"
        android:paddingTop="15dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="@color/general__day_night__999999"
            android:id="@+id/personal__message_push_item_view__pub_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__shared__user_name_highlight_color"
            android:ellipsize="end"
            android:id="@+id/personal__message_push_item_view__name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/personal__message_push_item_view__name"
            android:singleLine="true"
            android:layout_toLeftOf="@+id/personal__message_push_item_view__pub_time"
            android:layout_alignParentLeft="true"/>
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="@color/general__day_night__555555"
            android:gravity="fill"
            android:id="@+id/personal__message_push_item_view__desc"
            android:paddingTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/personal__message_push_item_view__name"
            android:lineSpacingExtra="6sp"/>
    </RelativeLayout>
    <CheckBox
        android:enabled="true"
        android:layout_gravity="center_vertical"
        android:id="@+id/personal__message_push_item_view__checkbox"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:button="@drawable/general__shared__multi_checkbox_gray"/>
</LinearLayout>
