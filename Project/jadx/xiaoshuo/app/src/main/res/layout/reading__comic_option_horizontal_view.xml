<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/general__shared__141414f2"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">
    <com.duokan.core.ui.BoxView
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="640dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="@color/general__shared__999999_selected"
                android:id="@+id/reading__comic_option_view__vertical"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/reading__comic_option_view__vertical"
                android:drawablePadding="15dp"
                android:layout_weight="1"
                android:drawableStart="@drawable/reading__comic_option_view__vertical"/>
            <FrameLayout
                android:id="@+id/reading__comic_option_view__horizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__999999_selected"
                    android:layout_gravity="center_horizontal"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__comic_option_view__horizontal"
                    android:drawablePadding="15dp"
                    android:drawableStart="@drawable/reading__comic_option_view__horizontal"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/reading__comic_option_view__landscape"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__999999_selected"
                    android:layout_gravity="center_horizontal"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__comic_option_view__landscape"
                    android:drawablePadding="15dp"
                    android:drawableStart="@drawable/reading__comic_option_view__landscape"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/reading__reading_mode_view__auto_pagedown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="@dimen/general_font__shared__c"
                    android:textColor="@color/general__shared__999999_selected"
                    android:layout_gravity="end"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__reading_mode_view__auto_pagedown"
                    android:drawablePadding="15dp"
                    android:drawableStart="@drawable/reading__reading_menu_bottom_view__turn_mode"/>
            </FrameLayout>
        </LinearLayout>
    </com.duokan.core.ui.BoxView>
</FrameLayout>
