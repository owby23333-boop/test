<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.duokan.reader.ui.general.PageHeaderView
        android:id="@+id/task__bind_alipay_account__header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.duokan.core.ui.LinearScrollView
        android:orientation="vertical"
        android:background="@color/general__f8f8f8"
        android:paddingLeft="19.3dp"
        android:paddingRight="19.3dp"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:src="@drawable/task__bind_alipay_account__alipay_logo"/>
        <TextView
            android:textSize="12.6sp"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.7dp"
            android:layout_marginBottom="29dp"
            android:text="@string/task__bind_alipay_account__hint"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/task__bind_alipay_account__bind"
            android:background="@drawable/task__bind_alipay_account__button_bg"
            android:layout_width="match_parent"
            android:layout_height="40.6dp"
            android:text="@string/task__bind_alipay_account__action"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#333333"
            android:id="@+id/task__bind_alipay_account__announcement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="46dp"/>
    </com.duokan.core.ui.LinearScrollView>
</LinearLayout>
