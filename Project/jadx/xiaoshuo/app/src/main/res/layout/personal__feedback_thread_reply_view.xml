<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.duokan.personal.ui.view.DkSmallFaceView
            android:id="@+id/personal__feedback_thread_reply_view__face"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="centerCrop"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp">
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#505050"
                android:id="@+id/personal__feedback_thread_reply_view__nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/general_font__shared__d"
                android:textColor="#b5b5b5"
                android:id="@+id/personal__feedback_thread_reply_view__time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"/>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#505050"
                android:id="@+id/personal__feedback_thread_reply_view__reply"
                android:paddingTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
