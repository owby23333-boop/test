<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/general_font__shared__c"
            android:textColor="#505050"
            android:id="@+id/personal__feedback_list_view__title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/general_font__shared__d"
            android:textColor="#b5b5b5"
            android:id="@+id/personal__feedback_list_view__date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/personal__feedback_list_view__unread"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
