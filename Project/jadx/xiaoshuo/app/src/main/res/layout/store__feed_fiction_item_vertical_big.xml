<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <include
        android:layout_width="@dimen/store__feed_fiction_cover_width_big"
        android:layout_height="@dimen/store__feed_fiction_cover_height_big"
        layout="@layout/store__feed_fiction_card"/>
    <TextView
        android:textSize="13.33sp"
        android:textColor="@color/general__day_night__333333"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_title"
        android:layout_width="@dimen/store__feed_fiction_cover_width_big"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lines="2"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/general__day_night__9ca0a8"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_detail"
        android:layout_width="@dimen/store__feed_fiction_cover_width_big"
        android:layout_height="wrap_content"
        android:layout_marginTop="3.3dp"
        android:maxLines="1"/>
</LinearLayout>
