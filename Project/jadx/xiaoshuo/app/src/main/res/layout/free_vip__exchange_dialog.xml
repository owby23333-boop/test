<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:background="#a6000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:layout_gravity="center"
        android:background="@drawable/free_vip__exchange_dialog_bg"
        android:layout_width="264dp"
        android:layout_height="205dp">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:background="@drawable/free_vip__exchange_success_icon"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"/>
        <ImageView
            android:layout_gravity="right"
            android:id="@+id/free_vip__exchange_dialog__cancel"
            android:padding="7dp"
            android:layout_width="25.33dp"
            android:layout_height="25.33dp"
            android:layout_marginTop="5.3dp"
            android:layout_marginRight="5.3dp"
            android:src="@drawable/general__app_store_guide_view__close"/>
        <TextView
            android:textSize="15sp"
            android:textColor="#1a1a1a"
            android:gravity="center"
            android:id="@+id/free_vip__exchange_dialog__msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="80.33dp"
            android:lineSpacingMultiplier="1.3"/>
        <View
            android:layout_gravity="bottom"
            android:background="#cccccc"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginBottom="52dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="52dp">
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#ff999999"
                android:gravity="center"
                android:id="@+id/free_vip__exchange_dialog__continue"
                android:background="@drawable/store__app_store_guide__background"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="@string/free_account__exchange_vip_continue"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
            <View
                android:background="#cccccc"
                android:layout_width="1px"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="@dimen/general_font__shared__c"
                android:textColor="#ff942b"
                android:gravity="center"
                android:id="@+id/free_vip__exchange_dialog__read"
                android:background="@drawable/store__app_store_guide__background"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="@string/free_account__exchange_vip_read"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
