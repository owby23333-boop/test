<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/general__shared__ad_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/reading__reading_bottom_ad_view"
            android:layout_width="0dp"
            android:layout_height="@dimen/general__reading__bottom_ad_height"
            android:layout_weight="1">
            <com.duokan.reader.ui.general.RoundImageView
                android:id="@+id/reading__reading_bottom_ad_view__logo"
                android:layout_width="@dimen/view_dimen_148"
                android:layout_height="@dimen/view_dimen_148"
                android:scaleType="centerCrop"
                android:layout_marginStart="@dimen/view_dimen_30"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:radius="@dimen/view_dimen_14"/>
            <View
                android:id="@+id/reading__app_ad_view__together_flag"
                android:background="@drawable/sdk_ad_tag_bg_green"
                android:visibility="gone"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_marginTop="@dimen/view_dimen_5"
                app:layout_constraintLeft_toLeftOf="@+id/reading__reading_bottom_ad_view__logo"
                app:layout_constraintTop_toTopOf="@+id/reading__reading_bottom_ad_view__logo"/>
            <TextView
                android:textSize="@dimen/text_font_size_40"
                android:textColor="@color/general__910000"
                android:id="@+id/reading__app_ad_view__together_platform_flag"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22"
                android:includeFontPadding="false"
                app:layout_constraintLeft_toRightOf="@+id/reading__app_ad_view__together_flag"
                app:layout_constraintTop_toTopOf="@+id/reading__reading_bottom_ad_view__logo"/>
            <TextView
                android:textSize="@dimen/text_font_size_24"
                android:textColor="@color/general__ffffff_90"
                android:gravity="center"
                android:id="@+id/reading__reading_bottom_ad_view__ad_label__rectangle"
                android:background="@drawable/general__page__close_ad_view_background"
                android:paddingLeft="@dimen/view_dimen_12"
                android:paddingTop="@dimen/view_dimen_3"
                android:paddingRight="@dimen/view_dimen_12"
                android:paddingBottom="@dimen/view_dimen_3"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_13"
                android:layout_marginRight="@dimen/view_dimen_13"
                android:text="@string/reading__close_ad_view__close_text"
                android:includeFontPadding="false"
                android:drawableRight="@drawable/reading__app_ad_view__close_right_x_icon"
                android:drawablePadding="@dimen/view_dimen_11"
                app:layout_constraintRight_toRightOf="@+id/reading__reading_bottom_ad_view__logo"
                app:layout_constraintTop_toTopOf="@+id/reading__reading_bottom_ad_view__logo"/>
            <TextView
                android:textSize="@dimen/text_font_size_44"
                android:textStyle="bold"
                android:textColor="@color/black_70_transparent"
                android:ellipsize="end"
                android:id="@+id/reading__reading_bottom_ad_view__title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/view_dimen_27"
                android:layout_marginTop="@dimen/view_dimen_27"
                android:maxLines="1"
                android:includeFontPadding="false"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintLeft_toRightOf="@+id/reading__reading_bottom_ad_view__logo"
                app:layout_constraintRight_toLeftOf="@+id/fl_csj"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="wrap"/>
            <FrameLayout
                android:id="@+id/fl_csj"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/view_dimen_13"
                app:layout_constraintBottom_toBottomOf="@+id/reading__reading_bottom_ad_view__title"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintLeft_toRightOf="@+id/reading__reading_bottom_ad_view__title"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@+id/reading__reading_bottom_ad_view__title">
                <ImageView
                    android:id="@+id/iv_csj"
                    android:visibility="gone"
                    android:layout_width="@dimen/view_dimen_100"
                    android:layout_height="@dimen/view_dimen_40"
                    android:src="@drawable/reading_ad_platform_csj"/>
                <TextView
                    android:textSize="@dimen/view_dimen_26"
                    android:id="@+id/reading__reading_bottom_ad_view__ad_label__square"
                    android:background="@drawable/general__shared__rounded_stroke_grey"
                    android:paddingLeft="@dimen/view_dimen_12"
                    android:paddingRight="@dimen/view_dimen_12"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reading__close_ad_view__close_text"
                    android:drawableRight="@drawable/reading__reading_bottom_ad_close"
                    android:drawablePadding="@dimen/view_dimen_11"/>
            </FrameLayout>
            <TextView
                android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/black_40_transparent"
                android:ellipsize="end"
                android:id="@+id/reading__reading_bottom_ad_view__summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/view_dimen_30"
                android:layout_marginBottom="@dimen/view_dimen_27"
                android:maxLines="1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintLeft_toLeftOf="@+id/reading__reading_bottom_ad_view__title"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintWidth_default="wrap"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <FrameLayout
            android:id="@+id/reading__app_ad_view__download_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:minWidth="@dimen/view_dimen_86">
            <TextView
                android:textSize="@dimen/text_font_size_32"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@+id/reading__app_ad_view__download"
                android:background="@drawable/general__shared__rounded_button_yellow"
                android:visibility="gone"
                android:layout_width="@dimen/view_dimen_190"
                android:layout_height="@dimen/view_dimen_72"
                android:layout_marginLeft="@dimen/view_dimen_86"
                android:layout_marginRight="@dimen/view_dimen_60"
                android:text="@string/general__shared__ad_free_experience"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
