<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.duokan.reader.ui.general.RoundImageView
        android:id="@+id/store__feed_book_common_cover"
        android:layout_width="@dimen/view_dimen_180"
        android:layout_height="@dimen/view_dimen_260"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/view_dimen_12"
        app:strokeWidth="@dimen/view_dimen_1"/>
    <TextView
        android:textSize="@dimen/text_font_size_46"
        android:textColor="#3d3d3d"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/store__feed_book_score"
        app:layout_constraintStart_toEndOf="@+id/store__feed_book_common_cover"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_42"
        android:textColor="#3d3d3d"
        android:id="@+id/store__feed_book_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_marginEnd="@dimen/view_dimen_6"
        app:layout_constraintBottom_toBottomOf="@+id/store__feed_book_common_title"
        app:layout_constraintEnd_toStartOf="@+id/store__feed_book_score_tv"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="#3d3d3d"
        android:id="@+id/store__feed_book_score_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/store__feed_book_score_unit"
        app:layout_constraintBottom_toBottomOf="@+id/store__feed_book_score"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:textSize="@dimen/text_font_size_38"
        android:textColor="@color/black_40_transparent"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_26"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/store__feed_book_common_title"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_title"/>
    <TextView
        android:textSize="@dimen/text_font_size_34"
        android:textColor="#66000000"
        android:ellipsize="end"
        android:id="@+id/store__feed_book_common_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_8"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/store__feed_book_common_title"
        app:layout_constraintTop_toBottomOf="@+id/store__feed_book_common_summary"/>
    <TextView
        android:id="@+id/tv_add_book"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/reading__recommend_add_bookshelf_text"/>
</androidx.constraintlayout.widget.ConstraintLayout>
