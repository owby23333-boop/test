<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/elegant__user_detail__layout"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground">
    <include
        android:id="@+id/elegant__user_news_item__top"
        layout="@layout/elegant__user_news_item_top"/>
    <TextView
        android:textSize="15.33sp"
        android:textColor="@color/elegant__day_night__292b33"
        android:ellipsize="end"
        android:id="@+id/elegant__user_news_item__comment_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="3"
        android:lineSpacingExtra="8dp"
        android:layout_marginStart="45.33dp"
        android:layout_marginEnd="18.67dp"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__top"/>
    <View
        android:id="@+id/elegant__user_news_item__book_area"
        android:background="@drawable/elegant__user_news_item__book_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="13.33dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:layout_marginStart="45.33dp"
        android:layout_marginEnd="18.67dp"
        app:layout_constraintBottom_toTopOf="@+id/elegant__user_news_item__bottom"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__comment_text"/>
    <TextView
        android:textColor="@color/elegant__day_night__8a8f99"
        android:ellipsize="end"
        android:id="@+id/elegant__user_news_item__quote_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="13.3dp"
        android:maxLines="2"
        android:lineSpacingExtra="6dp"
        android:layout_marginStart="13dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@+id/elegant__user_news_item__book_divider"
        app:layout_constraintEnd_toEndOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintStart_toStartOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintTop_toTopOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintVertical_chainStyle="packed"/>
    <View
        android:id="@+id/elegant__user_news_item__book_divider"
        android:background="@color/elegant__day_night__DFE2E6"
        android:layout_width="0dp"
        android:layout_height="0.33dp"
        android:layout_marginBottom="75.67dp"
        android:layout_marginStart="13.33dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintEnd_toEndOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintStart_toStartOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__quote_txt"/>
    <ImageView
        android:id="@+id/elegant__user_news_item__cover"
        android:background="@drawable/store__feed_book_cover_frame_background"
        android:layout_width="33.33dp"
        android:layout_height="48.7dp"
        android:scaleType="fitXY"
        android:layout_marginStart="13.33dp"
        app:layout_constraintBottom_toBottomOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintStart_toStartOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__book_divider"/>
    <TextView
        android:textSize="13.33sp"
        android:textColor="@color/elegant__day_night__5c5f66"
        android:ellipsize="end"
        android:id="@+id/elegant__user_news_item__title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="13.33dp"
        android:layout_marginEnd="16dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@+id/elegant__user_news_item__author"
        app:layout_constraintEnd_toEndOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/elegant__user_news_item__cover"
        app:layout_constraintTop_toTopOf="@+id/elegant__user_news_item__cover"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="11sp"
        android:textColor="@color/elegant__day_night__A8AEB3"
        android:ellipsize="end"
        android:id="@+id/elegant__user_news_item__author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:maxLines="1"
        android:layout_marginEnd="16dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@+id/elegant__user_news_item__cover"
        app:layout_constraintEnd_toEndOf="@+id/elegant__user_news_item__book_area"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/elegant__user_news_item__title"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__title"/>
    <include
        android:id="@+id/elegant__user_news_item__bottom"
        android:layout_width="match_parent"
        android:layout_height="43.67dp"
        android:layout_marginBottom="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/elegant__user_news_item__book_area"
        layout="@layout/elegant__user_news_item_bottom"/>
    <View
        android:background="@color/elegant__day_night__DFE2E6"
        android:layout_width="match_parent"
        android:layout_height="0.33dp"
        android:layout_marginStart="45.33dp"
        android:layout_marginEnd="18.67dp"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
