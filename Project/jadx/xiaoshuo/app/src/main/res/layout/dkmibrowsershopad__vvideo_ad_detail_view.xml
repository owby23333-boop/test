<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/general__shared__rounded_white_bg"
    android:padding="@dimen/view_dimen_40"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/dkmibrowsershopad__yimi_video_detail_view_x"
        android:paddingLeft="@dimen/view_dimen_39"
        android:paddingBottom="@dimen/view_dimen_39"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/dkmibrowsershopad__yimi_video_detail_view_x"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dkmibrowsershopad__yimi_video_detail_view_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/dkmibrowsershopad__yimi_video_detail_view_x"
        app:layout_constraintTop_toTopOf="parent">
        <com.duokan.reader.ui.general.RoundImageView
            android:id="@+id/dkmibrowsershopad__ad_view_icon"
            android:layout_width="58.66dp"
            android:layout_height="58.66dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:radius="@dimen/view_dimen_20"/>
        <TextView
            android:textSize="@dimen/text_font_size_40"
            android:textColor="@color/dkcommon__day_night__333333"
            android:id="@+id/dkmibrowsershopad__ad_view_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_31"
            android:singleLine="true"
            app:layout_constraintLeft_toRightOf="@+id/dkmibrowsershopad__ad_view_icon"
            app:layout_constraintTop_toTopOf="@+id/dkmibrowsershopad__ad_view_icon"/>
        <TextView
            android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/dkcommon__day_night__999999"
            android:ellipsize="end"
            android:id="@+id/dkmibrowsershopad__ad_view_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_31"
            android:layout_marginTop="@dimen/view_dimen_18"
            android:maxLines="2"
            app:layout_constraintLeft_toRightOf="@+id/dkmibrowsershopad__ad_view_icon"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__ad_view_title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:textSize="@dimen/text_font_size_40"
        android:textColor="@color/dkcommon__day_night__333333"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/view_dimen_40"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dkmibrowsershopad__yimi_video_detail_view_info"
        layout="@layout/dkmibrowsershopad__ad_big_button_view2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
