<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners
                android:topLeftRadius="@dimen/dimen20dp"
                android:bottomLeftRadius="@dimen/dimen20dp"
                android:bottomRightRadius="@dimen/dimen20dp"/>
            <solid android:color="#ffe1b3"/>
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <scale android:scaleWidth="100%">
            <shape>
                <corners android:radius="@dimen/dimen20dp"/>
                <solid android:color="@color/transparent"/>
            </shape>
        </scale>
    </item>
    <item android:id="@android:id/progress">
        <clip
            android:gravity="right"
            android:clipOrientation="horizontal">
            <scale
                android:drawable="@drawable/progress_bar_ct"
                android:scaleWidth="0%"/>
        </clip>
    </item>
</layer-list>
