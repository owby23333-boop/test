<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_root"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="right"
            android:id="@+id/iv_exitreg"
            android:padding="@dimen/dimen12dp"
            android:layout_width="@dimen/dimen40dp"
            android:layout_height="@dimen/dimen40dp"
            android:layout_marginTop="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:src="@drawable/icon_closelogin"/>
        <com.amgcyo.cuttadon.view.otherview.CustomTextView
            android:textSize="@dimen/dimen23dp"
            android:textColor="@color/text_33"
            android:id="@+id/cus_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="@dimen/dimen45dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen25dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <TextView
                android:textColor="@color/color_EC5C07"
                android:gravity="center"
                android:id="@+id/tv_countryCode"
                android:background="?android:attr/selectableItemBackground"
                android:layout_width="@dimen/dimen60dp"
                android:layout_height="match_parent"
                android:text="+86"
                android:drawablePadding="@dimen/dimen5dp"
                android:drawableEnd="@drawable/quhaojt"
                android:drawableTint="@color/color_EC5C07"/>
            <EditText
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_username"
                android:background="@color/transparency"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:hint="请输入手机号"
                android:maxLength="11"
                android:layout_weight="1"
                android:inputType="phone"/>
        </LinearLayout>
        <View
            android:background="@color/color_f1"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <EditText
                android:enabled="false"
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_smsCode"
                android:background="@color/transparency"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="请输入验证码"
                android:maxLength="6"
                android:layout_weight="1"
                android:inputType="number"/>
            <TextView
                android:enabled="false"
                android:textColor="@color/color_EC5C07"
                android:gravity="center"
                android:id="@+id/tv_getCode"
                android:layout_width="@dimen/dimen120dp"
                android:layout_height="match_parent"
                android:text="点击获取验证码"/>
        </LinearLayout>
        <View
            android:background="@color/color_f1"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <EditText
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_pwd"
                android:background="@color/transparency"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="请输入密码(由6-20位字母、数字或特殊字符组成)"
                android:layout_weight="1"
                android:inputType="textPassword"/>
        </LinearLayout>
        <View
            android:id="@+id/view_codeline"
            android:background="@color/color_f1"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_valicode"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <EditText
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_invitation_code"
                android:background="@color/transparency"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="请输入邀请码(选填)"
                android:layout_weight="1"
                android:inputType="text"/>
        </LinearLayout>
        <View
            android:id="@+id/view_line_invli"
            android:background="@color/color_f1"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <TextView
            android:textSize="@dimen/dimen15dp"
            android:textStyle="bold"
            android:textColor="@color/btn_white"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_reg"
            android:background="@drawable/bg_corners_login"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen48dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen30dp"
            android:text="立即注册"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_tip"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen35dp"
            android:layout_marginTop="@dimen/dimen10dp">
            <CheckBox
                android:layout_gravity="center"
                android:id="@+id/checkbox_private"
                android:background="@drawable/checkbox_selector"
                android:layout_width="@dimen/dimen18dp"
                android:layout_height="@dimen/dimen18dp"
                android:layout_marginRight="@dimen/dimen5dp"
                android:checked="false"
                android:button="@null"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/dimen11dp"
                android:textColor="@color/a2a9b2"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="我已阅读并同意"/>
            <TextView
                android:textSize="@dimen/dimen11dp"
                android:textColor="@color/color_EC5C07"
                android:gravity="center_vertical"
                android:id="@+id/tv_privacy"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="《隐私政策》"/>
            <TextView
                android:textSize="@dimen/dimen11dp"
                android:textColor="@color/a2a9b2"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="及"/>
            <TextView
                android:textSize="@dimen/dimen11dp"
                android:textColor="@color/color_EC5C07"
                android:gravity="center_vertical"
                android:id="@+id/tv_useragree"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="《用户协议》"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
