<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <CheckBox
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_66"
        android:id="@+id/cb_bgm_switch"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen52dp"
        android:layout_marginLeft="@dimen/dimen8dp"
        android:text="语音听书时播放背景音乐"/>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:padding="@dimen/dimen16dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen52dp">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_66"
            android:id="@+id/tv_bgm_volume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <SeekBar
            android:id="@+id/seekBar_bgm"
            android:tag="tint_accent_color"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:maxHeight="@dimen/dimen2dp"
            android:max="100"
            android:progress="100"
            android:secondaryProgress="0"
            android:layout_weight="1"/>
    </LinearLayout>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_selector_bgm"
        android:background="?attr/selectableItemBackground"
        android:paddingLeft="@dimen/dimen16dp"
        android:paddingTop="@dimen/dimen8dp"
        android:paddingRight="@dimen/dimen16dp"
        android:paddingBottom="@dimen/dimen8dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen52dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_66"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择背景音乐"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="@color/text_99"
                android:ellipsize="middle"
                android:id="@+id/tv_current_gbm_name"
                android:layout_width="@dimen/dimen200dp"
                android:layout_height="wrap_content"
                android:text="gaoshanliushui.mp3"
                android:singleLine="true"/>
        </LinearLayout>
        <ImageView
            android:layout_width="@dimen/dimen6dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:src="@drawable/icon_mine_join"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_find_bgm"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/dimen16dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen52dp">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_66"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="发现更多好听的背景音乐"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="@dimen/dimen6dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:src="@drawable/icon_mine_join"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
</LinearLayout>
