<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen56dp"
        android:layout_marginTop="@dimen/dimen10dp">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:textColor="@color/color_3E3E3E"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:text="夜间模式"
            android:layout_weight="1"/>
        <Switch
            android:id="@+id/sb_yjms"
            android:background="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen15dp"
            android:thumb="@drawable/switch_ios_thumb"
            android:track="@drawable/switch_ios_track_selector"
            style="@style/SwitchButtonStyle"/>
    </LinearLayout>
    <LinearLayout
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen25dp">
        <View
            android:layout_gravity="center"
            android:background="@color/color_EAE7E7"
            android:layout_width="@dimen/dimen20dp"
            android:layout_height="@dimen/dimen1dp"
            android:layout_marginLeft="@dimen/dimen20dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen56dp">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:textColor="@color/color_3E3E3E"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:text="护眼模式"
            android:layout_weight="1"/>
        <Switch
            android:id="@+id/sb_hyms"
            android:background="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen15dp"
            android:thumb="@drawable/switch_ios_thumb"
            android:track="@drawable/switch_ios_track_selector"
            style="@style/SwitchButtonStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen56dp">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_3E3E3E"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:text="过滤有害光比例"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_3E3E3E"
            android:gravity="center"
            android:id="@+id/tv_blue_radio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen15dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <SeekBar
        android:id="@+id/seekBar_radio"
        android:tag="tint_accent_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"
        android:maxHeight="@dimen/dimen2dp"
        android:max="80"
        android:progress="40"
        android:secondaryProgress="0"
        android:paddingStart="0dp"
        android:paddingEnd="@dimen/dimen7dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen56dp">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_3E3E3E"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:text="根据个人需求调节过滤比例"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/btn_white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/csb_default"
            android:background="@drawable/bg_corners_login"
            android:paddingTop="@dimen/dimen5dp"
            android:paddingBottom="@dimen/dimen5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen15dp"
            android:text="恢复默认"
            android:paddingStart="@dimen/dimen18dp"
            android:paddingEnd="@dimen/dimen18dp"/>
    </LinearLayout>
</LinearLayout>
