<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/translucent"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="center"
        android:id="@+id/cons_root_have_net"
        android:background="@color/translucent"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/continue_img"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:gravity="top|center_horizontal"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/color_FED587"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen10dp"
                    android:text="开启纯净模式"/>
                <TextView
                    android:textSize="@dimen/sp_24"
                    android:textColor="@color/color_FED587"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="23.5dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginRight="23.5dp"
                    android:text="无广告 | 更新快 | 更流畅"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/white"
                    android:id="@+id/tv_read_time_have_net"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen5dp"/>
                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/continue_book"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/color_002903"
                    android:gravity="center"
                    android:id="@+id/tv_look_video_have_net"
                    android:background="@drawable/bg_btn_continue_read_look_video"
                    android:layout_width="191dp"
                    android:layout_height="@dimen/dimen48dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/look_video"/>
                <com.amgcyo.cuttadon.view.otherview.LabelTextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/labeltextview"
                    android:background="@drawable/reward_bg"
                    android:paddingLeft="@dimen/dimen20dp"
                    android:paddingTop="@dimen/dimen10dp"
                    android:paddingRight="@dimen/dimen20dp"
                    android:paddingBottom="@dimen/dimen10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen15dp"
                    android:text="广告太烦？点击此处免广告"
                    app:label_backgroundColor="@color/red"
                    app:label_distance="10dp"
                    app:label_orientation="RIGHT_TOP"
                    app:label_text="推荐"
                    app:label_textColor="@color/white"
                    app:label_textSize="10sp"/>
                <TextView
                    android:textColor="@color/color_FED587"
                    android:id="@+id/tv_not_have_net"
                    android:padding="11dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen10dp"
                    android:text="返回"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/white"
                    android:id="@+id/tv_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen8dp"/>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/material_background"
        android:background="@drawable/roung_white_all"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen30dp"
        android:layout_marginRight="@dimen/dimen30dp">
        <TextView
            android:textSize="@dimen/sp_20"
            android:textColor="@color/color_dd111111"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_marginBottom="@dimen/dimen10dp"
            android:text="阅读提示"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_33"
            android:id="@+id/dialog_message"
            android:paddingLeft="@dimen/dimen20dp"
            android:paddingTop="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen20dp"
            android:paddingBottom="@dimen/dimen20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="@dimen/dimen5dp"/>
        <TextView
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_gravity="right"
            android:id="@+id/dialog_tv_ok"
            android:layout_width="@dimen/dimen68dp"
            android:layout_height="@dimen/dimen56dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:text="我知道了"/>
    </LinearLayout>
</FrameLayout>
