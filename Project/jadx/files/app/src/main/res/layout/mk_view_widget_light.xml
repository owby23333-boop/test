<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.amgcyo.cuttadon.view.lightview.RoundedImageView
        android:id="@+id/riWgInside"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="4dp"
        android:src="@mipmap/ic_theme2_read_bg"
        android:layout_centerInParent="true"
        app:img_border_width="0dp"
        app:mutate_background="true"
        app:oval="true"/>
    <ImageView
        android:id="@+id/ivWgCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <com.amgcyo.cuttadon.view.lightview.RoundedImageView
        android:id="@+id/riWgOutside"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@mipmap/ic_theme2_border"
        android:layout_centerInParent="true"
        app:img_border_width="0dp"
        app:mutate_background="true"
        app:oval="true"/>
</RelativeLayout>
