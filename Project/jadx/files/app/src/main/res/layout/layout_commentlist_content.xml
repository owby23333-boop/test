<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">
    <com.amgcyo.cuttadon.view.comment.DisInterceptNestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:background="@color/color_F6F6F6"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen48dp">
                <com.amgcyo.cuttadon.view.otherview.CustomTextView
                    android:textSize="@dimen/dimen15dp"
                    android:textColor="@color/text_33"
                    android:gravity="center"
                    android:id="@+id/tv_coment_count"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/dimen10dp"
                    android:layout_weight="2"/>
                <com.amgcyo.cuttadon.view.xtablayout.XTabLayout
                    android:layout_gravity="center"
                    android:id="@+id/xtablayout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:xTabIndicatorColor="@color/colorTheme"
                    app:xTabIndicatorHeight="@dimen/dimen2dp"
                    app:xTabIndicatorWidth="@dimen/dimen10dp"
                    app:xTabMinWidth="@dimen/dimen10dp"
                    app:xTabMode="fixed"
                    app:xTabSelectedTextColor="@color/colorTheme"
                    app:xTabSelectedTextSize="@dimen/dimen15dp"
                    app:xTabTextAppearance="@color/text_33"
                    app:xTabTextColor="@color/text_33"
                    app:xTabTextSize="@dimen/dimen13dp"/>
            </LinearLayout>
            <View
                android:background="@color/dddddd"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen0_5dp"/>
        </LinearLayout>
    </com.amgcyo.cuttadon.view.comment.DisInterceptNestedScrollView>
    <com.amgcyo.cuttadon.view.comment.NoScrollViewPager
        android:id="@+id/uc_viewpager"
        android:background="@color/color_F6F6F6"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
