<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/ll_root"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen60dp"
            android:layout_height="@dimen/dimen80dp"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginBottom="@dimen/dimen15dp"
            android:scaleType="fitXY"/>
        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/tv_ad_solgan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_logos"
            android:layout_alignLeft="@+id/iv_bookImg"
            android:layout_alignBottom="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/sp_10"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_status"
            android:background="@color/colorPrimary"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="漫画"
            android:layout_alignLeft="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"
            android:paddingStart="@dimen/dimen2dp"
            android:paddingEnd="@dimen/dimen2dp"/>
        <TextView
            android:textSize="@dimen/dimen14dp"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/tv_bookName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:maxLines="1"
            android:singleLine="true"
            android:layout_toRightOf="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/a2a9b2"
            android:id="@+id/tv_authorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_marginRight="@dimen/dimen15dp"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_below="@+id/tv_bookName"
            android:layout_alignLeft="@+id/tv_bookName"/>
        <TextView
            android:textSize="@dimen/dimen10dp"
            android:textColor="@color/ff9125"
            android:id="@+id/tv_redu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_alignBottom="@+id/tv_authorName"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tv_book_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:maxLines="2"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignLeft="@+id/tv_bookName"
            android:layout_alignBottom="@+id/iv_bookImg"/>
    </RelativeLayout>
</LinearLayout>
