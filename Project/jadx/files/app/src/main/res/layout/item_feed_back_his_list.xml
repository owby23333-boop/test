<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_F6F6F6"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/dimen15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/dimen15dp"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/tv_feedback_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:maxLines="3"
            android:lineSpacingExtra="@dimen/dimen5dp"/>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/text_66"
            android:ellipsize="end"
            android:id="@+id/tv_feedback_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/text_63"
            android:ellipsize="end"
            android:autoLink="all"
            android:linksClickable="true"
            android:id="@+id/tv_feedback_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:maxLines="6"
            android:lineSpacingExtra="@dimen/dimen5dp"
            android:textIsSelectable="true"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_99"
            android:ellipsize="end"
            android:id="@+id/tv_feedback_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
