<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_book_cache"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/dimen16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/dimen14dp"
            android:textColor="@color/text_33"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="清除书籍、漫画缓存"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/text_99"
            android:gravity="right"
            android:id="@+id/tv_book_cache_size"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="@dimen/dimen6dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:src="@drawable/icon_mine_join"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_pic_cache"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/dimen16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/dimen14dp"
            android:textColor="@color/text_33"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="清除封面缓存"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/text_99"
            android:gravity="right"
            android:id="@+id/tv_pic_cache_size"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="@dimen/dimen6dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:src="@drawable/icon_mine_join"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_ad_cache"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/dimen16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/dimen14dp"
            android:textColor="@color/text_33"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="清除其它缓存"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/text_99"
            android:gravity="right"
            android:id="@+id/tv_ad_cache_size"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="@dimen/dimen6dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:src="@drawable/icon_mine_join"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>
</LinearLayout>
