<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_F6F6F6"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/head"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen100dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"/>
    <com.amgcyo.cuttadon.view.otherview.ImageCycleView
        android:id="@+id/icv_topView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen300dp"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen15dp"
        android:layout_below="@+id/icv_topView"/>
</RelativeLayout>
