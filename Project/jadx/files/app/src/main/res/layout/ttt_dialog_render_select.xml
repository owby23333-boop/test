<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/ttt_dialog_bg_shape"
    android:layout_width="250dp"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/ttt_color_title"
        android:id="@+id/title_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:text="测试渲染类型"/>
    <RadioGroup
        android:orientation="vertical"
        android:id="@+id/radio_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_below="@+id/title_desc">
        <RadioButton
            android:textColor="@color/ttt_color_333"
            android:id="@+id/radio_native"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="自渲染"/>
        <RadioButton
            android:textColor="@color/ttt_color_333"
            android:id="@+id/radio_express1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模板（含广点通1.0）"/>
        <RadioButton
            android:textColor="@color/ttt_color_333"
            android:id="@+id/radio_express2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模板（含广点通2.0）"/>
    </RadioGroup>
    <TextView
        android:textSize="14sp"
        android:textColor="#338aff"
        android:id="@+id/confirm_btn"
        android:padding="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="12dp"
        android:text="确认"
        android:layout_below="@+id/radio_group"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/ttt_color_999"
        android:id="@+id/cancel_btn"
        android:padding="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="12dp"
        android:text="取消"
        android:layout_toLeftOf="@+id/confirm_btn"
        android:layout_below="@+id/radio_group"/>
</RelativeLayout>
