<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#fff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/callback_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/ttt_callback_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/callback_name"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/right_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="12dp"
            android:src="@drawable/ttt_arrow_selector"/>
    </LinearLayout>
    <View
        android:background="#ebebeb"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"/>
    <RelativeLayout
        android:id="@+id/callback_info_layout"
        android:background="#fafafa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/ttt_color_333"
            android:id="@+id/callback_content"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="8dp"/>
        <View
            android:background="#ebebeb"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</LinearLayout>
