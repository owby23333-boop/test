<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.amgcyo.cuttadon.view.otherview.CustomTextView
        android:textSize="@dimen/dimen15dp"
        android:textColor="@color/text_33"
        android:id="@+id/tv_theme_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginTop="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"
        android:maxLines="3"/>
    <TextView
        android:textSize="@dimen/dimen12dp"
        android:textColor="@color/a2a9b2"
        android:id="@+id/tv_theme_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginTop="@dimen/dimen8dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
    <TextView
        android:textSize="@dimen/dimen13dp"
        android:textColor="@color/a2a9b2"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_theme_remark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginTop="@dimen/dimen8dp"
        android:layout_marginRight="@dimen/dimen20dp"
        android:layout_marginBottom="@dimen/dimen15dp"
        android:maxLines="2"/>
    <View
        android:background="@color/f8f8f8"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen10dp"/>
</LinearLayout>
