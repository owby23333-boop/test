<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/translucent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/danmu_color_layout"
            android:background="@color/f8f8f8"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen52dp">
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_white"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_white_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_orange"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_orange_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_pink"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_pink_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_yellow"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_yellow_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_green"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_green_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
            <com.amgcyo.cuttadon.view.comic.DanmuColorSelectedView
                android:layout_gravity="center"
                android:id="@+id/danmu_blue"
                android:layout_width="@dimen/dimen38dp"
                android:layout_height="@dimen/dimen38dp"
                app:danmu_bg="@drawable/danmu_blue_color"/>
            <View
                android:layout_gravity="center"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen40dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/danmu_color_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="12dp"
                android:src="@drawable/menu_color_change"/>
            <EditText
                android:textSize="15sp"
                android:textColor="@color/text_33"
                android:textColorHint="@color/text_color_c_default"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/danmu_edit"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/danmu_edit_tips"
                android:singleLine="true"
                android:maxLength="21"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_17"
                android:textColor="@color/colorPrimary"
                android:layout_gravity="center_vertical"
                android:id="@+id/send_danmu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="16dp"
                android:text="发送"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
