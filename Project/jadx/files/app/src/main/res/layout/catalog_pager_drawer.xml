<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/ll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_root"
        android:background="@color/color_FDFDFD"
        android:paddingTop="@dimen/dimen32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen57dp"
            android:layout_height="@dimen/dimen75dp"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:scaleType="centerCrop"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            android:textColor="@color/color_101010"
            android:ellipsize="end"
            android:gravity="left"
            android:layout_gravity="center"
            android:id="@+id/book_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen28dp"
            android:maxLines="1"
            android:maxEms="10"
            android:singleLine="true"
            android:layout_toRightOf="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_535353"
            android:ellipsize="end"
            android:id="@+id/book_author"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginRight="@dimen/dimen14dp"
            android:drawablePadding="@dimen/dimen5dp"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_below="@+id/book_title_tv"
            android:lineSpacingExtra="4dp"
            android:layout_alignStart="@+id/book_title_tv"/>
        <ImageView
            android:id="@+id/img_right"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen20dp"
            android:src="@drawable/ic_chevron_right_black_24dp"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:id="@+id/tv_status"
            android:padding="@dimen/dimen5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginBottom="@dimen/dimen15dp"
            android:layout_below="@+id/iv_bookImg"
            android:layout_alignLeft="@+id/iv_bookImg"/>
        <TextView
            android:textColor="@color/color_4D4D4D"
            android:gravity="center"
            android:id="@+id/tv_sort"
            android:background="?android:attr/selectableItemBackground"
            android:padding="@dimen/dimen5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:text="正序"
            android:layout_below="@+id/iv_bookImg"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/view_line"
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ListView
            android:scrollbarThumbVertical="@null"
            android:scrollbarTrackVertical="@null"
            android:id="@+id/listView_index"
            android:background="@android:color/transparent"
            android:scrollbars="none"
            android:fadingEdge="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@android:color/transparent"
            android:cacheColorHint="@null"
            android:divider="@drawable/divider_horizontal_gray"
            android:dividerHeight="@dimen/dimen0_5dp"
            android:fastScrollEnabled="true"
            android:overScrollMode="never"
            android:fastScrollAlwaysVisible="false"/>
    </LinearLayout>
</LinearLayout>
