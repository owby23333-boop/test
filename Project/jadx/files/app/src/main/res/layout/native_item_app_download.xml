<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="36dp">
    <ImageView
        android:id="@+id/app_download_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ks_app_default_icon"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="16dp"
        android:layout_weight="1">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/app_download_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"/>
        <TextView
            android:textSize="11dp"
            android:textColor="#9c9c9c"
            android:ellipsize="end"
            android:id="@+id/app_download_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:includeFontPadding="false"/>
    </LinearLayout>
    <TextView
        android:textSize="11dp"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:id="@+id/app_download_btn"
        android:background="@drawable/native_item_btn_bg"
        android:layout_width="64dp"
        android:layout_height="24dp"/>
</LinearLayout>
