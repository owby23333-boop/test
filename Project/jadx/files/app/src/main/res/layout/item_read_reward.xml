<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/re_top"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen300dp">
    <ImageView
        android:id="@+id/temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"/>
    <ImageView
        android:id="@+id/iv_temp_pic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"/>
    <ImageView
        android:id="@+id/fade_cover"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="#90000000"/>
    <TextView
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_chapter_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen100dp"
        android:layout_marginBottom="@dimen/dimen20dp"/>
    <TextView
        android:enabled="true"
        android:textSize="@dimen/sp_14"
        android:textColor="@color/colorWhite"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_unlock_next"
        android:background="@drawable/cm_certification_bg"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingRight="@dimen/dimen20dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen38dp"
        android:layout_below="@+id/tv_chapter_title"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
