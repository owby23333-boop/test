<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/permission_dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="right"
        android:id="@+id/iv_close"
        android:padding="@dimen/dimen5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen10dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:src="@drawable/close_sign"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_33"
        android:gravity="center"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-5dp"
        android:text="二维码快速安装"/>
    <TextView
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:id="@+id/tv"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen5dp"
        android:text="(已保存到相册)"/>
    <ImageView
        android:id="@+id/qrcode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen5dp"
        android:layout_marginBottom="@dimen/dimen5dp"
        android:src="@drawable/icon_pic_def"/>
    <TextView
        android:textSize="@dimen/sp_13"
        android:textColor="@color/text_33"
        android:gravity="center"
        android:id="@+id/tv_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen20dp"
        android:layout_marginTop="@dimen/dimen5dp"
        android:layout_marginRight="@dimen/dimen20dp"
        android:layout_marginBottom="@dimen/dimen5dp"
        android:text="使用“微信”、“QQ”、或者其他具有扫描功能的第三方软件扫描以上二维码进行软件下载"
        android:lineSpacingExtra="@dimen/dimen2dp"/>
    <LinearLayout
        android:id="@+id/ll_button"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen45dp"
        android:layout_marginTop="@dimen/dimen10dp">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_63"
            android:gravity="center"
            android:id="@+id/tv_help"
            android:background="@drawable/text_round_bg"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="充值遇到问题"
            android:layout_weight="1"/>
        <View
            android:background="#ffebebeb"
            android:layout_width="1px"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_finish"
            android:background="@drawable/text_round_bg_colorpri"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/order_finish"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
