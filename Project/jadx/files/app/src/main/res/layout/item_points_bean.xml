<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen72dp">
    <TextView
        android:textSize="@dimen/sp_17"
        android:textColor="@color/color_050505"
        android:ellipsize="end"
        android:gravity="top"
        android:id="@+id/reg_from"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginTop="@dimen/dimen15dp"
        android:maxEms="12"
        android:singleLine="true"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/color_979FA9"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/reg_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:singleLine="true"
        android:layout_below="@+id/reg_from"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textSize="@dimen/sp_17"
        android:textColor="@color/color_FF5E00"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/reg_gold"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginRight="@dimen/dimen15dp"
        android:singleLine="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
