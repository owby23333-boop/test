<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg_round"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen20dp"
        android:layout_centerInParent="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_18"
                android:textColor="@color/text_66"
                android:gravity="center"
                android:id="@+id/tv_tips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen25dp"
                android:text="提示"/>
            <ImageView
                android:id="@+id/iv_close"
                android:padding="@dimen/dimen5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen5dp"
                android:layout_marginRight="@dimen/dimen5dp"
                android:src="@drawable/close_sign"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <com.amgcyo.cuttadon.widget.ui.AlignTextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:autoLink="web"
            android:id="@+id/tv_content"
            android:background="@android:color/white"
            android:paddingTop="@dimen/dimen8dp"
            android:paddingBottom="@dimen/dimen8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen30dp"
            android:lineSpacingExtra="@dimen/dimen5dp"/>
        <com.amgcyo.cuttadon.view.otherview.CommonShapeButton
            android:textSize="@dimen/sp_14"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/btn_kown"
            android:paddingTop="@dimen/dimen9dp"
            android:paddingBottom="@dimen/dimen9dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginBottom="@dimen/dimen10dp"
            android:text="我知道了"
            android:paddingStart="@dimen/dimen18dp"
            android:paddingEnd="@dimen/dimen18dp"
            app:csb_cornerRadius="@dimen/dimen5dp"
            app:csb_fillColor="@color/text_ff500a"
            app:csb_shapeMode="rectangle"/>
        <TextView
            android:textSize="@dimen/sp_10"
            android:textColor="@color/a2a9b2"
            android:gravity="center"
            android:autoLink="web"
            android:layout_gravity="center"
            android:id="@+id/tv_ad_tips"
            android:background="@android:color/white"
            android:paddingTop="@dimen/dimen2dp"
            android:paddingBottom="@dimen/dimen2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:text="@string/ad_tips_str"/>
    </LinearLayout>
</RelativeLayout>
