<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_ad_native_banner"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center"
        android:id="@+id/rl_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen8dp"
        android:layout_marginTop="@dimen/dimen5dp"
        android:layout_marginBottom="@dimen/dimen5dp">
        <ImageView
            android:id="@+id/iv_native_image"
            android:layout_width="@dimen/dimen75dp"
            android:layout_height="@dimen/dimen52dp"
            android:src="@drawable/icon_pic_def"
            android:scaleType="fitXY"
            android:contentDescription="@string/app_name"/>
        <include
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/iv_native_image"
            layout="@layout/ksad_logo_layout"/>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen5dp"
        android:layout_marginRight="@dimen/dimen2dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/dimen15dp"
                android:textColor="@color/text_33"
                android:id="@+id/qm_tv_native_ad_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:singleLine="true"/>
            <TextView
                android:textSize="@dimen/dimen10dp"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:id="@+id/tv_native_ad_from"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="快手广告"
                android:singleLine="true"
                android:paddingStart="@dimen/dimen8dp"
                android:paddingEnd="@dimen/dimen6dp"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/text_99"
            android:gravity="bottom"
            android:id="@+id/tv_native_ad_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:singleLine="true"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/dimen10dp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/btn_native_creative"
        android:background="@drawable/bg_native_ad"
        android:layout_width="@dimen/dimen70dp"
        android:layout_height="@dimen/dimen28dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:text="查看详情"/>
</LinearLayout>
