<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/re_top"
        android:background="?android:attr/selectableItemBackground"
        android:padding="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/horizontal_cover"
            android:layout_width="@dimen/dimen72dp"
            android:layout_height="@dimen/dimen96dp"/>
        <TextView
            android:textSize="@dimen/dimen15dp"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/horizontal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/horizontal_cover"/>
        <TextView
            android:textSize="@dimen/dimen10dp"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/horizontal_status"
            android:background="@drawable/tag_shape_noradius"
            android:paddingLeft="@dimen/dimen8dp"
            android:paddingTop="@dimen/dimen2dp"
            android:paddingRight="@dimen/dimen8dp"
            android:paddingBottom="@dimen/dimen2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen2dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/horizontal_title"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/text_66"
            android:ellipsize="end"
            android:id="@+id/horizontal_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:maxLines="1"
            android:layout_toRightOf="@+id/horizontal_cover"
            android:layout_below="@+id/horizontal_title"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:gravity="left"
            android:id="@+id/horizontal_remark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:maxLines="3"
            android:layout_toRightOf="@+id/horizontal_cover"
            android:layout_below="@+id/horizontal_author"
            android:lineSpacingExtra="@dimen/dimen2dp"/>
        <TextView
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:id="@+id/horizontal"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:maxLines="1"
            android:layout_toRightOf="@+id/horizontal_cover"
            android:layout_below="@+id/horizontal_remark"/>
    </RelativeLayout>
</LinearLayout>
