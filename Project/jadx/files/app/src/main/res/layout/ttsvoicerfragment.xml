<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.amgcyo.cuttadon.widget.ui.AlignTextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:id="@+id/tv_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:lineSpacingExtra="@dimen/dimen8dp"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/iv_tts_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:src="@drawable/tts_step1"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen20dp">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tv_voicer"
                android:background="@drawable/bg_corners_login"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen42dp"
                android:layout_marginRight="@dimen/dimen10dp"
                android:text="发音人设置"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tv_default_rate"
                android:background="@drawable/bg_corners_login"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen42dp"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:text="恢复默认语速"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
