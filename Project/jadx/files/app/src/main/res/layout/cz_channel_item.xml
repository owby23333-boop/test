<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen50dp">
    <ImageView
        android:id="@+id/iv_pay"
        android:layout_width="@dimen/dimen25dp"
        android:layout_height="@dimen/dimen25dp"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:src="@drawable/pay_zfb"
        android:layout_alignParentLeft="true"
        android:layout_centerInParent="true"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_channel_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_toRightOf="@+id/iv_pay"
        android:layout_centerInParent="true"/>
    <CheckBox
        android:enabled="false"
        android:id="@+id/channel_check"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginRight="@dimen/dimen10dp"
        android:checked="true"
        android:layout_alignParentRight="true"
        android:layout_centerInParent="true"
        android:layout_centerHorizontal="true"
        style="@style/CustomCheckboxTheme"/>
    <View
        android:background="@color/color_848589"
        android:layout_width="wrap_content"
        android:layout_height="1px"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_toRightOf="@+id/iv_pay"
        android:layout_alignParentBottom="true"
        android:alpha="0.2"/>
</RelativeLayout>
