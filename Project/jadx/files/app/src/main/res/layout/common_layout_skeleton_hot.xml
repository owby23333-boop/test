<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/banner"
        android:background="@color/colorDefault"
        android:layout_width="match_parent"
        android:layout_height="158dp"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/horizontalScrollView"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        app:layout_constraintTop_toBottomOf="@+id/banner">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="68dp"
            android:layout_height="match_parent">
            <FrameLayout
                android:background="@drawable/round_bg_skeleton"
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@+id/line1"
        android:layout_width="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/horizontalScrollView"
        style="@style/PrimaryHLine"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ih_like"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@+id/line1">
        <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:textColor="@color/colorDefault"
            android:id="@+id/tv_title"
            android:background="@color/colorDefault"
            android:layout_width="120dp"
            android:layout_height="25dp"
            android:layout_marginLeft="9dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/colorDefault"
            android:id="@+id/tv_right_text"
            android:background="@color/colorDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:text="更多"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_arrow"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/iv_arrow"
            android:visibility="gone"
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:layout_marginRight="9dp"
            android:src="@drawable/tx_arrow"
            android:tint="@color/colorDefault"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_like"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintTop_toBottomOf="@+id/ih_like"/>
    <ImageView
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="107dp"
        android:layout_marginLeft="8dp"
        android:src="@color/colorDefault"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toStartOf="@+id/view3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/view2"
        app:layout_constraintTop_toBottomOf="@+id/ih_like"/>
    <ImageView
        android:id="@+id/view2"
        android:layout_width="0dp"
        android:layout_height="107dp"
        android:layout_marginLeft="8dp"
        android:src="@color/colorDefault"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toStartOf="@+id/view"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ih_like"/>
    <ImageView
        android:id="@+id/view3"
        android:layout_width="0dp"
        android:layout_height="107dp"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:src="@color/colorDefault"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view4"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view2"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view7"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="@+id/view"
        app:layout_constraintTop_toBottomOf="@+id/view"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view6"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="@+id/view"
        app:layout_constraintTop_toBottomOf="@+id/view7"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view8"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view3"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="@+id/view3"
        app:layout_constraintTop_toBottomOf="@+id/view3"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view9"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view3"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/view3"
        app:layout_constraintTop_toBottomOf="@+id/view8"/>
    <com.amgcyo.cuttadon.view.comic.skeleton.SkeletonBlock
        android:id="@+id/view5"
        android:background="@color/colorDefault"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/view2"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
