<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/vip_root_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/vip_root_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_free_time"
            android:background="@color/vip_item_bg"
            android:padding="@dimen/dimen10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen10dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen40dp">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="@dimen/dimen30dp"
                    android:layout_height="@dimen/dimen30dp"
                    android:src="@drawable/vip_crown"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textStyle="italic|bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/tv_vip_title"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen30dp"
                    android:layout_marginLeft="@dimen/dimen5dp"/>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/tv_time"
                    android:background="@drawable/vip_dscr_bg"
                    android:paddingLeft="@dimen/dimen8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen20dp"
                    android:layout_marginLeft="@dimen/dimen5dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_package"
            android:background="@color/vip_item_bg"
            android:padding="@dimen/dimen10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen10dp">
            <TextView
                android:textSize="@dimen/sp_18"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_pack"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen30dp"
                android:text="@string/vip_package"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cz_recyclerview"
                android:background="@color/vip_item_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen5dp"
                android:overScrollMode="never"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_pay"
            android:background="@color/vip_item_bg"
            android:padding="@dimen/dimen10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen10dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen30dp"
                    android:text="支付方式"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/color_EF4F73"
                    android:gravity="end|center_vertical"
                    android:layout_gravity="end"
                    android:id="@+id/tv_cz_help"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen30dp"
                    android:layout_marginRight="@dimen/dimen5dp"
                    android:text="@string/pay_helper"
                    android:layout_weight="1"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/zffs_recyclerview"
                android:background="@color/vip_item_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen5dp"
                android:overScrollMode="never"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_submit"
        android:background="@color/vip_item_bg"
        android:paddingLeft="@dimen/dimen10dp"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingRight="@dimen/dimen10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/white"
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总价"/>
            <TextView
                android:textSize="@dimen/sp_15"
                android:textStyle="bold"
                android:textColor="@color/color_EF4F73"
                android:id="@+id/tv_money"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="￥68"
                android:layout_toRightOf="@+id/tv_total"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="@color/color_9E9FA3"
                android:id="@+id/tv_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen2dp"
                android:layout_marginTop="@dimen/dimen3dp"
                android:layout_marginBottom="@dimen/dimen3dp"
                android:layout_below="@+id/tv_total"
                android:layout_alignLeft="@+id/tv_total"/>
        </RelativeLayout>
        <Button
            android:textSize="@dimen/sp_16"
            android:textColor="@color/white"
            android:layout_gravity="right"
            android:id="@+id/btn_submit"
            android:background="@drawable/vippkg_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vip_submit_str"
            android:layout_weight="1"/>
    </LinearLayout>
</RelativeLayout>
