<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/img"
            android:layout_width="@dimen/dimen200dp"
            android:layout_height="@dimen/dimen200dp"
            android:layout_margin="@dimen/dimen20dp"
            android:src="@drawable/treasure_success"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/iv_close"
            android:padding="@dimen/dimen5dp"
            android:layout_width="@dimen/dimen30dp"
            android:layout_height="@dimen/dimen30dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:src="@drawable/treasure_close"
            android:scaleType="center"
            android:layout_toRightOf="@+id/img"
            android:layout_alignTop="@+id/img"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/sp_20"
        android:textColor="@color/color_F6F6F6"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tv_tips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.amgcyo.cuttadon.view.numbertextview.NumberRunningTextView
        android:textSize="38sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_money"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen20dp"
        android:layout_marginBottom="@dimen/dimen20dp"
        app:numDuration="1500"
        app:runWhenChange="false"
        app:textType="num"
        app:useCommaFormat="false"/>
    <Button
        android:layout_gravity="center"
        android:id="@+id/btn_video"
        android:background="@drawable/treasure_button"
        android:paddingLeft="@dimen/dimen10dp"
        android:layout_width="@dimen/dimen150dp"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/dimen10dp"/>
</LinearLayout>
