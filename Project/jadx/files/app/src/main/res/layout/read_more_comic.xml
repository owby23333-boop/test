<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="right"
    android:orientation="vertical"
    android:background="@color/transparent"
    android:visibility="visible"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginRight="@dimen/dimen10dp">
    <ImageView
        android:layout_gravity="right"
        android:layout_width="@dimen/dimen18dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen5dp"
        android:layout_marginRight="@dimen/dimen12dp"
        android:src="@drawable/svg_black_triangle"
        android:adjustViewBounds="true"
        android:contentDescription="@null"/>
    <TextView
        android:textSize="@dimen/text_24"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_go_main"
        android:background="@color/colorBlackAlpha8"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingRight="@dimen/dimen20dp"
        android:paddingBottom="@dimen/dimen10dp"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen40dp"
        android:text="@string/comic_detail"
        android:drawableLeft="@drawable/read_home_ic"
        android:drawablePadding="@dimen/dimen20dp"/>
    <TextView
        android:textSize="@dimen/text_24"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_go_share"
        android:background="@color/colorBlackAlpha8"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingRight="@dimen/dimen20dp"
        android:paddingBottom="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen40dp"
        android:text="@string/share"
        android:drawableLeft="@drawable/read_share_iv"
        android:drawablePadding="@dimen/dimen20dp"/>
    <TextView
        android:textSize="@dimen/text_24"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_go_feedback"
        android:background="@color/colorBlackAlpha8"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingRight="@dimen/dimen20dp"
        android:paddingBottom="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen40dp"
        android:text="@string/comic_feed_back"
        android:drawableLeft="@drawable/read_feedback_ic"
        android:drawablePadding="@dimen/dimen20dp"/>
    <TextView
        android:textSize="@dimen/text_24"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_go_help"
        android:background="@color/colorBlackAlpha8"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingRight="@dimen/dimen20dp"
        android:paddingBottom="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen40dp"
        android:text="@string/comic_feed_help"
        android:drawableLeft="@drawable/read_help_ic"
        android:drawablePadding="@dimen/dimen20dp"/>
</LinearLayout>
