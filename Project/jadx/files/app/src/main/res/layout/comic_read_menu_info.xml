<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="right"
    android:orientation="horizontal"
    android:id="@+id/reader_info_layout"
    android:paddingTop="@dimen/dimen2dp"
    android:visibility="gone"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentRight="true"
    android:layout_alignParentBottom="true">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="bottom|right"
        android:orientation="horizontal"
        android:background="@drawable/drawable_black_left_top_cicrle"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/text_24"
            android:textColor="@color/white"
            android:ellipsize="middle"
            android:gravity="center"
            android:id="@+id/reader_chapter_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/dimen120dp"
            android:minWidth="@dimen/dimen35dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/text_24"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/reader_chapter_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen8dp"
            android:maxLines="1"/>
        <TextView
            android:textSize="@dimen/text_24"
            android:textColor="@color/white"
            android:id="@+id/tv_net"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen8dp"/>
        <com.amgcyo.cuttadon.view.comic.MiniClockText
            android:textSize="@dimen/text_24"
            android:textColor="@color/white"
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen8dp"
            android:text="11:39"
            android:maxLines="1"/>
        <FrameLayout
            android:background="@drawable/battery_bg"
            android:layout_width="@dimen/dimen20dp"
            android:layout_height="@dimen/dimen10dp"
            android:layout_marginLeft="@dimen/dimen5dp">
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_battery"
                android:layout_width="@dimen/dimen16dp"
                android:layout_height="@dimen/dimen8dp"
                android:max="100"
                android:progressDrawable="@drawable/battery"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
        </FrameLayout>
        <View
            android:background="@color/white"
            android:layout_width="@dimen/dimen1dp"
            android:layout_height="@dimen/dimen4dp"/>
        <TextView
            android:textSize="@dimen/text_24"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/reader_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen5dp"
            android:maxLines="1"
            android:drawablePadding="@dimen/dimen5dp"/>
    </LinearLayout>
</RelativeLayout>
