<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/rl_item_book_grid"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/re_top"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen136dp">
        <View
            android:background="@drawable/border"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dimen3dp"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/iv_bookImg_grid"
            android:layout_width="@dimen/dimen25dp"
            android:layout_height="@dimen/dimen30dp"
            android:src="@drawable/addbook"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_33"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:paddingLeft="@dimen/dimen5dp"
        android:paddingRight="@dimen/dimen5dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen3dp"
        android:singleLine="true"/>
    <TextView
        android:textSize="12sp"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:id="@+id/tv_add"
        android:paddingLeft="@dimen/dimen5dp"
        android:paddingRight="@dimen/dimen5dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen3dp"
        android:singleLine="true"/>
</LinearLayout>
