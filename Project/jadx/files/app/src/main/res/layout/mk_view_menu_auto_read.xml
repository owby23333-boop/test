<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:id="@+id/layout_autoRead"
        style="@style/ReaderMenu.Panel">
        <RelativeLayout style="@style/ReaderMenu.Row">
            <TextView
                android:id="@+id/textView_speedDown"
                android:paddingLeft="@dimen/dimen16dp"
                android:paddingRight="@dimen/dimen16dp"
                android:text="@string/reader_speed_down"
                android:layout_alignParentLeft="true"
                style="@style/ReaderMenu.NormalText"/>
            <TextView
                android:id="@+id/textView_speedUp"
                android:paddingLeft="@dimen/dimen16dp"
                android:paddingRight="@dimen/dimen16dp"
                android:text="@string/reader_speed_up"
                android:layout_alignParentRight="true"
                style="@style/ReaderMenu.NormalText"/>
            <SeekBar
                android:id="@+id/seekBar_autoSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="8"
                android:layout_toLeftOf="@+id/textView_speedUp"
                android:layout_toRightOf="@+id/textView_speedDown"
                android:layout_centerVertical="true"
                style="@style/ReaderMenu.SeekBar"/>
            <TextView
                android:textSize="@dimen/dimen12dp"
                android:textColor="@color/reader_menu_text_color_1"
                android:gravity="center"
                android:id="@+id/textView_speedNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_above="@+id/seekBar_autoSpeed"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
        <ImageView
            android:paddingLeft="@dimen/dimen16dp"
            android:paddingRight="@dimen/dimen16dp"
            android:visibility="gone"
            style="@style/ReaderMenu.Line"/>
        <LinearLayout
            android:paddingLeft="@dimen/dimen16dp"
            android:paddingRight="@dimen/dimen16dp"
            android:visibility="gone"
            style="@style/ReaderMenu.Row">
            <TextView
                android:id="@+id/textView_anim_sx"
                android:text="@string/reader_anim_4"
                style="@style/ReaderMenu.CheckText01"/>
            <TextView
                android:id="@+id/textView_anim_py"
                android:layout_marginLeft="@dimen/dimen20dp"
                android:text="@string/reader_anim_3"
                style="@style/ReaderMenu.CheckText01"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/line"
            android:paddingLeft="@dimen/dimen16dp"
            android:paddingRight="@dimen/dimen16dp"
            style="@style/ReaderMenu.Line"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/layout_finishAuto"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen56dp">
            <ImageView
                android:id="@+id/iv_exit"
                android:layout_width="@dimen/dimen20dp"
                android:layout_height="@dimen/dimen20dp"
                android:src="@drawable/mk_reader_voice_finish"
                android:scaleType="centerInside"/>
            <TextView
                android:textSize="@dimen/dimen10dp"
                android:textColor="@color/reader_menu_text_color_1"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen4dp"
                android:text="@string/str_quit_auto_read"/>
        </LinearLayout>
    </LinearLayout>
</merge>
