<?xml version="1.0" encoding="utf-8"?>
<com.kwad.sdk.widget.KSFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ksad_container"
    android:background="@color/ksad_default_dialog_bg_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.kwad.sdk.widget.swipe.HorizontalSwipeLayout
        android:id="@+id/ksad_swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.kwad.sdk.widget.KSFrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/ksad_interstitial_video_blur"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <com.kwad.sdk.widget.KSFrameLayout
                android:id="@+id/ksad_video_container"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/ksad_video_first_frame_container"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
            </com.kwad.sdk.widget.KSFrameLayout>
            <com.kwad.sdk.core.webview.KsAdWebView
                android:scrollbarStyle="insideOverlay"
                android:id="@+id/ksad_web_card_webView"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@+id/ksad_interstitial_native"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.kwad.components.core.widget.KsAutoCloseView
                    android:layout_gravity="right"
                    android:id="@+id/ksad_interstitial_auto_close"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <com.kwad.components.core.widget.ComplianceTextView
                android:textSize="10dp"
                android:textColor="#ffffff"
                android:id="@+id/ksad_compliance_view"
                android:padding="8dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"/>
            <FrameLayout
                android:id="@+id/ksad_tk_view"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </com.kwad.sdk.widget.KSFrameLayout>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/ksad_interstitial_guide_bg"
            android:layout_width="500dp"
            android:layout_height="1000dp"
            android:src="@drawable/ksad_interstitail_guide_bg"
            android:scaleType="fitXY"
            android:alpha="1"/>
        <View
            android:layout_gravity="right"
            android:id="@+id/ksad_interstitial_guide_bg_bg"
            android:background="@drawable/ksad_interstitial_guide_h_bg"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:alpha="1"/>
        <FrameLayout
            android:layout_gravity="center"
            android:id="@+id/ksad_interstitial_guide_button_layout"
            android:layout_width="178dp"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@+id/ksad_interstitial_guide_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/ksad_interstitial_guide_button_img_1"
                    android:layout_width="27.5dp"
                    android:layout_height="41dp"
                    android:src="@drawable/ksad_interstitial_guide_button_img"
                    android:alpha="0"/>
                <ImageView
                    android:id="@+id/ksad_interstitial_guide_button_img_2"
                    android:layout_width="27.5dp"
                    android:layout_height="41dp"
                    android:layout_marginLeft="-16dp"
                    android:src="@drawable/ksad_interstitial_guide_button_img"
                    android:alpha="0"/>
                <ImageView
                    android:id="@+id/ksad_interstitial_guide_button_img_3"
                    android:layout_width="27.5dp"
                    android:layout_height="41dp"
                    android:layout_marginLeft="-16dp"
                    android:src="@drawable/ksad_interstitial_guide_button_img"
                    android:alpha="0"/>
            </LinearLayout>
        </FrameLayout>
        <com.kwad.sdk.widget.KSFrameLayout
            android:id="@+id/ksad_land_page_root"
            android:background="@drawable/ksad_interstitail_guide_landing_page_bg"
            android:fitsSystemWindows="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <View
            android:layout_gravity="right"
            android:id="@+id/ksad_interstitial_guide_click_layout"
            android:layout_width="45dp"
            android:layout_height="match_parent"/>
    </com.kwad.sdk.widget.swipe.HorizontalSwipeLayout>
</com.kwad.sdk.widget.KSFrameLayout>
