<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fission6_chapter_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/ll_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_33"
            android:gravity="top|center_horizontal"
            android:id="@+id/tv_ad_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_centerHorizontal="true"/>
        <ImageView
            android:id="@+id/iv_close"
            android:padding="@dimen/dimen3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen10dp"
            android:src="@drawable/close_sign"
            android:layout_alignParentRight="true"
            android:layout_centerInParent="true"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_info"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen5dp"
            android:text="如已确认充值或已邀请好友或提示在其他设备登录，\10请退出账号再重新登录！"
            android:layout_toLeftOf="@+id/iv_close"
            android:layout_below="@+id/tv_ad_end_time"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_layout"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/ll_title">
        <ImageView
            android:id="@+id/img_qrcode"
            android:layout_width="@dimen/dimen150dp"
            android:layout_height="@dimen/dimen150dp"
            android:src="@drawable/fission6_nochapter"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen18dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginRight="@dimen/dimen18dp"
            android:layout_marginBottom="@dimen/dimen16dp"
            android:text="@string/fission6_no_login_tips"
            android:lineSpacingExtra="@dimen/dimen3dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_cz_root_child"
            android:background="@drawable/bg_mine_to_member_vip_no_open"
            android:padding="@dimen/dimen10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen16dp"
            android:layout_marginRight="@dimen/dimen16dp"
            app:layout_constraintDimensionRatio="1029:198"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/vip_icon"
                android:background="#ff1f1f25"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:src="@drawable/ic_mine_to_member_vip"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ImageCirCornerStyle"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#fffdc33e"
                android:id="@+id/vip_name_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="@string/mine_vip_prime"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintBottom_toTopOf="@+id/vip_des_text"
                app:layout_constraintStart_toEndOf="@+id/vip_icon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="#fff3e0cc"
                android:ellipsize="end"
                android:id="@+id/vip_des_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen3dp"
                android:layout_marginRight="16dp"
                android:text="@string/cz_noad_read"
                android:maxLines="1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/vip_join_btn"
                app:layout_constraintStart_toStartOf="@+id/vip_name_text"
                app:layout_constraintTop_toBottomOf="@+id/vip_name_text"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="12sp"
                android:textColor="#ff25180b"
                android:gravity="center"
                android:id="@+id/vip_join_btn"
                android:background="@drawable/shape_mine_vip_join_now"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginRight="12dp"
                android:text="@string/mine_vip_join_now"
                android:drawablePadding="2dp"
                android:drawableEnd="@drawable/ic_join_now_right"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintBottom_toBottomOf="@+id/vip_des_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/vip_icon"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_fission6"
            android:background="@color/white"
            android:padding="@dimen/dimen10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen16dp"
            android:layout_marginTop="@dimen/dimen14dp"
            android:layout_marginRight="@dimen/dimen16dp"
            app:layout_constraintDimensionRatio="1029:198"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_fission6_icon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:src="@drawable/ic_mine_activity_center"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ImageCirCornerStyle"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_33"
                android:id="@+id/tv_fission6_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="@string/title_wallet"
                app:layout_constraintStart_toEndOf="@+id/iv_fission6_icon"
                app:layout_constraintTop_toTopOf="parent"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="@dimen/dimen3dp"
                app:layout_constraintStart_toEndOf="@+id/iv_fission6_icon"
                app:layout_constraintTop_toBottomOf="@+id/tv_fission6_title">
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:id="@+id/tv_fission6_people"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen3dp"
                    android:text="已邀请0人"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_fission6_inval"
                android:background="@drawable/bg_btn_solid_theme_20"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginRight="12dp"
                android:text="@string/invitation_str"
                android:drawablePadding="2dp"
                android:drawableEnd="@drawable/ic_join_now_right"
                android:fontFamily="sans-serif-medium"
                app:drawableTint="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/iv_fission6_icon"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/sp_11"
            android:textColor="@color/text_66"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_feedback"
            android:paddingLeft="@dimen/dimen30dp"
            android:paddingRight="@dimen/dimen30dp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen28dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:text="充值未到账或未生效等问题，可点击此处反馈给客服"
            android:drawablePadding="2dp"
            app:drawableTint="@color/white"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen20dp"/>
    </LinearLayout>
    <com.amgcyo.cuttadon.view.otherview.ProgressWheel
        android:layout_gravity="center"
        android:id="@+id/fission6_progresswheel"
        android:padding="@dimen/dimen3dp"
        android:visibility="gone"
        android:layout_width="@dimen/dimen30dp"
        android:layout_height="@dimen/dimen30dp"
        android:layout_centerInParent="true"
        app:matProg_barColor="@color/colorPrimary"
        app:matProg_barWidth="@dimen/dimen2dp"
        app:matProg_progressIndeterminate="true"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_error"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen200dp"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen18dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginRight="@dimen/dimen18dp"
            android:layout_marginBottom="@dimen/dimen16dp"
            android:text="用户数据请求失败，请点击重试以便再次获取！"
            android:lineSpacingExtra="@dimen/dimen3dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_try"
            android:background="@drawable/bg_btn_solid_theme_20"
            android:paddingLeft="@dimen/dimen30dp"
            android:paddingRight="@dimen/dimen30dp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen32dp"
            android:text="点击重试"
            android:drawablePadding="2dp"
            android:fontFamily="sans-serif-medium"
            app:drawableTint="@color/white"/>
    </LinearLayout>
</RelativeLayout>
