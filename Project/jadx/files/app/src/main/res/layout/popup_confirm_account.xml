<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_round3"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dimen40dp"
    android:layout_marginRight="@dimen/dimen40dp">
    <TextView
        android:textSize="@dimen/sp_18"
        android:textColor="@color/color_363636"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen15dp"
        android:text="@string/zhqr"/>
    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="@dimen/dimen20dp"
        android:layout_height="@dimen/dimen20dp"
        android:layout_marginTop="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"
        android:src="@drawable/close_sign"
        android:layout_alignParentRight="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_title">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_99"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:text="快速提现至以下账户"/>
        <TextView
            android:textSize="@dimen/sp_24"
            android:textStyle="bold"
            android:textColor="@color/color_222222"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_account"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen8dp"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/btn_white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_tx"
            android:background="@drawable/bg_tx"
            android:layout_width="@dimen/dimen200dp"
            android:layout_height="@dimen/dimen42dp"
            android:layout_marginTop="@dimen/dimen15dp"
            android:text="立即提现"/>
        <com.amgcyo.cuttadon.view.otherview.RightDrawableCenterTextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_99"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_other_account"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginBottom="@dimen/dimen15dp"
            android:text="我要提现至其他账户"
            android:drawableRight="@drawable/tx_arrow"/>
    </LinearLayout>
</RelativeLayout>
