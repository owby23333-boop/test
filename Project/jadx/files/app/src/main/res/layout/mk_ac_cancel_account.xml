<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_root"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginTop="@dimen/dimen40dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <TextView
                android:enabled="false"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:id="@+id/tv_countryCode"
                android:background="?android:attr/selectableItemBackground"
                android:layout_width="@dimen/dimen60dp"
                android:layout_height="match_parent"
                android:text="+86"/>
            <EditText
                android:enabled="false"
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_username"
                android:background="@color/transparency"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:hint="请输入手机号"
                android:maxLength="11"
                android:layout_weight="1"
                android:inputType="phone"/>
        </LinearLayout>
        <View
            android:background="@color/color_f1"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen30dp">
            <EditText
                android:enabled="false"
                android:textSize="@dimen/dimen14dp"
                android:textColorHint="@color/text_99"
                android:id="@+id/et_smsCode"
                android:background="@color/transparency"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="请输入验证码"
                android:maxLength="6"
                android:layout_weight="1"
                android:inputType="number"/>
            <TextView
                android:textColor="@color/color_EC5C07"
                android:gravity="center"
                android:id="@+id/tv_getCode"
                android:layout_width="@dimen/dimen120dp"
                android:layout_height="match_parent"
                android:text="点击获取验证码"/>
        </LinearLayout>
        <View
            android:background="@color/color_f1"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginLeft="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen20dp"/>
        <TextView
            android:enabled="false"
            android:textSize="@dimen/dimen15dp"
            android:textStyle="bold"
            android:textColor="@color/btn_white"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_reg"
            android:background="@drawable/bg_corners_login"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen48dp"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="@dimen/dimen20dp"
            android:layout_marginRight="@dimen/dimen30dp"
            android:text="注销账号"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/ll_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen12dp">
            <TextView
                android:textSize="@dimen/dimen11dp"
                android:textColor="@color/a2a9b2"
                android:gravity="left"
                android:id="@+id/tv_change_tips"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/zhuxiao_tips"
                android:lineSpacingExtra="@dimen/dimen8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
