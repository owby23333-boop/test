<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/ksad_reflux_back"
        android:background="#82000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:background="#82000000"
        android:layout_width="match_parent"
        android:layout_height="42dp">
        <ImageView
            android:id="@+id/ksad_reflux_title_bar"
            android:background="@drawable/ksad_reflux_title_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <RelativeLayout
            android:paddingLeft="@dimen/ksad_reflux_card_padding"
            android:paddingRight="@dimen/ksad_reflux_card_padding"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/ksad_reflux_recommend"
                android:layout_width="@dimen/ksad_reflux_icon_size"
                android:layout_height="@dimen/ksad_reflux_icon_size"
                android:src="@drawable/ksad_reward_reflux_recommand"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/ksad_reflux_close"
                android:layout_width="@dimen/ksad_reflux_icon_size"
                android:layout_height="@dimen/ksad_reflux_icon_size"
                android:src="@drawable/ksad_reward_reflux_title_close"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/ksad_reflux_title"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_marginLeft="6dp"
                android:src="@drawable/ksad_ic_reflux_recommend"
                android:layout_toRightOf="@+id/ksad_reflux_recommend"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </FrameLayout>
    <ImageView
        android:background="#ffeaeef2"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <com.kwad.components.ad.reflux.KsRefluxContentView
        android:id="@+id/ksad_reflux_content"
        android:background="@android:color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.kwad.components.ad.reflux.KsRefluxNativeView
            android:id="@+id/ksad_reflux_native"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.kwad.sdk.core.webview.KsAdWebView
            android:id="@+id/ksad_reflux_webview"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </com.kwad.components.ad.reflux.KsRefluxContentView>
</LinearLayout>
