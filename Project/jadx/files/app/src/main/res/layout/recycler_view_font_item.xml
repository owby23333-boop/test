<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/com_common_item_selector"
    android:paddingLeft="@dimen/dimen10dp"
    android:paddingRight="@dimen/dimen10dp"
    android:visibility="visible"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen52dp">
    <ImageView
        android:id="@+id/iv_font_url"
        android:layout_width="@dimen/dimen120dp"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dimen3dp"
        android:layout_marginBottom="@dimen/dimen3dp"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"/>
    <TextView
        android:textSize="@dimen/dimen13dp"
        android:textColor="@color/color_100_000000"
        android:gravity="bottom"
        android:layout_gravity="bottom"
        android:id="@+id/tv_font_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_marginRight="@dimen/dimen8dp"
        android:layout_marginBottom="@dimen/dimen10dp"
        android:text="1.8M"
        android:layout_toLeftOf="@+id/download"
        android:layout_toRightOf="@+id/iv_font_url"
        android:layout_alignParentBottom="true"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/white"
        android:layout_gravity="center"
        android:id="@+id/download"
        android:layout_width="@dimen/dimen80dp"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/dimen10dp"
        android:text="未下载"
        android:layout_centerInParent="true"
        android:layout_alignParentEnd="true"
        style="@style/downd"/>
</RelativeLayout>
