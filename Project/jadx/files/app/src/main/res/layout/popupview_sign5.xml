<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen20dp"
        android:layout_marginRight="@dimen/dimen20dp"
        android:src="@drawable/sign_bg5"
        android:adjustViewBounds="true"/>
    <TextView
        android:textSize="@dimen/sp_22"
        android:textColor="@color/white"
        android:id="@+id/tv_sign_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen90dp"
        android:layout_marginBottom="@dimen/dimen18dp"
        android:layout_centerHorizontal="true"/>
    <RelativeLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/rl_sign"
        android:background="@drawable/bg_round3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen25dp"
        android:layout_marginRight="@dimen/dimen25dp"
        android:layout_marginBottom="@dimen/dimen15dp"
        android:layout_below="@+id/tv_sign_tips"
        android:layout_alignLeft="@+id/iv_bg"
        android:layout_alignRight="@+id/iv_bg">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_coin_tips"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen80dp"
            android:layout_marginTop="@dimen/dimen12dp">
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_msg"
                android:background="@drawable/bg_conners_coin"
                android:paddingLeft="@dimen/dimen6dp"
                android:paddingTop="@dimen/dimen2dp"
                android:paddingRight="@dimen/dimen6dp"
                android:paddingBottom="@dimen/dimen2dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="明日领取"/>
            <ImageView
                android:layout_gravity="center"
                android:background="@drawable/dsj"
                android:layout_width="@dimen/dimen10dp"
                android:layout_height="@dimen/dimen10dp"
                android:layout_marginTop="-2dp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/ll_top_img"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen30dp"
            android:layout_alignLeft="@+id/ph_top"
            android:layout_centerHorizontal="true">
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:scaleType="fitCenter"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableAlpha="80"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableAlpha="80"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:scaleType="fitCenter"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:scaleType="fitCenter"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:scaleType="fitCenter"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:id="@+id/dti_day6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:scaleType="fitCenter"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/sign_gold_icon"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"/>
        </LinearLayout>
        <ProgressBar
            android:layout_gravity="center_horizontal"
            android:id="@+id/ph_top"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen12dp"
            android:layout_marginLeft="@dimen/dimen6dp"
            android:layout_marginRight="@dimen/dimen6dp"
            android:max="7"
            android:progressDrawable="@drawable/progress_bar_drawable1"
            android:layout_below="@+id/ll_top_img"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:id="@+id/ll_top_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-9dp"
            android:layout_below="@+id/ph_top"
            android:layout_alignLeft="@+id/ph_top"
            android:layout_centerHorizontal="true">
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/ll_bottom"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/ph_bottom"
            android:layout_below="@+id/ll_top_text"
            android:layout_alignLeft="@+id/ph_top"
            android:layout_centerHorizontal="true">
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/dti_day30"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/jb"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/dti_day21"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/lw"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/dti_day14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/lw"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <com.amgcyo.cuttadon.view.otherview.DrawTextImageView
                android:textSize="@dimen/sp_10"
                android:textColor="@drawable/coin_textcolor"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/dti_day7"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen2dp"
                android:button="@null"
                android:src="@drawable/sign_gold_icon"
                android:drawablePadding="@dimen/dimen2dp"
                android:layout_weight="1"
                app:drawable="@drawable/lw"
                app:drawableHeight="@dimen/dimen25dp"
                app:drawableWidth="@dimen/dimen25dp"
                app:positionType="top"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"/>
        </LinearLayout>
        <ProgressBar
            android:layout_gravity="right"
            android:id="@+id/ph_bottom"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen12dp"
            android:layout_marginLeft="@dimen/dimen6dp"
            android:layout_marginRight="@dimen/dimen6dp"
            android:max="31"
            android:progressDrawable="@drawable/progress_bar_drawable3"
            android:layout_below="@+id/vpb_right"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-9dp"
            android:layout_marginBottom="@dimen/dimen10dp"
            android:layout_below="@+id/ph_bottom"
            android:layout_alignLeft="@+id/ph_top"
            android:layout_centerHorizontal="true">
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day30"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:button="@null"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/shape_layer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day21"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/shape_layer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/shape_layer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_day7"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/shape_oval_white"
                android:drawablePadding="@dimen/dimen10dp"
                android:layout_weight="1"/>
            <Space
                android:layout_width="@dimen/dimen0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/vpb_right"
            android:layout_width="@dimen/dimen12dp"
            android:layout_height="@dimen/dimen120dp"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_marginBottom="-8dp"
            android:max="8"
            android:indeterminateOnly="false"
            android:progressDrawable="@drawable/progress_vertical_gradient_simple_shape"
            android:layout_below="@+id/ph_top"
            android:layout_alignTop="@+id/ph_top"
            android:layout_alignRight="@+id/ph_bottom"/>
    </RelativeLayout>
    <Button
        android:textSize="@dimen/sp_12"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/bt_lxqd"
        android:background="@drawable/lx_sign_bg"
        android:paddingLeft="@dimen/dimen20dp"
        android:paddingRight="@dimen/dimen20dp"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen20dp"
        android:layout_marginBottom="-10dp"
        android:layout_above="@+id/rl_sign"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/btn_white"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/csb_login"
        android:background="@drawable/bg_corners_sign"
        android:paddingLeft="@dimen/dimen50dp"
        android:paddingRight="@dimen/dimen50dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen12dp"
        android:text="@string/good"
        android:layout_alignBottom="@+id/iv_bg"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/iv_close"
        android:padding="@dimen/dimen10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen15dp"
        android:src="@drawable/lib_update_app_close"
        android:layout_below="@+id/iv_bg"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
