<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.amgcyo.cuttadon.widget.ui.FixedSpeedViewpager
        android:layout_gravity="center"
        android:id="@+id/viewpager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/dimen50dp"/>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@+id/tabradios"/>
    <RadioGroup
        android:orientation="horizontal"
        android:id="@+id/tabradios"
        android:background="@color/card_white"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen50dp"
        android:layout_alignParentBottom="true">
        <com.amgcyo.cuttadon.view.otherview.FixedAnimatedRadioButton
            android:textSize="@dimen/sp_12"
            android:textColor="@drawable/radiobutton_text"
            android:id="@+id/rb_bookshelf"
            android:background="@color/card_white"
            android:paddingTop="@dimen/dimen2dp"
            android:checked="true"
            android:text="@string/book_shelf"
            android:drawableTop="@drawable/rb_bookcity"
            android:drawablePadding="-5dp"
            android:layout_weight="1"
            app:max_scale="1.1"
            style="@style/radioButton"/>
        <com.amgcyo.cuttadon.view.otherview.FixedAnimatedRadioButton
            android:textSize="@dimen/sp_12"
            android:textColor="@drawable/radiobutton_text"
            android:id="@+id/rb_bookCity"
            android:background="@color/card_white"
            android:paddingTop="@dimen/dimen2dp"
            android:text="书城"
            android:drawableTop="@drawable/rb_bookshelf"
            android:drawablePadding="-5dp"
            android:layout_weight="1"
            style="@style/radioButton"/>
        <com.amgcyo.cuttadon.view.otherview.FixedAnimatedRadioButton
            android:textSize="@dimen/sp_12"
            android:textColor="@drawable/radiobutton_text"
            android:id="@+id/rb_qiushu"
            android:background="@color/card_white"
            android:paddingTop="@dimen/dimen2dp"
            android:text="求书"
            android:drawableTop="@drawable/rb_qiushu"
            android:drawablePadding="-5dp"
            android:layout_weight="1"
            style="@style/radioButton"/>
        <com.amgcyo.cuttadon.view.otherview.FixedAnimatedRadioButton
            android:textSize="@dimen/sp_12"
            android:textColor="@drawable/radiobutton_text"
            android:id="@+id/rb_fission6"
            android:background="@color/card_white"
            android:paddingTop="@dimen/dimen2dp"
            android:text="@string/share"
            android:drawableTop="@drawable/rb_fission"
            android:drawablePadding="-5dp"
            android:layout_weight="1"
            style="@style/radioButton"/>
        <com.amgcyo.cuttadon.view.otherview.FixedAnimatedRadioButton
            android:textSize="@dimen/sp_12"
            android:textColor="@drawable/radiobutton_text"
            android:id="@+id/rb_mine"
            android:background="@color/card_white"
            android:paddingTop="@dimen/dimen2dp"
            android:text="我的"
            android:drawableTop="@drawable/rb_mine"
            android:drawablePadding="-5dp"
            android:layout_weight="1"
            style="@style/radioButton"/>
    </RadioGroup>
    <LinearLayout
        android:orientation="horizontal"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen50dp"
        android:layout_alignParentBottom="true">
        <Button
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <Button
            android:background="#00000000"
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/btn_qiushu"
            android:background="#00000000"
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/btn_fission6"
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/btn_my"
            android:visibility="invisible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
    </LinearLayout>
</RelativeLayout>
