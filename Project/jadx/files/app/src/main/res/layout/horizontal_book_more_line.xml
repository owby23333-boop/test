<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_rop"
        android:background="?android:attr/selectableItemBackground"
        android:padding="@dimen/dimen10dp"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/dimen10dp"
                android:textColor="@color/colorPrimary"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/hori_book_more_line_status"
                android:background="@drawable/tag_shape_solid"
                android:paddingLeft="@dimen/dimen5dp"
                android:paddingRight="@dimen/dimen5dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:singleLine="true"/>
            <TextView
                android:textSize="@dimen/dimen14dp"
                android:textColor="@color/text_33"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/hori_book_more_line_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:layout_marginRight="@dimen/dimen10dp"
                android:singleLine="true"/>
            <TextView
                android:textSize="@dimen/dimen12dp"
                android:textColor="@color/a2a9b2"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/hori_book_more_line_author"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:maxLines="1"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:gravity="left"
            android:id="@+id/hori_book_more_line_remark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:maxLines="1"/>
    </LinearLayout>
</LinearLayout>
