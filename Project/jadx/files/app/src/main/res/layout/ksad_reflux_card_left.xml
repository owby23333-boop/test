<?xml version="1.0" encoding="utf-8"?>
<com.kwad.sdk.widget.KSLinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingBottom="@dimen/ksad_reflux_card_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="@dimen/ksad_reflux_card_padding"
        android:paddingTop="@dimen/ksad_reflux_card_padding"
        android:paddingRight="@dimen/ksad_reflux_card_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="@dimen/ksad_reflux_card_left_inner_height"
            android:layout_marginRight="12dp"
            android:layout_weight="1.95">
            <TextView
                android:ellipsize="end"
                android:layout_gravity="top"
                android:id="@+id/ksad_reflux_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:maxLines="2"/>
            <com.kwad.components.ad.widget.DownloadProgressView
                android:layout_gravity="bottom"
                android:id="@+id/ksad_reflux_app_download_btn"
                android:layout_width="64dp"
                android:layout_height="22dp"
                app:ksad_backgroundDrawable="@drawable/ksad_reflux_left_app_download_before_bg"
                app:ksad_downloadLeftTextColor="@color/ksad_reward_main_color"
                app:ksad_downloadRightTextColor="@color/ksad_reward_main_color"
                app:ksad_downloadingFormat="%s%%"
                app:ksad_progressDrawable="@drawable/ksad_reflux_left_download_progress"
                app:ksad_textColor="@color/ksad_reward_main_color"
                app:ksad_textSize="12sp"/>
        </FrameLayout>
        <com.kwad.sdk.widget.KSFrameLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/ksad_reflux_card_left_inner_height"
            android:layout_weight="1"
            app:ksad_radius="3dp">
            <ImageView
                android:id="@+id/ksad_reflux_card_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:foreground="#b3000000"
                android:scaleType="centerCrop"/>
            <ImageView
                android:id="@+id/ksad_reflux_card_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.kwad.components.core.widget.KsLogoView
                android:layout_gravity="top|right"
                android:id="@+id/ksad_reflux_card_logo"
                android:background="@drawable/ksad_splash_logo_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </com.kwad.sdk.widget.KSFrameLayout>
    </LinearLayout>
    <com.kwad.components.core.widget.ComplianceTextView
        android:textSize="10sp"
        android:textColor="#ff9c9c9c"
        android:id="@+id/ksad_reflux_card_title_compliance"
        android:background="@android:color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/ksad_reflux_card_padding"
        android:layout_marginTop="5dp"
        android:layout_marginRight="@dimen/ksad_reflux_card_padding"
        app:ksad_privacy_color="#ff9c9c9c"
        app:ksad_width_in_landscape="0dp"/>
</com.kwad.sdk.widget.KSLinearLayout>
