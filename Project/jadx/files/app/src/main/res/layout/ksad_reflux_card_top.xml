<?xml version="1.0" encoding="utf-8"?>
<com.kwad.sdk.widget.KSLinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="@dimen/ksad_reflux_card_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:ellipsize="end"
        android:id="@+id/ksad_reflux_card_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:maxLines="1"/>
    <com.kwad.sdk.widget.KSFrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/ksad_reflux_card_top_img_height"
        app:ksad_radius="3dp">
        <ImageView
            android:id="@+id/ksad_reflux_card_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <com.kwad.components.core.widget.KsLogoView
            android:layout_gravity="top|right"
            android:id="@+id/ksad_reflux_card_logo"
            android:background="@drawable/ksad_splash_logo_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="bottom"
            android:background="@drawable/ksad_reflux_card_cover"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>
        <include
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="11dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="8dp"
            layout="@layout/ksad_reflux_app_download"/>
    </com.kwad.sdk.widget.KSFrameLayout>
    <com.kwad.components.core.widget.ComplianceTextView
        android:textSize="10sp"
        android:textColor="#ff9c9c9c"
        android:id="@+id/ksad_reflux_card_title_compliance"
        android:background="@android:color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        app:ksad_privacy_color="#ff9c9c9c"
        app:ksad_width_in_landscape="0dp"/>
</com.kwad.sdk.widget.KSLinearLayout>
