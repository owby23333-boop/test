<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.amgcyo.cuttadon.view.readermenu.ReaderNewTitle
        android:id="@+id/readerTitleView"
        android:background="@color/color_F6F6F6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:id="@+id/layout_toolBar"
        android:layout_alignParentBottom="true"
        style="@style/ReaderMenu.Panel">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/menu_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_download"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/reader_menu_text_color_1"
                    android:gravity="center"
                    android:paddingLeft="@dimen/dimen16dp"
                    android:paddingTop="@dimen/dimen10dp"
                    android:paddingRight="@dimen/dimen16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正在缓存..."/>
                <com.amgcyo.cuttadon.widget.ui.HProgressBarWithNumber
                    android:id="@+id/pb_download_pregress"
                    android:paddingLeft="@dimen/dimen18dp"
                    android:paddingRight="@dimen/dimen18dp"
                    android:paddingBottom="@dimen/dimen10dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="30"
                    app:progress_reached_bar_height="@dimen/dimen1dp"
                    app:progress_reached_color="@color/colorPrimary"
                    app:progress_text_color="#ff530d"
                    app:progress_text_size="@dimen/sp_12"
                    app:progress_unreached_bar_height="@dimen/dimen1dp"
                    app:progress_unreached_color="#ff530d"/>
                <ImageView
                    android:paddingLeft="@dimen/dimen16dp"
                    android:paddingRight="@dimen/dimen16dp"
                    style="@style/ReaderMenu.Line"/>
            </LinearLayout>
            <RelativeLayout style="@style/ReaderMenu.Row">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/reader_menu_text_color_1"
                    android:gravity="center"
                    android:id="@+id/textView_preChapter"
                    android:paddingLeft="@dimen/dimen16dp"
                    android:paddingRight="@dimen/dimen16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/reader_pre_chapter"
                    android:layout_alignParentLeft="true"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/reader_menu_text_color_1"
                    android:gravity="center"
                    android:id="@+id/textView_nextChapter"
                    android:paddingLeft="@dimen/dimen16dp"
                    android:paddingRight="@dimen/dimen16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/reader_next_chapter"
                    android:layout_alignParentRight="true"/>
                <SeekBar
                    android:id="@+id/seekBar_readProgress"
                    android:paddingLeft="@dimen/dimen10dp"
                    android:paddingRight="@dimen/dimen10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="@dimen/dimen2dp"
                    android:progressDrawable="@drawable/reader_seekbar_style"
                    android:minHeight="@dimen/dimen2dp"
                    android:thumb="@drawable/reader_seekbar_btn"
                    android:thumbOffset="@dimen/dimen10dp"
                    android:layout_toLeftOf="@+id/textView_nextChapter"
                    android:layout_toRightOf="@+id/textView_preChapter"
                    android:layout_centerVertical="true"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <TextView
                    android:textSize="@dimen/dimen10dp"
                    android:textColor="@color/reader_menu_text_color_1"
                    android:gravity="center"
                    android:id="@+id/textView_percent"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_above="@+id/seekBar_readProgress"
                    android:layout_centerHorizontal="true"/>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/menu_set"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true">
            <include layout="@layout/version_setting_layout"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/img_line"
            android:paddingLeft="@dimen/dimen16dp"
            android:paddingRight="@dimen/dimen16dp"
            style="@style/ReaderMenu.Line"/>
        <LinearLayout
            android:id="@+id/ll_bottom"
            style="@style/ReaderMenu.Row">
            <LinearLayout
                android:id="@+id/menu_chapter"
                style="@style/ReaderMenu.MainItem">
                <ImageView
                    android:id="@+id/img_category"
                    android:src="@drawable/icon_mulu"
                    style="@style/ReaderMenu.MainItemIcon"/>
                <TextView
                    android:text="@string/reader_catalog"
                    style="@style/ReaderMenu.MainItemText"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/menu_brightness"
                style="@style/ReaderMenu.MainItem">
                <ImageView
                    android:id="@+id/img_day_night"
                    android:src="@drawable/yejian_icon"
                    style="@style/ReaderMenu.MainItemIcon"/>
                <TextView
                    android:id="@+id/tv_day_night"
                    android:text="@string/reader_menu_brightness"
                    style="@style/ReaderMenu.MainItemText"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/menu_setting"
                style="@style/ReaderMenu.MainItem">
                <ImageView
                    android:id="@+id/iv_seting"
                    android:src="@drawable/icon_shezhi"
                    style="@style/ReaderMenu.MainItemIcon"/>
                <TextView
                    android:text="@string/reader_menu_setting"
                    style="@style/ReaderMenu.MainItemText"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/toggleButton_mode"
        android:background="@drawable/round_background"
        android:layout_width="@dimen/dimen48dp"
        android:layout_height="@dimen/dimen48dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen10dp"
        android:layout_above="@+id/layout_toolBar"
        android:layout_alignParentRight="true">
        <TextView
            android:textSize="@dimen/sp_26"
            android:textColor="@color/color_f7f7f7"
            android:gravity="center"
            android:id="@+id/tv_tts_name"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="源"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
