<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_category_new"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_marginTop="@dimen/dimen10dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen5dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_bookImg0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen6dp"
                android:layout_marginTop="@dimen/dimen6dp"
                android:layout_marginRight="@dimen/dimen3dp"
                android:layout_marginBottom="@dimen/dimen3dp"
                android:src="@drawable/category1"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/iv_bookImg1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen3dp"
                android:layout_marginTop="@dimen/dimen6dp"
                android:layout_marginRight="@dimen/dimen6dp"
                android:layout_marginBottom="@dimen/dimen3dp"
                android:src="@drawable/category2"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_bookImg2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen6dp"
                android:layout_marginTop="@dimen/dimen3dp"
                android:layout_marginRight="@dimen/dimen3dp"
                android:layout_marginBottom="@dimen/dimen6dp"
                android:src="@drawable/category3"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/iv_bookImg3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen3dp"
                android:layout_marginTop="@dimen/dimen3dp"
                android:layout_marginRight="@dimen/dimen6dp"
                android:layout_marginBottom="@dimen/dimen6dp"
                android:src="@drawable/category4"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/text_66"
        android:ellipsize="middle"
        android:id="@+id/tv_cate_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen12dp"
        android:singleLine="true"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/text_99"
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen14dp"
        android:layout_marginBottom="@dimen/dimen10dp"/>
</LinearLayout>
