<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/color_F6F6F6"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/iv_bookImg"
        android:layout_width="@dimen/dimen76dp"
        android:layout_height="@dimen/dimen96dp"
        android:layout_marginTop="@dimen/dimen10dp"
        android:foreground="?android:attr/selectableItemBackground"/>
    <TextView
        android:textSize="@dimen/dimen13dp"
        android:textColor="@color/text_33"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_bookName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen8dp"
        android:layout_marginBottom="@dimen/dimen8dp"
        android:maxLines="1"/>
    <TextView
        android:textSize="@dimen/dimen13dp"
        android:textColor="@color/a2a9b2"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_last_read_chapterName"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen5dp"
        android:maxLines="1"/>
</LinearLayout>
