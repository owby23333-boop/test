<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/ll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@android:color/black"
        android:clickable="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen50dp">
        <CheckBox
            android:id="@+id/cb_vloume"
            android:padding="@dimen/dimen10dp"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:button="@null"
            android:src="@drawable/ylk"
            android:alpha="0.9"
            android:drawableStart="@drawable/vloume_selector"/>
        <ImageView
            android:id="@+id/iv_close_ad"
            android:padding="@dimen/dimen8dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:visibility="invisible"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginRight="@dimen/dimen10dp"
            android:src="@drawable/dd_close"
            android:layout_alignParentRight="true"
            android:alpha="0.9"/>
        <TextView
            android:textSize="@dimen/sp_13"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_ad_time"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toLeftOf="@+id/iv_close_ad"
            android:layout_centerInParent="true"
            android:alpha="0.9"/>
    </RelativeLayout>
    <FrameLayout
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <xyz.doikki.videoplayer.player.VideoView
            android:id="@+id/player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:id="@+id/imageview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"/>
        <ImageView
            android:layout_gravity="bottom|right"
            android:id="@+id/logoImgeview"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_logos"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"/>
        <com.amgcyo.cuttadon.view.otherview.ProgressWheel
            android:layout_gravity="center"
            android:id="@+id/progress_wheel"
            android:padding="@dimen/dimen3dp"
            android:visibility="gone"
            android:layout_width="@dimen/dimen50dp"
            android:layout_height="@dimen/dimen50dp"
            app:matProg_barColor="@color/white"
            app:matProg_barWidth="@dimen/dimen2dp"
            app:matProg_progressIndeterminate="true"/>
    </FrameLayout>
    <RelativeLayout
        android:id="@+id/rl_ad_bottom"
        android:background="@drawable/simple_bg_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_adImg"
            android:layout_width="@dimen/dimen60dp"
            android:layout_height="@dimen/dimen60dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_marginBottom="@dimen/dimen10dp"
            android:src="@drawable/icon_pic_def"
            android:scaleType="fitXY"/>
        <ImageView
            android:layout_gravity="bottom|left"
            android:id="@+id/logoImgeview_small"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_logos"
            android:adjustViewBounds="true"
            android:layout_alignLeft="@+id/iv_adImg"
            android:layout_alignBottom="@+id/iv_adImg"
            android:contentDescription="@string/app_name"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/tv_adTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen5dp"
            android:maxLines="1"
            android:maxEms="10"
            android:singleLine="true"
            android:layout_toLeftOf="@+id/btn_action"
            android:layout_toRightOf="@+id/iv_adImg"
            android:layout_alignTop="@+id/iv_adImg"/>
        <com.amgcyo.cuttadon.view.comic.SimpleRatingBar
            android:id="@+id/simpleratingbar"
            android:layout_width="@dimen/dimen60dp"
            android:layout_height="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_marginRight="@dimen/dimen15dp"
            android:layout_toRightOf="@+id/iv_adImg"
            android:layout_below="@+id/tv_adTitle"
            android:layout_alignLeft="@+id/tv_adTitle"
            app:srb_borderColor="@color/F5A623"
            app:srb_fillColor="@color/F5A623"
            app:srb_isIndicator="true"
            app:srb_numberOfStars="5"
            app:srb_rating="5"/>
        <com.amgcyo.cuttadon.view.otherview.CommonShapeButton
            android:textSize="@dimen/sp_14"
            android:textColor="@color/white"
            android:id="@+id/btn_action"
            android:paddingLeft="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen10dp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen35dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:layout_alignParentRight="true"
            android:layout_centerInParent="true"
            app:csb_activeEnable="true"
            app:csb_cornerRadius="@dimen/dimen5dp"
            app:csb_fillColor="@color/colorPrimary"/>
        <TextView
            android:textSize="@dimen/sp_10"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tv_ad_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:maxLines="2"
            android:layout_toRightOf="@+id/iv_adImg"
            android:layout_below="@+id/simpleratingbar"
            android:layout_alignLeft="@+id/tv_adTitle"/>
    </RelativeLayout>
</LinearLayout>
