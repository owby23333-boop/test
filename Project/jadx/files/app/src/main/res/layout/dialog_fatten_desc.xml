<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/fatten_desc_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="270dp"
            android:layout_height="155dp"
            android:src="@drawable/feed_dialog_intro_img"/>
        <TextView
            android:textSize="@dimen/sp_17"
            android:textColor="@color/text_33"
            android:gravity="center"
            android:id="@+id/tv_fatten_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:text="已移入养肥区"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_66"
            android:id="@+id/tv_fatten_desc"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen20dp"
            android:text="该小说已经移入养肥区，你可以在书架找到它。"
            android:lineSpacingMultiplier="1.2"/>
        <View
            android:background="@color/dddddd"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen0_5dp"
            android:layout_marginTop="@dimen/dimen25dp"/>
        <Button
            android:textSize="@dimen/sp_17"
            android:textColor="@color/color_ffee4745"
            android:id="@+id/fatten_desc_btn"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="11dp"
            android:layout_marginRight="@dimen/dimen30dp"
            android:text="@string/ikonow"/>
    </LinearLayout>
</LinearLayout>
