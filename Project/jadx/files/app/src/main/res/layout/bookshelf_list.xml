<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/card_view"
    android:background="@color/color_F6F6F6"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/rl_item_book"
        android:background="?android:attr/selectableItemBackground"
        android:paddingTop="@dimen/dimen10dp"
        android:paddingBottom="@dimen/dimen15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/dimen15dp"
        android:paddingEnd="@dimen/dimen5dp">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen64dp"
            android:layout_height="@dimen/dimen87dp"
            android:scaleType="centerCrop"
            android:layout_alignParentLeft="true"/>
        <ImageView
            android:id="@+id/fade_cover"
            android:visibility="gone"
            android:layout_width="@dimen/dimen57dp"
            android:layout_height="@dimen/dimen75dp"
            android:src="#80000000"/>
        <ImageView
            android:id="@+id/book_top_icon"
            android:visibility="visible"
            android:layout_width="@dimen/dimen20dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="-1dp"
            android:src="@drawable/top_book"
            android:layout_alignBaseline="@+id/iv_bookImg"
            android:layout_alignLeft="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"
            android:layout_alignParentTop="true"/>
        <com.amgcyo.cuttadon.widget.ui.RoundProgressWidthNumber
            android:id="@+id/progressBarSmall"
            android:visibility="gone"
            android:layout_width="@dimen/dimen30dp"
            android:layout_height="@dimen/dimen30dp"
            android:layout_marginLeft="@dimen/dimen14dp"
            android:layout_alignLeft="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"
            android:layout_centerInParent="true"
            app:progress_reached_bar_height="@dimen/dimen1dp"
            app:progress_reached_color="@color/white"
            app:progress_text_color="@color/white"
            app:progress_text_size="@dimen/sp_10"
            app:progress_unreached_bar_height="@dimen/dimen1dp"
            app:progress_unreached_color="@color/color_e3e3e3"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tv_bookName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen12dp"
            android:layout_marginTop="@dimen/dimen3dp"
            android:maxEms="12"
            android:singleLine="true"
            android:layout_toEndOf="@+id/iv_bookImg"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/tv_bookName"
            android:layout_alignBottom="@+id/tv_bookName"
            android:layout_marginStart="@dimen/dimen2dp"
            android:layout_toEndOf="@+id/tv_bookName">
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tv_status"
                android:background="@color/colorPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="更新"
                android:paddingStart="@dimen/dimen2dp"
                android:paddingEnd="@dimen/dimen2dp"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:id="@+id/tv_time_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_below="@+id/tv_bookName"
            android:layout_alignLeft="@+id/tv_bookName"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/shelf_more"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:gravity="bottom"
            android:id="@+id/tv_last_read_chapterName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen5dp"
            android:singleLine="true"
            android:layout_toLeftOf="@+id/shelf_more"
            android:layout_alignBaseline="@+id/iv_bookImg"
            android:layout_alignLeft="@+id/tv_bookName"
            android:layout_alignBottom="@+id/iv_bookImg"/>
        <ImageView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/shelf_more"
            android:background="?android:attr/selectableItemBackground"
            android:padding="@dimen/dimen10dp"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_shelf_more"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
</LinearLayout>
