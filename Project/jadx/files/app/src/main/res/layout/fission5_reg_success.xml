<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/title_layout"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="146dp"
        android:src="@drawable/fission5_reg_bgs"
        android:scaleType="fitXY"/>
    <ImageView
        android:id="@+id/iv_gold"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginTop="119dp"
        android:src="@drawable/icon_money_gg"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="@dimen/sp_22"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen45dp"
        android:text="恭喜你\10获得新人奖励"
        android:layout_below="@+id/iv_gold"
        android:layout_centerInParent="true"/>
    <RelativeLayout
        android:layout_gravity="center"
        android:id="@+id/rl_money"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen25dp"
        android:layout_below="@+id/tv_tip"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="60sp"
            android:textColor="@color/color_ffef5841"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_money"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_ffef5841"
            android:id="@+id/tv_yuan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="元"
            android:layout_toRightOf="@+id/tv_money"
            android:layout_alignBaseline="@+id/tv_money"/>
    </RelativeLayout>
    <TextView
        android:textSize="13sp"
        android:textColor="#ff999999"
        android:id="@+id/tv_cruye"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:text="@string/crye"
        android:layout_below="@+id/rl_money"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/imageView_back"
        android:padding="10dp"
        android:layout_width="30dp"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/fission5_back"
        android:scaleType="centerInside"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/white"
        android:gravity="center_vertical"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:text="收到的红包"
        android:layout_centerHorizontal="true"/>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/ll_yqhy"
        android:background="@drawable/iu"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginLeft="47dp"
        android:layout_marginTop="48dp"
        android:layout_marginRight="47dp"
        android:layout_below="@+id/tv_cruye"
        android:layout_centerHorizontal="true">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/white"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/make_money"/>
    </LinearLayout>
</RelativeLayout>
