<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/ll_danmu_swtich"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rel_danmu_button"
        android:background="@drawable/shape_danmu_normal_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/lin_danmu_button"
            android:paddingLeft="@dimen/dimen8dp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen26dp">
            <ImageView
                android:id="@+id/iv_danmu_states"
                android:layout_width="@dimen/dimen14dp"
                android:layout_height="@dimen/dimen14dp"
                android:layout_marginRight="@dimen/dimen4dp"
                android:src="@drawable/menu_danmu_switch_open"/>
            <TextView
                android:textSize="@dimen/sp_11"
                android:textColor="#fff8f7f6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="弹幕"/>
            <TextView
                android:textSize="@dimen/sp_11"
                android:textColor="#fff8f7f6"
                android:id="@+id/danmu_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen2dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/iv_danmu_set"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen26dp"
            android:layout_toRightOf="@+id/lin_danmu_button"
            android:layout_centerInParent="true">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="@dimen/dimen12dp"
                android:layout_height="@dimen/dimen12dp"
                android:layout_marginLeft="@dimen/dimen4dp"
                android:layout_marginRight="@dimen/dimen8dp"
                android:src="@drawable/svg_white_button_set_b"
                android:contentDescription="@null"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
