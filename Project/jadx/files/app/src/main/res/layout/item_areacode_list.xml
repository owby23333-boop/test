<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sp_15"
        android:textColor="@color/text_63"
        android:id="@+id/tv_key"
        android:background="@color/FBFBFB"
        android:paddingLeft="@dimen/dimen15dp"
        android:paddingTop="@dimen/dimen5dp"
        android:paddingBottom="@dimen/dimen5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen60dp">
        <TextView
            android:textSize="@dimen/sp_17"
            android:textColor="@color/text_66"
            android:ellipsize="end"
            android:gravity="start|center_vertical"
            android:id="@+id/reg_from"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:maxEms="12"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_99"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/reg_code"
            android:background="@drawable/text_round"
            android:paddingTop="@dimen/dimen3dp"
            android:paddingBottom="@dimen/dimen3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen35dp"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:paddingStart="@dimen/dimen5dp"
            android:paddingEnd="@dimen/dimen5dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
