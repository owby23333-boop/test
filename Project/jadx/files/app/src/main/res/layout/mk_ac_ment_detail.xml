<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        layout="@layout/fragment_list"/>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_gravity="bottom|right"
        android:id="@+id/fb_comment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen20dp"
        android:src="@drawable/write_comment"
        android:scaleType="fitXY"
        app:backgroundTint="@color/color_EC5C07"
        app:borderWidth="0dp"
        app:elevation="@dimen/dimen5dp"
        app:fabSize="normal"
        app:pressedTranslationZ="@dimen/dimen5dp"
        app:rippleColor="@color/dddddd"/>
    <include layout="@layout/bottom_comment_layout"/>
</FrameLayout>
