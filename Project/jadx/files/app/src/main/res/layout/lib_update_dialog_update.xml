<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="right"
        android:id="@+id/iv_close"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/lib_update_app_close"/>
    <ImageView
        android:layout_gravity="top"
        android:id="@+id/iv_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-20dp"
        android:src="@mipmap/top_3"
        android:adjustViewBounds="true"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/lib_update_app_info_bg"
            android:paddingLeft="15dp"
            android:paddingTop="15dp"
            android:paddingRight="15dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="20sp"
                android:textColor="#333333"
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="版本更新"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@android:color/holo_red_light"
                android:id="@+id/tvForceUpdate"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提示：你需要更新应用才能继续使用！"/>
            <com.open.hule.library.view.MaxHeightScrollView
                android:id="@+id/scrollview"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:fadeScrollbars="false">
                <TextView
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:autoLink="web"
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="5dp"/>
            </com.open.hule.library.view.MaxHeightScrollView>
            <RelativeLayout
                android:id="@+id/rl_app_info"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tips_logo"
                    android:background="?android:attr/selectableItemBackground"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:contentDescription="@string/app_name"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:ellipsize="end"
                    android:id="@+id/tips_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@+id/tips_logo"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:ellipsize="end"
                    android:id="@+id/tips_appremark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_alignBottom="@+id/tips_logo"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@+id/tips_logo"/>
            </RelativeLayout>
            <Button
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:id="@+id/btnUpdateNow"
                android:background="@drawable/update_round_bg"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="5dp"
                android:text="@string/update_text"/>
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tv_help"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"
                    android:singleLine="true"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tv_feedback"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="5dp"
                    android:text="反馈给客服"
                    android:singleLine="true"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
