<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/translucent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen60dp"
            android:layout_height="@dimen/dimen80dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen1dp"
            android:layout_marginBottom="@dimen/dimen15dp"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:ellipsize="end"
            android:id="@+id/tv_bookName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen40dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/a2a9b2"
            android:ellipsize="end"
            android:id="@+id/tv_book_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen6dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:maxLines="2"
            android:layout_below="@+id/tv_bookName"
            android:layout_alignLeft="@+id/tv_bookName"
            android:lineSpacingExtra="@dimen/dimen2dp"/>
        <ImageView
            android:textColor="@color/a2a9b2"
            android:id="@+id/tv_authoricon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:src="@drawable/icon_author"
            android:tint="@color/a2a9b2"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignBottom="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/color_EC5C07"
            android:id="@+id/book_coll_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_toRightOf="@+id/tv_authoricon"
            android:layout_alignLeft="@+id/tv_bookName"
            android:layout_alignBottom="@+id/iv_bookImg"/>
    </RelativeLayout>
</LinearLayout>
