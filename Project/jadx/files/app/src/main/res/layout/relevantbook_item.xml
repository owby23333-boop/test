<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/translucent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="vertical"
        android:background="?android:attr/selectableItemBackground"
        android:padding="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen76dp"
            android:layout_height="@dimen/dimen96dp"
            android:scaleType="fitXY"
            android:layout_alignParentLeft="true"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_3E3E3E"
            android:ellipsize="end"
            android:gravity="top"
            android:id="@+id/tv_bookName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginTop="@dimen/dimen2dp"
            android:layout_marginRight="@dimen/dimen40dp"
            android:singleLine="true"
            android:layout_toLeftOf="@+id/tv_score"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            android:textColor="@color/color_EC5C07"
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_alignBottom="@+id/tv_bookName"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/sp_13"
            android:textColor="@color/text_66"
            android:ellipsize="end"
            android:id="@+id/tv_book_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:maxLines="1"
            android:layout_below="@+id/tv_bookName"
            android:layout_alignLeft="@+id/tv_bookName"
            android:lineSpacingExtra="@dimen/dimen2dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignLeft="@+id/tv_book_content"
            android:layout_alignBottom="@+id/iv_bookImg">
            <TextView
                android:textSize="@dimen/sp_13"
                android:textColor="@color/text_99"
                android:id="@+id/tv_authorname"
                android:padding="@dimen/dimen1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen12dp"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:id="@+id/tv_book_status"
                android:background="@drawable/item_shape_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen12dp"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:id="@+id/tv_chapter_count"
                android:background="@drawable/item_shape_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen12dp"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:id="@+id/tv_word_count"
                android:background="@drawable/item_shape_stroke"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen12dp"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
