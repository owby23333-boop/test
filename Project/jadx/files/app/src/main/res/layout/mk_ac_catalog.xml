<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="?android:attr/selectableItemBackground"
    android:paddingTop="@dimen/dimen15dp"
    android:paddingBottom="@dimen/dimen15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:background="@drawable/cache_shape"
        android:visibility="gone"
        android:layout_width="@dimen/dimen5dp"
        android:layout_height="@dimen/dimen5dp"
        android:layout_marginLeft="@dimen/dimen10dp"/>
    <TextView
        android:textSize="@dimen/dimen14dp"
        android:textColor="@color/text_33"
        android:ellipsize="end"
        android:id="@+id/directory_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:singleLine="true"
        android:layout_weight="1"/>
    <TextView
        android:textSize="@dimen/dimen11dp"
        android:textColor="@color/color_50_1A1A1A"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:id="@+id/textView_isFree"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen10dp"
        android:text="@string/free"/>
</LinearLayout>
