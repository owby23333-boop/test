<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/translucent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="vertical"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_bookImg"
            android:layout_width="@dimen/dimen76dp"
            android:layout_height="@dimen/dimen96dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginBottom="@dimen/dimen15dp"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_3E3E3E"
            android:ellipsize="end"
            android:gravity="top"
            android:id="@+id/tv_bookName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:layout_marginRight="@dimen/dimen40dp"
            android:singleLine="true"
            android:layout_toLeftOf="@+id/tv_position"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignTop="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            android:textColor="@color/color_EC5C07"
            android:id="@+id/tv_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_alignBottom="@+id/tv_bookName"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:textColor="@color/color_EC5C07"
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_alignBottom="@+id/tv_bookName"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/sp_13"
            android:textColor="@color/text_66"
            android:ellipsize="end"
            android:id="@+id/tv_book_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen3dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:maxLines="2"
            android:layout_below="@+id/tv_bookName"
            android:layout_alignLeft="@+id/tv_bookName"
            android:lineSpacingExtra="@dimen/dimen2dp"/>
        <ImageView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/a2a9b2"
            android:id="@+id/tv_authoricon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen15dp"
            android:src="@drawable/icon_author"
            android:tint="@color/a2a9b2"
            android:layout_toRightOf="@+id/iv_bookImg"
            android:layout_alignTop="@+id/tv_authorName"
            android:layout_alignBottom="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/dimen12dp"
            android:textColor="@color/text_99"
            android:id="@+id/tv_authorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_toRightOf="@+id/tv_authoricon"
            android:layout_alignLeft="@+id/tv_bookName"
            android:layout_alignBottom="@+id/iv_bookImg"/>
        <TextView
            android:textSize="@dimen/dimen11dp"
            android:textColor="@color/ff9125"
            android:id="@+id/tv_redu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginRight="@dimen/dimen20dp"
            android:layout_alignBottom="@+id/tv_authorName"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
</LinearLayout>
