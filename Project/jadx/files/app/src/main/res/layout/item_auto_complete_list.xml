<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen42dp">
        <ImageView
            android:id="@+id/ivIconSeach"
            android:padding="@dimen/dimen3dp"
            android:layout_width="@dimen/dimen22dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/dimen30dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginBottom="@dimen/dimen5dp"
            android:src="@drawable/ic_search_icon"
            android:tint="@color/color_ff767575"
            android:contentDescription="@string/app_name"/>
        <TextView
            android:textSize="@dimen/dimen15dp"
            android:textColor="@color/color_ff767575"
            android:id="@+id/tvAutoCompleteItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_toRightOf="@+id/ivIconSeach"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/sp_10"
            android:textColor="@color/color_e5331c"
            android:id="@+id/tv_type"
            android:background="@drawable/border_shape_novel"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_toRightOf="@+id/tvAutoCompleteItem"
            android:layout_centerVertical="true"/>
        <ImageView
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/auto_status"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/tv_type"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <View
        android:background="@color/dddddd"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"/>
</LinearLayout>
