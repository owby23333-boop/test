<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_bar"
        android:background="@color/white"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <RelativeLayout
        android:id="@+id/rl_empty"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/icon_bookshelf_null"
            android:layout_centerInParent="true"/>
        <TextView
            android:textSize="@dimen/dimen16dp"
            android:textColor="@color/text_99"
            android:gravity="center"
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen20dp"
            android:text="@string/empty"
            android:layout_below="@+id/image"
            android:layout_centerInParent="true"
            android:layout_centerHorizontal="true"
            android:lineSpacingExtra="@dimen/dimen3dp"/>
    </RelativeLayout>
    <com.amgcyo.cuttadon.view.smilerefresh.MkPullToRefresh
        android:id="@+id/swipe_refresh_layout"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.amgcyo.cuttadon.widget.ui.ObservableScrollView
            android:id="@+id/observablescrollview"
            android:background="@color/color_f7efe1"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:src="@drawable/fission5_account_head"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen26dp">
                    <androidx.cardview.widget.CardView
                        android:layout_gravity="center"
                        android:id="@+id/cd_notice"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen32dp"
                        android:layout_marginLeft="@dimen/dimen15dp"
                        android:layout_marginRight="@dimen/dimen15dp"
                        app:cardBackgroundColor="@color/color_ff8c5e"
                        app:cardCornerRadius="@dimen/dimen10dp">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:id="@+id/ll_notice"
                            android:visibility="visible"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dimen32dp"
                            android:layout_marginRight="@dimen/dimen15dp">
                            <ImageView
                                android:layout_gravity="center"
                                android:id="@+id/laba"
                                android:layout_width="@dimen/dimen22dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="@dimen/dimen15dp"
                                android:src="@drawable/laba_animl"/>
                            <com.gongwen.marqueen.SimpleMarqueeView
                                android:id="@+id/marqueerewardview"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginRight="@dimen/dimen20dp"
                                android:layout_weight="1"
                                app:smvTextColor="@color/color_fffcca"
                                app:smvTextEllipsize="end"
                                app:smvTextGravity="center_vertical"
                                app:smvTextSingleLine="true"
                                app:smvTextSize="@dimen/sp_14"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:layout_gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen150dp"
                        android:layout_marginLeft="@dimen/dimen15dp"
                        android:layout_marginTop="@dimen/dimen16dp"
                        android:layout_marginRight="@dimen/dimen15dp"
                        app:cardBackgroundColor="@color/color_ff8c5e"
                        app:cardCornerRadius="@dimen/dimen10dp">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:id="@+id/ll_nologin"
                            android:visibility="visible"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:textSize="@dimen/sp_16"
                                android:textColor="@color/color_fa6725"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:id="@+id/tv_login"
                                android:background="@drawable/bg_conners_login"
                                android:layout_width="@dimen/dimen136dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen10dp"
                                android:layout_marginBottom="@dimen/dimen10dp"
                                android:text="登录查看余额"/>
                            <TextView
                                android:textColor="@color/color_fffcca"
                                android:gravity="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="登录后现金红包天天领"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_login"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="@dimen/dimen20dp">
                            <TextView
                                android:textSize="@dimen/sp_18"
                                android:textColor="@color/color_fffcca"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:id="@+id/tv_tipsmoney"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dimen10dp"
                                android:text="现金金额："/>
                            <RelativeLayout
                                android:id="@+id/rl_money"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="@dimen/dimen5dp">
                                <TextView
                                    android:textSize="@dimen/dimen40dp"
                                    android:textColor="@color/color_fffcca"
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:id="@+id/tv_money"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/dimen12dp"
                                    android:singleLine="true"/>
                                <TextView
                                    android:textSize="@dimen/sp_16"
                                    android:textColor="@color/color_fffcca"
                                    android:id="@+id/tv_yuan"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="元"
                                    android:layout_toRightOf="@+id/tv_money"
                                    android:layout_alignBaseline="@+id/tv_money"/>
                            </RelativeLayout>
                            <View
                                android:id="@+id/view_line"
                                android:background="#ffb788"
                                android:visibility="invisible"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dimen0_5dp"
                                android:layout_marginLeft="@dimen/dimen10dp"
                                android:layout_marginRight="@dimen/dimen15dp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dimen10dp"
                                android:layout_marginTop="@dimen/dimen12dp">
                                <TextView
                                    android:textSize="@dimen/sp_18"
                                    android:textColor="@color/color_fffcca"
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:id="@+id/tv_coin"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView
                                    android:textSize="@dimen/sp_12"
                                    android:textColor="@color/color_fffcca"
                                    android:layout_gravity="center"
                                    android:id="@+id/tv_login_dh"
                                    android:background="@drawable/dh_shape_soli"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/dimen15dp"
                                    android:text="兑换"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_view_banner"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dimen15dp"
                        android:layout_marginTop="@dimen/dimen16dp"
                        android:layout_marginRight="@dimen/dimen15dp"
                        android:layout_marginBottom="@dimen/dimen8dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/dimen10dp"
                        app:cardElevation="@dimen/dimen2dp">
                        <com.amgcyo.cuttadon.view.otherview.ImageCycleView
                            android:id="@+id/icv_topView"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dimen100dp"/>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:layout_gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dimen15dp"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:layout_marginRight="@dimen/dimen15dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/dimen10dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_daylist"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/ll_bottom_tips"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen30dp"
                        android:layout_marginBottom="@dimen/dimen30dp">
                        <TextView
                            android:textSize="@dimen/dimen12dp"
                            android:textColor="@color/color_909090"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:duplicateParentState="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="@dimen/dimen2dp"
                            android:text="如有疑问请参考"/>
                        <TextView
                            android:textSize="@dimen/dimen12dp"
                            android:textColor="@color/color_1e2023"
                            android:gravity="center"
                            android:id="@+id/tv_rule_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="活动规则"/>
                    </LinearLayout>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>
        </com.amgcyo.cuttadon.widget.ui.ObservableScrollView>
    </com.amgcyo.cuttadon.view.smilerefresh.MkPullToRefresh>
    <ImageView
        android:id="@+id/img_box"
        android:visibility="gone"
        android:layout_width="@dimen/dimen70dp"
        android:layout_height="@dimen/dimen76dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen10dp"
        android:src="@drawable/bx"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
    <TextView
        android:textSize="@dimen/sp_10"
        android:textColor="@color/color_FFF076"
        android:gravity="center"
        android:id="@+id/tv_bx"
        android:visibility="gone"
        android:layout_width="@dimen/dimen70dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen21dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
