<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fr_root"
    android:background="#ffecc047"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.amgcyo.cuttadon.view.smilerefresh.MkPullToRefresh
        android:id="@+id/swipe_refresh_layout"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.amgcyo.cuttadon.widget.ui.ObservableScrollView
            android:id="@+id/scrollView"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scrollbars="none"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/img_top"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:src="@drawable/fission6_bg"/>
                <ImageView
                    android:id="@+id/img_vip"
                    android:background="@drawable/fission6_cz1"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-10dp"
                    android:layout_marginBottom="@dimen/dimen10dp"
                    android:adjustViewBounds="true"
                    android:layout_below="@+id/img_top"
                    android:layout_alignLeft="@+id/img_top"
                    android:layout_alignRight="@+id/img_top"
                    android:layout_centerHorizontal="true"/>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/ll_fission6"
                    android:background="@drawable/shape_popup_white_bg"
                    android:padding="@dimen/dimen16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="30dp"
                    android:layout_marginRight="30dp"
                    android:layout_below="@+id/img_vip">
                    <LinearLayout
                        android:layout_gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="每成功推荐 "/>
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#ffff0000"
                            android:id="@+id/tv_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"/>
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 人，送 "/>
                        <TextView
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:id="@+id/tv_fission_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5天 "/>
                        <TextView
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:id="@+id/tv_fission6_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="免广告"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="#ffff4500"
                        android:id="@+id/tv_vali_count"
                        android:background="@drawable/vali_bg"
                        android:paddingLeft="30dp"
                        android:paddingTop="6dp"
                        android:paddingRight="30dp"
                        android:paddingBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:layout_marginBottom="@dimen/dimen10dp"
                        android:text="正在加载..."/>
                    <FrameLayout
                        android:layout_width="200dp"
                        android:layout_height="200dp">
                        <ImageView
                            android:id="@+id/img_qrcode"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:scaleType="fitXY"/>
                        <com.amgcyo.cuttadon.view.otherview.ProgressWheel
                            android:layout_gravity="center"
                            android:id="@+id/fission6_progresswheel"
                            android:padding="@dimen/dimen3dp"
                            android:visibility="gone"
                            android:layout_width="@dimen/dimen60dp"
                            android:layout_height="@dimen/dimen60dp"
                            app:matProg_barColor="@color/colorPrimary"
                            app:matProg_barWidth="@dimen/dimen2dp"
                            app:matProg_progressIndeterminate="true"/>
                    </FrameLayout>
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:id="@+id/tv_mycode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:text="我的邀请码"/>
                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmer_view_container1"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        app:shimmer_base_alpha="1"
                        app:shimmer_duration="2000"
                        app:shimmer_highlight_alpha="0.4"
                        app:shimmer_shape="linear"
                        app:shimmer_tilt="45">
                        <TextView
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/tv_share"
                            android:background="@drawable/share_bg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="立即分享"/>
                    </com.facebook.shimmer.ShimmerFrameLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="30dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="@dimen/dimen10dp"
                    android:layout_below="@+id/ll_fission6">
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="推广说明"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ff686548"
                        android:id="@+id/tv_desc_fission6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:text="@string/fission6_default_remark"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="怎样才算推广成功？"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:text="分享给你的好友，好友下载安装后在注册页面\10输入你的邀请码，注册成功后你即可享受特权～"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:text="为什么推广链接别人打不开"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:layout_marginRight="30dp"
                        android:text="因为微信或QQ等第三方内置浏览器会自动屏蔽，推荐使用自带浏览器等打开～"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:text="为什么邀请了好友特权没生效"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ff686548"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen10dp"
                        android:layout_marginRight="30dp"
                        android:text="因数据缓存问题，请尝试重新登录或在个人中心查看到期时间是否过期~\10如果还有问题，请反馈给客服！"/>
                </LinearLayout>
                <ViewStub
                    android:id="@+id/viewstub"
                    android:layout="@layout/fission6_comic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </RelativeLayout>
        </com.amgcyo.cuttadon.widget.ui.ObservableScrollView>
    </com.amgcyo.cuttadon.view.smilerefresh.MkPullToRefresh>
</FrameLayout>
