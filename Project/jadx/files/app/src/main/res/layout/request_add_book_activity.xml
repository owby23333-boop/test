<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:background="@color/color_F6F6F6"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/color_F6F6F6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_504a41"
            android:ellipsize="marquee"
            android:gravity="start|center_vertical"
            android:id="@+id/tv_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen5dp"
            android:text="如果出现无法提交求书的问题，请先退出APP后重新打开APP再进行求书即可！"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"/>
        <ImageView
            android:id="@+id/img_category"
            android:paddingTop="@dimen/dimen8dp"
            android:paddingBottom="@dimen/dimen8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:src="@drawable/classify_desc"
            android:tint="@color/text_66"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_3E3E3E"
            android:id="@+id/tv_desc"
            android:paddingBottom="@dimen/dimen20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:text="如果搜索不到你想看的书籍，可以提交以下信息进行求书；处理成功后会自动绑定到你的书架。"
            android:lineSpacingExtra="@dimen/dimen5dp"/>
        <ImageView
            android:layout_gravity="right"
            android:padding="@dimen/dimen8dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="-30dp"
            android:src="@drawable/classify_desc_bottom"
            android:tint="@color/text_66"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_qiushu_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.amgcyo.cuttadon.view.otherview.CustomTextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_33"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:layout_marginBottom="@dimen/dimen5dp"
                android:text="请选择求书类型:"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen42dp"
                android:layout_marginLeft="@dimen/dimen10dp"
                android:layout_marginBottom="@dimen/dimen5dp">
                <TextView
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:id="@+id/tv_novel1"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginRight="@dimen/dimen5dp"
                    android:text="小说"/>
                <com.amgcyo.cuttadon.widget.ui.SmoothCheckBox
                    android:enabled="true"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/scb_novel1"
                    android:layout_width="@dimen/dimen22dp"
                    android:layout_height="@dimen/dimen22dp"
                    android:layout_marginRight="@dimen/dimen20dp"
                    app:color_checked="@color/colorPrimary"
                    app:color_unchecked_stroke="@color/color_15_000000"
                    app:stroke_width="1px"/>
                <TextView
                    android:textColor="@color/text_33"
                    android:gravity="center"
                    android:id="@+id/tv_comic3"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginRight="@dimen/dimen5dp"
                    android:text="漫画"/>
                <com.amgcyo.cuttadon.widget.ui.SmoothCheckBox
                    android:enabled="false"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/scb_comic3"
                    android:layout_width="@dimen/dimen22dp"
                    android:layout_height="@dimen/dimen22dp"
                    android:layout_marginRight="@dimen/dimen20dp"
                    app:color_checked="@color/colorPrimary"
                    app:color_unchecked_stroke="@color/color_15_000000"
                    app:stroke_width="1px"/>
            </LinearLayout>
        </LinearLayout>
        <com.amgcyo.cuttadon.view.otherview.CustomTextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen32dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginBottom="@dimen/dimen5dp"
            android:text="请务必输入以下必要信息:"/>
        <EditText
            android:textSize="@dimen/sp_12"
            android:textColor="@color/grey_888"
            android:textColorHint="@color/text_66"
            android:gravity="center_vertical"
            android:id="@+id/book_name"
            android:background="@drawable/edit_shage"
            android:paddingLeft="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen10dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen42dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:hint="请输入小说名(必填)"
            android:singleLine="true"
            android:inputType="text"/>
        <EditText
            android:textSize="@dimen/sp_12"
            android:textColor="@color/grey_888"
            android:textColorHint="@color/text_66"
            android:gravity="center_vertical"
            android:id="@+id/book_author"
            android:background="@drawable/edit_shage"
            android:paddingLeft="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen10dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen42dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:hint="请输入作者名(必填)"
            android:singleLine="true"
            android:inputType="text"/>
        <EditText
            android:textSize="@dimen/sp_12"
            android:textColor="@color/grey_888"
            android:textColorHint="@color/text_66"
            android:gravity="center_vertical"
            android:id="@+id/book_mian_name"
            android:background="@drawable/edit_shage"
            android:paddingLeft="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen10dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen42dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:hint="请输入小说主角名(必填)"
            android:inputType="text"/>
        <com.amgcyo.cuttadon.view.otherview.CustomTextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen32dp"
            android:layout_margin="@dimen/dimen10dp"
            android:text="您是在哪个网站知道这本书的?"/>
        <EditText
            android:textSize="@dimen/sp_12"
            android:textColor="@color/grey_888"
            android:textColorHint="@color/text_66"
            android:gravity="center_vertical"
            android:id="@+id/book_website"
            android:background="@drawable/edit_shage"
            android:paddingLeft="@dimen/dimen10dp"
            android:paddingRight="@dimen/dimen10dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen42dp"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:hint="请输入来源，如某某APP、某某网站、某某公众号等"
            android:singleLine="true"
            android:inputType="text"/>
        <Button
            android:textSize="@dimen/sp_14"
            android:textColor="#ffffff"
            android:id="@+id/btn_request"
            android:background="@drawable/bg_corners_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen30dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:text="提交"/>
    </LinearLayout>
</ScrollView>
