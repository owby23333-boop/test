<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/ll_have_comment"
        android:padding="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/comment_user_icon"
            android:layout_width="@dimen/dimen40dp"
            android:layout_height="@dimen/dimen40dp"
            android:src="@drawable/icon_unlogin_men"
            android:layout_alignParentLeft="true"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_3E3E3E"
            android:ellipsize="end"
            android:id="@+id/comment_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginRight="@dimen/dimen5dp"
            android:maxEms="8"
            android:singleLine="true"
            android:layout_toRightOf="@+id/comment_user_icon"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_33"
            android:id="@+id/comment_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen8dp"
            android:layout_marginTop="@dimen/dimen8dp"
            android:layout_toRightOf="@+id/comment_user_icon"
            android:layout_below="@+id/comment_user_name"/>
        <TextView
            android:textSize="@dimen/sp_11"
            android:textColor="@color/text_66"
            android:id="@+id/comment_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginTop="@dimen/dimen10dp"
            android:layout_toRightOf="@+id/comment_user_icon"
            android:layout_below="@+id/comment_content"/>
        <TextView
            android:textSize="@dimen/sp_11"
            android:textColor="@android:color/holo_red_light"
            android:id="@+id/comment_delete"
            android:background="?android:attr/selectableItemBackground"
            android:paddingLeft="@dimen/dimen15dp"
            android:paddingRight="@dimen/dimen15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen10dp"
            android:text="删除"
            android:layout_below="@+id/comment_content"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/lv_new_layout"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen10dp">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/lv_like"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen5dp"
            android:layout_marginBottom="@dimen/dimen5dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <com.amgcyo.cuttadon.view.comment.CommentFlowLayout
                    android:gravity="center"
                    android:id="@+id/flow_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/dimen10dp"/>
                <TextView
                    android:textSize="@dimen/sp_11"
                    android:textColor="@color/text_66"
                    android:gravity="center"
                    android:id="@+id/comment_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"/>
            </LinearLayout>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/comment_like_btn"
                android:background="@null"
                android:padding="@dimen/dimen7dp"
                android:layout_width="@dimen/dimen30dp"
                android:layout_height="@dimen/dimen30dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_praise_normal"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/comment_more"
                android:background="@null"
                android:padding="@dimen/dimen7dp"
                android:layout_width="@dimen/dimen30dp"
                android:layout_height="@dimen/dimen30dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/comment_more"/>
        </LinearLayout>
    </LinearLayout>
    <View style="@style/LineEight"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_66"
        android:id="@+id/tv_replay_status"
        android:padding="@dimen/dimen10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen10dp"/>
</LinearLayout>
