<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="@dimen/permission_dialog_title_padding"
    android:paddingRight="@dimen/permission_dialog_title_padding"
    android:paddingBottom="@dimen/permission_dialog_title_padding_bottom"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/item_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_centerInParent="true"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="#000000"
        android:id="@+id/item_title"
        android:paddingLeft="@dimen/dimen10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_toRightOf="@+id/item_img"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="#54000000"
        android:id="@+id/item_info"
        android:paddingLeft="@dimen/dimen10dp"
        android:paddingTop="@dimen/dimen5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_toRightOf="@+id/item_img"
        android:layout_below="@+id/item_title"/>
</RelativeLayout>
