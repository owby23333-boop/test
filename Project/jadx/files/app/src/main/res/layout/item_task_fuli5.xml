<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dimen5dp">
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/color_1e2023"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_task_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_marginTop="@dimen/dimen10dp"
        android:maxEms="8"
        android:singleLine="true"
        android:layout_alignParentStart="true"/>
    <ImageView
        android:id="@+id/img_type"
        android:layout_width="@dimen/dimen20dp"
        android:layout_height="@dimen/dimen20dp"
        android:layout_marginLeft="@dimen/dimen3dp"
        android:layout_marginRight="@dimen/dimen3dp"
        android:src="@drawable/task_jb"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:layout_toRightOf="@+id/tv_task_title"
        android:layout_alignTop="@+id/tv_task_title"
        android:layout_alignBottom="@+id/tv_task_title"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/text_99"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_task_remark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen10dp"
        android:layout_marginBottom="@dimen/dimen15dp"
        android:singleLine="true"
        android:layout_below="@+id/tv_task_title"
        android:layout_alignStart="@+id/tv_task_title"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textStyle="bold"
        android:textColor="@color/color_fa6725"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_task_integral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen10dp"
        android:singleLine="true"
        android:layout_toLeftOf="@+id/tv_task_action"
        android:layout_alignTop="@+id/tv_task_title"
        android:layout_alignBottom="@+id/tv_task_title"
        android:layout_toEndOf="@+id/img_type"/>
    <TextView
        android:textSize="@dimen/dimen12dp"
        android:textColor="@color/color_fa6725"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tv_task_action"
        android:background="@drawable/background_task"
        android:paddingTop="@dimen/dimen5dp"
        android:paddingBottom="@dimen/dimen5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen5dp"
        android:layout_centerInParent="true"
        android:paddingStart="@dimen/dimen12dp"
        android:paddingEnd="@dimen/dimen12dp"
        android:layout_alignParentEnd="true"/>
    <View
        android:background="@color/dddddd"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen0_5dp"
        android:layout_marginLeft="@dimen/dimen15dp"
        android:layout_marginRight="@dimen/dimen15dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
