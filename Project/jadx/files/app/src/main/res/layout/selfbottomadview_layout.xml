<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_ad_native_banner"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen10dp"
        android:layout_marginTop="@dimen/dimen7dp"
        android:layout_marginBottom="@dimen/dimen7dp">
        <com.amgcyo.cuttadon.view.otherview.SelfAdLogoFrameLayout
            android:id="@+id/selfadlogo_fl"
            android:layout_width="@dimen/dimen64dp"
            android:layout_height="@dimen/dimen38dp"/>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen5dp"
        android:layout_marginRight="@dimen/dimen2dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/dimen15dp"
                android:textColor="@color/text_33"
                android:id="@+id/qm_tv_native_ad_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:singleLine="true"/>
            <TextView
                android:textSize="@dimen/dimen10dp"
                android:textColor="@color/text_99"
                android:gravity="center"
                android:id="@+id/tv_native_ad_from"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="穿山甲广告"
                android:singleLine="true"
                android:paddingStart="@dimen/dimen8dp"
                android:paddingEnd="@dimen/dimen6dp"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/dimen13dp"
            android:textColor="@color/text_99"
            android:id="@+id/tv_native_ad_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <ImageView
        android:visibility="gone"
        android:layout_width="@dimen/dimen15dp"
        android:layout_height="@dimen/dimen15dp"
        android:layout_marginLeft="@dimen/dimen3dp"
        android:contentDescription="@string/app_name"/>
    <LinearLayout
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="@dimen/dimen10dp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/btn_native_creative"
        android:background="@drawable/bg_native_ad"
        android:layout_width="@dimen/dimen70dp"
        android:layout_height="@dimen/dimen28dp"
        android:layout_marginRight="@dimen/dimen10dp"
        android:text="查看详情"/>
    <ImageView
        android:id="@+id/img_native_dislike"
        android:visibility="gone"
        android:layout_width="@dimen/dimen20dp"
        android:layout_height="@dimen/dimen20dp"
        android:layout_marginTop="@dimen/dimen2dp"
        android:layout_marginRight="@dimen/dimen6dp"
        android:src="@drawable/ic_close_notice"
        android:contentDescription="@string/app_name"/>
</LinearLayout>
