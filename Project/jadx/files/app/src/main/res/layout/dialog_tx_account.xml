<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:gravity="center"
        android:background="@drawable/framelayout_round_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen40dp"
        android:layout_marginRight="@dimen/dimen40dp"
        android:layout_centerInParent="true">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/text_22"
                android:id="@+id/title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="温馨提示"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen20dp"
                android:layout_marginTop="@dimen/dimen8dp"
                android:layout_marginRight="@dimen/dimen20dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_63"
                    android:textColorLink="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="提现金额   ："
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/color_ab4d4d"
                    android:id="@+id/tv_money"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1元"
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen20dp"
                android:layout_marginTop="@dimen/dimen5dp"
                android:layout_marginRight="@dimen/dimen20dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_63"
                    android:textColorLink="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="支付宝姓名："
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/color_ab4d4d"
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="xxx"
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen20dp"
                android:layout_marginTop="@dimen/dimen5dp"
                android:layout_marginRight="@dimen/dimen20dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_63"
                    android:textColorLink="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="支付宝账户："
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/color_ab4d4d"
                    android:id="@+id/tv_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="xxx"
                    android:lineSpacingExtra="@dimen/dimen4dp"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_63"
                android:textColorLink="@color/colorPrimary"
                android:layout_gravity="left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen20dp"
                android:layout_marginTop="@dimen/dimen5dp"
                android:text="是否确认？"
                android:lineSpacingExtra="@dimen/dimen4dp"/>
            <LinearLayout
                android:background="#ffebebeb"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="@dimen/dimen16dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen45dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_63"
                    android:gravity="center"
                    android:id="@+id/tv_update"
                    android:background="@drawable/text_round_bg"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="修改"
                    android:layout_weight="1"/>
                <View
                    android:background="#ffebebeb"
                    android:layout_width="1px"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/confirm_tv"
                    android:background="@drawable/text_round_bg_colorpri"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="确认"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
