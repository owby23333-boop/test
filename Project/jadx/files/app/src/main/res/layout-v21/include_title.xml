<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dimen48dp"
    android:elevation="@dimen/dimen3dp"
    app:contentInsetStart="0dp">
    <RelativeLayout
        android:gravity="left"
        android:id="@+id/toolbar_back"
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <com.amgcyo.cuttadon.view.otherview.TintableImageView
            android:id="@+id/img_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen10dp"
            android:layout_marginRight="@dimen/dimen10dp"
            android:src="@drawable/ic_back_new"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <com.amgcyo.cuttadon.view.otherview.CustomTextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/text_33"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/toolbar_title"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:singleLine="true"
        android:maxLength="20"/>
    <com.amgcyo.cuttadon.view.xtablayout.XTabLayout
        android:layout_gravity="center"
        android:id="@+id/xtablayout"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen40dp"
        android:layout_marginLeft="@dimen/dimen10dp"
        app:xTabIndicatorColor="@color/colorTheme"
        app:xTabIndicatorHeight="@dimen/dimen2dp"
        app:xTabIndicatorWidth="@dimen/dimen10dp"
        app:xTabMinWidth="@dimen/dimen10dp"
        app:xTabMode="scrollable"
        app:xTabSelectedTextColor="@color/colorTheme"
        app:xTabSelectedTextSize="@dimen/dimen18dp"
        app:xTabTextAppearance="@color/text_33"
        app:xTabTextColor="@color/text_33"
        app:xTabTextSelectedBold="true"
        app:xTabTextSize="@dimen/dimen15dp"/>
    <com.amgcyo.cuttadon.widget.ui.MoreTextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_33"
        android:gravity="center"
        android:layout_gravity="end"
        android:id="@+id/toolbar_right"
        android:background="?android:attr/selectableItemBackground"
        android:padding="@dimen/dimen10dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:singleLine="true"
        android:drawablePadding="-5dp"/>
</androidx.appcompat.widget.Toolbar>
